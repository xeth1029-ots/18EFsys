        Years = Session("Years")
        Rid = Request("Rid")
        OrgName = Server.UrlDecode(Request("OrgName"))
        PlanName = Server.UrlDecode(Request("PlanName"))

        sql = "select ClassName,(select name from Key_Identity where identityid=a.IdentityID)  as IdentityName,Name, Birthday,IDNO, TSDate, TEDate, "
        sql += "OPayMoney,(OPayMoney-RtnMoney), RtnMoney,LDate, "
        sql += "(select Reason from Key_RejectTReaSon where RTReasonId=a.RTReason) +( Case isnull(RTReason_O,'') when '' then '' else ','+RTReason_O end) as RTReason"
        sql += " ,a.ocid from Sub_SubSidyApply_All a "
        sql += "where fromtype='1' and LFlag in('1','2') "

        If sad <> "" Then
            condsql += "and CONVERT(varchar,LDate,111) >= '" & (sad).ToString & "' "
        End If

        If ead <> "" Then
            condsql += "and CONVERT(varchar,LDate,111) <= '" & (ead).ToString & "' "
        End If

        If OCID.ToString <> "" Then '訓練機構
            condsql = condsql & " And OCID in (" & OCID & ") "
        Else
            If PlanId.ToString <> "" Then
                condsql = condsql & " And OCID in (Select OCID From Class_ClassInfo Where PlanId=" & PlanId & " And Years='" & Right(Session("Years").ToString, 2) & "' And Rid like '" & Rid.ToString & "%')"
            End If
        End If

        Dim strOrg As String
        Dim objconn As SqlConnection

        objconn = DbAccess.GetConnection
        objconn.Open()

