    Public Shared Function GET_CLASSNAME2S_SF(oConn As SqlConnection, s1Parms As Hashtable, outTYPE As String) As String
        'outTYPE: CLSNM,PCSVAL
        'Public Const cst_outTYPE_CLSNM As String="CLSNM"
        'Public Const cst_outTYPE_PCSVAL As String="PCSVAL"
        Dim rst As String = ""
        If oConn Is Nothing OrElse Not OpenDbConn(oConn) Then Return rst

        Dim str_CLSNM As String = ""
        Dim str_PCSVAL As String = ""
        Dim vSFCID As String = GetMyValue2(s1Parms, "SFCID")
        Dim vTPLANID As String = GetMyValue2(s1Parms, "TPLANID")
        Dim vRID As String = GetMyValue2(s1Parms, "RID")
        Dim vPLANID As String = GetMyValue2(s1Parms, "PLANID")
        Dim vAPPSTAGE As String = GetMyValue2(s1Parms, "APPSTAGE")
        '任1資訊為空異常
        If vTPLANID = "" OrElse vRID = "" OrElse vPLANID = "" OrElse vAPPSTAGE = "" Then Return rst

        Dim fgUseSFCID As Boolean = (vSFCID <> "" AndAlso IsNumeric2(vSFCID))
        Dim sParms1 As New Hashtable
        Dim sSql_WC1 As String = ""
        If fgUseSFCID Then
            sParms1.Add("SFCID", vSFCID)
            sSql_WC1 = " WITH WC1 AS (SELECT b.PLANID,b.COMIDNO,b.SEQNO,b.SFCID,b.SFCPID FROM ORG_SFCASEPI b WHERE b.SFCID=@SFCID)" & vbCrLf
        End If
        'Dim sParms1 As New Hashtable
        sParms1.Add("TPLANID", vTPLANID)
        sParms1.Add("RID", vRID)
        sParms1.Add("PLANID", vPLANID)
        sParms1.Add("APPSTAGE", vAPPSTAGE)

        Dim sSql As String = ""
        sSql = sSql_WC1
        sSql &= " SELECT pp.PLANID,pp.COMIDNO,pp.SEQNO" & vbCrLf
        sSql &= " ,dbo.FN_GET_APPSTAGE(pp.APPSTAGE) APPSTAGE_N" & vbCrLf
        sSql &= " ,pp.ORGNAME,pp.DISTNAME,pp.RID" & vbCrLf
        sSql &= " ,pp.STDATE,pp.FTDATE" & vbCrLf
        sSql &= " ,dbo.FN_CDATE1B(pp.STDATE) STDATE_ROC" & vbCrLf
        sSql &= " ,dbo.FN_CDATE1B(pp.FTDATE) FTDATE_ROC" & vbCrLf
        sSql &= " ,pp.PCS,pp.OCID,pp.DISTID,pp.APPSTAGE ,pp.ORGID,pp.CLASSCNAME2" & vbCrLf
        sSql &= " ,pp.TransFlag,pp.IsApprPaper,pp.AppliedResult,pp.RESULTBUTTON,pp.PVR_ISAPPRPAPER" & vbCrLf
        If fgUseSFCID Then
            sSql &= " FROM WC1 bc" & vbCrLf
            sSql &= " JOIN dbo.VIEW2B pp ON pp.PLANID=bc.PLANID AND pp.COMIDNO=bc.COMIDNO AND pp.SEQNO=bc.SEQNO" & vbCrLf
            sSql &= " JOIN dbo.PLAN_STAFFOPIN pf WITH(NOLOCK) ON pf.PSNO28=pp.PSNO28 AND LEN(pf.SFCONTREASONS)>1" & vbCrLf '申復理由及說明
            'sSql &= " WHERE pp.TransFlag='N' AND pp.IsApprPaper='Y' AND pp.AppliedResult IS NULL AND pp.RESULTBUTTON IS NULL" & vbCrLf
            sSql &= " WHERE pp.ISAPPRPAPER='Y' AND pp.PVR_ISAPPRPAPER='Y' AND pp.RESULTBUTTON IS NULL" & vbCrLf
        Else
            sSql &= " FROM dbo.VIEW2B pp" & vbCrLf
            sSql &= " JOIN dbo.PLAN_STAFFOPIN pf WITH(NOLOCK) ON pf.PSNO28=pp.PSNO28 AND LEN(pf.SFCONTREASONS)>1" & vbCrLf '申復理由及說明
            'sSql &= " WHERE pp.TransFlag='N' AND pp.IsApprPaper='Y' AND pp.AppliedResult IS NULL AND pp.RESULTBUTTON IS NULL" & vbCrLf
            sSql &= " WHERE pp.ISAPPRPAPER='Y' AND pp.PVR_ISAPPRPAPER='Y' AND pp.RESULTBUTTON IS NULL" & vbCrLf
        End If
        sSql &= " AND pp.TPLANID=@TPLANID AND pp.RID=@RID" & vbCrLf
        sSql &= " AND pp.PLANID=@PLANID" & vbCrLf
        sSql &= " AND pp.APPSTAGE=@APPSTAGE" & vbCrLf
        sSql &= " ORDER BY pp.RID,pp.STDATE,pp.CLASSCNAME2" & vbCrLf
        'sSql &= " WHERE pp.ISAPPRPAPER='Y' AND pp.AppliedResult IS NULL AND pp.RESULTBUTTON IS NULL" & vbCrLf
        'sSql &= " WHERE a.TPLANID=@TPlanID AND YEARS='2023' AND APPSTAGE=1 AND DISTID='001' AND ORGID=5321" & vbCrLf
        Dim dtPP As DataTable = DbAccess.GetDataTable(sSql, oConn, sParms1)
        If dtPP Is Nothing OrElse dtPP.Rows.Count = 0 Then Return ""

        str_CLSNM = ""
        str_PCSVAL = ""
        For Each drP1 As DataRow In dtPP.Rows
            If outTYPE = cst_outTYPE_CLSNM Then
                str_CLSNM &= String.Concat(If(str_CLSNM <> "", vbCrLf, ""), drP1("CLASSCNAME2"), "(", drP1("STDATE_ROC"), ")")
            ElseIf outTYPE = cst_outTYPE_PCSVAL Then
                str_PCSVAL &= String.Concat(If(str_PCSVAL <> "", ",", ""), drP1("PCS"))
            End If
        Next
        Return If(outTYPE = cst_outTYPE_CLSNM, str_CLSNM, If(outTYPE = cst_outTYPE_PCSVAL, str_PCSVAL, ""))
    End Function

