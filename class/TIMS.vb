    ''' <summary>
    ''' 傳入日期格式字串(YYYY/MM/DD or YYYY/MM/DD hh:mi:ss)
    ''' 回傳 SQL 中的 Convert(datetime, str) 的語法字串
    ''' </summary>
    ''' <param name="str"></param>
    ''' <returns></returns>
    Public Shared Function To_date(ByVal str As String) As String
        If Not IsDate(str) Then Return "convert(date, NULL)"

        Try
            If str.Length > 10 Then Return $"convert(datetime, '{Common.FormatNow(str)}')"

            Return $"convert(date, '{Common.FormatDate(str)}')"
        Catch ex As Exception
            Dim V_GUID As String = Guid.NewGuid().ToString()
            LOG.Warn(ex.Message, ex) '取得錯誤資訊寫入
            Dim strErrmsg As String = $"ex.Message:{ex.Message},[{V_GUID}]{vbCrLf}str:{str}{vbCrLf}"
            WriteTraceLog(strErrmsg, ex)
            Throw New Exception(strErrmsg, ex)
        End Try
        Return str
    End Function

    ''' <summary> 判斷是否為正整數(含0)(其它狀況為FALSE) </summary>
    ''' <param name="chkstr"></param>
    ''' <returns></returns>
    Public Shared Function IsInt(ByVal chkstr As String) As Boolean
        Dim rst As Boolean = False ' 否 不是正整數 
        If String.IsNullOrEmpty(chkstr) OrElse Not IsNumeric(chkstr) Then Return rst
        '判斷是否為正整數 ---(0忽略不做判斷)
        Try
            rst = (Int32.Parse(chkstr) = chkstr) 'True '是正整數
        Catch ex As Exception
            'LOG.Warn(ex.Message, ex)
        End Try
        Return rst
    End Function

