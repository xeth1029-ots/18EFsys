    ''' <summary>
    ''' 任何值都轉成CINT 異常也輸出0
    ''' </summary>
    ''' <param name="obj"></param>
    ''' <returns></returns>
    Public Shared Function CINT1(obj As Object) As Integer
        Dim rst As Integer = 0
        If (obj Is Nothing) Then Return rst
        Try
            rst = CInt(obj) '任何值都轉成CINT
        Catch ex As Exception
            'ex.ToString()
            LOG.Warn($"CINT1 轉型失敗:{ex.Message},原值:{obj}", ex)
        End Try
        Return rst
    End Function

    Public Shared Function CINT64(obj As Object) As Int64
        Dim rst As Int64 = 0
        If obj Is Nothing OrElse IsDBNull(obj) Then Return rst ' 檢查 Nothing 或 DBNull
        Dim strVal As String = $"{obj}".Trim()
        If strVal = "" Then Return rst
        ' 使用 TryParse 效能較佳，且不會拋出例外 ' 若數值可能包含小數點，建議先轉 Decimal/Double 再取整
        If Int64.TryParse($"{obj}", rst) Then Return rst
        ' 若 TryParse 失敗，嘗試處理可能的小數位 (例如 "123.0")
        Try
            rst = Convert.ToInt64(Val(strVal))
        Catch ex As Exception
            LOG.Warn($"CINT64 轉型失敗:{ex.Message},原值:{obj}")
        End Try
        Return rst
    End Function

    ''' <summary>
    ''' 任何值都轉成CDBL 異常也輸出0
    ''' </summary>
    ''' <param name="obj"></param>
    ''' <returns></returns>
    Public Shared Function CDBL1(ByRef obj As Object) As Double
        Dim rst As Double = 0
        If (obj Is Nothing) Then Return rst
        Try
            rst = CDbl(obj)
        Catch ex As Exception
            LOG.Warn($"CDBL1: {ex.Message},{obj}", ex)
        End Try
        Return rst
    End Function

