        Dim rst As New DataTable
        If OCID = "" Then Return rst

        '保險證號(ActNo)前二碼意義：
        '01:工廠
        '02:公會 x
        '03:漁會 x
        '04:政府機關
        '05/15:公司(商)
        '06:農會 x
        '07:自由業
        '08:自由業
        '09:職訓保

        Dim sql As String = ""
        sql &= " SELECT a.SBDID" & vbCrLf
        sql &= " ,a.SB3ID" & vbCrLf
        sql &= " ,a.IDNO" & vbCrLf
        sql &= " ,a.OCID" & vbCrLf
        sql &= " ,a.STATUSPT" & vbCrLf
        sql &= " ,a.STATUSNC1" & vbCrLf
        sql &= " ,a.STATUSNC2" & vbCrLf
        sql &= " ,a.STATUSNCREASON" & vbCrLf
        sql &= " ,a.STATUSNCMACCT" & vbCrLf
        sql &= " ,a.STATUSNCMDATE" & vbCrLf
        sql &= " ,b.ACTNO" & vbCrLf
        sql &= " ,CASE WHEN LEFT(b.ACTNO,2) IN ('02','03','06') THEN 'Y' END NGACTNO" & vbCrLf
        sql &= " FROM STUD_SELRESULTBLIDET a" & vbCrLf
        sql &= " LEFT JOIN STUD_SELRESULTBLI b on b.SB3ID=a.SB3ID" & vbCrLf
        sql &= " JOIN CLASS_CLASSINFO cc on cc.ocid=a.ocid" & vbCrLf
