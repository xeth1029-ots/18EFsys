                sql &= " FROM KEY_PLAN WHERE ISNULL(CLSYEAR,CONVERT(varchar(4),YEAR(GETDATE())))>=CONVERT(varchar(4),YEAR(GETDATE()))" & vbCrLf
                sql &= " ORDER BY TPLANID"
            Case 3
                sql = " SELECT '(' + TPLANID + ')' + PLANNAME PLANNAME, TPLANID, PROPERTYID FROM KEY_PLAN" & vbCrLf
                sql &= " WHERE QUERYDISPLAY='Y'"
                sql &= " AND ISNULL(CLSYEAR,CONVERT(varchar(4),YEAR(GETDATE())))>=CONVERT(varchar(4),YEAR(GETDATE()))" & vbCrLf
                sql &= " ORDER BY TPLANID"
        End Select
