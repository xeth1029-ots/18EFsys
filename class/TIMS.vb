                    strBirth = GetADDate(Convert.ToString(itemNode.ChildNodes.Item(cst_col_birth).InnerText))
                    strActNo = Convert.ToString(itemNode.ChildNodes.Item(cst_col_uno).InnerText)
                    strMDate = GetRocADDate(Convert.ToString(itemNode.ChildNodes.Item(cst_col_txdate).InnerText))
                    strChgMode = Convert.ToString(itemNode.ChildNodes.Item(cst_col_txcd).InnerText)
                    strFType = strUType
                    Dim s_INAME As String = Convert.ToString(itemNode.ChildNodes.Item(cst_col_Iname).InnerText) '姓名
                    Dim s_COOP As String = Convert.ToString(itemNode.ChildNodes.Item(cst_col_coop).InnerText) '公司名稱
                    Dim s_WAGE As String = Convert.ToString(itemNode.ChildNodes.Item(cst_col_wage).InnerText) '投保薪資
                    Dim s_DEPTCODE As String = Convert.ToString(itemNode.ChildNodes.Item(cst_col_deptcode).InnerText) '工作部門代碼
                    Dim s_BIEF As String = Convert.ToString(itemNode.ChildNodes.Item(cst_col_bief).InnerText) '勞保註記代碼
                    Dim s_BIEFDESC As String = Convert.ToString(itemNode.ChildNodes.Item(cst_col_biefDesc).InnerText) '勞保註記中文說明

                    Dim flagCanSave As Boolean = False
                    flagCanSave = True
                    '改為全部都記錄 BY AMU-20190222
                    '只記錄加保(txcd=4)&退保(txcd=2)
                    'Select Case strChgMode
                    '    Case "1", "2", "3", "4"
                    '        flagCanSave=True
                    'End Select
                    If flagCanSave Then
                        Try
                            'Dim ds As New DataSet
                            Dim dtB4 As New DataTable
                            With sCmd
                                .Parameters.Clear()
                                .Parameters.Add("@idno", SqlDbType.VarChar).Value = strIDNO
                                .Parameters.Add("@birthday", SqlDbType.VarChar).Value = strBirth
                                .Parameters.Add("@actno", SqlDbType.VarChar).Value = strActNo
                                .Parameters.Add("@mdate", SqlDbType.VarChar).Value = strMDate
                                .Parameters.Add("@changemode", SqlDbType.VarChar).Value = strChgMode
                                .Parameters.Add("@ftype", SqlDbType.VarChar).Value = strFType
                                dtB4.Load(.ExecuteReader()) '.Fill(ds, "stud_bligatedata4")
                            End With

                            '勾稽資料
                            If dtB4.Rows.Count = 0 Then
                                Dim iSB4ID As Integer = DbAccess.GetNewId(oConn, "STUD_BLIGATEDATA4_SB4ID_SEQ,STUD_BLIGATEDATA4,SB4ID")
                                With iCmd
                                    .Parameters.Clear()
                                    .Parameters.Add("@sb4id", SqlDbType.VarChar).Value = iSB4ID
                                    .Parameters.Add("@idno", SqlDbType.VarChar).Value = If(strIDNO = "", Convert.DBNull, strIDNO)
                                    .Parameters.Add("@ftype", SqlDbType.VarChar).Value = If(strFType = "", Convert.DBNull, strFType)
                                    .Parameters.Add("@name", SqlDbType.NVarChar).Value = If(s_INAME = "", Convert.DBNull, s_INAME)
                                    .Parameters.Add("@birthday", SqlDbType.DateTime).Value = If(strBirth = "", Convert.DBNull, strBirth)
                                    .Parameters.Add("@actno", SqlDbType.VarChar).Value = If(strActNo = "", Convert.DBNull, strActNo)
                                    .Parameters.Add("@comname", SqlDbType.NVarChar).Value = If(s_COOP = "", Convert.DBNull, s_COOP)
                                    .Parameters.Add("@changemode", SqlDbType.VarChar).Value = If(strChgMode = "", Convert.DBNull, strChgMode)
                                    .Parameters.Add("@mdate", SqlDbType.DateTime).Value = If(strMDate = "", Convert.DBNull, strMDate)
                                    .Parameters.Add("@salary", SqlDbType.VarChar).Value = If(s_WAGE = "", Convert.DBNull, s_WAGE)
                                    .Parameters.Add("@department", SqlDbType.VarChar).Value = Convert.DBNull
                                    .Parameters.Add("@deptment", SqlDbType.VarChar).Value = If(s_DEPTCODE = "", Convert.DBNull, s_DEPTCODE)
                                    .Parameters.Add("@bief", SqlDbType.VarChar).Value = If(s_BIEF = "", Convert.DBNull, s_BIEF)
                                    .Parameters.Add("@biefdesc", SqlDbType.NVarChar).Value = If(s_BIEFDESC = "", Convert.DBNull, s_BIEFDESC)
                                    .ExecuteNonQuery()
                                End With
                            End If
                            dtB4 = Nothing 'ds.Tables("stud_bligatedata4").Clear()
                        Catch ex As Exception
                            LOG.Error(ex.Message, ex)
                            Call WriteTraceLog(MyPage, ex)
                            Throw ex
                        End Try
                    End If
                Next

            End If
        End If

        Return strMsg
    End Function

    Public Shared Function GET_BLI_WSV4(ByRef MyPage As Page, oConn As SqlConnection, strIDNO As String, strBIRTH As String, strCNAME As String, ByRef s_ERRMSG As String) As String
        Dim strMsg As String = ""
        Dim strXML As String = String.Empty
        'Const cst_勞保就保 As String="A" 'Const cst_自願職災保險 As String="V" 'Const cst_農保 As String="F" 'Const cst_農民自願職災保險 As String="FV"
        Dim s_Bli_TYPE As String = "A,V,F,FV"
        Dim aBli_TYPE As String() = s_Bli_TYPE.Split(",")

        Dim strIName As String = ""
        strIDNO = ChangeIDNO(strIDNO)
        Dim strBDate As String = DateTime.Now.ToString("yyyyMMdd")
        Dim strEDate As String = strBDate 'DateTime.Now.ToString("yyyyMMdd")
        'Dim BIRTHDAY_C3 As String=Cdate3(Convert.ToDateTime(strBIRTH, "yyyyMMdd"))

        Dim s_BIRTYDAY As String = ""
        Try
            Dim dateBIRTYDAY As Date = DateTime.ParseExact(strBIRTH, "yyyyMMdd", System.Globalization.CultureInfo.InvariantCulture)
            s_BIRTYDAY = Cdate3(dateBIRTYDAY)
        Catch ex As Exception
            Call WriteTraceLog(ex.Message, ex)
        End Try

        '= Nothing 's_FUNCNAME
        Dim htSS As New Hashtable From {
            {"sysname", cst_gSysName},
            {"strIDNO", strIDNO},
            {"strBIRTH", strBIRTH},
            {"strCNAME", strCNAME},
            {"strBDate", strBDate},
            {"strEDate", strEDate},
            {"strUType", ""},
            {"strXML", ""}
        }

        'WebRequest物件如何忽略憑證問題
        System.Net.ServicePointManager.ServerCertificateValidationCallback = New System.Net.Security.RemoteCertificateValidationCallback(AddressOf TIMS.ValidateServerCertificate)
        'TLS 1.2-基礎連接已關閉: 傳送時發生未預期的錯誤 'HttpClient
        System.Net.ServicePointManager.SecurityProtocol = Net.SecurityProtocolType.Tls12
        Dim strUType As String = ""
        Try
            'https://wltims.wda.gov.tw/bli_wsv4/get_data2.asmx
            'https://wltims.wda.gov.tw/bli_wsv4/get_data3.asmx
            Using bliWs As New bli_wsv4.get_data3
                For Each strUType In aBli_TYPE
                    'strUType=s_UType 'cst_勞保就保 '查詢勞保+就保勾稽資料 '呼叫勞保勾稽webservice
                    strXML = bliWs.get_detail(cst_gSysName, strIDNO, strIName, strBIRTH, strUType, strBDate, strEDate)
                    htSS("strUType") = strUType
                    htSS("strXML") = strXML
                    strMsg = parseXML(MyPage, htSS, oConn) '解析XML 並儲存 STUD_BLIGATEDATA4 
                    Select Case strMsg
                        Case "-1"
                            s_ERRMSG = "勾稽時產生錯誤!!"
                            SetMyValue2(htSS, "ERRMSG", s_ERRMSG)
                            Return s_ERRMSG
                        Case "7"
                            If strCNAME = "" Then Exit Select
                            strIName = strCNAME '(使用姓名重新勾稽)
                            'strUType=s_UType 'cst_勞保就保 '查詢勞保+就保勾稽資料
                            '呼叫勞保勾稽webservice
                            strXML = bliWs.get_detail(TIMS.cst_gSysName, strIDNO, strIName, strBIRTH, strUType, strBDate, strEDate)
                            htSS("strUType") = strUType
                            htSS("strXML") = strXML
                            strMsg = parseXML(MyPage, htSS, oConn) '解析XML 並儲存 STUD_BLIGATEDATA4 
                    End Select
                Next
            End Using
            'bliWs=Nothing
        Catch ex As Exception
            Dim strErrmsg As String = ""
            strErrmsg &= "##Get_STUDBLIGATEDATA4:" & vbCrLf
            strErrmsg &= String.Concat("ex.Message:", ex.Message, vbCrLf)
            strErrmsg &= ",sysname:" & cst_gSysName & vbCrLf
            strErrmsg &= ",strUType:" & strUType & vbCrLf
            strErrmsg &= EncryptAes(String.Concat(",strIDNO:", strIDNO, vbCrLf, ",strBIRTH:", strBIRTH, vbCrLf, ",strCNAME:", strCNAME, vbCrLf))
            strErrmsg &= ",strIName:" & strIName & vbCrLf
            strErrmsg &= ",strBDate:" & strBDate & vbCrLf
            strErrmsg &= ",strEDate:" & strEDate & vbCrLf
            strErrmsg &= ",strXML:" & strXML & vbCrLf
            'strErrmsg &= GetErrorMsg(MyPage) '取得錯誤資訊寫入
            Call WriteTraceLog(strErrmsg, ex)
            Throw ex
        End Try

        Dim pms_s1 As New Hashtable From {{"IDNO", strIDNO}, {"BIRTHDAY", s_BIRTYDAY}}
        Dim Sql As String = ""
        Sql &= " SELECT top 11 c.SB4ID ,c.IDNO ,c.FTYPE ,c.NAME,CONVERT(varchar(11), c.BIRTHDAY, 111) BIRTHDAY" & vbCrLf
        Sql &= " ,c.ACTNO ,c.COMNAME ,c.CHANGEMODE" & vbCrLf
        Sql &= " ,CONVERT(varchar, c.MDATE, 111) MDATE" & vbCrLf
        Sql &= " ,CASE WHEN c.CHANGEMODE=4 THEN CONVERT(varchar, c.MDATE, 111) END SMDATE" & vbCrLf
        Sql &= " ,CASE WHEN c.CHANGEMODE=2 THEN CONVERT(varchar, c.MDATE, 111) END FMDATE" & vbCrLf
        Sql &= " ,c.SALARY ,c.DEPARTMENT" & vbCrLf
        Sql &= " ,c.MODIFYDATE" & vbCrLf
        Sql &= " ,c.DEPTMENT" & vbCrLf
        Sql &= " ,c.BIEF ,c.BIEFDESC" & vbCrLf
        Sql &= " ,ISNULL(c.ComName, e.UName) UNAME" & vbCrLf
        Sql &= " ,convert(varchar, getdate(), 111) TODAY1" & vbCrLf
        'sql += " ,dbo.DECODE8(c.deptment,'M','M:多元就業計畫進用人員不適用就保','N','N:農保被保險人參加短期就業或職業訓練僅加職災不適用就保墊償','P','P:公共服務擴大就業計畫進用人員不適用就保', '') deptmentN" & vbCrLf
        'sql &= " ,dbo.DECODE8(c.BIEF,'M','M:多元就業計畫進用人員不適用就保','N','N:農保被保險人參加短期就業或職業訓練僅加職災不適用就保墊償','P','P:公共服務擴大就業計畫進用人員不適用就保', '') biefN" & vbCrLf
        Sql &= " ,CASE c.BIEF WHEN 'M' THEN 'M:多元就業計畫進用人員不適用就保'" & vbCrLf
        Sql &= " WHEN 'N' THEN 'N:農保被保險人參加短期就業或職業訓練僅加職災不適用就保墊償'" & vbCrLf
        Sql &= " WHEN 'P' THEN 'P:公共服務擴大就業計畫進用人員不適用就保' ELSE '' END biefN" & vbCrLf
        'https://jira.turbotech.com.tw/browse/TIMSC-134
        Sql &= " ,case when dbo.SUBSTR(c.ACTNO,0,2) IN (" & TIMS.cst_Actno_NG2 & ") then 'Y'" & vbCrLf
        Sql &= " when dbo.SUBSTR(c.ACTNO,0,3) IN (" & TIMS.cst_Actno_NG3 & ") then 'Y' END NOUSE" & vbCrLf
        Sql &= " FROM dbo.STUD_BLIGATEDATA4 c" & vbCrLf
        Sql &= " LEFT JOIN dbo.BUS_BASICDATA e ON c.ActNo=e.Ubno" & vbCrLf
        Sql &= " WHERE c.IDNO=@IDNO AND c.BIRTHDAY=@BIRTHDAY" & vbCrLf
        Sql &= " ORDER BY c.MDATE DESC,c.CHANGEMODE DESC" & vbCrLf

        Dim dt As DataTable = DbAccess.GetDataTable(Sql, oConn, pms_s1)

        Dim iRow As Integer = 1
        Dim rst As String = ""
        For Each dr1 As DataRow In dt.Rows
            rst &= String.Concat("[", iRow, "]", dr1("idno"), "-", dr1("ftype"), "-", dr1("NAME"), "-", dr1("BIRTHDAY"), "-", dr1("ACTNO"), "-", dr1("COMNAME"), "-", dr1("CHANGEMODE"), "-", dr1("SMDATE"), "-", dr1("FMDATE"), "-", dr1("SALARY"), "-", vbCrLf)
            iRow += 1
        Next
        Return rst
    End Function

    '申請階段:1:上半年/2:下半年/3:政策性產業/4:進階政策性產業
    ''' <summary> 依 受理階段 取得 申請階段 </summary>
    ''' <param name="sACCEPTSTAGE"></param>
    ''' <returns></returns>
    Public Shared Function GET_APPSTAGE_12(ByVal sACCEPTSTAGE As String) As Integer
        Dim rst As Integer = 0
        '受理階段 ACCEPTSTAGE A1/A2 : 上半年/申復 :: 申請階段:1:上半年
        '受理階段 ACCEPTSTAGE C1/C2 : 下半年/申復 :: 申請階段:2:下半年
        '受理階段 ACCEPTSTAGE B1/B2 : 政策性/申復 :: 申請階段:3:政策性產業
        '受理階段 ACCEPTSTAGE D1/D2 : 進階政策性/申復 :: 申請階段:4:進階政策性產業
        Dim v_ACCEPT As String = If(sACCEPTSTAGE.Length > 1, sACCEPTSTAGE.Substring(0, 1), "")
        If v_ACCEPT = "" Then Return rst
        rst = If(v_ACCEPT = "A", 1, If(v_ACCEPT = "C", 2, If(sACCEPTSTAGE = "B", 3, If(sACCEPTSTAGE = "D", 4, 0))))
        Return rst
    End Function

