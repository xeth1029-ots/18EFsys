        'Dim blnRst As Boolean=True '可報名(回傳值) 'Dim iPeriod As Integer=0    '可報名期間 (依天)
        Dim iPeriod2 As Integer = 0   '可報名期間 (依月) 'Dim rqSDate As String=STDATE 'GetMyValue2(htCC, "STDate")
        rqSDate = Cdate3(rqSDate) 'If Trim(rqSDate)="" Then Return blnRst
        If rqSDate = "" Then Return '(開訓日期為空，無法處理狀況)
        '(開始報名日期)開訓日期1個月前 'Dim SEnterDateM1 As String=Common.FormatDate(DateAdd(DateInterval.Month, -1, CDate(rqSDate)))
        '(開始報名日期)開訓日期30天前
        Dim SEnterDateD30 As String = Common.FormatDate(DateAdd(DateInterval.Day, -30, CDate(rqSDate)))
        iPeriod2 = DateDiff(DateInterval.Day, CDate(Now), CDate(SEnterDateD30))
        ' 1、未開放報名 【報名開始日期】：開訓日前1個月(30天)。/【報名結束日期】：開訓日前3天。
        ' 2、已開放報名 【報名開始日期】：不變 / 【報名結束日期】：開訓日前3天。
        ' 當變更審核通過後，系統自動將儲存之設定回帶至開班資料查詢功能之【報名開始日期】、【報名結束日期】。
        rSEnterDate = "" '(清空雖然沒用)
        rFEnterDate = "" '(清空雖然沒用)
        '受訓期間超過14天或未超過14天(不分)
        If iPeriod2 > 0 Then
            '超過一個月 (則報名起日為 開訓日前一個月(約30天),報名迄日為開訓前三日)
            rSEnterDate = String.Concat(Common.FormatDate(SEnterDateD30), " 12:00") '中午12點
            rFEnterDate = String.Concat(Common.FormatDate(DateAdd(DateInterval.Day, -3, CDate(rqSDate))), " 18:00") '下午18點(晚上6點)
        Else
            '未滿一個月 (則報名起日為 開班轉入日的次日,報名迄日為開訓前三日)
            rSEnterDate = String.Concat(Common.FormatDate(DateAdd(DateInterval.Day, 1, CDate(Now))), " 12:00") '中午12點
            rFEnterDate = String.Concat(Common.FormatDate(DateAdd(DateInterval.Day, -3, CDate(rqSDate))), " 18:00") '下午18點(晚上6點)
        End If
        'SetMyValue2(htCC, "SEnterDate", SEnterDate) 'SetMyValue2(htCC, "FEnterDate", FEnterDate) 'Return blnRst
    End Sub

    ''' <summary>異動報名時間。(計算)(預設值)-班級轉入</summary>
    ''' <param name="rqSDate"></param>
    ''' <param name="rSEnterDate"></param>
    ''' <param name="rFEnterDate"></param>
    ''' <param name="vSEnterDateOrg1"></param>
    Public Shared Sub ChangeSEnterDate(ByVal rqSDate As String, ByRef rSEnterDate As String, ByRef rFEnterDate As String, ByRef vSEnterDateOrg1 As String)
        Call ChangeSEnterDate(rqSDate, rSEnterDate, rFEnterDate)
        If rqSDate = "" OrElse rSEnterDate = "" OrElse rFEnterDate = "" OrElse vSEnterDateOrg1 = "" Then Return
        If DateDiff(DateInterval.Day, CDate(rSEnterDate), CDate(vSEnterDateOrg1)) > 0 Then
            'OJT-24082802：<系統> 產投 -班級變更審核：功能邏輯與頁面顯示調整
            '1、報名開始日期：調整預帶日期邏輯。
            '目前預帶為開訓日前30天， 但若此日期早於「開班資料查詢-報名開始日期」，
            '則自動帶入「開班資料查詢-報名開始日期」已設定的日期；較晚者，才顯示為由系統預設的日期。
            '例如某班次3/6開訓， 經分流後改2/8開放報名， 訓練單位來文申請結訓日期變更（開訓日期未異動），
            '目前報名開始日期會自動跳回預設的2/5，與分流結果不符， 爰請調整預帶日期邏輯。
            rSEnterDate = Cdate3(vSEnterDateOrg1)
        End If
    End Sub

