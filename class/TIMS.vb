    ''' </summary>
    ''' <returns></returns>
    Public Shared Function Chk_DateisRoc(ByVal str1 As String) As Boolean
        Dim flag1 As Boolean = IsDate7(str1) '是民國年月日
        Dim flag2 As Boolean = IsDate1(str1) '是西元年月日
        If flag1 Then Return True '是民國年月日
        If flag2 Then Return False '是西元年月日
        Return Nothing '異常
    End Function

    ''' <summary>
    ''' 取得負值的pk數
    ''' </summary>
    ''' <param name="MyPage"></param>
    ''' <param name="PKNAME"></param>
    ''' <returns></returns>
    Public Shared Function GET_NEWPK_INT(ByRef MyPage As Page, ByVal PKNAME As String) As Integer
        Dim iVal As Integer = -1
        Const cst_newpk_name As String = "NEWPK_NAME_"
        If MyPage.Session(cst_newpk_name & PKNAME) Is Nothing Then
            MyPage.Session(cst_newpk_name & PKNAME) = iVal
        Else
            iVal = CINT1(MyPage.Session(cst_newpk_name & PKNAME)) - 1
        End If
        MyPage.Session(cst_newpk_name & PKNAME) = iVal
        Return iVal
    End Function

