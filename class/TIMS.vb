    ''' <summary>(資訊室提供黑箱弱掃)Information room provides black box weak scan</summary>
    ''' <param name="v_IpAddress"></param>
    ''' <returns></returns>
    Public Shared Function CanBlackboxWeakScan(v_IpAddress As String) As Boolean
        '資訊室提供黑箱弱掃IP為172.121.211.130、172.21.45.138，弱掃期間2/27至3/6，再請協助設定排除。
        '172.21.45.138、172.21.211.130 7/15-7/18-重掃要再開白名單，開到星期五 7/25
        Dim CanScanIPs As String() = {"172.121.211.130", "172.21.45.138"}
        Dim dateSDATE As Date = CDate("2025/7/21")
        Dim dateFDATE As Date = CDate("2025/7/25")
        Dim fgCanUse As Boolean = (CanScanIPs.Contains(v_IpAddress) AndAlso DateDiff(DateInterval.Day, dateSDATE, Now) >= 0 AndAlso DateDiff(DateInterval.Day, Now, dateFDATE) > 0)
        Return fgCanUse
    End Function

    ''' <summary>查詢目前攻擊數</summary>
    ''' <param name="v_IpAddress"></param>
    ''' <returns></returns>
    Public Shared Function SUtl_ChkHISTORY1_CNT(v_IpAddress As String) As Integer
        Dim rst As Integer = 0 '未發生異常'rst@true:異常
        '(查無ip或太短-無法判斷，放棄-防止駭客攻擊)
        If String.IsNullOrEmpty(v_IpAddress) OrElse v_IpAddress.Length < 4 Then Return rst
        Dim fgCan As Boolean = CanBlackboxWeakScan(v_IpAddress)
        If fgCan Then Return rst '(資訊室提供黑箱弱掃)

        Using oConn As SqlConnection = DbAccess.GetConnection()
            '(資料庫異常，放棄-防止駭客攻擊)
            If oConn Is Nothing OrElse Not OpenDbConn(oConn) Then Return rst

            '15分鐘內(有異動) '達到9次的(登入)錯誤
            Dim sql As String = ""
            sql &= " SELECT L_COUNT FROM SYS_HISTORY1 WITH(NOLOCK)"
            sql &= " WHERE L_IP=@L_IP AND L_MODIFYTIME>=GETDATE()-(1./24./4.)"
            sql &= " AND L_COUNT>=9 AND CONVERT(date,L_MODIFYTIME)=CONVERT(date,GETDATE())" '當日
            Dim sCmd As New SqlCommand(sql, oConn)
            'Dim v_IpAddress As String=Common.GetIpAddress() 'MyPage.Request.UserHostAddress
            Dim dt As New DataTable
            With sCmd
                .Parameters.Clear()
                .Parameters.Add("L_IP", SqlDbType.VarChar).Value = v_IpAddress 'Common.GetIpAddress() 'MyPage.Request.UserHostAddress
                dt.Load(.ExecuteReader())
            End With
            If dt.Rows.Count > 0 Then rst = GetValue2(dt.Rows(0)("L_COUNT"), 0) '有達標(異常)

            Call CloseDbConn(oConn)
        End Using
