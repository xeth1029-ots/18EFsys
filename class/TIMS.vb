        sql &= " FROM STUD_ENTERTEMP a" & vbCrLf
        sql &= " JOIN STUD_ENTERTYPE b on b.SETID=a.SETID" & vbCrLf
        sql &= " JOIN CLASS_CLASSINFO cc on cc.ocid=b.OCID1" & vbCrLf
        sql &= " JOIN ID_PLAN ip on ip.planid=cc.planid" & vbCrLf
        sql &= " JOIN ADP_RESOLDER rs1 on rs1.IDNO=a.IDNO and rs1.CREATEDISTID=ip.DISTID" & vbCrLf
        sql &= " AND convert(date,rs1.PREEXDATE) > convert(date,GETDATE())" & vbCrLf
        sql &= " WHERE cc.IsSuccess='Y'" & vbCrLf
        sql &= " AND cc.NotOpen='N'" & vbCrLf
        sql &= " AND convert(date,DATEADD('dd', -2, cc.ExamDate) <= convert(date,GETDATE())" & vbCrLf
        sql &= " AND cc.STDATE > convert(date,GETDATE())" & vbCrLf
        sql &= " AND cc.STDATE >= DATEADD(DAY, GETDATE(), -200)" & vbCrLf
        sql &= " AND cc.STDATE <= DATEADD(DAY, GETDATE(), +100)" & vbCrLf
        sql &= " AND b.modifydate >= DATEADD(DAY, GETDATE(), -200)" & vbCrLf
        sql &= " AND cc.PlanID='" & vPlanID & "'" & vbCrLf
        sql &= " AND cc.RID='" & vRID & "'" & vbCrLf
        sql &= " AND cc.OCID='" & vOCID & "'" & vbCrLf
        sql &= " )" & vbCrLf
        sql &= " ,T2 AS (" & vbCrLf
        sql &= " select a.idno,a.name namex" & vbCrLf
        sql &= " FROM STUD_ENTERTEMP2 a" & vbCrLf
        sql &= " JOIN STUD_ENTERTYPE2 b on b.ESETID=a.ESETID" & vbCrLf
        sql &= " JOIN CLASS_CLASSINFO cc on cc.ocid=b.OCID1" & vbCrLf
        sql &= " JOIN ID_PLAN ip on ip.planid=cc.planid" & vbCrLf
        sql &= " JOIN ADP_RESOLDER rs1 on rs1.IDNO=a.IDNO and rs1.CREATEDISTID=ip.DISTID" & vbCrLf
        sql &= " AND convert(date,rs1.PREEXDATE) > convert(date,GETDATE())" & vbCrLf
        sql &= " WHERE cc.IsSuccess='Y'" & vbCrLf
        sql &= " AND cc.NotOpen='N'" & vbCrLf
        sql &= " AND convert(date,DATEADD(DAY, cc.ExamDate, -2) <= convert(date,GETDATE())" & vbCrLf
        sql &= " AND cc.STDATE > convert(date,GETDATE())" & vbCrLf
        sql &= " AND cc.STDATE >=DATEADD(DAY, GETDATE(), -200)" & vbCrLf
        sql &= " AND cc.STDATE <=DATEADD(DAY, GETDATE(), +100)" & vbCrLf
        sql &= " AND b.modifydate>=DATEADD(DAY, GETDATE(), -200)" & vbCrLf
        sql &= " AND cc.PlanID='" & vPlanID & "'" & vbCrLf
        sql &= " AND cc.RID='" & vRID & "'" & vbCrLf
        sql &= " AND cc.OCID='" & vOCID & "'" & vbCrLf
        sql &= " )" & vbCrLf
        sql &= " select b.namex+' 報名資料為屆退官兵身分者' contextx" & vbCrLf
        sql &= " from (SELECT * FROM T1 UNION SELECT * FROM T2) b" & vbCrLf
        rDt = DbAccess.GetDataTable(sql, oConn)
        Return rDt
    End Function

