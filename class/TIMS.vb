    ''' <summary> 產生新的SID 供 STUD_STUDENTINFO 使用 依時間產生</summary>
    ''' <param name="iEnterNum">多筆儲存時若有時間相同可能性，加1個序號處理</param>
    ''' <returns></returns>
    Public Shared Function GET_STUDENT_NEWSID(ByRef iEnterNum As Integer) As String
        Dim sid As String = ""
        Dim objLock As New Object
        SyncLock objLock
            'iEnterNum 多筆儲存時若有時間相同可能性，加1個序號處理
            '查無SID  
            If iEnterNum < 10 Then
                sid = String.Concat(Get_DateNo, "0", iEnterNum)
            ElseIf iEnterNum > 99 Then
                iEnterNum = 1 '(從1再開始)
                sid = String.Concat(Get_DateNo, "0", iEnterNum)
            Else
                sid = String.Concat(Get_DateNo, iEnterNum)
            End If
            iEnterNum += 1
            '制定SID編號 End
        End SyncLock
        Return sid
    End Function

