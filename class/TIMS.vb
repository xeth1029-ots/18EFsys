    '又改可以輸入小數點了(.只能輸入.5)
    Public Shared Function Chk_GetHoursNum5(ByVal sSub1 As String, ByRef sHours As String, ByRef sErrmsg As String) As Boolean
        Dim rst As Boolean = True '驗證ok false:異常
        sHours = ClearSQM(sHours)
        If sHours = "" Then Return rst

        If Len(sHours) > 10 Then sHours = sHours.Substring(0, 10)
        If Not IsNumeric(sHours) Then
            sErrmsg += $"({sSub1})時數格式有誤{vbCrLf}"
            Return False 'Exit For
        Else
            sHours = Val(sHours)
            'If Not CDbl(sHours)=-1 Then '-1為刪除該資料 'End If
            '新增不提供刪除。
            sHours = CDbl(sHours)
            If CDbl(sHours) < 0 Then
                sErrmsg &= $"({sSub1})時數格式有誤，不得為負數{vbCrLf}"
                Return False 'Exit For
            End If
            '僅提供填寫小數點後為5，或是整數的數字
            If Not IsNumeric5(sHours) Then
                sErrmsg &= $"({sSub1})時數格式僅提供填寫小數點後為5，或是整數的數字，且不得為負數{vbCrLf}"
                Return False 'Exit For
            End If
        End If
        Return rst
    End Function

    ''' <summary>'顯示列數不正確「顯示列數」相關設定</summary>
    ''' <param name="MyPage"></param>
    ''' <param name="oTxtPageSize"></param>
    ''' <param name="oDG"></param>
    Public Shared Sub SUtl_TxtPageSize(ByRef MyPage As Page, ByRef oTxtPageSize As TextBox, ByRef oDG As DataGrid)
        Const cst_scErr1 As String = "<script>alert('顯示列數不正確，以10 帶入');</script>"
        oTxtPageSize.Text = ClearSQM(oTxtPageSize.Text)
        If Trim(oTxtPageSize.Text) <> "" AndAlso IsNumeric(oTxtPageSize.Text) Then
            If CInt(oTxtPageSize.Text) >= 1 Then
                oTxtPageSize.Text = Trim(oTxtPageSize.Text)
            Else
                Common.RespWrite(MyPage, cst_scErr1)
                oTxtPageSize.Text = 10
            End If
        Else
            Common.RespWrite(MyPage, cst_scErr1)
            oTxtPageSize.Text = 10
        End If
        If oTxtPageSize.Text <> oDG.PageSize Then oDG.PageSize = oTxtPageSize.Text
    End Sub

    'Base64的解碼
    Public Shared Function Get_Base64Decode1(ByRef base64Encoded As String) As String
        Dim rstbase64Decoded As String = ""
        Dim Bytedata() As Byte = Nothing
        Try
            Bytedata = System.Convert.FromBase64String(base64Encoded)
        Catch ex As Exception
            rstbase64Decoded = "***ERROR:" & vbCrLf
            rstbase64Decoded &= ex.ToString
            Return rstbase64Decoded
        End Try
        If Bytedata Is Nothing Then Return rstbase64Decoded
        rstbase64Decoded = System.Text.ASCIIEncoding.ASCII.GetString(Bytedata)
        Return rstbase64Decoded
    End Function

