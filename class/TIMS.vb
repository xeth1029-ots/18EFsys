    Public Shared Function Chk_ClassStdApprAll(ByRef MyPage As Page, ByVal tmpOCID As String, ByVal objconn As SqlConnection, ByRef r_MSG1 As String) As Boolean
        '此函數用來判斷學員資料維護的必要欄位是否有填寫完整，為了避免資料庫中被存入NULL，
        '所以判斷時都一致使用ISNULL轉換。
        'PS.此檢核對應學員資料維護的*號標示。
        Dim sm As SessionModel = SessionModel.Instance()
        Dim flag_tplanid2854_chk_SupplyID As Boolean = False
        If Cst_TPlanID28AppPlan.IndexOf(sm.UserInfo.TPlanID) > -1 Then flag_tplanid2854_chk_SupplyID = True

        'Dim flag_OnTheJob_Display As Boolean=False 'false:職前班顯示／'在職班-有些職前的選項不顯示 
        ''07:接受企業委託訓練
        'If Cst_TPlanID07.IndexOf(sm.UserInfo.TPlanID) > -1 Then flag_OnTheJob_Display=True 'true:不顯示 
        ''70:區域產業據點職業訓練計畫(在職)
        'If Cst_TPlanID70.IndexOf(sm.UserInfo.TPlanID) > -1 Then flag_OnTheJob_Display=True 'true:不顯示 
        ''28,54 產業人才投資計劃與充電起飛計畫-在職
        'If Cst_TPlanID28AppPlan.IndexOf(sm.UserInfo.TPlanID) > -1 Then flag_OnTheJob_Display=True 'true:不顯示 

        Dim Rst As Boolean = False
        Dim sql As String = ""
        sql &= " SELECT 'SOCID:'+convert(varchar,a.SOCID) SOCIDtxt" & vbCrLf
        'sql &= " ,a.StudStatus" & vbCrLf
        sql &= " ,case when ISNULL(a.MidentityID,' ')=' ' then ',MidentityID-NG' else '' END" & vbCrLf
        sql &= " +case when ISNULL(a.IdentityID,' ')=' ' then ',IdentityID-NG' else '' END" & vbCrLf
        sql &= " +case when ISNULL(a.BudgetID,' ')=' ' then ',BudgetID-NG' else '' END" & vbCrLf
        If flag_tplanid2854_chk_SupplyID Then
            sql &= " +case when ISNULL(a.SupplyID,' ')=' ' then ',SupplyID-NG' else '' END" & vbCrLf
        End If
        'If Not flag_OnTheJob_Display Then
        '    sql &= " +case when ISNULL(a.SubsidyID,' ')=' ' then ',SubsidyID-NG' else '' END" & vbCrLf
        'End If
        sql &= " +case when ISNULL(b.EngName,' ')=' ' then ',EngName-NG' else '' END" & vbCrLf
        sql &= " +case when ISNULL(b.IsAgree,' ')=' ' then ',IsAgree-NG' else '' END" & vbCrLf
        sql &= " +case when ISNULL(c.Email,' ')=' ' then ',Email-NG' else '' END" & vbCrLf
        sql &= " +case when ISNULL(c.school,' ')=' ' then ',school-NG' else '' END" & vbCrLf
        sql &= " +case when ISNULL(c.Department,' ')=' ' then ',Department-NG' else '' END" & vbCrLf
        'sql &= " +case when (ISNULL(c.PhoneD,' ')=' ' and ISNULL(c.PhoneN,' ')=' ' and ISNULL(c.CellPhone,' ')=' ') then 'Phone-NG' else '' END" & vbCrLf
        'sql &= " +case when ISNULL(c.address,' ')=' ' then ',address-NG' else '' END" & vbCrLf
        'sql &= " +case when ISNULL(c.EmergencyContact,' ')=' ' then ',EmergencyContact-NG' else '' END" & vbCrLf
        'sql &= " +case when ISNULL(c.EmergencyRelation,' ')=' ' then ',EmergencyRelation-NG' else '' END" & vbCrLf
        'sql &= " +case when c.ZipCode3 is null then ',ZipCode3-NG' else '' END" & vbCrLf
        sql &= " +case when ISNULL(c.ShowDetail,' ')=' ' then ',ShowDetail-NG' else '' END msg1" & vbCrLf
        sql &= " FROM CLASS_STUDENTSOFCLASS a WITH(NOLOCK)" & vbCrLf
        sql &= " JOIN STUD_STUDENTINFO b WITH(NOLOCK) on a.SID=b.SID" & vbCrLf
        sql &= " JOIN STUD_SUBDATA c WITH(NOLOCK) on c.SID=a.SID" & vbCrLf
        '排除離退維護。
        sql &= " WHERE a.StudStatus NOT IN (2,3)" & vbCrLf
        sql &= " and a.OCID=@OCID" & vbCrLf 'sql &= " and a.OCID= 123223" & vbCrLf

        sql &= " and (1!=1" & vbCrLf
        sql &= " or ISNULL(a.MidentityID,' ')=' '" & vbCrLf
        sql &= " or ISNULL(a.IdentityID,' ')=' '" & vbCrLf
        sql &= " or ISNULL(a.BudgetID,' ')=' '" & vbCrLf
        If flag_tplanid2854_chk_SupplyID Then
            '產學訓與非產學訓的例外檢核
            'SupplyID 0: 請選擇 ,1: 一般80% ,2: 特定100% ,9: 0% '請選擇變為空。
            sql &= " or ISNULL(a.SupplyID,' ')=' '" & vbCrLf
        End If
        'If Not flag_OnTheJob_Display Then
        '    '津貼類別'(職前檢核) 在職不檢核
        '    sql &= " or ISNULL(a.SubsidyID,' ')=' '" & vbCrLf
        'End If
        sql &= " or ISNULL(b.EngName,' ')=' '" & vbCrLf
        sql &= " or ISNULL(b.IsAgree,' ')=' '" & vbCrLf
        sql &= " or ISNULL(c.Email,' ')=' '" & vbCrLf
        sql &= " or ISNULL(c.school,' ')=' '" & vbCrLf
        sql &= " or ISNULL(c.Department ,' ')=' '" & vbCrLf
        'sql &= " or (ISNULL(c.PhoneD,' ')=' ' and ISNULL(c.PhoneN,' ')=' ' and ISNULL(c.CellPhone,' ')=' ')" & vbCrLf
        'sql &= " or ISNULL(c.address,' ')=' '" & vbCrLf
        'sql &= " or ISNULL(c.EmergencyContact,' ')=' '" & vbCrLf
        'sql &= " or ISNULL(c.EmergencyRelation,' ')=' '" & vbCrLf
        'sql &= " or c.ZipCode3 is null" & vbCrLf
        sql &= " or ISNULL(c.ShowDetail,' ')=' '" & vbCrLf
        sql &= " )" & vbCrLf

        Dim dt As New DataTable
        Call OpenDbConn(objconn)
        Dim sCmd As New SqlCommand(sql, objconn)
        With sCmd
            .Parameters.Clear()
            .Parameters.Add("OCID", SqlDbType.VarChar).Value = tmpOCID
            dt.Load(.ExecuteReader())
        End With
        If dt.Rows.Count > 0 Then Rst = True
        r_MSG1 = ""
        For Each dr As DataRow In dt.Rows
            If Convert.ToString(dr("msg1")) <> "" Then
                If r_MSG1 <> "" Then r_MSG1 &= vbCrLf
                r_MSG1 &= Convert.ToString(dr("SOCIDtxt")) & Convert.ToString(dr("msg1"))
            End If
        Next
        Return Rst
    End Function

