            'Dim s_parms As New Hashtable From {{"PLANID", iPlanID}, {"RID", s_RID}, {"ACCOUNT", sAccount}}
            Dim sSql As String = String.Concat(" SELECT * FROM AUTH_ACCTORG WHERE PLANID=@PLANID AND RID=@RID AND ", s_Acct, "=@ACCT")
            'Dim dtS1 As DataTable=DbAccess.GetDataTable(sql, oConn, s_parms)
            Dim dtS1 As New DataTable
            Using sCmd As New SqlCommand(sSql, oConn)
                With sCmd
                    .Parameters.Clear()
                    .Parameters.Add("PLANID", SqlDbType.Int).Value = iPlanID
                    .Parameters.Add("RID", SqlDbType.VarChar).Value = s_RID 'cbl_OrgList.Items(i).Value
                    .Parameters.Add("ACCT", SqlDbType.VarChar).Value = sAccount
                    dtS1.Load(.ExecuteReader())
                End With
            End Using

            If cbl_OrgList.Items(i).Selected Then '有選取
                If dtS1.Rows.Count = 0 Then
                    Using iCmd As New SqlCommand(i_sql, oConn)
                        '查無資料-新增 是 (5146, , A609301, B8351)
                        Dim iCID As Integer = DbAccess.GetNewId(oConn, "AUTH_ACCTORG_CID_SEQ,AUTH_ACCTORG,CID")
                        With iCmd
                            .Parameters.Clear()
                            .Parameters.Add("CID", SqlDbType.Int).Value = iCID
                            .Parameters.Add("PLANID", SqlDbType.Int).Value = iPlanID
                            .Parameters.Add("RID", SqlDbType.VarChar).Value = s_RID 'cbl_OrgList.Items(i).Value
                            .Parameters.Add(s_Acct, SqlDbType.VarChar).Value = sAccount
                            .Parameters.Add(s_AcctOther, SqlDbType.VarChar).Value = " "
                            .Parameters.Add("MODIFYACCT", SqlDbType.VarChar).Value = sm.UserInfo.UserID
                            .ExecuteNonQuery()
                        End With
                    End Using
                End If
            Else
                '沒有選取-刪除
                If dtS1.Rows.Count > 0 Then
                    Dim dr1 As DataRow = dtS1.Rows(0)
                    Dim iCID As Integer = dr1("CID")
                    Using dCmd As New SqlCommand(d_sql, oConn)
                        With dCmd
                            .Parameters.Add("CID", SqlDbType.Int).Value = iCID
                            .ExecuteNonQuery()
                        End With
                    End Using

                End If
            End If
        Next

        'If dtTemp.Rows.Count <> 0 Then
        '    For Each drTemp In dtTemp.Rows
        '        Dim iCID As Integer=DbAccess.GetNewId(tConn, "AUTH_ACCTORG_CID_SEQ,AUTH_ACCTORG,CID")
        '        dr=dt.NewRow
