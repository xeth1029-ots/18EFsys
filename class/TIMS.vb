    '資料表名稱'欄位名稱'欄位型態'欄位長度
    Public Shared Function Get_USERTABCOLUMNS(ByVal TABLE_NAME As String, ByRef tConn As SqlConnection) As DataTable
        Dim rst As New DataTable
        If tConn Is Nothing Then Return rst
        Dim tmpName As String = ""
        If TABLE_NAME Is Nothing OrElse TABLE_NAME = "" Then Return rst '輸入為空白 /Nothing
        If TABLE_NAME.IndexOf("'") > -1 Then TABLE_NAME = Replace(TABLE_NAME, "'", "") '清除單引號
        TABLE_NAME = Trim(UCase(TABLE_NAME)) '清除空白/'轉大寫
        If TABLE_NAME Is Nothing OrElse TABLE_NAME = "" Then Return rst '整理後為空白 /Nothing
        '重組
        If TABLE_NAME.IndexOf(",") = -1 Then
            tmpName = String.Concat("'", TABLE_NAME, "'")
        ElseIf TABLE_NAME.IndexOf(",") > -1 Then
            Dim StrAry As String() = TABLE_NAME.Split(",")
            For i As Integer = 0 To StrAry.Length - 1
                tmpName &= $"{If(tmpName <> "", ",", "")}'{ StrAry(i)}'"
            Next
        End If
        '資料表名稱'欄位名稱'欄位型態'欄位長度 '設定欄位輸入字數的限制
        '資料表名稱 '欄位名稱 '欄位型態 '欄位長度
        'oracle
        'sql &= " SELECT TABLE_NAME,COLUMN_NAME,DATA_TYPE" & vbCrLf 'COLUMN_NAME
        'sql &= " ,CHAR_LENGTH CHARACTER_MAXIMUM_LENGTH" & vbCrLf
        'sql &= " ,CHAR_LENGTH" & vbCrLf  'CHAR_LENGTH
        'sql &= " FROM USER_TAB_COLUMNS" & vbCrLf
        'sql &= " WHERE TABLE_NAME IN (" & tmpName & ")" & vbCrLf
        'sql &= " AND DATA_TYPE IN ('NVARCHAR2','VARCHAR2','CHAR','NCHAR')" & vbCrLf

        'sql server
        Call OpenDbConn(tConn)
        Dim sql As String = ""
        sql &= " SELECT TABLE_NAME,COLUMN_NAME,DATA_TYPE" & vbCrLf 'COLUMN_NAME
        sql &= ",CHARACTER_MAXIMUM_LENGTH" & vbCrLf
        sql &= ",CHARACTER_MAXIMUM_LENGTH CHAR_LENGTH" & vbCrLf
        sql &= " FROM INFORMATION_SCHEMA.COLUMNS "
        sql &= $" WHERE TABLE_NAME IN ({tmpName})" & vbCrLf
        sql &= " AND DATA_TYPE IN ('NVARCHAR','VARCHAR','CHAR','NCHAR')" & vbCrLf
        Dim oCmd As New SqlCommand(sql, tConn)
        With oCmd
            .Parameters.Clear()
            rst.Load(.ExecuteReader())
        End With
        Return rst
    End Function

