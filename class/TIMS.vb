    ''' <summary>SYS_TRANS_LOG-只有 insert/ update </summary>
    ''' <param name="sm"></param>
    ''' <param name="oConn"></param>
    ''' <param name="oTrans"></param>
    ''' <param name="dr"></param>
    ''' <param name="htPP"></param>
    Public Shared Sub SaveTRANSLOG(ByRef sm As SessionModel, ByRef oConn As SqlConnection, ByRef oTrans As SqlTransaction, ByRef dr As DataRow, ByRef htPP As Hashtable)
        'Dim s_TransType, s_TargetTable, s_FuncPath, s_WHERE As String
        Dim TransType As String = GetMyValue2(htPP, "TransType")
        Dim TargetTable As String = GetMyValue2(htPP, "TargetTable")
        Dim FuncPath As String = GetMyValue2(htPP, "FuncPath")
        Dim s_WHERE As String = GetMyValue2(htPP, "s_WHERE")
        Dim flag_Use_oTrans As Boolean = If(oTrans Is Nothing AndAlso oConn IsNot Nothing, False, True)

        Const cst_datef1 As String = "yyyy-MM-dd HH:mm:ss.fff"
        Const cst_datef2 As String = "yyyy-MM-dd"
        Dim flag_isDate As Boolean = False '日期判斷
        Dim flag_isDateTime As Boolean = False '時間判斷
        Dim flag_isEmpty As Boolean = False '空白資料判斷
        Dim t_iSql As String = ""
        Dim BeforeValues As String = ""
        Dim AfterValues As String = ""
        Dim dt As DataTable = dr.Table
        'Dim myParam As New Hashtable
        Select Case TransType
            Case cst_TRANS_LOG_Insert
                '新增作業
                BeforeValues = ""
                For i As Integer = 0 To dt.Columns.Count - 1 '所有欄位
                    'flag_isEmpty=String.IsNullOrEmpty(dr(dt.Columns(i).ColumnName))
                    flag_isEmpty = IsDBNull(dr(dt.Columns(i).ColumnName))
                    flag_isDate = False 'System.Type.GetType("System.DateTime") '"System.DateTime"
                    If Not flag_isEmpty Then flag_isDate = IsDate1(dr(dt.Columns(i).ColumnName))
                    flag_isDateTime = False
                    If flag_isDate Then flag_isDateTime = IsDateTime1(dr(dt.Columns(i).ColumnName))

                    BeforeValues &= If(BeforeValues <> "", ",", "")
                    BeforeValues &= String.Format("{0}={1}", dt.Columns(i).ColumnName.ToUpper, If(flag_isDate, If(flag_isDateTime, Convert.ToDateTime(dr(dt.Columns(i).ColumnName)).ToString(cst_datef1), Convert.ToDateTime(dr(dt.Columns(i).ColumnName)).ToString(cst_datef2)), Convert.ToString(dr(dt.Columns(i).ColumnName))))
                Next

                t_iSql &= " INSERT INTO SYS_TRANS_LOG (SessionID, TransTime, FuncPath, UserID, TransType, TargetTable, Conditions, BeforeValues, AfterValues) "
                t_iSql &= " VALUES(@SessionID, @TransTime, @FuncPath, @UserID, @TransType, @TargetTable, '', @BeforeValues, '') "
                Dim myParam As New Hashtable From {
                    {"TransTime", DateTime.Now.ToString("yyyy-MM-dd HH:mm:ss.fff")},
                    {"SessionID", sm.SessionID.ToString},
                    {"FuncPath", FuncPath},
                    {"UserID", sm.UserInfo.UserID},
                    {"TransType", TransType},
                    {"TargetTable", TargetTable},
                    {"BeforeValues", BeforeValues}
                }
                If flag_Use_oTrans Then
                    Using sCmd As New SqlCommand(t_iSql, oTrans.Connection) With {.Transaction = oTrans}
                        DbAccess.HashParmsChange(sCmd, myParam)
                        sCmd.ExecuteNonQuery()
                    End Using
                Else
                    Using sCmd As New SqlCommand(t_iSql, oConn)
                        DbAccess.HashParmsChange(sCmd, myParam)
                        sCmd.ExecuteNonQuery()
                    End Using
                End If

            Case cst_TRANS_LOG_Update
                '修改作業
                Dim t_BeforeSql As String = String.Format("SELECT * FROM dbo.{0} WHERE {1}", TargetTable, s_WHERE)
                Dim t_BeforeTB As DataTable = Nothing
                Dim t_BeforeRow As DataRow = Nothing
                If Not flag_Use_oTrans Then
                    t_BeforeTB = DbAccess.GetDataTable(t_BeforeSql, oConn)
                Else
                    Dim tr_Parms As New Hashtable
                    t_BeforeTB = DbAccess.GetDataTable(t_BeforeSql, oTrans, tr_Parms)
                End If
                If t_BeforeTB Is Nothing Then Return

                t_BeforeRow = t_BeforeTB.Rows(0)
                '異動前資料
                BeforeValues = ""
                For i As Integer = 0 To t_BeforeTB.Columns.Count - 1 '所有欄位
                    'flag_isEmpty=String.IsNullOrEmpty(t_BeforeRow(t_BeforeTB.Columns(i).ColumnName))
                    flag_isEmpty = IsDBNull(t_BeforeRow(t_BeforeTB.Columns(i).ColumnName))
                    flag_isDate = False 'System.Type.GetType("System.DateTime") '"System.DateTime"
                    If Not flag_isEmpty Then flag_isDate = IsDate1(t_BeforeRow(t_BeforeTB.Columns(i).ColumnName))
                    flag_isDateTime = False
                    If flag_isDate Then flag_isDateTime = IsDateTime1(t_BeforeRow(t_BeforeTB.Columns(i).ColumnName))

                    BeforeValues &= If(BeforeValues <> "", ",", "")
                    BeforeValues &= String.Format("{0}={1}", t_BeforeTB.Columns(i).ColumnName.ToUpper, If(flag_isDate, If(flag_isDateTime, Convert.ToDateTime(t_BeforeRow(t_BeforeTB.Columns(i).ColumnName)).ToString(cst_datef1), Convert.ToDateTime(t_BeforeRow(t_BeforeTB.Columns(i).ColumnName)).ToString(cst_datef2)), Convert.ToString(t_BeforeRow(t_BeforeTB.Columns(i).ColumnName))))
                Next

                '異動後資料
                AfterValues = ""
                For i As Integer = 0 To dt.Columns.Count - 1 '所有欄位
                    'flag_isEmpty=String.IsNullOrEmpty(dr(dt.Columns(i).ColumnName))
                    flag_isEmpty = IsDBNull(dr(dt.Columns(i).ColumnName))
                    flag_isDate = False 'System.Type.GetType("System.DateTime") '"System.DateTime"
                    If Not flag_isEmpty Then flag_isDate = IsDate1(dr(dt.Columns(i).ColumnName))
                    flag_isDateTime = False
                    If flag_isDate Then flag_isDateTime = IsDateTime1(dr(dt.Columns(i).ColumnName))

                    AfterValues &= If(AfterValues <> "", ",", "")
                    AfterValues &= String.Format("{0}={1}", dt.Columns(i).ColumnName.ToUpper, If(flag_isDate, If(flag_isDateTime, Convert.ToDateTime(dr(dt.Columns(i).ColumnName)).ToString(cst_datef1), Convert.ToDateTime(dr(dt.Columns(i).ColumnName)).ToString(cst_datef2)), Convert.ToString(dr(dt.Columns(i).ColumnName))))
                Next
                t_iSql &= " INSERT INTO SYS_TRANS_LOG (SessionID, TransTime, FuncPath, UserID, TransType, TargetTable, Conditions, BeforeValues, AfterValues) "
                t_iSql &= " VALUES(@SessionID, @TransTime, @FuncPath, @UserID, @TransType, @TargetTable, @Conditions, @BeforeValues, @AfterValues) "
                Dim myParam As New Hashtable From {
                    {"TransTime", DateTime.Now.ToString("yyyy-MM-dd HH:mm:ss.fff")},
                    {"SessionID", sm.SessionID.ToString},
                    {"FuncPath", FuncPath},
                    {"UserID", sm.UserInfo.UserID},
                    {"TransType", TransType},
                    {"TargetTable", TargetTable},
                    {"Conditions", s_WHERE},
                    {"BeforeValues", BeforeValues},
                    {"AfterValues", AfterValues}
                }

                If flag_Use_oTrans Then
                    Using sCmd As New SqlCommand(t_iSql, oTrans.Connection) With {.Transaction = oTrans}
                        DbAccess.HashParmsChange(sCmd, myParam)
                        sCmd.ExecuteNonQuery()
                    End Using
                Else
                    Using sCmd As New SqlCommand(t_iSql, oConn)
                        DbAccess.HashParmsChange(sCmd, myParam)
                        sCmd.ExecuteNonQuery()
                    End Using
                End If
        End Select
    End Sub

