    ''' <summary>檢核時效內有無執行，True:有執行(True) False:尚未執行, 取得線上簽到退紀錄使用 LINEAT.Wdaline</summary>
    ''' <param name="oConn"></param>
    ''' <param name="rPMS"></param>
    ''' <returns></returns>
    Public Shared Function CHK_ADP_STUDATTEDNHP(oConn As SqlConnection, rPMS As Hashtable) As Boolean
        Dim rst As Boolean = False 'True: 驗證有資料 False: 驗證無資料 
        Dim s_HP As String = GetMyValue2(rPMS, "HP") '取得方式紀錄：1:依班級/日期 , 2:依班級
        If s_HP = "" Then Return rst
        Dim s_OCID As String = GetMyValue2(rPMS, "OCID")
        If s_OCID = "" Then Return rst
        Dim iOCID As Integer = CINT1(s_OCID) 'CInt(res.ClassCode)
        Dim drCC As DataRow = GetOCIDDate(iOCID, oConn)
        If drCC Is Nothing Then Return rst
        '在訓期間內1小時執行1次，超過在訓期間1天執行1次
        Dim SCH_STR As String = If(Convert.ToString(drCC("TRAININGDATE")) = "Y", "(1.0/24)", "1")

        If s_HP = "1" Then
            Dim s_STRAINDATE As String = GetMyValue2(rPMS, "STRAINDATE")
            Dim dSTRAINDATE As DateTime = If(s_STRAINDATE <> "", CDate(Cdate3(s_STRAINDATE)), DateTime.Today)
            If s_STRAINDATE = "" Then Return rst
            Dim oDt As New DataTable
            Dim sql As String = String.Concat(" SELECT 1 FROM ADP_STUDATTENDHP1 WITH(NOLOCK) WHERE OCID=@OCID AND STRAINDATE=@STRAINDATE AND MODIFYDATE>=GETDATE()-", SCH_STR)
            Using oCmd As New SqlCommand(sql, oConn)
                With oCmd
                    .Parameters.Clear()
                    .Parameters.Add("OCID", SqlDbType.Int).Value = iOCID
                    .Parameters.Add("STRAINDATE", SqlDbType.DateTime).Value = dSTRAINDATE
                    oDt.Load(.ExecuteReader())
                End With
            End Using
            If oDt.Rows.Count > 0 Then rst = True
            Return rst

        ElseIf s_HP = "2" Then
            Dim oDt As New DataTable
            Dim sql As String = String.Concat(" SELECT 1 FROM ADP_STUDATTENDHP2 WITH(NOLOCK) WHERE OCID=@OCID AND MODIFYDATE>=GETDATE()-", SCH_STR)
            Using oCmd As New SqlCommand(sql, oConn)
                With oCmd
                    .Parameters.Clear()
                    .Parameters.Add("OCID", SqlDbType.Int).Value = iOCID
                    oDt.Load(.ExecuteReader())
                End With
            End Using
            If oDt.Rows.Count > 0 Then rst = True
            Return rst

        End If
    End Function

    Public Shared ReadOnly Property DicFileSignatures As Dictionary(Of Byte(), String)
        Get
            'https://en.wikipedia.org/wiki/List_of_file_signatures
            'zip:'Also used by DOCX, XLSX, PPTX zip,aar,apk,docx,epub,ipa,jar,kmz,maff,msix,odp,ods,odt,pk3,pk4,pptx,usdz,vsdx,xlsx,xpi,
            'doc: doc,xls,ppt,msi,msg, 
            'KEY:head / VALUE: filetype
            Dim _fileSignatures As New Dictionary(Of Byte(), String) From {
                {New Byte() {&HFF, &HD8, &HFF}, "jpg"},
                {New Byte() {&H89, &H50, &H4E, &H47, &HD, &HA, &H1A, &HA}, "png"},
                {New Byte() {&H47, &H49, &H46, &H38}, "gif"},
                {New Byte() {&H42, &H4D}, "bmp"},
                {New Byte() {&H49, &H49, &H2A, &H0}, "tif"},
                {New Byte() {&H4D, &H4D, &H0, &H2A}, "tif"},
                {New Byte() {&H25, &H50, &H44, &H46}, "pdf"},
                {New Byte() {&HD0, &HCF, &H11, &HE0, &HA1, &HB1, &H1A, &HE1}, "doc"},
                {New Byte() {&H50, &H4B, &H3, &H4}, "zip"}
            }
            Return _fileSignatures
        End Get
    End Property

    ''' <summary> Function to get file type based on its content</summary>
    ''' <param name="filePath"></param>
    ''' <returns></returns>
    Public Shared Function GetActualFileType(filePath As String) As String
        ' Adjust size based on your needs (here 8 bytes)
        Dim fileHeader(8) As Byte
        Try
            Using fileStream As New FileStream(filePath, FileMode.Open, FileAccess.Read)
                fileStream.Read(fileHeader, 0, fileHeader.Length)
            End Using
            For Each KVPair As KeyValuePair(Of Byte(), String) In DicFileSignatures
                If fileHeader.Take(KVPair.Key.Length).SequenceEqual(KVPair.Key) Then
                    Return KVPair.Value
                End If
            Next
        Catch ex As Exception
            ' Handle potential exceptions (e.g., file not found)
            Return String.Concat("Exception:", ex.Message)
        End Try
        Return "unknown"
    End Function

