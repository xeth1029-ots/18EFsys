                        End Try
                    Next

                Else
                    For Each drFLOTH As DataRow In dtFLOTH.Rows
                        Try
                            oFILENAME1 = $"{drFLOTH("FILENAME1")}"
                            oUploadPath = $"{drFLOTH("FILEPATH1")}"
                            s_FilePath1 = MyPage.Server.MapPath(Path.Combine(oUploadPath, oFILENAME1))
