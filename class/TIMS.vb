    ''' <summary>轉換HTML顯示</summary>
    ''' <param name="MailBody"></param>
    ''' <returns></returns>
    Public Shared Function GetResponseWrite(ByVal MailBody As String) As String
        If MailBody = "" Then Return ""
        MailBody = Replace(MailBody, vbCrLf, "<BR>")
        MailBody = Replace(MailBody, vbCr, "<BR>")
        MailBody = Replace(MailBody, vbLf, "<BR>")
        MailBody = Replace(MailBody, vbFormFeed, "<BR>")
        MailBody = Replace(MailBody, vbTab, "&nbsp;&nbsp;&nbsp;")
        MailBody = Replace(MailBody, " ", "&nbsp;")
        Return MailBody
    End Function

