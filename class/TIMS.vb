#Region "CHECK VALUE"
    Public Const cst_st字串 As String = "字串"
    Public Const cst_st整數 As String = "整數"
    Public Const cst_st字串必填 As String = "字串必填"
    Public Const cst_st數字必填 As String = "數字必填"
    Public Const cst_st日期必填 As String = "日期必填"

    ''' <summary>
    ''' 檢核輸入值3
    ''' </summary>
    ''' <param name="fN1">欄位名稱</param>
    ''' <param name="vN1">輸入內容值</param>
    ''' <param name="sType">應符合形態</param>
    ''' <returns></returns>
    Public Shared Function ChkValue1(ByVal fN1 As String, ByVal vN1 As Object, ByVal sType As String) As String
        Return ChkValue1(fN1, vN1, sType, 0)
    End Function

    ''' <summary>
    ''' 檢核輸入值4
    ''' </summary>
    ''' <param name="fN1">欄位名稱</param>
    ''' <param name="vN1">輸入內容值</param>
    ''' <param name="sType">應符合形態</param>
    ''' <param name="iSize">字串長度限制</param>
    ''' <returns></returns>
    Public Shared Function ChkValue1(ByVal fN1 As String, ByVal vN1 As Object, ByVal sType As String, ByVal iSize As Integer) As String
        Dim rst As String = ""
        Select Case sType
            Case cst_st字串
                If $"{vN1}" <> "" Then
                    If $"{vN1}".Length > iSize Then rst &= $"{fN1}字串長度 必須小於等於{iSize}字數<br>"
                End If
            Case cst_st整數
                If Not IsNumeric2(vN1) Then rst &= $"{fN1}{fN1} 必須為整數數字<br>"

            Case cst_st字串必填
                If $"{vN1}" <> "" Then
                    If $"{vN1}".Length > iSize Then rst &= $"{fN1}字串長度 必須小於等於{iSize}字數<br>"
                Else
                    rst &= $"{fN1} 為必填資料<br>"
                End If
            Case cst_st數字必填
                If $"{vN1}" <> "" Then
                    If Not IsNumeric(vN1) Then rst &= $"{fN1}必需為數字<br>"
                Else
                    rst &= $"{fN1}必須填寫<br>"
                End If
            Case cst_st日期必填
                If $"{vN1}" <> "" Then
                    If Not IsDate(vN1) Then
                        rst &= $"{fN1}必須是西元年格式(yyyy/MM/dd)<br>"
                    Else
                        If CDate(vN1) < "1900/1/1" Or CDate(vN1) > "2100/1/1" Then rst &= $"{fN1}範圍有誤<br>"
                    End If
                Else
                    rst &= $"{fN1}必須填寫<br>"
                End If
        End Select
        Return rst
    End Function

    ''' <summary>檢核輸入值5</summary>
    ''' <param name="fN1">欄位名稱</param>
    ''' <param name="vN1">輸入內容值</param>
    ''' <param name="sType">應符合形態</param>
    ''' <param name="iMin">數值大小限制-至少</param>
    ''' <param name="iMax">數值大小限制-至多</param>
    ''' <returns></returns>
    Public Shared Function ChkValue1(ByVal fN1 As String, ByVal vN1 As Object, ByVal sType As String, ByVal iMin As Integer, ByVal iMax As Integer) As String
        Dim rst As String = ""
        Select Case sType
            Case cst_st整數
                If Not IsInt(vN1) Then
                    rst &= $"{fN1} 必須為整數數字<br>"
                    Return rst
                End If
                If CINT1(vN1) < CINT1(iMin) Then
                    rst &= $"{fN1} 數字超過範圍<br>"
                    Return rst
                End If
                If CINT1(vN1) > CINT1(iMax) Then
                    rst &= $"{fN1} 數字超過範圍<br>"
                    Return rst
                End If
        End Select
        Return rst
    End Function
#End Region

#Region "HASHPWD1"

    ''' <summary>
    ''' 清理未設定密碼的無效資料
    ''' 刪除3小時內的密碼-如果還未設定密碼 AUTH_PXSSWARD_HIS
    ''' </summary>
    ''' <param name="oConn"></param>
    ''' <param name="s_parms"></param>
    Public Shared Sub Del_PXSSWARDHIS_3h(ByRef oConn As SqlConnection, ByRef s_parms As Hashtable)
        Dim vACCOUNT As String = GetMyValue2(s_parms, "ACCOUNT")
        If vACCOUNT = "" Then Exit Sub

        Dim parms As New Hashtable From {{"ACCOUNT", UCase(vACCOUNT)}}
        Dim sqlstr As String = "" 'sqlstr &= " SELECT PXSEQ,ACCOUNT,HSEQ,SENDMAIL,SENDMAILDATE"
        sqlstr &= " DELETE dbo.AUTH_PXSSWARD_HIS"
        sqlstr &= " WHERE upper(ACCOUNT)=@ACCOUNT"
        '/*密碼寄信種類-1:新設密碼-2:忘記密碼(修改密碼)-3:修改密碼 */ SENDMAILTYPE /SDMATYPE
        sqlstr &= " AND SENDMAILTYPE IN ('1','2')"
        sqlstr &= " AND SENDMAILDATE>=DATEADD(HH,-3,GETDATE())" '有效期限：3HR
        sqlstr &= " AND HASHPWD1 IS NULL" '未設定的
        Dim dr As DataRow = DbAccess.GetOneRow(sqlstr, oConn, parms) '取得內部資訊
    End Sub

    ''' <summary>
    ''' 取得內部資訊-DataRow AUTH_PXSSWARD_HIS ADP_HASHLOG
    ''' </summary>
    ''' <param name="oConn"></param>
    ''' <param name="s_parms"></param>
    ''' <returns></returns>
    Public Shared Function GET_drPXSSWARDHIS(ByRef oConn As SqlConnection, ByRef s_parms As Hashtable) As DataRow
        Dim vHSEQ As String = GetMyValue2(s_parms, "HSEQ")
        If vHSEQ = "" Then Return Nothing
        If Not IsNumeric2(vHSEQ) Then Return Nothing
        Dim vHASH1 As String = GetMyValue2(s_parms, "HASH1")
        If vHASH1 = "" Then Return Nothing
        Dim parms As New Hashtable From {{"HSEQ", CINT1(vHSEQ)}, {"HASH1", vHASH1}} 'parms.Clear()
        Dim sqlstr As String = ""
        sqlstr &= " SELECT a.PXSEQ,a.ACCOUNT,a.SENDMAIL,a.SENDMAILDATE"
        sqlstr &= " ,a.HSEQ,b.GUID1,b.HASH1"
        sqlstr &= " FROM dbo.AUTH_PXSSWARD_HIS a"
        sqlstr &= " JOIN dbo.ADP_HASHLOG b on b.HSEQ=a.HSEQ"
        sqlstr &= " WHERE b.HSEQ=@HSEQ AND b.HASH1=@HASH1"
        sqlstr &= " AND a.SENDMAILDATE>=DATEADD(HH,-3,GETDATE())" '有效期限：3HR
        sqlstr &= " AND a.HASHPWD1 IS NULL" '未設定的
        Dim dr As DataRow = DbAccess.GetOneRow(sqlstr, oConn, parms) '取得內部資訊
        Return dr
    End Function

    ''' <summary>
    ''' 取得內部資訊-3代 AUTH_PXSSWARD_HIS ADP_HASHLOG
    ''' </summary>
    ''' <param name="oConn"></param>
    ''' <param name="s_parms"></param>
    ''' <returns></returns>
    Public Shared Function GET_dtPXSSWARDHIS(ByRef oConn As SqlConnection, ByRef s_parms As Hashtable) As DataTable
        Dim dt1 As DataTable = Nothing
        Dim vHSEQ As String = GetMyValue2(s_parms, "HSEQ")
        If vHSEQ = "" Then Return Nothing
        If Not IsNumeric2(vHSEQ) Then Return Nothing
        Dim vHASH1 As String = GetMyValue2(s_parms, "HASH1")
        If vHASH1 = "" Then Return dt1
        Dim vACCOUNT As String = GetMyValue2(s_parms, "ACCOUNT")
        If vACCOUNT = "" Then Return dt1

        Dim parms As New Hashtable From {{"HSEQ", vHSEQ}, {"HASH1", vHASH1}, {"ACCOUNT", UCase(vACCOUNT)}} 'parms.Clear()
        Dim sqlstr As String = ""
        sqlstr &= " SELECT TOP 3 a.PXSEQ" '3代
        sqlstr &= " ,a.ACCOUNT,a.HSEQ,a.HASHPWD1,a.SENDMAIL,a.SENDMAILDATE"
        sqlstr &= " ,b.GUID1,b.HASH1"
        sqlstr &= " FROM dbo.AUTH_PXSSWARD_HIS a" '設定碼的歷史
        sqlstr &= " JOIN dbo.ADP_HASHLOG b on b.HSEQ=a.HSEQ" '回覆信件 加密序號表
        sqlstr &= " WHERE a.HSEQ!=@HSEQ" '設定碼的歷史(非)
        sqlstr &= " AND b.HASH1!=@HASH1" ''回覆信件 加密序號表(非)
        sqlstr &= " AND upper(a.ACCOUNT)=@ACCOUNT" '同帳號
        sqlstr &= " AND a.HASHPWD1 IS NOT NULL" '有設定的
        sqlstr &= " ORDER BY a.PXSEQ DESC" '3代排序
        dt1 = DbAccess.GetDataTable(sqlstr, oConn, parms) '取得內部資訊
        Return dt1
    End Function

    ''' <summary>
    ''' 新增(HASHLOG)與取得(HSEQ)資訊 ADP_HASHLOG
    ''' </summary>
    ''' <param name="oConn"></param>
    ''' <param name="s_parms"></param>
    ''' <returns></returns>
    Public Shared Function Get_drHSEQ(ByRef oConn As SqlConnection, ByRef s_parms As Hashtable) As DataRow
        Dim dr As DataRow = Nothing
        'in MODIFYACCT
        Dim vMODIFYACCT As String = GetMyValue2(s_parms, "MODIFYACCT")
        If vMODIFYACCT = "" Then vMODIFYACCT = "system"

        Dim iHSEQ As Integer = DbAccess.GetNewId(oConn, "ADP_HASHLOG_HSEQ_SEQ,ADP_HASHLOG,HSEQ")
        Dim vGUID1 As String = TIMS.GetGUID(oConn)
        Dim vHASH1 As String = TIMS.CreateHash(vGUID1 & "." & CStr(iHSEQ))

        Dim iprams As New Hashtable From {{"HSEQ", iHSEQ}, {"GUID1", vGUID1}, {"HASH1", vHASH1}, {"MODIFYACCT", vMODIFYACCT}} 'iprams.Clear()
        Dim sqlstr As String = ""
        sqlstr &= " INSERT INTO ADP_HASHLOG( HSEQ ,GUID1 ,HASH1 ,MODIFYACCT ,MODIFYDATE)" & vbCrLf
        sqlstr &= " VALUES ( @HSEQ ,@GUID1 ,@HASH1 ,@MODIFYACCT ,GETDATE())" & vbCrLf
        DbAccess.ExecuteNonQuery(sqlstr, objConn:=oConn, parms:=iprams)

        Dim pms1 As New Hashtable From {{"HSEQ", iHSEQ}}
        sqlstr = " SELECT * FROM dbo.ADP_HASHLOG WHERE HSEQ=@HSEQ"
        dr = DbAccess.GetOneRow(sqlstr, objConn:=oConn, parms:=pms1)
        Return dr
    End Function

