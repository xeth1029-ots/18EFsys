    ''' <param name="o_MM"></param>
    ''' <returns></returns>
    Public Shared Function GET_DateHM2(ByRef o_HH As DropDownList, ByRef o_MM As DropDownList) As String
        Dim s_HH As String = GetListValue(o_HH)
        Dim s_MM As String = GetListValue(o_MM)
        s_HH = If(s_HH.Length < 2, $"0{s_HH}", s_HH) '補0
        s_MM = If(s_MM.Length < 2, $"0{s_MM}", s_MM) '補0
        Return String.Format("{0}:{1}", s_HH, s_MM)
    End Function

