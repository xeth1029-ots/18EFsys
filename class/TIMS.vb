    ''' <summary>訓練經費編列/支用標準文件</summary>
    ''' <param name="sm"></param>
    ''' <returns></returns>
    Friend Shared Function Get_PDF_GovTraining(ByRef sm As SessionModel) As String
        Dim Rst As String = ""
        If sm Is Nothing Then Return Rst
        'Standards for the preparation of training funds
        '訓練經費編列/支用標準 文件
        'Public Const pdf_g20171226 As String="https://tims.etraining.gov.tw/doc/%E6%96%B0%E7%89%88%E8%A8%93%E7%B7%B4%E7%B6%93%E8%B2%BB%E7%B7%A8%E5%88%97%E6%A8%99%E6%BA%96.pdf"
        'Public Const pdf_g20171226 As String="https://ojtims.wda.gov.tw/doc/新版訓練經費編列標準.pdf"
        '訓練經費編列標準_0926.pdf
        '訓練經費編列標準_1130.pdf
        'https://ojtims.wda.gov.tw/doc/訓練經費編列標準_0926.pdf
        'https://ojtims.wda.gov.tw/doc/訓練經費編列標準_1130.pdf
        'https://ojtims.wda.gov.tw/doc/%E8%A8%93%E7%B7%B4%E7%B6%93%E8%B2%BB%E7%B7%A8%E5%88%97%E6%A8%99%E6%BA%96_0926.pdf
        'https://ojtims.wda.gov.tw/doc/%E8%A8%93%E7%B7%B4%E7%B6%93%E8%B2%BB%E7%B7%A8%E5%88%97%E6%A8%99%E6%BA%96_1130.pdf
        '新版訓練經費編列標準
        Const pdf_g20171226 As String = "https://ojtims.wda.gov.tw/doc/%E6%96%B0%E7%89%88%E8%A8%93%E7%B7%B4%E7%B6%93%E8%B2%BB%E7%B7%A8%E5%88%97%E6%A8%99%E6%BA%96.pdf"
        Const pdf_g20230926 As String = "https://ojtims.wda.gov.tw/doc/%E8%A8%93%E7%B7%B4%E7%B6%93%E8%B2%BB%E7%B7%A8%E5%88%97%E6%A8%99%E6%BA%96_0926.pdf"
        Const pdf_g20231130 As String = "https://ojtims.wda.gov.tw/doc/%E8%A8%93%E7%B7%B4%E7%B6%93%E8%B2%BB%E7%B7%A8%E5%88%97%E6%A8%99%E6%BA%96_1130.pdf"
        '二、上開增修，基於產投及充飛受理時間不同，請依不同計畫各自上版
        '1、產業人才投資方案先於9月26日上版。
        '2、充電起飛計畫於11月30日上版。
        Dim date_ACTHUMCOST_28_2023 As Date = CDate("2023/09/26")
        Dim date_ACTHUMCOST_54_2023 As Date = CDate("2023/11/30")

        If (Cst_TPlanID28.IndexOf(sm.UserInfo.TPlanID) > -1) AndAlso DateDiff(DateInterval.Day, date_ACTHUMCOST_28_2023, Now) >= 0 Then
            Rst = pdf_g20230926 '訓練經費編列標準
        ElseIf (Cst_TPlanID54AppPlan.IndexOf(sm.UserInfo.TPlanID) > -1) AndAlso DateDiff(DateInterval.Day, date_ACTHUMCOST_54_2023, Now) >= 0 Then
            Rst = pdf_g20231130 '訓練經費編列標準
        Else
            Rst = pdf_g20171226 '訓練經費編列標準
        End If
        Return Rst
    End Function

