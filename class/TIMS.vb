    ''' <summary>依 PSNO28 由 PLAN_PLANINFO 取得 DataRow </summary>
    ''' <param name="s_PSNO28"></param>
    ''' <param name="oConn"></param>
    ''' <returns></returns>
    Public Shared Function Get_PSNO28_row(s_PSNO28 As String, oConn As SqlConnection) As DataRow
        Dim rst As DataRow = Nothing
        s_PSNO28 = ClearSQM(s_PSNO28)
        If s_PSNO28 = "" OrElse Not OpenDbConn(oConn) Then Return rst

        Dim sql As String = ""
        sql &= " SELECT pp.PSNO28,pp.PLANID,pp.COMIDNO,pp.SEQNO,pp.CLASSNAME" & vbCrLf
        sql &= " ,ip.YEARS,ip.TPLANID,ip.DISTID" & vbCrLf
        sql &= " ,ig3.GCODE31 GCODE" & vbCrLf
        sql &= " FROM dbo.PLAN_PLANINFO pp" & vbCrLf
        sql &= " JOIN dbo.V_GOVCLASSCAST3 ig3 on ig3.GCID3=pp.GCID3" & vbCrLf
        sql &= " JOIN dbo.ID_PLAN ip on ip.PLANID=pp.PLANID" & vbCrLf
        sql &= " WHERE pp.PSNO28=@PSNO28" & vbCrLf

        Dim sCmd As New SqlCommand(sql, oConn)
        Dim dt As New DataTable
        With sCmd
            .Parameters.Clear()
            .Parameters.Add("PSNO28", SqlDbType.VarChar).Value = s_PSNO28
            dt.Load(.ExecuteReader())
        End With
        If dt.Rows.Count = 1 Then rst = dt.Rows(0)
        Return rst
    End Function

