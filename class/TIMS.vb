    Public Shared Function Get_PNamePlanTrainDesc(ByVal Planid As String, ByVal ComIDNO As String, ByVal SeqNO As String, ByVal tConn As SqlConnection) As String
        Dim rst As String = ""

        Call OpenDbConn(tConn)
        Dim dt As New DataTable
        Dim sql As String = " SELECT PName FROM PLAN_TRAINDESC WHERE Planid=@Planid AND ComIDNO=@ComIDNO AND SeqNO=@SeqNO" & vbCrLf
        Dim sCmd As New SqlCommand(sql, tConn)
        With sCmd
            '.Parameters.Clear()
            .Parameters.Add("PlanID", SqlDbType.Int).Value = CINT1(Planid)
            .Parameters.Add("ComIDNO", SqlDbType.VarChar).Value = ComIDNO
            .Parameters.Add("SeqNO", SqlDbType.Int).Value = CINT1(SeqNO)
            dt.Load(.ExecuteReader())
        End With
        If dt.Rows.Count > 0 Then
            For i As Integer = 0 To dt.Rows.Count - 1
                Dim sPName As String = ChangeSQM(dt.Rows(i)("PName"))
                If sPName <> "" AndAlso rst.IndexOf(sPName) = -1 Then
                    rst &= String.Concat(If(rst <> "", ",", ""), "'", sPName, "'")
                End If
            Next
        End If
        Return rst
    End Function

