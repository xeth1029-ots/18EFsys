    ''' <summary>'格式正確才返回-辦公室電話-資訊,其它為空</summary>
    ''' <param name="vPhone"></param>
    ''' <param name="hCtPhone"></param>
    ''' <returns></returns>
    Public Shared Function CHK_ContactPhoneFMT(ByVal vPhone As String, ByRef hCtPhone As Hashtable) As Boolean
        '一、 於「班別資料」頁籤，調整班級聯絡人電話格式：
        '將原聯絡人【電話】欄位，區分為兩欄【辦公室電話】、【行動電話】，系統卡控至少須擇一填寫。
        '介面統一填寫格式(可參考圖一)：
        '【辦公室電話】：區碼 (2~3馬) + 電話(8碼內) + 分機(8碼內) '【行動電話】：手機號碼前4碼 + 手機號碼後6碼
        '考慮舊資料無法帶入顯示問題，舊資料可都帶入【辦公室電話】欄位，若無法符合格式也沒關係，等run過幾次以後，資料格式會慢慢導正。(因為他們大都用班級複製)
        '會配合調整「班級複製功能」(會再另提需求)，推行初期先不複製電話欄位，由訓練單位自行填寫正確格式，並請分署協助宣導。之後視情況可調整回可複製電話欄位。
        '另外在職訓練網、系統相關報表之聯絡電話顯示方式也會配合調整(會再另提需求)，改為同時顯示辦公室電話+行動電話(以有輸入者顯示)。
        vPhone = ChangeIDNO(vPhone)
        If (vPhone.IndexOf("分機") > -1) Then vPhone = Replace(vPhone, "分機", "#")
        If (vPhone.IndexOf("轉") > -1) Then vPhone = Replace(vPhone, "轉", "#")
        If RegularExpressions.Regex.IsMatch(vPhone, "^\(\d+\)") Then
            Dim m As RegularExpressions.Match = RegularExpressions.Regex.Match(vPhone, "^\(\d+\)")
            Dim s_P1 As String = String.Concat(RegularExpressions.Regex.Match(m.Value, "\d+").Value, "-")
            vPhone = Replace(vPhone, m.Value, s_P1)
        End If
        If hCtPhone Is Nothing Then hCtPhone = New Hashtable
        hCtPhone.Clear()
        Dim s_Phone_1 As String = ""
        Dim s_Phone_2 As String = ""
        Dim s_Phone_3 As String = ""
        If vPhone IsNot Nothing AndAlso Not String.IsNullOrEmpty(vPhone) Then
            If vPhone.Length > 1 AndAlso vPhone.Split("-").Length = 2 AndAlso vPhone.Split("#").Length = 2 Then
                s_Phone_1 = ClearSQM(vPhone.Split("-")(0))
                s_Phone_2 = ClearSQM(vPhone.Split("-")(1).Split("#")(0))
                s_Phone_3 = ClearSQM(vPhone.Split("#")(1))
                'If s_Phone_1.Length > 4 OrElse s_Phone_2.Length > 8 OrElse s_Phone_3.Length > 8 Then
                '    s_Phone_1=""
                '    s_Phone_2=""
                '    s_Phone_3=""
                'End If
                hCtPhone.Add("ContactPhone_1", s_Phone_1)
                hCtPhone.Add("ContactPhone_2", s_Phone_2)
                hCtPhone.Add("ContactPhone_3", s_Phone_3)
                Return True
            ElseIf vPhone.Length > 1 AndAlso vPhone.Split("-").Length = 2 AndAlso vPhone.IndexOf("#") = -1 Then
                s_Phone_1 = ClearSQM(vPhone.Split("-")(0))
                s_Phone_2 = ClearSQM(vPhone.Split("-")(1))
                'If s_Phone_1.Length > 4 OrElse s_Phone_2.Length > 8 Then
                '    s_Phone_1=""
                '    s_Phone_2=""
                'End If
                hCtPhone.Add("ContactPhone_1", s_Phone_1)
                hCtPhone.Add("ContactPhone_2", s_Phone_2)
                hCtPhone.Add("ContactPhone_3", "")
                Return True
            ElseIf vPhone.Length > 1 AndAlso vPhone.Split("-").Length > 2 AndAlso vPhone.IndexOf("#") = -1 Then
                s_Phone_1 = ClearSQM(vPhone.Split("-")(0))
                s_Phone_2 = ""
                For i As Integer = 1 To vPhone.Split("-").Length - 1
                    s_Phone_2 &= vPhone.Split("-")(i)
                Next
                s_Phone_2 = ClearSQM(s_Phone_2)
                'If s_Phone_1.Length > 4 OrElse s_Phone_2.Length > 8 Then
                '    s_Phone_1=""
                '    s_Phone_2=""
                'End If
                hCtPhone.Add("ContactPhone_1", s_Phone_1)
                hCtPhone.Add("ContactPhone_2", s_Phone_2)
                hCtPhone.Add("ContactPhone_3", "")
                Return True
            ElseIf vPhone.Length > 1 AndAlso vPhone.Split("-").Length > 2 Then
                s_Phone_1 = ClearSQM(vPhone.Split("-")(0))
                s_Phone_2 = ""
                For i As Integer = 1 To vPhone.Split("-").Length - 1
                    s_Phone_2 &= vPhone.Split("-")(i)
                Next
                s_Phone_2 = ClearSQM(s_Phone_2)
                If vPhone.IndexOf("#") > -1 Then
                    Dim tmp2 As String = ClearSQM(s_Phone_2.Split("#")(0))
                    Dim tmp3 As String = ClearSQM(s_Phone_2.Split("#")(1))
                    s_Phone_2 = tmp2
                    s_Phone_3 = tmp3
                End If
                'If s_Phone_1.Length > 4 OrElse s_Phone_2.Length > 8 Then
                '    s_Phone_1=""
                '    s_Phone_2=""
                'End If
                hCtPhone.Add("ContactPhone_1", s_Phone_1)
                hCtPhone.Add("ContactPhone_2", s_Phone_2)
                hCtPhone.Add("ContactPhone_3", s_Phone_3)
                Return True
            End If
        End If
        hCtPhone.Add("ContactPhone_1", "")
        hCtPhone.Add("ContactPhone_2", "")
        hCtPhone.Add("ContactPhone_3", "")
        Return False
    End Function

