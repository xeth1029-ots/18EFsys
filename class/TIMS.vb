    ''' <summary>只能執行一次，DB 寫入／重新設定 系統參數 時間 yyyyMMddHHmm</summary>
    ''' <param name="oConn"></param>
    Public Shared Sub SET_First_CFG_RELOAD_TIME_DB(oConn As SqlConnection, hostName As String)
        Const cst_CFG_RELOAD_TIME_ITEMNAME As String = "CFG_RELOAD_TIME_"
        Const cst_CFG_RELOAD_TIME_MEMO1 As String = "重新取得系統參數時間"

        OpenDbConn(oConn)
        Dim pms1 As New Hashtable From {{"ITEMNAME", cst_CFG_RELOAD_TIME_ITEMNAME}, {"hostName", hostName}}
        Dim sql As String = "SELECT SVID,ITEMNAME,ITEMVALUE,FORMAT(GETDATE(),'yyyyMMddHHmm') YMDVAL FROM SYS_VAR WITH(NOLOCK) WHERE SPAGE='Config' AND ITEMNAME=@ITEMNAME+@hostName"
        'Dim dt1 As DataTable = DbAccess.GetDataTable(sql, oConn, pms1) '取得
        Dim dt1 As New DataTable
        Dim oCmd As New SqlCommand(sql, oConn)
        DbAccess.HashParmsChange(oCmd, pms1)
        dt1.Load(oCmd.ExecuteReader())

        Dim iSVID As Integer = -1
        Dim ITEMVALUE As String = ""
        Dim YMDVAL As String = ""
        Dim MEMO1 As String = cst_CFG_RELOAD_TIME_MEMO1
        Try
            If dtNODATA(dt1) Then
                iSVID = DbAccess.GetNewId(oConn, "SYS_VAR_SVID_SEQ,SYS_VAR,SVID")
                Dim iPMS As New Hashtable From {{"SVID", iSVID}, {"ITEMNAME", cst_CFG_RELOAD_TIME_ITEMNAME}, {"hostName", hostName}, {"MEMO1", MEMO1}}
                Dim isSql As String = "INSERT INTO SYS_VAR(SVID,SPAGE,ITEMNAME,ITEMVALUE,MEMO1) VALUES(@SVID,'Config',@ITEMNAME+@hostName,FORMAT(GETDATE(),'yyyyMMddHHmm'),@MEMO1)" & vbCrLf
                Dim isCmd As New SqlCommand(isSql, oConn)
                DbAccess.HashParmsChange(isCmd, iPMS)
                isCmd.ExecuteNonQuery() 'DbAccess.ExecuteNonQuery(isSql, oConn, iPMS)

                Dim pms1B As New Hashtable From {{"ITEMNAME", cst_CFG_RELOAD_TIME_ITEMNAME}, {"hostName", hostName}}
                Dim sqlB As String = "SELECT SVID,ITEMNAME,ITEMVALUE,FORMAT(GETDATE(),'yyyyMMddHHmm') YMDVAL FROM SYS_VAR WITH(NOLOCK) WHERE SPAGE='Config' AND ITEMNAME=@ITEMNAME+@hostName"
                Dim dt1B As DataTable = DbAccess.GetDataTable(sqlB, oConn, pms1B) '取得
                'iSVID = CINT1(dt1B.Rows(0)("SVID"))
                ITEMVALUE = $"{dt1B.Rows(0)("ITEMVALUE")}"
                YMDVAL = $"{dt1B.Rows(0)("YMDVAL")}"
            Else
                If dt1.Rows.Count > 1 Then
                    '(超過1筆)(刪除1筆)
                    iSVID = CINT1(dt1.Rows(1)("SVID"))
                    ITEMVALUE = $"{dt1.Rows(1)("ITEMVALUE")}"
                    Dim PMS_D As New Hashtable From {{"SVID", iSVID}, {"ITEMNAME", cst_CFG_RELOAD_TIME_ITEMNAME}, {"hostName", hostName}}
                    Dim SQL_D As String = "DELETE SYS_VAR WHERE SVID=@SVID AND ITEMNAME=@ITEMNAME+@hostName"
                    Dim DCmd As New SqlCommand(SQL_D, oConn)
                    DbAccess.HashParmsChange(DCmd, PMS_D)
                    DCmd.ExecuteNonQuery()
                End If
                iSVID = CINT1(dt1.Rows(0)("SVID"))
                ITEMVALUE = $"{dt1.Rows(0)("ITEMVALUE")}"
                YMDVAL = $"{dt1.Rows(0)("YMDVAL")}"
                Dim uPMS As New Hashtable From {{"SVID", iSVID}, {"ITEMNAME", cst_CFG_RELOAD_TIME_ITEMNAME}, {"hostName", hostName}, {"MEMO1", MEMO1}}
                Dim usSql As String = "UPDATE SYS_VAR SET ITEMVALUE=FORMAT(GETDATE(),'yyyyMMddHHmm'),MEMO1=@MEMO1 WHERE SVID=@SVID AND ITEMNAME=@ITEMNAME+@hostName AND ITEMVALUE!=FORMAT(GETDATE(),'yyyyMMddHHmm') " & vbCrLf
                Dim usCmd As New SqlCommand(usSql, oConn)
                DbAccess.HashParmsChange(usCmd, uPMS)
                usCmd.ExecuteNonQuery() 'DbAccess.ExecuteNonQuery(usSql, oConn, uPMS)
            End If
            LOG.Info($"#SET_First_CFG_RELOAD_TIME_DB: iSVID:{iSVID},ITEMNAME:{cst_CFG_RELOAD_TIME_ITEMNAME},hostName:{hostName},ITEMVALUE:{ITEMVALUE},YMDVAL:{YMDVAL}")
        Catch ex As Exception
            'LOG.Error($"#SET_CFG_RELOAD_TIME_DB:{ex.Message},iSVID:{iSVID},ITEMNAME:{cst_CFG_RELOAD_TIME_ITEMNAME},YMDVAL:{YMDVAL}", ex)
            WriteTraceLog($"#SET_First_CFG_RELOAD_TIME_DB:{ex.Message},iSVID:{iSVID},ITEMNAME:{cst_CFG_RELOAD_TIME_ITEMNAME},hostName:{hostName},ITEMVALUE:{ITEMVALUE},YMDVAL:{YMDVAL}", ex)
            Return
        End Try

    End Sub

    Public Shared Sub SET_Last_CFG_RELOAD_TIME_DB(oConn As SqlConnection, hostName As String)
        Const cst_CFG_RELOAD_TIME_ITEMNAME As String = "CFG_RELOAD_TIME_"
        Const cst_CFG_RELOAD_TIME_MEMO2 As String = "系統參數時間USED"
        OpenDbConn(oConn)
        Dim pms1 As New Hashtable From {{"ITEMNAME", cst_CFG_RELOAD_TIME_ITEMNAME}, {"hostName", hostName}}
        Dim sql As String = "SELECT SVID,SPAGE,ITEMNAME,ITEMVALUE,MEMO1,FORMAT(GETDATE(),'yyyyMMddHHmm') YMDVAL FROM SYS_VAR WITH(NOLOCK) WHERE SPAGE='Config' AND ITEMNAME=@ITEMNAME+@hostName"
        'Dim dt1 As DataTable = DbAccess.GetDataTable(sql, oConn, pms1) '取得
        Dim dt1 As New DataTable
        Dim oCmd As New SqlCommand(sql, oConn)
        DbAccess.HashParmsChange(oCmd, pms1)
        dt1.Load(oCmd.ExecuteReader())

        If dtNODATA(dt1) Then Return
        Dim iSVID As Integer = CINT1(dt1.Rows(0)("SVID"))
        Dim ITEMVALUE As String = $"{dt1.Rows(0)("ITEMVALUE")}"
        Dim MEMO1 As String = cst_CFG_RELOAD_TIME_MEMO2
        Try
            If dt1.Rows.Count > 1 Then
                '(超過1筆)(刪除1筆)
                iSVID = CINT1(dt1.Rows(1)("SVID"))
                ITEMVALUE = $"{dt1.Rows(1)("ITEMVALUE")}"
                Dim PMS_D As New Hashtable From {{"SVID", iSVID}, {"ITEMNAME", cst_CFG_RELOAD_TIME_ITEMNAME}, {"hostName", hostName}}
                Dim SQL_D As String = "DELETE SYS_VAR WHERE SVID=@SVID AND ITEMNAME=@ITEMNAME+@hostName"
                Dim DCmd As New SqlCommand(SQL_D, oConn)
                DbAccess.HashParmsChange(DCmd, PMS_D)
                DCmd.ExecuteNonQuery()
            End If
            iSVID = CINT1(dt1.Rows(0)("SVID"))
            ITEMVALUE = $"{dt1.Rows(0)("ITEMVALUE")}"
            Dim uPMS As New Hashtable From {{"SVID", iSVID}, {"ITEMNAME", cst_CFG_RELOAD_TIME_ITEMNAME}, {"hostName", hostName}, {"MEMO1", MEMO1}}
            Dim usSql As String = "UPDATE SYS_VAR SET MEMO1=@MEMO1 WHERE SVID=@SVID AND ITEMNAME=@ITEMNAME+@hostName" & vbCrLf
            Dim usCmd As New SqlCommand(usSql, oConn)
            DbAccess.HashParmsChange(usCmd, uPMS)
            usCmd.ExecuteNonQuery() 'DbAccess.ExecuteNonQuery(usSql, oConn, uPMS)
            LOG.Info($"#SET_First_CFG_RELOAD_TIME_DB: iSVID:{iSVID},ITEMNAME:{cst_CFG_RELOAD_TIME_ITEMNAME},hostName:{hostName},ITEMVALUE:{ITEMVALUE},MEMO1:{MEMO1}")
        Catch ex As Exception
            'LOG.Error($"#SET_CFG_RELOAD_TIME_DB:{ex.Message},iSVID:{iSVID},ITEMNAME:{cst_CFG_RELOAD_TIME_ITEMNAME},YMDVAL:{YMDVAL}", ex)
            WriteTraceLog($"#SET_First_CFG_RELOAD_TIME_DB:{ex.Message},iSVID:{iSVID},ITEMNAME:{cst_CFG_RELOAD_TIME_ITEMNAME},hostName:{hostName},ITEMVALUE:{ITEMVALUE},MEMO1:{MEMO1}", ex)
            Return
        End Try

    End Sub


