    ''' <summary>依sm.UserInfo.PlanID取得PlanKind  '1:自辦(內訓) 2:委外</summary>
    ''' <param name="MyPage"></param>
    ''' <param name="conn"></param>
    ''' <returns></returns>
    Public Shared Function Get_PlanKind(ByRef MyPage As Page,
                                        ByVal conn As SqlConnection) As String
        '1:自辦(內訓) 2:委外
        Dim sm As SessionModel = SessionModel.Instance()
        Dim oRst As Object = Nothing
        Dim InConnFlag As Boolean = If(conn Is Nothing, True, False) '使用內部連線
        'If conn Is Nothing Then InConnFlag=True
        If InConnFlag Then conn = DbAccess.GetConnection()
        Call OpenDbConn(conn)
        Dim sql As String = ""
        sql = "SELECT PlanKind FROM ID_Plan WHERE PlanID=@PlanID "
        Dim sCmd As New SqlCommand(sql, conn)
        Dim dt As New DataTable
        With sCmd
            .Parameters.Clear()
            .Parameters.Add("PlanID", SqlDbType.VarChar).Value = sm.UserInfo.PlanID
