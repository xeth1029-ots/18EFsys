    '取得N個亂數文字 (大寫/數字) 
    Public Shared Function GetRndEngN(ByVal iLengthN As Integer) As String
        Dim vCdoe As String = ""
        'Randomize()
        For i As Integer = 0 To iLengthN - 1
            Dim iXX As Integer = CInt(1 * Rnd1X()) '0-1
            Select Case iXX
                Case 0
                    '0-8(1-9)
                    vCdoe += CStr(CInt(8 * Rnd1X()) + 1)
                Case Else
                    '0~25(65-90)
                    vCdoe += Chr(CInt(25 * Rnd1X()) + 65)
            End Select
        Next
        Return vCdoe
    End Function

    '取得N個亂數文字 (大寫) 
    Public Shared Function GetRndEngNN(ByVal iLengthN As Integer) As String
        Dim vCdoe As String = ""
        'Randomize()
        For i As Integer = 0 To iLengthN - 1
            Dim iXX As Integer = CInt(3 * Rnd1X()) '0-3
            For j As Integer = 0 To iXX
                If j = iXX Then
                    vCdoe += Chr(CInt(25 * Rnd1X()) + 65)
                    Exit For
                End If
            Next
        Next
        Return vCdoe
    End Function

