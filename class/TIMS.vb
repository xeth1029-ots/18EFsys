    ''' <summary>DataTable-COLNAMEs-組合json字串</summary>
    ''' <param name="dt"></param>
    ''' <param name="COLNAMEs"></param>
    ''' <returns></returns>
    Public Shared Function GET_RESDESCdt(dt As DataTable, COLNAMEs As String) As String
        Dim rst As String = ""
        Dim tmp2 As String = ""
        If dtNODATA(dt) OrElse String.IsNullOrEmpty(COLNAMEs) Then Return rst
        Dim iERRCNT As Integer = 0
        For Each dr1 As DataRow In dt.Rows
            Dim tmp1 As String = ""
            Try
                For Each v As String In COLNAMEs.Split(",")
                    'Dim fg_IsDBNull As Boolean=IsDBNull(dr1(v)) 'Dim fg_IsDateTime As Boolean=(Not fg_IsDBNull AndAlso IS_DateTime(dt, v))
                    If dr1(v) Is Nothing OrElse IsDBNull(dr1(v)) Then
                        '處理null資料
                        tmp1 &= $"{If(tmp1 <> "", ",", "")}""{v}"":null"
                    ElseIf (Not IsDBNull(dr1(v)) AndAlso IS_DateTime(dt, v)) Then
                        '處理日期資料
                        tmp1 &= $"{If(tmp1 <> "", ",", "")}""{v}"":""{Cdate3j(dr1(v))}"""
                    Else
                        'tmp1 &= String.Concat(If(tmp1 <> "", ",", ""), """", v, """:""", Replace(Convert.ToString(dr1(v)), """", "\"""), """")
                        'tmp1 &= String.Concat(If(tmp1 <> "", ",", ""), """", v, """:", EscapeStringForJson($"{dr1(v)}"))
                        tmp1 &= $"{If(tmp1 <> "", ",", "")}""{v}"":{EscapeStringForJson($"{dr1(v)}")}"
                    End If
                Next
                tmp2 &= String.Concat(If(tmp2 <> "", ",", ""), "{", tmp1, "}")
            Catch ex As Exception
                iERRCNT += 1
                Dim s_ERRMSG1 As String = $"GET_RESDESCdt:{ex.Message}{vbCrLf},tmp1:{tmp1}{vbCrLf},tmp2:{tmp2}{vbCrLf}"
                WriteTraceLog(s_ERRMSG1, ex) : Exit For
            End Try
        Next
        rst = $"[{tmp2}]"
        If Not IsValidJson(rst) Then Return "[]"
        Return rst
    End Function

    ''' <summary>帶有雙引號的json字串匯出</summary>
    ''' <param name="input"></param>
    ''' <returns></returns>
    Public Shared Function EscapeStringForJson(input As String) As String
        If input Is Nothing Then Return Nothing
        Return JsonConvert.SerializeObject(input.Trim(""""))
    End Function

