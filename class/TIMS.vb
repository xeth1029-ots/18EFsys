    Public Shared Function CHECK_Q61TXTVAL(ByVal vTmpT1 As String, ByVal str_QTXTVAL As String, ByRef errMsg1 As String) As String
        Dim rst As String = ""
        If str_QTXTVAL = "" Then Return rst

        'vTmpT1="個人工作年資"
        If Not IsNumeric(str_QTXTVAL) Then
            errMsg1 &= String.Format("{0}必須為數字", vTmpT1) & vbCrLf
            Return rst
        ElseIf Val(str_QTXTVAL) > 100 OrElse Val(str_QTXTVAL) < 0 Then
            errMsg1 &= String.Format("{0}必須小於100", vTmpT1) & vbCrLf
            Return rst
        Else
            rst = Val(str_QTXTVAL)
        End If

        Const cst_x05 As Double = 0.5
        If Not Val(str_QTXTVAL) Mod cst_x05 = 0 Then
            '年資開放小數點填寫，但必須以0.5為最小單位。
            errMsg1 &= String.Format("{0} 開放小數點填寫，但必須以0.5為最小單位。", vTmpT1) & vbCrLf
        End If

        Return rst
    End Function

