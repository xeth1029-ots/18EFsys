    ''' <returns></returns>
    Public Shared Function CHK_STR_CNT(XSTR1 As String, vSTR1 As String) As Integer
        If $"{XSTR1}" = "" OrElse $"{vSTR1}" = "" Then Return 0
        Dim iLENSTR1 As Integer = Len(vSTR1)
        Dim iLENXSTR1 As Integer = Len(XSTR1)
        Dim iCount As Integer = 0
        ' 檢查當前字元是否為 vSTR1
        For i As Integer = 1 To iLENXSTR1
            If Mid(XSTR1, i, iLENSTR1) = vSTR1 Then iCount += 1
        Next i
        Return iCount
    End Function

