    ''' <summary>開啟測試連線資料庫(並偵錯), 若連線失敗則導向停機說明頁面</summary>
    ''' <param name="MyPage"></param>
    ''' <param name="objconn"></param>
    ''' <returns></returns>
    Public Shared Function OpenDbConn(ByRef MyPage As Page, ByRef objconn As SqlConnection) As Boolean
        If objconn Is Nothing Then
            LOG.Info("OpenDbConn: Redirect to " + cst_stopindexA1)
            HttpContext.Current.Response.Redirect(cst_stopindexA1)
            HttpContext.Current.Response.End()
            Return False
        End If
        Try
            If objconn.State = ConnectionState.Closed Then objconn.Open()
        Catch ex As Exception
            LOG.Error("OpenDbConn: " + ex.Message, ex)
            LOG.Info("OpenDbConn: Redirect to " + cst_stopindexA1)
            HttpContext.Current.Response.Redirect(cst_stopindexA1)
            HttpContext.Current.Response.End()
            Return False
        End Try
        Return True
    End Function

    ''' <summary>開啟測試連線資料庫</summary>
    ''' <param name="objconn"></param>
    ''' <returns></returns>
    Public Shared Function OpenDbConn(ByRef objconn As SqlConnection) As Boolean
        If objconn Is Nothing Then Return False
        Try
            If objconn.State = ConnectionState.Closed Then objconn.Open()
        Catch ex As Exception
            LOG.Error(String.Concat("OpenDbConn: ", ex.Message), ex)
            Return False
        End Try
        Return True
    End Function

    ''' <summary>'(完全)關閉測試連線資料庫</summary>
    ''' <param name="objconn"></param>
    Public Shared Sub CloseDbConn(ByRef objconn As SqlConnection)
        If objconn Is Nothing Then Return ' Exit Sub
        Try
            If objconn.State = ConnectionState.Open Then objconn.Close()
            objconn.Dispose()
        Catch ex As Exception
            LOG.Warn(String.Concat("CloseDbConn: ", ex.Message), ex)
            Return
        End Try
    End Sub

