                                             ByVal DistID As String, ByVal PlanID As String,
                                             ByVal retDt As DataTable, ByVal tConn As SqlConnection,
                                             ByVal trans As SqlTransaction) As DataTable

        Dim dr As DataRow = Nothing
        Dim chkflag As Boolean = False

        Try
            Select Case chkType
                Case "Class" 'by 班級
                    retDt = Get_ClassEComment(OrgID, OCID, RID, DistID, tConn, trans)
                Case "Org" 'by 機構(分區)
                    retDt = Get_OrgEComment(OrgID, RID, PlanID, tConn, trans) '不同年度、計畫、轄區
            End Select

            If Not retDt Is Nothing Then
                If retDt.Rows.Count > 0 Then
                    dr = retDt.Rows(0)
                    If Convert.ToString(dr("eComment")) <> "" Then
                        chkflag = True
                    End If
                End If
            End If

            If chkType = "Class" AndAlso Not chkflag Then '班級沒有說明事項時，繼續向上找單位
                retDt = Get_FinalEComment("Org", OrgID, OCID, RID, DistID, PlanID, Nothing, tConn, trans)
            ElseIf chkType = "Org" AndAlso Not chkflag Then
                retDt = Nothing
            End If
        Catch ex As Exception
            Dim V_GUID As String = Guid.NewGuid().ToString()
            LOG.Warn(ex.Message, ex) '取得錯誤資訊寫入
            Dim strErrmsg As String = String.Concat("ex.Message:", ex.Message, "[", V_GUID, "]", vbCrLf)
            WriteTraceLog(strErrmsg, ex)
            Throw ex
        End Try

        Return retDt
    End Function

