    ''' <summary> 解析XML 並儲存 STUD_BLIGATEDATA4 </summary>
    ''' <param name="htSS"></param>
    ''' <param name="oConn"></param>
    ''' <returns></returns>
    ''' <remarks></remarks>
    Public Shared Function parseXML(ByRef MyPage As Page, ByRef htSS As Hashtable, ByVal oConn As SqlConnection) As String
        Dim strMsg As String = "" '回傳錯誤碼！
        Dim strXML As String = GetMyValue2(htSS, "strXML")
        Dim strUType As String = GetMyValue2(htSS, "strUType")
        '檢核攻擊xml
        If Not Check_xml(strXML) Then
            'Dim htSS As New Hashtable 'htSS Hashtable() 'htSS.Add("strSetId", strSetId)
            Call SendMailTestErr1(MyPage, htSS)
            Return "-1"
        End If

        Dim xmlDoc As New XmlDocument
        Dim XmlNodes As XmlNodeList

        'Dim strRtnMsg As String="0" '成功代碼 0:成功 
        'Dim iNodeCnt As Integer=0
        'Const Cst_OKmsg As String="0,8" '成功代碼 0:成功 8:資料超過100筆
        Const Cst_OKmsg As String = "0" '成功代碼 0:成功 

        Dim strIDNO As String = String.Empty
        Dim strBirth As String = String.Empty
        Dim strActNo As String = String.Empty
        Dim strMDate As String = String.Empty
        Dim strChgMode As String = String.Empty 'txcd
        Dim strFType As String = String.Empty

        xmlDoc.LoadXml(strXML) '解析XML

        OpenDbConn(oConn)
        'oTrans=conn.BeginTransaction

        '查詢勾稽資料是否存在，存在就不再寫入
        Dim strSql As String = ""
        strSql &= " select 1 from dbo.STUD_BLIGATEDATA4"
        strSql &= " where idno=@idno and birthday=convert(date, @birthday) " 'strSql &= " and birthday=convert(datetime, @birthday, 111) "
        strSql &= " and actno=@actno and mdate=convert(date, @mdate) " 'strSql &= " and mdate=convert(datetime, @mdate, 111) "
        strSql &= " and changemode=@changemode and ftype=@ftype "
        Dim sCmd As New SqlCommand(strSql, oConn)

        '新增勾稽資料
        Dim strSqli As String = ""
        strSqli &= " INSERT INTO STUD_BLIGATEDATA4 (sb4id,idno,ftype,name,birthday,actno ,comname,changemode,mdate,salary ,department,modifydate,deptment,bief,biefdesc )"
        strSqli &= " values (@sb4id,@idno,@ftype,@name,@birthday,@actno,@comname,@changemode,@mdate,@salary ,@department,getdate(),@deptment,@bief,@biefdesc )"
        Dim iCmd As New SqlCommand(strSqli, oConn)

        'IDN Iname	type_code	type	uno	coop	datefrom	dateto	txcd	txtype	txdate	wage	bief	biefDesc	birth	deptcode	itrmy	itrmd	tsMk	birthday
        Const cst_col_IDN As Integer = 0
        Const cst_col_Iname As Integer = 1 '姓名
        'Const cst_col_type_code As Integer=2
        'Const cst_col_type As Integer=3
