    ''' <summary>
    ''' '採換行顯示功能
    ''' </summary>
    ''' <param name="S_COM"></param>
    ''' <param name="iCutLen"></param>
    ''' <returns></returns>
    Public Shared Function Utl_WORDWRAP(ByRef S_COM As String, ByRef iCutLen As Integer) As String
        Dim rst As String = ""
        If S_COM = "" Then Return rst
        Dim num As Int16 = Len(S_COM) \ iCutLen
        Dim last As Int16 = Len(S_COM) Mod iCutLen
        Dim j As Int16 = 1
        For i As Int16 = 1 To num + 1
            If i = num + 1 Then
                'last line
                rst &= Mid(S_COM, j, last)
            Else
                rst &= String.Format("{0}<br/>", Mid(S_COM, j, iCutLen))
                j = j + iCutLen
            End If
        Next
        Return rst
    End Function

