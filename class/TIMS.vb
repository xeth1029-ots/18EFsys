    ''' <summary>取得(企業包班)資料</summary>
    ''' <param name="ocid"></param>
    ''' <param name="planid"></param>
    ''' <param name="comidno"></param>
    ''' <param name="seqno"></param>
    ''' <returns></returns>
    ''' <remarks></remarks>
    Public Shared Function Get_BUSPACKAGEdt(ByRef oConn As SqlConnection, ByVal ocid As String, ByVal planid As String, ByVal comidno As String, ByVal seqno As String) As DataTable
        Dim dt As New DataTable
        Dim type1 As String = If(ocid <> "", "c", If(planid <> "" AndAlso comidno <> "" AndAlso seqno <> "", "p", "")) 'c@ocid / p@pcs
        Call OpenDbConn(oConn)
        Select Case type1
            Case "c" '轉班
                Dim sql As String = ""
                sql &= " SELECT p2.bpid ,p2.uname ,p2.Intaxno ,p2.Ubno" & vbCrLf
                sql &= " FROM dbo.PLAN_BUSPACKAGE p2" & vbCrLf
                sql &= " JOIN dbo.PLAN_PLANINFO ppi ON ppi.planid=p2.planid AND ppi.comidno=p2.comidno AND ppi.seqno=p2.seqno" & vbCrLf
                sql &= " JOIN dbo.CLASS_CLASSINFO cc ON ppi.planid=cc.planid AND ppi.comidno=cc.comidno AND ppi.seqno=cc.seqno" & vbCrLf
                sql &= " WHERE cc.OCID=@OCID" & vbCrLf
                sql &= " ORDER BY p2.bpid" & vbCrLf
                Dim sCmd As New SqlCommand(sql, oConn)
                'Call OpenDbConn(objconn)
                With sCmd
                    .Parameters.Clear()
                    .Parameters.Add("OCID", SqlDbType.VarChar).Value = ocid
                    dt.Load(.ExecuteReader())
                End With
            Case "p" '未轉班
                Dim sql As String = ""
                sql &= " SELECT p2.bpid ,p2.uname ,p2.Intaxno ,p2.Ubno" & vbCrLf
                sql &= " FROM dbo.PLAN_BUSPACKAGE p2" & vbCrLf
                sql &= " JOIN dbo.PLAN_PLANINFO ppi ON ppi.planid=p2.planid AND ppi.comidno=p2.comidno AND ppi.seqno=p2.seqno" & vbCrLf
                sql &= " WHERE ppi.PlanID=@PlanID AND ppi.ComIDNO=@ComIDNO AND ppi.SeqNo=@SeqNo"
                sql &= " ORDER BY p2.bpid" & vbCrLf
                Dim sCmd As New SqlCommand(sql, oConn)
                'Call OpenDbConn(objconn)
                With sCmd
                    .Parameters.Clear()
                    .Parameters.Add("PlanID", SqlDbType.Int).Value = CINT1(planid)
                    .Parameters.Add("ComIDNO", SqlDbType.VarChar).Value = comidno
                    .Parameters.Add("SeqNo", SqlDbType.Int).Value = CINT1(seqno)
                    dt.Load(.ExecuteReader())
                End With
        End Select
        Return dt
    End Function

