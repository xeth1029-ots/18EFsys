    Public Shared Function GET_iPROGRESS_SF(oConn As SqlConnection, showMSG As String, vSFCID As String, vORGKINDGW As String) As Integer
        Dim iProgress As Integer = 0
        showMSG = ""

        '(排除:其他佐證文件)
        Dim rParmsA As New Hashtable From {{"ORGKINDGW", vORGKINDGW}}
        Dim sSqlA As String = "SELECT 1 FROM KEY_SFCASE WHERE ORGKINDGW=@ORGKINDGW AND SFID!='04'"
        Dim dtA As DataTable = DbAccess.GetDataTable(sSqlA, oConn, rParmsA)
        If dtA Is Nothing Then Return iProgress

        '(排除:其他佐證文件)
        Dim rParms As New Hashtable From {{"SFCID", CINT1(vSFCID)}, {"ORGKINDGW", vORGKINDGW}}
        Dim rsSql As String = ""
        rsSql &= " SELECT 1 FROM ORG_SFCASEFL a" & vbCrLf
        rsSql &= " JOIN KEY_SFCASE kb on kb.KSFID=a.KSFID" & vbCrLf
        rsSql &= " JOIN ORG_SFCASE ob on ob.SFCID=a.SFCID" & vbCrLf
        rsSql &= " JOIN AUTH_RELSHIP rr on rr.RID=ob.RID" & vbCrLf
        rsSql &= " WHERE a.SFCID=@SFCID AND kb.ORGKINDGW=@ORGKINDGW AND kb.SFID!='04'" & vbCrLf
        Dim dt As DataTable = DbAccess.GetDataTable(rsSql, oConn, rParms)
        If dt Is Nothing Then Return iProgress

        Dim iCNT1SC As Double = dt.Rows.Count
        Dim iCNT1AL As Double = dtA.Rows.Count
        iProgress = If(iCNT1AL > 0, (iCNT1SC / iCNT1AL * 100), 0)

        If iProgress > 30 AndAlso iProgress < 100 Then
            '(排除:其他佐證文件)
            Dim rParms2 As New Hashtable From {{"SFCID", CINT1(vSFCID)}, {"ORGKINDGW", vORGKINDGW}}
            Dim sSql2 As String = ""
            sSql2 &= " SELECT ob.SFCID,kb.SFID,kb.SFNAME ,kb.ORGKINDGW" & vbCrLf
            sSql2 &= " ,concat(kb.SFID,'.',kb.SFNAME) KBSFNAME2" & vbCrLf
            sSql2 &= " ,CASE WHEN a.SFCFID IS NULL then 'Y' END SFCFID_NG" & vbCrLf
            sSql2 &= " FROM ORG_SFCASE ob" & vbCrLf
            sSql2 &= " JOIN AUTH_RELSHIP rr on rr.RID=ob.RID" & vbCrLf
            sSql2 &= " JOIN KEY_SFCASE kb on kb.ORGKINDGW=@ORGKINDGW" & vbCrLf
            sSql2 &= " LEFT JOIN ORG_SFCASEFL a on a.SFCID=ob.SFCID and a.KSFID=kb.KSFID" & vbCrLf
            sSql2 &= " WHERE ob.SFCID=@SFCID AND kb.SFID!='04'" & vbCrLf
            Dim dt2 As DataTable = DbAccess.GetDataTable(sSql2, oConn, rParms2)
            If dt2.Rows.Count = 0 Then Return iProgress
            For Each dr2 As DataRow In dt2.Rows
                If (Convert.ToString(dr2("SFCFID_NG")) = "Y") Then
                    showMSG &= String.Concat(If(showMSG <> "", "、", ""), dr2("KBSFNAME2"))
                End If
            Next
        End If
        Return iProgress
    End Function

