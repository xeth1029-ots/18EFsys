                .Parameters.Add("SUMOFMONEY", SqlDbType.Int).Value = If(ClearSQM(drv("SUMOFMONEY")) <> "", CINT1(drv("SUMOFMONEY")), Convert.DBNull)
                .Parameters.Add("PAYMONEY", SqlDbType.Int).Value = If(ClearSQM(drv("PayMoney")) <> "", CINT1(drv("PayMoney")), Convert.DBNull)
                'SumOfMoney,BudIDName,AppliedStatus,AppliedStatusM
                'Dim vBUDID As Object=CHG_BudIDName(drv("BudIDName"))
                'Dim vAPPLIEDSTATUS As Object=CHG_AppliedStatus(drv("AppliedStatus"))
                'Dim vAPPLIEDSTATUSM As Object=CHG_AppliedStatusM(drv("AppliedStatusM"))
                Dim vBUDID As String = ClearSQM(drv("BudID"))
                Dim vAPPLIEDSTATUS As String = ClearSQM(drv("AppliedStatus"))
                Dim vAPPLIEDSTATUSM As String = ClearSQM(drv("AppliedStatusM"))
