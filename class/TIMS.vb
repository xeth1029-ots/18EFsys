    '如果有重複為true，如果沒重複為false
    Public Shared Function CheckDblExamNo(ByVal OCID1 As String, ByVal ExamNo As String, ByVal tConn As SqlConnection) As Boolean
        ExamNo = ClearSQM(ExamNo)
        OCID1 = ClearSQM(OCID1)
        If OCID1 = "" Then Return True 'OCID1不可為空
        Dim Rst As Boolean = False '預設:沒有重複
        If ExamNo <> "" Then
            Dim pms1 As New Hashtable From {{"OCID1", OCID1}, {"EXAMNO", ExamNo}}
            Dim sql As String = " SELECT COUNT(1) CNT FROM STUD_ENTERTYPE WHERE OCID1=@OCID1 AND EXAMNO=@EXAMNO GROUP BY OCID1, EXAMNO HAVING COUNT(1)>1"
            Dim dr As DataRow = DbAccess.GetOneRow(sql, tConn, pms1)
            If dr IsNot Nothing Then Rst = True '有重複 
            Return Rst
        Else
            Dim pms1 As New Hashtable From {{"OCID1", OCID1}}
            Dim sql As String = " SELECT COUNT(1) CNT FROM STUD_ENTERTYPE WHERE OCID1=@OCID1 GROUP BY OCID1, EXAMNO HAVING COUNT(1)>1"
            Dim dr As DataRow = DbAccess.GetOneRow(sql, tConn, pms1)
            If dr IsNot Nothing Then Rst = True '有重複 
            Return Rst
        End If
        Return Rst
    End Function

    ''' <summary> 取出准考證號-前6碼 </summary>
    ''' <param name="OCID"></param>
    ''' <param name="oConn"></param>
    ''' <returns></returns>
    Public Shared Function Get_ExamNo1(ByVal OCID As String, ByRef oConn As SqlConnection) As String
        Dim rst As String = ""
        If OCID = "" Then Return rst

        '取出准考證號   Start
        'sql="SELECT b.ClassID,a.CyclType, cast(b.ClassID as varchar)+cast(a.CyclType as varchar) ExamNO1 FROM CLASS_CLASSINFO a    JOIN ID_Class b    ON a.CLSID=b.CLSID WHERE LEN(b.ClassID)=4 AND a.OCID='" & OCID & "' " '★
        Dim parms As New Hashtable() From {{"OCID", OCID}}
        Dim sql As String = ""
        sql &= " SELECT b.CLSID, b.CLASSID,ISNULL(a.CYCLTYPE,'01') CYCLTYPE"
        '(由於期別可為空，所以如果為空的時候補00/01) '基本上就是要2碼為期別
        sql &= " ,concat(ISNULL(b.CLASSID2,b.CLASSID),RIGHT('0'+ISNULL(a.CYCLTYPE,'01'),2)) EXAMNO1"
        sql &= " ,LEN(b.CLASSID) LENCLASSID ,b.CLASSID2"
        sql &= " FROM dbo.CLASS_CLASSINFO a WITH(NOLOCK)"
        sql &= " JOIN dbo.ID_CLASS b WITH(NOLOCK) ON a.CLSID=b.CLSID "
        sql &= " WHERE a.OCID=@OCID"
        Dim dt As DataTable = DbAccess.GetDataTable(sql, oConn, parms)

        Dim dr As DataRow = Nothing
        If dtHaveDATA(dt) Then dr = dt.Rows(0)
        If dr Is Nothing Then Return rst

        Dim vCYCLTYPE As String = Convert.ToString(dr("CYCLTYPE"))
        If (vCYCLTYPE = "") Then vCYCLTYPE = "01"
        If (vCYCLTYPE.Length = 1) Then vCYCLTYPE = String.Concat("0", vCYCLTYPE)

        If Convert.ToString(dr("CLASSID2")) <> "" Then '新版-CLASSID2
            rst = Convert.ToString(dr("CLASSID2")) & Convert.ToString(dr("CYCLTYPE"))
            Return rst '取出准考證號-新
        End If
        If Convert.ToString(dr("LENCLASSID")) <> 4 Then
            '取出一個亂數後修正-因為使用者 不想自已定義班別代碼，所以由系統代勞。
            Dim EA_ExamNO1_4 As String = Right(EncryptAes(dr("ExamNO1")), 4) '取出後4碼(亂數)
            UPDATE_ID_CLASS_CLASSID2(dr("CLSID"), EA_ExamNO1_4, oConn)
            rst = String.Concat(EA_ExamNO1_4, vCYCLTYPE)
            Return rst '取出准考證號
        End If

        '取出班級的CLASSID +期別 成為准考證編碼的前面的固定碼
        rst = $"{dr("ExamNO1")}" ' Convert.ToString()
        Return rst '取出准考證號
    End Function

