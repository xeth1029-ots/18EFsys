    Public Shared Sub ChkTextLength(ByRef txtObj As TextBox, ByVal iLen As Integer)
        Dim jsValue As String = "checkTextLength(this," & iLen & ");"
        Dim js_onfocus As String = ""
        Dim js_onblur As String = ""
        Dim js_onchange As String = ""
        Dim flag_act As Boolean = True

        js_onfocus = txtObj.Attributes("onfocus")
        flag_act = True : If js_onfocus <> "" AndAlso js_onfocus.IndexOf(jsValue) > -1 Then flag_act = False
        If flag_act Then
            If js_onfocus <> "" Then js_onfocus &= jsValue
            If js_onfocus = "" Then js_onfocus = jsValue
            txtObj.Attributes("onfocus") = js_onfocus
        End If

        js_onblur = txtObj.Attributes("onblur")
        flag_act = True : If js_onblur <> "" AndAlso js_onblur.IndexOf(jsValue) > -1 Then flag_act = False
        If flag_act Then
            If js_onblur <> "" Then js_onblur &= jsValue
            If js_onblur = "" Then js_onblur = jsValue
            txtObj.Attributes("onblur") = js_onblur
        End If

        js_onchange = txtObj.Attributes("onchange")
        flag_act = True : If js_onchange <> "" AndAlso js_onchange.IndexOf(jsValue) > -1 Then flag_act = False
        If flag_act Then
            If js_onchange <> "" Then js_onchange &= jsValue
            If js_onchange = "" Then js_onchange = jsValue
            txtObj.Attributes("onchange") = js_onblur
        End If
    End Sub

    Public Shared Sub PL_placeholder(ByRef txtObj As TextBox, ByVal str1 As String)
        txtObj.Attributes.Add("placeholder", str1)
        PL_placeholder(txtObj)
    End Sub

    ''' <summary>配合 placeholder / PL_focusState 顯示 提示信息 效果 common.js
    ''' 放在 If Not IsPostBack Then 中
    ''' </summary>
    ''' <param name="txtObj"></param>
    ''' <remarks></remarks>
    Public Shared Sub PL_placeholder(ByRef txtObj As TextBox)
        Dim str_placeholder As String = ""
        If txtObj.Text = "" Then
            str_placeholder = txtObj.Attributes("placeholder")
            If str_placeholder <> "" Then
                txtObj.Text = str_placeholder
                txtObj.ForeColor = ColorTranslator.FromHtml("#666666")
            End If
        End If
        If str_placeholder <> "" Then
            Dim jsValue As String = ""
            Dim js_onfocus As String = ""
            Dim js_onblur As String = ""
            Dim flag_act As Boolean = True

            jsValue = "PL_focusState('" & txtObj.ClientID & "');"
            js_onfocus = txtObj.Attributes("onfocus")
            flag_act = True : If js_onfocus <> "" AndAlso js_onfocus.IndexOf(jsValue) > -1 Then flag_act = False
            If flag_act Then
                If js_onfocus <> "" Then js_onfocus &= jsValue
                If js_onfocus = "" Then js_onfocus = jsValue
                txtObj.Attributes("onfocus") = jsValue
            End If

            jsValue = "PL_blurState('" & txtObj.ClientID & "');"
            js_onblur = txtObj.Attributes("onblur")
            flag_act = True : If js_onblur <> "" AndAlso js_onblur.IndexOf(jsValue) > -1 Then flag_act = False
            If flag_act Then
                If js_onblur <> "" Then js_onblur &= jsValue
                If js_onblur = "" Then js_onblur = jsValue
                txtObj.Attributes("onblur") = jsValue
            End If
        End If
    End Sub

    ''' <summary> 儲存時確認正確值，若無值清空 放在儲存前</summary>
    ''' <param name="txtObj"></param>
    ''' <remarks></remarks>
    Public Shared Sub Chk_placeholder(ByRef txtObj As TextBox)
        If txtObj Is Nothing Then Exit Sub
        Dim PLM_Value As String = txtObj.Attributes("placeholder")
        If PLM_Value <> "" AndAlso txtObj.Text = PLM_Value Then txtObj.Text = ""
    End Sub

    ''' <summary>取得Attributes("placeholder")</summary>
    ''' <param name="txtObj"></param>
    ''' <returns></returns>
    Public Shared Function Get_placeholder(ByRef txtObj As TextBox) As String
        If txtObj Is Nothing Then Return ""
        Dim PLM_Value As String = txtObj.Attributes("placeholder")
        Return PLM_Value
    End Function

    ''' <summary>回傳輸入值，避免取得 placeholder</summary>
    ''' <param name="txtObj"></param>
    ''' <returns></returns>
    Public Shared Function Get_placeholder_TXTVAL(ByRef txtObj As TextBox) As String
        If txtObj Is Nothing Then Return ""
        Dim PLM_Value As String = txtObj.Attributes("placeholder")
        Return If(PLM_Value <> "" AndAlso txtObj.Text = PLM_Value, "", txtObj.Text)
    End Function

