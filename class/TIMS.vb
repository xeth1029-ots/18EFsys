        Dim dt As DataTable = DbAccess.GetDataTable(sql, tConn)
        Select Case FieldName
            Case cst_PVR_DATA_YN '"DATA_YN" '資料是否存在 'rst="N" '不存在
                If dt.Rows.Count > 0 Then rst = "Y" '存在
