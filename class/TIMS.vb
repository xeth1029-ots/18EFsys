    ''' <summary> '取得Sheet Name </summary>
    ''' <param name="objOleConn"></param>
    ''' <returns></returns>
    Public Shared Function GetSheetName(ByRef objOleConn As OleDbConnection) As String
        Dim rst As String = "Sheet1$"

        If objOleConn Is Nothing Then Return rst
        If objOleConn.State = ConnectionState.Closed Then objOleConn.Open()
        Dim dtSheet As DataTable = objOleConn.GetOleDbSchemaTable(OleDbSchemaGuid.Tables, Nothing)
        If dtSheet Is Nothing Then Return rst
        Try
            'If objOleConn.State=ConnectionState.Open Then objOleConn.Close()
            For Each row As DataRow In dtSheet.Rows
                rst = row("TABLE_NAME").ToString()
                Return rst ' Exit For
            Next
        Catch ex As Exception
            LOG.Error(ex.Message, ex)
            If objOleConn.State = ConnectionState.Open Then objOleConn.Close()
            Throw ex
        End Try
        Return rst
    End Function

    ''' <summary> 使用 ODS檔匯入 DataTable </summary>
    ''' <param name="Fullfilename"></param>
    ''' <returns></returns>
    Public Shared Function GetDataTable_ODSFile(ByVal Fullfilename As String) As DataTable
        '使用欄位 '計算欄位
        Dim dtLog As New DataTable

        Dim tk As New TurboOdfUtil.OdsReaderWriter() '讀取參考【TurboOdfUtil】。
        'Dim MyFile As System.IO.File
        '使用 xls檔匯入
        'Imports System.Data.OleDb
        'Const Cst_FirstCol="事業單位名稱" '不可空白的一欄位
        'Const Cst_TableDefiniens="OrgInfo2" '請注意 Excel中的 名稱方塊 (插入-->名稱-->定義)
        'Dim dt1 As DataTable = Nothing
        Using ds As DataSet = tk.ReadOdsFile(Fullfilename)
            If ds Is Nothing Then Return dtLog
            If ds.Tables.Count = 0 Then Return dtLog
            If ds.Tables(0).Rows.Count = 0 Then Return dtLog
            Using dt1 As DataTable = ds.Tables(0)
                'dt1 = ds.Tables(0)
                Dim sColName As String = ""
                For i As Integer = 0 To dt1.Columns.Count - 1 '所有欄位
                    dtLog.Columns.Add(dt1.Columns(i).ColumnName）
                Next
                Dim iRow As Integer = 0
                For Each dr1 As DataRow In dt1.Rows
                    iRow += 1
                    If iRow > 1 Then
                        Dim drLog As DataRow = dtLog.NewRow
                        dtLog.Rows.Add(drLog)
                        For i As Integer = 0 To dt1.Columns.Count - 1 '所有欄位
                            '將值轉移。
                            drLog(dt1.Columns(i).ColumnName) = dr1(dt1.Columns(i).ColumnName)
                        Next
                    End If
                Next
                'dt1.Dispose()
            End Using
            'ds.Dispose()
        End Using
        Return dtLog
    End Function

    ''' <summary> 使用 CSV檔匯入 DataTable </summary>
    ''' <param name="Fullfilename"></param>
    ''' <returns></returns>
    Public Shared Function GetDataTable_CSVFile(ByVal Fullfilename As String) As DataTable
        '使用欄位 '計算欄位
        Dim dtLog As New DataTable

        '將檔案讀出放入記憶體
        Dim sr As System.IO.Stream
        sr = IO.File.OpenRead(Fullfilename)
        Dim srr As System.IO.StreamReader
        srr = New System.IO.StreamReader(sr, System.Text.Encoding.Default)

        Dim iColumnCnt As Integer = 0
        Dim iRowIndex As Integer = 0

        Do While srr.Peek >= 0
            Dim OneRow As String = srr.ReadLine
            If Replace(",", OneRow, "") = "" Then Exit Do

            Dim colArray As Array = Split(OneRow, ",")
            If (iRowIndex = 0 AndAlso iColumnCnt = 0) Then
                iColumnCnt = colArray.Length
                For iCol As Integer = 0 To iColumnCnt - 1
                    Dim ColumnName As String = "COLUMN" & CStr(iCol)
                    dtLog.Columns.Add(ColumnName)
                Next
            End If
            If (iRowIndex = 0 AndAlso iColumnCnt = 0) Then Exit Do

            '抬頭第一行我不要
            If iRowIndex <> 0 Then
                Dim drLog As DataRow = dtLog.NewRow
                dtLog.Rows.Add(drLog)
                For iCol As Integer = 0 To iColumnCnt - 1
                    Dim ColumnName As String = "COLUMN" & CStr(iCol)
                    Dim ColumnValue As String = If(colArray(iCol) IsNot Nothing, ClearSQM(colArray(iCol)), "")
                    drLog(ColumnName) = ColumnValue
                Next
            End If
            iRowIndex += 1
        Loop
        If sr IsNot Nothing Then sr.Close()
        If srr IsNot Nothing Then srr.Close()

        Return dtLog
    End Function

