    '檢查是否有重複的課程時間 true:有 false:沒有--PLAN_TRAINDESC
    Public Shared Function Chk_DoubleDESC(ByVal OCID1 As String, ByVal ssOCID As String,
                                          ByRef dtTrain As DataTable, ByRef sPTDID As String) As Boolean
        Dim rst As Boolean = False '預設為沒有
        Dim ff As String = ""
        ff = "OCID=" & OCID1
        If dtTrain.Select(ff).Length > 0 Then
            For Each dr As DataRow In dtTrain.Select(ff)
                Dim ff2 As String = ""
                ff2 = "OCID IN (" & ssOCID & ")"
                ff2 &= " AND OCID <>" & OCID1
                ff2 &= " AND (1<>1 "
                ff2 &= " OR (straindate1 <='" & dr("straindate1") & "' AND straindate2 >='" & dr("straindate1") & "')"
                ff2 &= " OR (straindate1 <='" & dr("straindate2") & "' AND straindate2 >='" & dr("straindate2") & "')"
                ff2 &= " OR (straindate1 <='" & dr("straindate1") & "' AND straindate2 >='" & dr("straindate2") & "')"
                ff2 &= " OR (straindate1 >='" & dr("straindate1") & "' AND straindate2 <='" & dr("straindate2") & "')"
                ff2 &= " )"
                If dtTrain.Select(ff2).Length > 0 Then
                    rst = True
                    For Each dr2 As DataRow In dtTrain.Select(ff2)
                        If sPTDID <> "" Then
                            '查不到才加入
                            If sPTDID.IndexOf(Convert.ToString(dr2("PTDID"))) = -1 Then
                                If sPTDID <> "" Then sPTDID &= ","
                                sPTDID &= Convert.ToString(dr2("PTDID"))
                            End If
                        Else
                            sPTDID &= Convert.ToString(dr2("PTDID"))
                        End If
                    Next
                End If
            Next
        End If
        Return rst
    End Function

