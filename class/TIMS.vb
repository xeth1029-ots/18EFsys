    ''' <param name="oConn"></param>
    ''' <returns></returns>
    Public Shared Function Get_BudIDrbl(ByRef sm As SessionModel, ByRef BudID As RadioButtonList, ByRef oConn As SqlConnection) As String
        'TIMS 選項
        Dim rstMsg As String = ""
        Dim sql As String = ""
        sql &= " SELECT p.BUDID, p.BUDNAME FROM dbo.KEY_BUDGET p WITH(NOLOCK)" & vbCrLf
        sql &= " WHERE EXISTS (" & vbCrLf
        sql &= "  SELECT 1 FROM dbo.PLAN_BUDGET x WITH(NOLOCK)" & vbCrLf
        sql &= "  WHERE x.BUDID=p.BUDID" & vbCrLf
        sql &= $"  AND x.SYEAR='{sm.UserInfo.Years}' AND x.TPLANID='{sm.UserInfo.TPlanID}')" & vbCrLf
        '產投 - 加不補助
        If Cst_TPlanID28AppPlan.IndexOf(sm.UserInfo.TPlanID) > -1 Then
            sql &= " UNION SELECT BUDID, BUDNAME FROM dbo.VIEW_BUDGET WHERE BUDID='99'" & vbCrLf
        End If
        sql &= " ORDER BY p.BUDID" & vbCrLf
        Dim sCmd As New SqlCommand(sql, oConn)
        Call OpenDbConn(oConn)
        Dim dt As New DataTable
        With sCmd
            .Parameters.Clear()
            dt.Load(.ExecuteReader())
        End With
        'dt=DbAccess.GetDataTable(sql, oConn)
        If dt.Rows.Count = 0 Then
            rstMsg = "尚未設定該年度計畫的預算別"
            Return rstMsg
        End If
        With BudID
            .DataSource = dt
            .DataTextField = "BUDNAME"
            .DataValueField = "BUDID"
            .DataBind()
        End With
        Return rstMsg
    End Function

