    ''' <summary>執行指定的Sql語法 (利用指定的資料庫連線去執行sql)
    ''' <para>以 Hashtable 為SQL參數</para>
    ''' </summary>
    ''' <param name="strSql"></param>
    ''' <param name="objConn"></param>
    ''' <returns></returns>
    Public Shared Function ExecuteNonQuery(ByVal strSql As String, ByVal objConn As SqlConnection, ByRef parms As Hashtable) As Integer
        Dim rst As Integer = 0
        'LOG.Debug("ExecuteNonQuery: " & strSql)
        Using sCmd As SqlCommand = New SqlCommand(strSql, objConn)

            DbAccess.HashParmsChange(sCmd, parms)

            '統一轉呼叫, 確保 異動記錄會被寫入
            rst = ExecuteNonQuery(strSql, objConn, sCmd.Parameters)
        End Using
        Return rst
    End Function

    ''' <summary>執行指定的Sql語法 (利用指定的資料庫連線去執行sql)
    ''' <para>直接以SqlParameterCollection為SQL參數</para>
    ''' </summary>
    ''' <param name="strSql"></param>
    ''' <param name="objConn"></param>
    ''' <param name="parms"></param>
    ''' <returns></returns>
    Public Shared Function ExecuteNonQuery(ByVal strSql As String, ByVal objConn As SqlConnection, ByRef parms As SqlParameterCollection) As Integer
        Dim rst As Integer = 0

        OpenDbConn(objConn)

        Using sCmd As New SqlCommand(strSql, objConn)
            If Not IsNothing(parms) Then
                Dim i As Integer = 0
                For Each p As SqlParameter In parms
                    Dim pValue As Object = p.Value
                    Dim pType As Type = pValue.GetType()
                    sCmd.Parameters.Add(CType(CType(p, ICloneable).Clone(), SqlParameter))
                    i = i + 1
                Next
            End If

            rst = sCmd.ExecuteNonQuery()
        End Using

        Return rst
    End Function

#End Region

