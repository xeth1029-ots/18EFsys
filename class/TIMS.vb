    ''' <summary> 依 ComIDNO,PlaceID,iClassType 取得PLAN_TRAINPLACE </summary>
    ''' <param name="ComIDNO"></param>
    ''' <param name="PlaceID"></param>
    ''' <param name="iClassType"></param>
    ''' <returns></returns>
    Public Shared Function GETPlaceVal(ByVal ComIDNO As String, ByVal PlaceID As String, ByVal iClassType As Integer, ByRef oConn As SqlConnection) As DataRow
        Dim dr As DataRow
        Dim sql As String = ""
        sql &= " SELECT a.PlaceID" & vbCrLf
        sql &= " ,CONCAT(a.PlaceNAME,' (',dbo.FN_GZIP33(a.ZipCode,a.ZIP6W),')',b.ZipName,a.Address) NAME" & vbCrLf
        sql &= " ,a.CLASSIFICATION" & vbCrLf
        sql &= " ,a.PTID" & vbCrLf
        sql &= " ,a.PlaceNAME" & vbCrLf
        sql &= " FROM PLAN_TRAINPLACE a" & vbCrLf
        sql &= " JOIN VIEW_ZIPNAME b ON a.ZipCode=b.ZipCode" & vbCrLf
        sql &= " WHERE a.ModifyType IS NULL" & vbCrLf
        If iClassType = 1 Then '學科
            sql &= " AND (a.classification=1 OR a.classification=3)" & vbCrLf
        ElseIf iClassType = 2 Then '術科
            sql &= " AND (a.classification=2 OR a.classification=3)" & vbCrLf
        End If
        sql &= " AND a.ComIDNO='" & ComIDNO & "'"
        sql &= " AND a.PlaceID='" & PlaceID & "'"
        dr = DbAccess.GetOneRow(sql, oConn)
        Return dr
    End Function

