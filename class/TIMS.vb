    ''' <summary>置換文字，最多10次</summary>
    ''' <param name="Expression"></param>
    ''' <param name="Find"></param>
    ''' <param name="Replacement"></param>
    ''' <returns></returns>
    Public Shared Function DoReplaceAll(ByVal Expression As String, ByVal Find As String, ByVal Replacement As String) As String
        Dim rst As String = ""
        If Expression = "" Then Return rst
        If Find = "" Then Return rst
        rst = Replace(Expression, Find, Replacement)
        Dim iCnt As Integer = 0
        Do While rst.IndexOf(Find) > -1
            iCnt += 1
            rst = Replace(rst, Find, Replacement)
            If (iCnt > 10) Then Exit Do '(最多跑10次，避免一直跑)
        Loop 'Console.WriteLine(x)
        Return rst
    End Function

