    ''' <summary> 取得最後帳號異動日期 </summary>
    ''' <param name="objconn"></param>
    ''' <param name="parms"></param>
    ''' <returns></returns>
    Function GET_LASTMDFIDATE(ByRef objconn As SqlConnection, ByRef parms As Hashtable) As String
        Dim rst As String = "" '最後帳號異動日期
        rst = Cdate3(DateTime.Now.AddDays(-365))
        Dim s_ACCOUNT As String = GetMyValue2(parms, "ACCOUNT")
        If s_ACCOUNT = "" Then Return rst

        Dim sql As String = ""
        sql &= " select ISNULL(max(MODIFYDATE),GETDATE()-365) MODIFYDATE" & vbCrLf
        sql &= " from (" & vbCrLf
        sql &= " SELECT MODIFYDATE FROM AUTH_ACCOUNT WHERE ACCOUNT=@ACCOUNT AND MODIFYDATE IS NOT NULL" & vbCrLf
        sql &= " union" & vbCrLf
        sql &= " SELECT CONFIRMDATE MODIFYDATE FROM AUTH_PXSSWARD_HIS WHERE ACCOUNT=@ACCOUNT AND CONFIRMDATE IS NOT NULL" & vbCrLf
        sql &= " ) gp" & vbCrLf
        Dim dt As DataTable = DbAccess.GetDataTable(sql, objconn, parms)
        If dt.Rows.Count > 0 Then rst = Cdate3(dt.Rows(0)("MODIFYDATE"))
        Return rst
    End Function

