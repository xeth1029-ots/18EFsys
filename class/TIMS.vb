    ''' <summary>傳入郵遞區號 返回 轄區或空白</summary>
    ''' <param name="ZIP"></param>
    ''' <returns></returns>
    Public Shared Function Get_ZipName(ByVal ZIP As String) As String
        Dim rst As String = ""
        ZIP = ClearSQM(ZIP)
        '判斷數字可能性，若不是數字就返回空白算了。
        If ZIP <> "" Then ZIP = If(ZIP.Length > 3, ZIP.Substring(0, 3), ZIP)
        If ZIP <> "" Then ZIP = If(IsNumeric2(ZIP), $"{CINT1(ZIP)}", "")
        If ZIP = "" Then Return rst

        Using tConn As SqlConnection = DbAccess.GetConnection()
            rst = Get_ZipName(ZIP, tConn)
            Call CloseDbConn(tConn)
        End Using
        Return rst
    End Function

