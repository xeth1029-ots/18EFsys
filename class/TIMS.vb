    ''' <summary>'(讀取XLSX檔案轉為dt_xls) 使用(xlsx) OfficeOpenXml.ExcelPackage</summary>
    ''' <param name="oFileInfo"></param>
    ''' <param name="Errmsg"></param>
    ''' <returns></returns>
    Public Shared Function ReadXLSX(ByRef oFileInfo As FileInfo, ByRef Errmsg As String) As DataTable
        Dim dtX As DataTable = Nothing

        Dim s_MSG1 As String = ""
        If oFileInfo Is Nothing Then
            Errmsg = "檔案格式有誤,請確認檔案是否正確!"
            LOG.Error(String.Concat("#ReadXLSX FileName:", oFileInfo.Name, ",Errmsg: ", Errmsg))
            Return dtX
        End If

        Dim package As OfficeOpenXml.ExcelPackage
        Try
            package = New OfficeOpenXml.ExcelPackage(oFileInfo)
        Catch ex As Exception
            Errmsg = "檔案格式有誤,請確認檔案是否正確!!"
            LOG.Error(String.Concat("#ReadXLSX FileName:", oFileInfo.Name, ",Errmsg: ", Errmsg, ex.Message), ex)
            Return dtX
        End Try

        Dim fg_wksheet_ok As Boolean = True
        Dim Wksheet As OfficeOpenXml.ExcelWorksheet = Nothing ' package.Workbook.Worksheets(1)
        Try
            Wksheet = package.Workbook.Worksheets(0)
        Catch ex As Exception
            fg_wksheet_ok = False
            WriteTraceLog(ex.Message, ex)
        End Try
        If Not fg_wksheet_ok Then
            fg_wksheet_ok = True
            Try
                Wksheet = package.Workbook.Worksheets(1)
            Catch ex As Exception
                fg_wksheet_ok = False
                WriteTraceLog(ex.Message, ex)
            End Try
        End If

        If Not fg_wksheet_ok Then Return dtX
        If Wksheet.Dimension Is Nothing Then Return dtX
        Dim iColCount As Integer = Wksheet.Dimension.End.Column ';Get Column Count
        If iColCount = 0 Then Return dtX
        Dim iRowCount As Integer = Wksheet.Dimension.End.Row ';Get row count
        If iRowCount = 0 Then Return dtX

        s_MSG1 = String.Concat("#ReadXLSX FileName:", oFileInfo.Name, ",RowCount:", iRowCount, "/iColCount:", iColCount)
        LOG.Debug(s_MSG1)

        '讀取表頭
        s_MSG1 = ""
        dtX = New DataTable
        For iCol As Integer = 1 To iColCount
            Dim wObj As Object = Wksheet.Cells(1, iCol).Value
            Dim wCOLNAME As String = If(wObj IsNot Nothing, Convert.ToString(wObj), String.Concat("COLUMN", iCol))
            s_MSG1 &= String.Concat(If(s_MSG1 <> "", " , ", ""), "COL:", iCol, "/CNM:", wCOLNAME)
            Try
                dtX.Columns.Add(wCOLNAME)
            Catch ex As Exception
                Errmsg = "檔案格式有誤,請確認檔案是否正確!!!"
                LOG.Warn(String.Concat("#ReadXLSX FileName:", oFileInfo.Name, ",Errmsg: ", Errmsg, ex.Message, vbCrLf, s_MSG1))
                LOG.Error(String.Concat("#ReadXLSX FileName:", oFileInfo.Name, ",Errmsg: ", Errmsg, ex.Message), ex)
                Return dtX
            End Try
        Next
        LOG.Debug(s_MSG1)
        s_MSG1 = ""

        '讀取資料
        For iRow As Integer = 2 To iRowCount
            's_MSG1=""
            Dim drX1 As DataRow = dtX.NewRow()
            dtX.Rows.Add(drX1)
            For iCol As Integer = 1 To iColCount
                Dim wObj As Object = Wksheet.Cells(iRow, iCol).Value
                's_MSG1 &= String.Concat(If(s_MSG1 <> "", " , ", ""), "R:", iRow, "/C:", iCol, "/V: ", If(wObj IsNot Nothing, Convert.ToString(wObj), ""))
                drX1(iCol - 1) = If(wObj, Convert.DBNull)
            Next
            'LOG.Debug(s_MSG1)
        Next
        oFileInfo = Nothing
        package.Dispose()
        package = Nothing
        'If (package IsNot Nothing) Then package=Nothing
        Return dtX
    End Function

