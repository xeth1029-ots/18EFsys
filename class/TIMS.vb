        If InConnFlag Then Call CloseDbConn(conn)
        Return If(oRst Is Nothing, "", Convert.ToString(oRst))
    End Function

    ''' <summary>'取得各別變更資料 (PLAN_REVISE),Request("PlanID") CID NO</summary>
    ''' <param name="MyPage"></param>
    ''' <param name="CreateDate"></param>
    ''' <param name="AltDataID"></param>
    ''' <param name="fieldName"></param>
    ''' <param name="oConn"></param>
    ''' <returns></returns>
    Public Shared Function GET_PlanRevise(ByRef MyPage As Page,
                                          ByVal CreateDate As String,
                                          ByVal AltDataID As String,
                                          ByVal fieldName As String,
                                          ByRef oConn As SqlConnection) As String
        Const Cst_sql As String = "SQL"
        Dim Rst As String = ""
        Dim oRst As Object = Nothing
        Dim rq_PlanID As String = ClearSQM(MyPage.Request("PlanID"))
        Dim rq_cid As String = ClearSQM(MyPage.Request("cid"))
        Dim rq_no As String = ClearSQM(MyPage.Request("no"))
        If rq_PlanID = "" OrElse rq_cid = "" OrElse rq_no = "" Then Return Rst
        Dim rq_ActCheck As String = "" & UCase(ClearSQM(MyPage.Request("check"))) 'PLAN_PLANINFO/PLAN_REVISE
        Dim rq_CDate As String = "" & ClearSQM(MyPage.Request("CDate"))
        Dim rq_SubNo As String = "" & ClearSQM(MyPage.Request("SubNo"))
        Dim rq_AltDataID As String = ClearSQM(MyPage.Request("AltDataID"))
        Dim rq_PARTREDUC1 As String = ClearSQM(MyPage.Request("PARTREDUC1"))

        Dim sql As String = ""
        Select Case fieldName.ToUpper '.ToLower
            Case Cst_sql 'SQL

                If rq_ActCheck = "PLAN_REVISE" AndAlso rq_PARTREDUC1 = "Y" AndAlso rq_AltDataID = AltDataID AndAlso rq_SubNo <> "" AndAlso rq_CDate <> "" Then
                    sql = ""
                    sql &= " SELECT * FROM PLAN_REVISE" & vbCrLf
                    sql &= " WHERE PlanID=" & rq_PlanID & " and ComIDNO='" & rq_cid & "' and SeqNO=" & rq_no & vbCrLf
                    sql &= " and CDate=" & To_date(rq_CDate) & " and AltDataID=" & rq_AltDataID & "" & vbCrLf
                    sql &= " and SUBSEQNO=" & rq_SubNo & "" & vbCrLf
                Else
                    '組合sql返回
                    sql = ""
                    sql &= " SELECT * FROM PLAN_REVISE" & vbCrLf
                    sql &= " WHERE PlanID=" & rq_PlanID & " and ComIDNO='" & rq_cid & "' and SeqNO=" & rq_no & vbCrLf
                    sql &= " and CDate=" & To_date(CreateDate) & " and AltDataID=" & AltDataID & "" & vbCrLf
                End If

                Rst = sql '回傳sql組合
            Case "" '無欄位名稱傳回 ReviseCont
                'Optional ByVal fieldName As String="ReviseCont"
                '取得該欄位資料返回
                sql = ""
                sql &= " SELECT REVISECONT FROM PLAN_REVISE" & vbCrLf
                sql &= " WHERE PlanID=" & rq_PlanID & " and ComIDNO='" & rq_cid & "' and SeqNO=" & rq_no & vbCrLf
                sql &= " and CDate=" & To_date(CreateDate) & " and AltDataID=" & AltDataID & "" & vbCrLf
                sql &= " ORDER BY SubSeqNO DESC" & vbCrLf
                oRst = DbAccess.ExecuteScalar(sql, oConn)
                If oRst IsNot Nothing Then Rst = $"{oRst}"

            Case Else
                '取得該欄位資料返回
                sql = ""
                sql &= " SELECT " & fieldName & " FROM PLAN_REVISE" & vbCrLf
                sql &= " WHERE PlanID=" & rq_PlanID & " and ComIDNO='" & rq_cid & "' and SeqNO=" & rq_no & vbCrLf
                sql &= " and CDate=" & To_date(CreateDate) & " and AltDataID=" & AltDataID & "" & vbCrLf
                sql &= " ORDER BY SubSeqNO DESC" & vbCrLf
                oRst = DbAccess.ExecuteScalar(sql, oConn)
                If oRst IsNot Nothing Then Rst = $"{oRst}"
        End Select

        Return Rst
    End Function

