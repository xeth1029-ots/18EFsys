    Public Shared Sub Check_dtSFCASEFL(MyPage As Page, ByRef dt As DataTable, download_Path As String)
        If dt Is Nothing OrElse dt.Rows.Count = 0 Then Return
        Const cst_errMsg_6 As String = "(檔案上傳失敗／異常，請刪除後重新上傳)"
        For i As Int16 = 0 To dt.Rows.Count - 1
            Dim filename1 As String = Convert.ToString(dt.Rows(i).Item("FILENAME1"))
            Dim filepath1 As String = Convert.ToString(dt.Rows(i).Item("FILEPATH1"))
            If filename1 <> "" Then
                Try
                    Dim flag_FL_EXISTS As Boolean = CHK_PIC_EXISTS_WITH_TIMEOUT(MyPage.Server, If(filepath1 <> "", filepath1, download_Path), filename1)
                    dt.Rows(i)("OKFLAG") = If(Not flag_FL_EXISTS, cst_errMsg_6, filename1)
                Catch ex As Exception
                    dt.Rows(i)("OKFLAG") = ex.Message
                End Try
            End If
        Next
    End Sub

