    ''' <summary>取得班級相關資料</summary>
    ''' <param name="OCID"></param>
    ''' <param name="oConn"></param>
    ''' <param name="Trans"></param>
    ''' <returns></returns>
    ''' <remarks></remarks>
    Public Shared Function GetOCIDDate(ByVal OCID As String, ByRef oConn As SqlConnection, ByRef Trans As SqlTransaction) As DataRow
        'select stdate,ftdate,examdate,senterdate, fenterdate,fenterdate2 from CLASS_CLASSINFO where fenterdate2  is not null and rownum <=10
        Dim Rst As DataRow = Nothing
        If OCID = "" OrElse Not IsNumeric2(OCID) Then Return Rst '(空值)'(非整數值)
        OCID = GetValue2(OCID) '(必為整數)

        Dim sql As String = ""
        sql &= " SELECT b.TMID ,ISNULL(b.TRAINID, b.JOBID) TRAINID" & vbCrLf
        sql &= " ,ISNULL(b.TRAINNAME, b.JOBNAME) TRAINNAME" & vbCrLf
        sql &= " ,concat('[',ISNULL(b.TRAINID, b.JOBID),']',ISNULL(b.TRAINNAME, b.JOBNAME)) TRAINNAME2" & vbCrLf
        sql &= " ,b.JOBID ,b.JOBNAME ,a.OCID ,a.CLASSCNAME ,a.CYCLTYPE" & vbCrLf
        sql &= " ,dbo.FN_GET_CLASSCNAME(a.CLASSCNAME,a.CYCLTYPE) CLASSCNAME2" & vbCrLf
        sql &= " ,ISNULL(a2.CLASSID2,a2.CLASSID) CLASSID" & vbCrLf
        sql &= " ,a.LEVELTYPE ,a.LEVELCOUNT" & vbCrLf '(階段似乎沒有使用該功能了)
        sql &= " ,a.RID ,d.RSID ,a.EXAMDATE ,a.CHECKINDATE" & vbCrLf
        sql &= " ,a.STDATE,a.FTDATE,a.ONSHELLDATE" & vbCrLf
        sql &= " ,c.ORGID ,c.ORGNAME" & vbCrLf
        sql &= " ,a.TNUM" & vbCrLf '核定人數 
        sql &= " ,a.THOURS" & vbCrLf '核定時數 
        sql &= " ,a.TADDRESSZIP ,a.TADDRESSZIP6W ,a.TADDRESS" & vbCrLf
        sql &= " ,a.PLANID,a.COMIDNO,a.SEQNO" & vbCrLf
        sql &= " ,a.YEARS ,ip.YEARS PLANYEARS" & vbCrLf 'YEARS(長度2),PLANYEARS(長度4)
        sql &= " ,dbo.FN_CYEAR2(ip.YEARS) YEARS_ROC" & vbCrLf
        sql &= " ,a.TPERIOD" & vbCrLf '訓練時段代碼
        sql &= " ,a.ISCLOSED" & vbCrLf
        sql &= " ,a.APPLIEDRESULTM" & vbCrLf '學員經費審核結果已經通過，不可新增
        sql &= " ,CONVERT(DATETIME, CURRENT_TIMESTAMP, 121) NOWDATE" & vbCrLf
        sql &= " ,convert(date,GETDATE()) TODAY1" & vbCrLf
        '開訓日期前可正常顯示個資。E網報名審核 SD_01_004 Y:可正常顯示
        sql &= " ,CASE WHEN convert(date,GETDATE())<=a.STDATE THEN 'Y' END ShowOK" & vbCrLf
        '過開訓日
        sql &= " ,CASE WHEN convert(date,GETDATE())>=a.STDATE THEN 'Y' END BEGINCLASS" & vbCrLf
        '開訓日期後第14天(內)可正常顯示個資。學員資料維護。 SD_03_002 Y:可正常顯示
        sql &= " ,CASE WHEN (a.STDATE-1)<=convert(date,GETDATE()) AND convert(date,GETDATE())<=(a.STDATE+14) THEN 'Y' END SHOWOK14" & vbCrLf
        'https://jira.turbotech.com.tw/browse/TIMSC-161 --InputOK
        '新增補登功能：首頁>>學員動態管理>>招生作業>>錄取作業 修改說明：提供可補登之功能，開訓日後鎖定功能填寫。
        sql &= " ,CASE WHEN convert(date,GETDATE())<=convert(date,a.STDATE) THEN 'Y' END INPUTOK" & vbCrLf
        'https://jira.turbotech.com.tw/browse/TIMSC-161 --InputOK14
        '若已過開訓14日，則不可進行儲存動作 Y:可儲存
        sql &= " ,CASE WHEN convert(date,GETDATE())<=convert(date,DATEADD(DAY, 14, a.STDATE)) THEN 'Y' END INPUTOK14" & vbCrLf
        'https://jira.turbotech.com.tw/browse/TIMSC-161
        '若已過結訓日後120日，則不可進行儲存動作 Y:可儲存
        sql &= " ,CASE WHEN convert(date,GETDATE())<=convert(date,DATEADD(DAY, 120, a.FTDATE)) THEN 'Y' END INPUTOK120" & vbCrLf
        'sql &= " ,'Y' SHOWOK14" & vbCrLf
        sql &= " ,a.CTNAME" & vbCrLf '導師
        sql &= " ,a.ISAPPLIC,a.eTRAIN_SHOW" & vbCrLf
        sql &= " ,a.SENTERDATE,a.FENTERDATE,a.FENTERDATE2" & vbCrLf '報名開始日/'報名截止日/'有報名截止
        sql &= " ,ip.DISTID" & vbCrLf
        sql &= " ,CASE WHEN GETDATE()<=a.FENTERDATE2 THEN 'Y' END FENTERDATE2Y" & vbCrLf 'Y:可報名
        'sql &= " ,ISNULL(a2.CLASSID2,a2.CLASSID)+ISNULL(a.CYCLTYPE,'') EXAMNO1" & vbCrLf
        sql &= " ,concat(ISNULL(a2.CLASSID2,a2.CLASSID),RIGHT('0'+ISNULL(a.CYCLTYPE,'01'),2)) EXAMNO1"
        sql &= " ,concat(a.YEARS,'0',ISNULL(a2.CLASSID2,a2.CLASSID),RIGHT('0'+ISNULL(a.CYCLTYPE,'01'),2)) BASICSTDID"
        sql &= " ,a2.TPLANID" & vbCrLf
        '學員資料審核鈕(班級)-AppliedResultR
        sql &= " ,a.AppliedResultR" & vbCrLf
        sql &= " ,FORMAT(a.MODIFYDATE,'mmssdd') MSD" & vbCrLf
        '申請階段 APPSTAGE '1：上半年、2：下半年、3：政策性產業 /4:進階政策性產業
        sql &= " ,pp.APPSTAGE" & vbCrLf
        sql &= " ,(SELECT x.ORGKINDGW FROM dbo.VIEW_RIDNAME x WHERE x.RID=pp.RID) ORGKINDGW" & vbCrLf
        sql &= " ,concat(pp.PLANID,'x',pp.COMIDNO,'x',pp.SEQNO) PCS" & vbCrLf
        sql &= " ,CASE WHEN a.STDATE<=GETDATE() AND GETDATE()<=DATEADD(DAY,3,a.FTDATE) THEN 'Y' END TRAININGDATE" & vbCrLf '在訓期間內
        sql &= " FROM dbo.CLASS_CLASSINFO a WITH(NOLOCK)" & vbCrLf
        sql &= " JOIN dbo.PLAN_PLANINFO pp WITH(NOLOCK) ON pp.PLANID=a.PLANID AND pp.COMIDNO=a.COMIDNO AND pp.SEQNO=a.SEQNO" & vbCrLf
        sql &= " JOIN dbo.ID_CLASS a2 WITH(NOLOCK) ON a2.CLSID=a.CLSID" & vbCrLf
        sql &= " JOIN dbo.KEY_TRAINTYPE b WITH(NOLOCK) ON b.TMID=a.TMID" & vbCrLf
        sql &= " JOIN dbo.AUTH_RELSHIP d WITH(NOLOCK) ON d.RID=a.RID" & vbCrLf
        sql &= " JOIN dbo.ORG_ORGINFO c WITH(NOLOCK) ON c.ORGID=d.ORGID" & vbCrLf
        sql &= " JOIN dbo.ID_PLAN ip WITH(NOLOCK) ON ip.PLANID=a.PLANID" & vbCrLf
        sql &= " WHERE a.OCID=@OCID" & vbCrLf
        Call OpenDbConn(oConn)
        Dim dt As New DataTable
        Dim sCmd As SqlCommand = If(Trans IsNot Nothing, New SqlCommand(sql, oConn, Trans), New SqlCommand(sql, oConn))
        With sCmd
            If Trans IsNot Nothing Then .Transaction = Trans
            '.Parameters.Clear()
            .Parameters.Add("OCID", SqlDbType.BigInt).Value = CINT1(OCID)
            dt.Load(.ExecuteReader())
        End With
        If dt.Rows.Count = 1 Then Rst = dt.Rows(0)
        Return Rst
    End Function

    ''' <summary> 欄位長度有限重新取得 40 </summary>
