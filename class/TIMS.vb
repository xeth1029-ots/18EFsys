    '將xml之特殊字元(如：&、<、>..等)轉為xml認得的編碼
    Public Shared Function Trn_code(ByVal strString As String) As String
        Dim turn_string As String = strString
        If turn_string = "" Then Return ""
        turn_string = turn_string.Replace("&", "&amp;").Replace("<", "&lt;").Replace(">", "&gt;").Replace("'", "&apos;").Replace("""", "&quot;")
        turn_string = $"<![CDATA[{turn_string}]]>"
        Return turn_string
    End Function

    Public Shared Function Trn_code2(ByVal strString As String) As String
        Dim turn_string As String = strString
        If turn_string = "" Then Return ""
        turn_string = turn_string.Replace("&", "&amp;").Replace("<", "&lt;").Replace(">", "&gt;").Replace("'", "&apos;").Replace("""", "&quot;")
        Return turn_string
    End Function


