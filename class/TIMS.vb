    ''' <summary> 取得 訓練計劃開班總表資料:產投 PLAN_VERREPORT </summary>
    ''' <param name="ss3"></param>
    ''' <returns></returns>
    ''' <remarks></remarks>
    Public Shared Function Get_VERREPORTDt5(ByRef oConn As SqlConnection, ByVal ss3 As String) As DataTable
        Dim dt1 As New DataTable
        Dim sType As String = GetMyValue(ss3, "sType")
        Dim OCID As String = GetMyValue(ss3, "OCID")
        Dim PlanID As String = GetMyValue(ss3, "PlanID")
        Dim ComIDNO As String = GetMyValue(ss3, "ComIDNO")
        Dim SeqNo As String = GetMyValue(ss3, "SeqNo")
        Select Case sType
            Case cst_sType_A_已轉班
                Dim sql As String = ""
                sql &= " SELECT CASE WHEN P2.RecDesc IS NOT NULL THEN 'Y' ELSE 'N' END AS Rec" & vbCrLf
                sql &= " ,CASE WHEN P2.LearnDesc IS NOT NULL THEN 'Y' ELSE 'N' END AS Learn" & vbCrLf
                sql &= " ,CASE WHEN P2.ActDesc IS NOT NULL THEN 'Y' ELSE 'N' END AS Act" & vbCrLf
                sql &= " ,CASE WHEN P2.ResultDesc IS NOT NULL THEN 'Y' ELSE 'N' END AS Rst" & vbCrLf
                sql &= " ,CASE WHEN P2.OtherDesc IS NOT NULL THEN 'Y' ELSE 'N' END AS oth" & vbCrLf
                sql &= " ,P2.RECDESC ,P2.LEARNDESC ,P2.ACTDESC ,P2.RESULTDESC ,P2.OTHERDESC , P1.DefGovCost, P1.DefStdCost" & vbCrLf
                sql &= " ,P2.ISiCAPCOUR, P2.iCAPCOURDESC" & vbCrLf
                sql &= " ,P1.iCAPNUM,format(P1.iCAPMARKDATE,'yyyy/MM/dd') iCAPMARKDATE" & vbCrLf
                sql &= " ,P2.RECRUIT, P2.SELMETHOD, P2.INSPIRE" & vbCrLf
                '「裝備與設施」區塊，增加【其他設施說明】欄位
                sql &= " ,p2.OTHFACDESC23" & vbCrLf
                sql &= " ,ROUND(P1.DefGovCost/P1.TNum,0) Total1" & vbCrLf
                sql &= " ,ROUND(P1.DefStdCost/P1.TNum,0) Total2" & vbCrLf
                sql &= " ,ROUND(P1.DefGovCost/P1.TNum,0) + ROUND(P1.DefStdCost/P1.TNum,0) Total3" & vbCrLf
                sql &= " ,ROUND(P1.DefGovCost+P1.DefStdCost,0) Total4" & vbCrLf
                sql &= " ,CASE WHEN P2.FirResult='Y' THEN '合格' WHEN P2.FirResult='N' THEN '不合格' ELSE '' END AS FirRst" & vbCrLf
                sql &= " ,CASE WHEN P2.SecResult='Y' THEN '合格' WHEN P2.SecResult='N' THEN '不合格' ELSE '' END AS SecRst" & vbCrLf
                sql &= " ,P2.MEMO8,P2.MEMO82 ,P1.TOTALCOST ,ROUND(P1.totalcost/P1.Tnum,0) Total1b" & vbCrLf
                sql &= " ,ip.TPLANID" & vbCrLf
                sql &= " ,dbo.FN_GET_REMOTER1(P1.COMIDNO,P1.RMTID) RMTNAME1" & vbCrLf
                sql &= " ,dbo.FN_GET_REMOTER1(P1.COMIDNO,P1.RMTID2) RMTNAME2" & vbCrLf

                sql &= " FROM CLASS_CLASSINFO a" & vbCrLf
                sql &= " JOIN PLAN_PLANINFO P1 ON a.PlanID=P1.PlanID AND a.ComIDNO=P1.ComIDNO AND a.SeqNo=P1.SeqNo" & vbCrLf
                sql &= " JOIN ID_PLAN ip ON ip.planid=a.planid" & vbCrLf
                sql &= " JOIN VIEW_RIDNAME V1 ON P1.RID=V1.RID" & vbCrLf
                sql &= " LEFT JOIN PLAN_VERREPORT P2 ON P1.PlanID= P2.PlanID AND P1.ComIDNO=P2.ComIDNO AND P1.SeqNo=P2.SeqNo" & vbCrLf
                sql &= " WHERE a.OCID=@OCID "
                Dim sCmd As New SqlCommand(sql, oConn)
                Call OpenDbConn(oConn)
                With sCmd
                    .Parameters.Clear()
                    .Parameters.Add("OCID", SqlDbType.VarChar).Value = OCID
                    dt1.Load(.ExecuteReader())
                End With

            Case cst_sType_B_未轉班
                Dim sql As String = ""
                sql &= " SELECT ppi.PlanID" & vbCrLf
                sql &= " ,CASE WHEN pvp.RecDesc IS NOT NULL THEN 'Y' ELSE 'N' END AS Rec" & vbCrLf
                sql &= " ,CASE WHEN pvp.LearnDesc IS NOT NULL THEN 'Y' ELSE 'N' END AS Learn" & vbCrLf
                sql &= " ,CASE WHEN pvp.ActDesc IS NOT NULL THEN 'Y' ELSE 'N' END AS Act" & vbCrLf
                sql &= " ,CASE WHEN pvp.ResultDesc IS NOT NULL THEN 'Y' ELSE 'N' END AS Rst" & vbCrLf
                sql &= " ,CASE WHEN pvp.OtherDesc IS NOT NULL THEN 'Y' ELSE 'N' END AS oth" & vbCrLf
                sql &= " ,pvp.RecDesc ,pvp.LearnDesc ,pvp.ActDesc ,pvp.ResultDesc ,pvp.OtherDesc ,ppi.DefGovCost ,ppi.DefStdCost" & vbCrLf
                sql &= " ,pvp.ISiCAPCOUR, pvp.iCAPCOURDESC" & vbCrLf
                sql &= " ,ppi.iCAPNUM,format(ppi.iCAPMARKDATE,'yyyy/MM/dd') iCAPMARKDATE" & vbCrLf
                sql &= " ,pvp.RECRUIT, pvp.SELMETHOD, pvp.INSPIRE" & vbCrLf
                '「裝備與設施」區塊，增加【其他設施說明】欄位
                sql &= " ,pvp.OTHFACDESC23" & vbCrLf
                sql &= " ,ROUND(ppi.DefGovCost/ppi.TNum,0) Total1" & vbCrLf
                sql &= " ,ROUND(ppi.DefStdCost/ppi.TNum,0) Total2" & vbCrLf
                sql &= " ,ROUND(ppi.DefGovCost/ppi.TNum,0) + ROUND(ppi.DefStdCost/ppi.TNum,0) Total3" & vbCrLf
                sql &= " ,ROUND(ppi.DefGovCost+ppi.DefStdCost,0) Total4" & vbCrLf
                sql &= " ,CASE WHEN pvp.FirResult='Y' THEN '合格' WHEN pvp.FirResult='N' THEN '不合格' END AS FirRst" & vbCrLf
                sql &= " ,CASE WHEN pvp.SecResult='Y' THEN '合格' WHEN pvp.SecResult='N' THEN '不合格' END AS SecRst" & vbCrLf
                sql &= " ,pvp.MEMO8,pvp.MEMO82 ,ppi.TOTALCOST,ROUND(ppi.totalcost/ppi.TNum,0) Total1b" & vbCrLf
                sql &= " ,ip.TPLANID" & vbCrLf
                sql &= " ,dbo.FN_GET_REMOTER1(ppi.COMIDNO,ppi.RMTID) RMTNAME1" & vbCrLf
                sql &= " ,dbo.FN_GET_REMOTER1(ppi.COMIDNO,ppi.RMTID2) RMTNAME2" & vbCrLf

                sql &= " FROM PLAN_PLANINFO ppi" & vbCrLf
                sql &= " JOIN ID_PLAN ip ON ip.planid=ppi.planid" & vbCrLf
                sql &= " LEFT JOIN PLAN_VERREPORT pvp ON pvp.PlanID=ppi.PlanID AND pvp.ComIDNO=ppi.ComIDNO AND pvp.SeqNO=ppi.SeqNO" & vbCrLf
                sql &= " WHERE ppi.PlanID=@PlanID AND ppi.ComIDNO=@ComIDNO AND ppi.SeqNo=@SeqNo" & vbCrLf
                Dim sCmd As New SqlCommand(sql, oConn)
                Call OpenDbConn(oConn)
                With sCmd
                    .Parameters.Clear()
                    .Parameters.Add("PlanID", SqlDbType.Int).Value = CINT1(PlanID)
                    .Parameters.Add("ComIDNO", SqlDbType.VarChar).Value = ComIDNO
                    .Parameters.Add("SeqNo", SqlDbType.Int).Value = CINT1(SeqNo)
                    dt1.Load(.ExecuteReader())
                End With
        End Select
        Return dt1
    End Function

    ''' <summary>新增【專長能力標籤】項目，並帶入專長能力及描述-PLAN_ABILITY</summary>
    ''' <param name="oConn"></param>
    ''' <param name="ss3"></param>
    ''' <returns></returns>
    Public Shared Function GET_PLAN_ABILITYdt(oConn As SqlConnection, ss3 As String) As DataTable
        Dim dt1 As New DataTable
        Dim sType As String = GetMyValue(ss3, "sType")
        Dim OCID As String = GetMyValue(ss3, "OCID")
        Dim PlanID As String = GetMyValue(ss3, "PlanID")
        Dim ComIDNO As String = GetMyValue(ss3, "ComIDNO")
        Dim SeqNo As String = GetMyValue(ss3, "SeqNo")
        Call OpenDbConn(oConn)
        Select Case sType
            Case cst_sType_A_已轉班
                Dim sSql As String = ""
                sSql &= " SELECT pa.PABID,pa.PLANID,pa.COMIDNO,pa.SEQNO" & vbCrLf
                sSql &= " ,pa.SEQ_ID,pa.ABILITY,pa.ABILITY_DESC,CONCAT(pa.ABILITY,'：',pa.ABILITY_DESC) ABILITYDESC" & vbCrLf
                sSql &= " FROM CLASS_CLASSINFO a" & vbCrLf
                sSql &= " JOIN PLAN_ABILITY pa ON pa.PlanID=a.PlanID AND pa.ComIDNO=a.ComIDNO AND pa.SeqNo=a.SeqNo" & vbCrLf
                sSql &= " WHERE a.OCID=@OCID" & vbCrLf
                sSql &= " ORDER BY pa.SEQ_ID" & vbCrLf
                Dim sCmd As New SqlCommand(sSql, oConn)
                With sCmd
                    .Parameters.Add("OCID", SqlDbType.BigInt).Value = CINT1(OCID)
                    dt1.Load(.ExecuteReader())
                End With

            Case cst_sType_B_未轉班
                Dim sSql As String = ""
                sSql &= " SELECT pa.PABID,pa.PLANID,pa.COMIDNO,pa.SEQNO" & vbCrLf
                sSql &= " ,pa.SEQ_ID,pa.ABILITY,pa.ABILITY_DESC,CONCAT(pa.ABILITY,'：',pa.ABILITY_DESC) ABILITYDESC" & vbCrLf
                sSql &= " FROM PLAN_PLANINFO pp" & vbCrLf
                sSql &= " JOIN PLAN_ABILITY pa ON pa.PlanID=pp.PlanID AND pa.ComIDNO=pp.ComIDNO AND pa.SeqNo=pp.SeqNo" & vbCrLf
                sSql &= " WHERE pp.PlanID=@PlanID AND pp.ComIDNO=@ComIDNO AND pp.SeqNo=@SeqNo" & vbCrLf
                sSql &= " ORDER BY pa.SEQ_ID" & vbCrLf
                Dim sCmd As New SqlCommand(sSql, oConn)
                With sCmd
                    .Parameters.Clear()
                    .Parameters.Add("PlanID", SqlDbType.Int).Value = CINT1(PlanID)
                    .Parameters.Add("ComIDNO", SqlDbType.VarChar).Value = ComIDNO
                    .Parameters.Add("SeqNo", SqlDbType.Int).Value = CINT1(SeqNo)
                    dt1.Load(.ExecuteReader())
                End With
        End Select
        Return dt1
    End Function
