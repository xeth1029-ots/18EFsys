    ''' <summary>
    ''' (基本)檢核上傳檔案1
    ''' </summary>
    ''' <param name="File1"></param>
    ''' <param name="sMyFileName"></param>
    ''' <param name="flag_File1_xls"></param>
    ''' <param name="flag_File1_ods"></param>
    ''' <returns></returns>
    Public Shared Function ChkFile1(ByRef File1 As HtmlInputFile, ByRef sMyFileName As String, ByRef flag_File1_xls As Boolean, ByRef flag_File1_ods As Boolean) As String
        'Dim sMyFileName As String=""
        'Dim sMyFileType As String=""
        '檢查檔案格式與大小----------   Start
        If File1.Value = "" Then
            Return "請選擇匯入檔案的路徑" 'Exit Sub
        End If
        If File1.PostedFile.ContentLength = 0 Then
            Return "檔案長度位置錯誤!" 'Exit Sub
        End If
        '取出檔案名稱
        sMyFileName = Split(File1.PostedFile.FileName, "\")((Split(File1.PostedFile.FileName, "\")).Length - 1)
        If sMyFileName = "" Then
            Return "檔案名稱錯誤!" 'Exit Sub
        End If
        '取出檔案類型
        If sMyFileName.IndexOf(".") = -1 Then
            Return "檔案類型錯誤!" 'Exit Sub
        End If

        'Dim flag_is_xls As Boolean=TIMS.CHK_FILETYPE(sMyFileName, "xls")
        'Dim flag_is_ods As Boolean=TIMS.CHK_FILETYPE(sMyFileName, "ods")
        flag_File1_xls = TIMS.CHK_FILETYPE(sMyFileName, "xls")
        flag_File1_ods = TIMS.CHK_FILETYPE(sMyFileName, "ods")
        Dim bln_NG1 As Boolean = If(Not flag_File1_xls, True, False)
        Dim bln_NG2 As Boolean = If(Not flag_File1_ods, True, False)

        If bln_NG1 AndAlso bln_NG2 Then
            Return "檔案類型錯誤，必須為xls或ods檔案類型!" 'Exit Sub
        End If
        '檢查檔案格式與大小----------   End
        Return ""
    End Function

