    '產業人才投資方案依照規則，產生學員編號 2008/7/11 AMU-shell
    Public Shared Function Get_TPlanID28_StudentID(Years As String, DistID As String, OrgKind As String, IsBusiness As String, ClassID As String,
                                                   CyclType As String, ClassCate As String, TMID As String, tConn As SqlConnection) As String

        Dim STR As String = ""
        If Years = "" OrElse Not IsNumeric1(Years) Then
            STR = Nothing '異常
            Return STR
        End If
        Select Case Years
            Case "08"
                STR += "a"
            Case "09"
                STR += "b"
            Case "10"
                STR += "c"
            Case Else
                STR += Right(Years, 1)
        End Select

        If DistID = "" Then
            STR = Nothing '異常
            Return STR
        End If
        Select Case DistID
            Case "001"
                STR += "1"
            Case "003"
                STR += "2"
            Case "004"
                STR += "3"
            Case "005"
                STR += "4"
            Case "006"
                STR += "5"
            Case Else
                STR += "9" '其它一律為9
        End Select

        STR += Get_OrgKind_A(OrgKind, tConn)

        '企業包班為1 '其它一律為0
        STR += If(IsBusiness = "Y", "1", "0")

        STR += ClassID

        If CyclType <> "" AndAlso IsNumeric(CyclType) Then
            If CStr(CInt(CyclType)).Length = 1 Then
                STR += CStr(CInt(CyclType)) '只留1位
            Else
                STR += Right(CStr(CInt(CyclType)), 1) '只留1位
            End If
        Else
            STR += "1" '無值一律為1
        End If

        '課程類別檔／訓練職能(產學訓)
        Select Case ClassCate
            Case "01"
                STR += "1"
            Case "02"
                STR += "6"
            Case "03"
                STR += "2"
            Case "04"
                STR += "3"
            Case "05"
                STR += "4"
            Case "06"
                STR += "5"
            Case Else
                STR = Nothing '異常
                Return STR
        End Select

        If TMID = "" Then
            '無TMID清空
            STR = Nothing '異常
            Return STR
        End If
        Dim TMID_A As String = Get_TMID_A(TMID, tConn)
        STR += TMID_A

        Return STR
    End Function

    '取得OCID 限定的各欄位資料
    Public Shared Function GET_OCIDInfo(ByVal OCID As String, ByVal field As String, ByRef oConn As SqlConnection) As String
        Dim rst As String = ""
        If OCID = "" Then Return rst

        Dim pms1 As New Hashtable From {{"OCID", OCID}}
        Dim sql As String = ""
        sql &= " SELECT a.TMID ,dbo.FN_GET_CLASSCNAME(a.CLASSCNAME,a.CYCLTYPE) CLASSCNAME" & vbCrLf
        sql &= " ,CONVERT(varchar, a.STDATE, 111) STDATE" & vbCrLf
        sql &= " ,CONVERT(varchar, a.FTDATE, 111) FTDATE" & vbCrLf
        sql &= " ,CASE when b.JobID is null then b.TrainID else b.JobID end TrainID" & vbCrLf
        sql &= " ,CASE when b.JobID is null then b.trainName else b.JobName end TrainName" & vbCrLf
        sql &= " ,ISNULL(c.STUDCOUNT,0) STUDCOUNT" & vbCrLf
        sql &= " ,ISNULL(c.STUDCOUNT2,0) STUDCOUNT2" & vbCrLf
        sql &= " ,e.OrgName" & vbCrLf
        sql &= " FROM CLASS_CLASSINFO a" & vbCrLf
        sql &= " JOIN Key_TrainType b on a.TMID=b.TMID" & vbCrLf
        sql &= " JOIN Auth_Relship d on a.RID=d.RID" & vbCrLf
        sql &= " JOIN Org_OrgInfo e on e.OrgID=d.OrgID" & vbCrLf
        sql &= " LEFT JOIN (SELECT OCID ,COUNT(1) STUDCOUNT" & vbCrLf
        sql &= " ,COUNT(CASE WHEN STUDSTATUS IN (2,3) THEN 1 END) STUDCOUNT2" & vbCrLf
        sql &= "  FROM dbo.CLASS_STUDENTSOFCLASS WITH(NOLOCK)" & vbCrLf
        sql &= "  WHERE OCID=@OCID GROUP BY OCID) c on a.OCID=c.OCID" & vbCrLf
        sql &= " WHERE a.OCID=@OCID" & vbCrLf
        Dim dr As DataRow = DbAccess.GetOneRow(sql, oConn, pms1)
        If dr Is Nothing Then Return rst

        Select Case UCase(field)
            Case "STUDCOUNT"
                rst = Convert.ToString(dr("STUDCOUNT"))
            Case "STUDCOUNT2"
                rst = Convert.ToString(dr("STUDCOUNT2"))
            Case "TMID1" '.ToUpper
                rst = String.Concat("[", dr("TrainID"), "]", dr("TrainName"))
            Case "TMIDVALUE1" '.ToUpper
                rst = Convert.ToString(dr("TMID"))
            Case "OCID1" '.ToUpper
                rst = Convert.ToString(dr("ClassCName"))
            Case "OCIDVALUE" '.ToUpper
                rst = Convert.ToString(dr("OCID"))
            Case "SDATE" '.ToUpper
                rst = Convert.ToString(dr("STDate"))
            Case "FDATE" '.ToUpper
                rst = Convert.ToString(dr("FTDate"))
        End Select

        Return rst
    End Function

    ''' <summary> 補助金-資料使用 </summary>
    ''' <param name="tConn"></param>
    ''' <param name="dt"></param>
    ''' <param name="IDNO"></param>
    ''' <param name="SOCID"></param>
    ''' <param name="AppliedStatusM"></param>
    Public Shared Sub Utl_SUBSIDYCOSTdt(ByRef tConn As SqlConnection, ByRef dt As DataTable, ByRef IDNO As String, ByRef SOCID As String, ByRef AppliedStatusM As String)
        'OpenDbConn(tConn)
        'Dim dt As New DataTable
        dt = New DataTable

        Dim sql As String = ""
        sql &= " SELECT e.OrgName" & vbCrLf
        sql &= " ,dbo.FN_GET_CLASSCNAME(d.CLASSCNAME,d.CYCLTYPE) CLASSCNAME" & vbCrLf
        sql &= " ,format(d.STDate,'yyyy/MM/dd') STDate"
        sql &= " ,format(d.FTDate,'yyyy/MM/dd') FTDate"
        sql &= " ,a.SumOfMoney" & vbCrLf
        sql &= " ,a.AppliedStatus" & vbCrLf
        sql &= " ,a.AppliedStatusM" & vbCrLf '主要審核資訊
        sql &= " FROM STUD_SUBSIDYCOST a WITH(NOLOCK)" & vbCrLf
        sql &= " JOIN CLASS_STUDENTSOFCLASS b WITH(NOLOCK) ON a.SOCID=b.SOCID" & vbCrLf
        sql &= " JOIN STUD_STUDENTINFO c WITH(NOLOCK) ON b.SID=c.SID AND c.IDNO='" & IDNO & "'" & vbCrLf
        sql &= " JOIN CLASS_CLASSINFO d WITH(NOLOCK) ON b.OCID=d.OCID" & vbCrLf
        sql &= " JOIN VIEW_RIDNAME e ON d.RID=e.RID" & vbCrLf
        sql &= " JOIN VIEW_PLAN ip ON ip.PLANID=d.PLANID" & vbCrLf
        '因為系統分家，所以要限定產投可使用的計畫，計算金額
        sql &= " WHERE ip.TPlanID IN (" & Cst_TPlanID28_1a & ")" & vbCrLf
        '排除再出發計算-公務(ECFA)
        sql &= " AND ISNULL(a.BudID,' ')!='04'" & vbCrLf
        Select Case UCase(AppliedStatusM)
            Case cst_YES
                '過濾字眼為 通過要計算的條件
                sql &= " and (a.AppliedStatus='1' OR a.AppliedStatusM='Y')"
            Case cst_NO
                '過濾字眼為 尚未通過的條件
                sql &= " and ISNULL(a.AppliedStatusM,'R')='R'"
        End Select
        If SOCID <> "" Then
            sql &= " AND a.SOCID NOT IN (" & SOCID & ")" & vbCrLf
        End If

        Dim sCmd As New SqlCommand(sql, tConn)
        With sCmd
            .Parameters.Clear()
            dt.Load(.ExecuteReader())
        End With
        'Return dt
    End Sub

