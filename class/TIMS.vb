    ''' <summary>實際參訓時數 </summary>
    ''' <param name="OCID1"></param>
    ''' <param name="objconn"></param>
    ''' <returns></returns>
    Public Shared Function Get_STUDINFOdt(ByVal OCID1 As String, ByVal objconn As SqlConnection) As DataTable
        Dim rDt As New DataTable
        OCID1 = ClearSQM(OCID1)
        If OCID1 = "" Then Return rDt

        Call OpenDbConn(objconn)

        'TURNOUT 1.【實際參訓時數】= 本班課程【總訓練時數】 -  出缺勤紀錄各假別 (除了未打卡) 的請假時數加總(圖一)，
        '新增時由系統自動計算帶入， 以節省人工計算時間，
        'User可自行修改， 儲存後再次進來不會再被系統覆蓋(系統自動計算)。

        Dim sql As String = ""
        sql &= " SELECT ss.IDNO,ss.NAME, cs.SOCID,cs.STUDSTATUS" & vbCrLf
        sql &= " ,CC.THOURS-dbo.FN_GET_TURNOUT3(cs.SOCID) TURNOUT" & vbCrLf
        sql &= " FROM CLASS_CLASSINFO cc" & vbCrLf
        sql &= " JOIN CLASS_STUDENTSOFCLASS cs ON cs.OCID=cc.OCID" & vbCrLf
        sql &= " JOIN STUD_STUDENTINFO ss on ss.SID=cs.SID" & vbCrLf
        sql &= " WHERE cc.OCID=@OCID1" & vbCrLf
        Dim oCmd As New SqlCommand(sql, objconn)
        With oCmd
            .Parameters.Clear()
            .Parameters.Add("OCID1", SqlDbType.Int).Value = CINT1(OCID1)
            rDt.Load(.ExecuteReader())
        End With
        Return rDt
    End Function

