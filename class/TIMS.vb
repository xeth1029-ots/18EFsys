    'output@date_object / Convert.DBNull
    '傳入字串、日期,空值返回 Convert.DBNull 若傳入fmt則為文字格式輸出 (通常dr/cmd儲存使用。不出錯)
    ''' <summary>output:日期字串obj (dr儲存用)</summary>
    ''' <param name="o_str"></param>
    ''' <param name="fmt"></param>
    ''' <returns></returns>
    ''' <remarks></remarks>
    Public Shared Function Cdate2(ByVal o_str As Object, Optional fmt As String = "") As Object
        Dim rst As Object = Convert.DBNull '其他狀況輸出 db用Null
        If o_str Is Nothing OrElse Convert.IsDBNull(o_str) OrElse Convert.ToString(o_str) = "" OrElse Not IsDate(o_str) Then Return rst

        Dim dd As Date = CDate(o_str) '轉成日期物件
        If fmt = "" Then Return dd '日期物件輸出
        Return dd.ToString(fmt) '文字格式輸出
    End Function

    'str重整 output:日期字串str
    '傳入字串、日期,空值或錯誤則清空返回 若傳入fmt則為文字格式輸出(輸出、顯示、重整使用。不出錯)
    ''' <summary>output:日期字串str (顯示用) yyyy/MM/dd</summary>
    ''' <param name="strDate"></param>
    ''' <returns></returns>
    ''' <remarks></remarks>
    Public Shared Function Cdate3(ByVal strDate As String) As String
        Dim rst As String = "" '其他狀況輸出 字串轉字串 標準化。
        If strDate <> "" Then strDate = Trim(strDate) '文字清除空白
        '異常不輸出。yy/M/d ／ '異常不輸出。 yyyy/MM/dd tt HH:mm:ss
        If strDate = "" OrElse Len(strDate) < 6 OrElse Len(strDate) > 24 Then Return ""

        '可能異常字串
        If strDate.IndexOf("'") > -1 Then Return rst '異常不輸出。
        If strDate.IndexOf(",") > -1 Then Return rst '異常不輸出。
        If strDate.IndexOf("_") > -1 Then Return rst '異常不輸出。
        If strDate.IndexOf("$") > -1 Then Return rst '異常不輸出。
        If strDate.IndexOf("(") > -1 Then Return rst '異常不輸出。
        If strDate.IndexOf(")") > -1 Then Return rst '異常不輸出。
        If strDate.IndexOf("~") > -1 Then Return rst '異常不輸出。
        If strDate.IndexOf("!") > -1 Then Return rst '異常不輸出。
        If strDate.IndexOf("%") > -1 Then Return rst '異常不輸出。
        If strDate.IndexOf("^") > -1 Then Return rst '異常不輸出。
        If strDate.IndexOf("&") > -1 Then Return rst '異常不輸出。
        If strDate.IndexOf("*") > -1 Then Return rst '異常不輸出。
        If strDate.IndexOf("{") > -1 Then Return rst '異常不輸出。
        If strDate.IndexOf("}") > -1 Then Return rst '異常不輸出。
        If strDate.IndexOf("[") > -1 Then Return rst '異常不輸出。
        If strDate.IndexOf("]") > -1 Then Return rst '異常不輸出。
        If strDate.IndexOf("\") > -1 Then Return rst '異常不輸出。
        If strDate.IndexOf("""") > -1 Then Return rst '異常不輸出。
        If strDate.IndexOf(";") > -1 Then Return rst '異常不輸出。
        If Not IsDate(strDate) Then Return rst

        rst = CDate(strDate).ToString("yyyy/MM/dd") '轉成日期字串
        rst = If(Not IsDate1(rst), Cdate18(rst), rst) '(可能為民國年)試著轉換為西元年(月日)
        Return rst
    End Function

