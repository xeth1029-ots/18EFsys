    ''' <summary>
    ''' 取出鍵詞-預算別
    ''' </summary>
    ''' <param name="obj"></param>
    ''' <param name="isType"></param>
    ''' <param name="tConn"></param>
    ''' <returns></returns>
    Public Shared Function Get_Budget(ByRef obj As ListControl, ByVal isType As Integer, ByVal tConn As SqlConnection) As ListControl
        '1:預設
        '2:含 (全部) 不補助, ECFA(協助) 產投預算別
        '22:含 (02:就安/03:就保/97:公務(ECFA)) 產投預算別
        '23:含 (02:就安/03:就保/97:公務(ECFA)) 產投預算別
        '23:含 (02:就安/03:就保/97:公務(ECFA)) 產投預算別
        '3:含 (全部) 特別預算 '統計用預算別(全部顯示)
        '主要特定對象統計表/各分署各項計畫訓練人數
        '33:含 (全部) 特別預算 '統計用預算別(全部顯示)-預算來源，增加"無"的勾選項目
        '4:含 (只有)@ECFA(協助)
        '29: 在職進修訓練(自辦)/區域產業據點計畫
        Dim sql As String = ""
        'sql="SELECT * FROM Key_Budget WHERE BudID<>'01'"
        Select Case isType
            Case 4
                sql = " SELECT BUDID, BUDNAME FROM VIEW_BUDGET WHERE BUDID='97' ORDER BY BUDID" & vbCrLf
            Case 2
                'sql=" SELECT BUDID, dbo.DECODE(BUDID,'97','協助',BUDNAME) BUDNAME FROM VIEW_BUDGET WHERE BUDID IN ('01','02','03','04','97','99') ORDER BY BUDID" & vbCrLf
                sql = " SELECT BUDID, BUDNAME FROM VIEW_BUDGET WHERE BUDID IN ('01','02','03','04','97','99') ORDER BY BUDID" & vbCrLf
            Case 22, 23
                sql = " SELECT BUDID, BUDNAME FROM VIEW_BUDGET WHERE BUDID IN ('02','03','97') ORDER BY BUDID" & vbCrLf
            Case 29 '在職進修訓練(自辦)/區域產業據點計畫
                sql = " SELECT BUDID, BUDNAME FROM VIEW_BUDGET WHERE BUDID IN ('02','03','99') ORDER BY BUDID" & vbCrLf
            Case 3
                'BUDID IN ('01','02','03','04','97','98','99') 'sql="SELECT BUDID, BUDNAME FROM VIEW_BUDGET ORDER BY BUDID" '20191125
                sql = " SELECT BUDID, BUDNAME FROM VIEW_BUDGET WHERE BUDID IN ('01','02','03','97','99') ORDER BY BUDID"
            Case 33 '-預算來源，增加"無"的勾選項目
                'BUDID IN ('01','02','03','04','97','98','99')
                sql = " SELECT BUDID, BUDNAME FROM VIEW_BUDGET ORDER BY BUDID" & vbCrLf
            Case 38
                '預算別 BUDID IN ('02','03') '01公務/02  就安 / 03  就保
                sql = " SELECT BUDID, BUDNAME FROM VIEW_BUDGET WHERE BUDID IN ('01','02','03') ORDER BY BUDID" & vbCrLf
            Case 39
                '預算別 BUDID IN ('02','03') '02  就安 / 03  就保
                sql = " SELECT BUDID, BUDNAME FROM VIEW_BUDGET WHERE BUDID IN ('02','03') ORDER BY BUDID" & vbCrLf
            Case 37
                '02  就安  '預算別 BUDID IN ('02')
                sql = " SELECT BUDID, BUDNAME FROM VIEW_BUDGET WHERE BUDID IN ('02') ORDER BY BUDID" & vbCrLf
            Case Else
                'KEY_BUDGET
                sql = " SELECT BUDID, BUDNAME FROM dbo.KEY_BUDGET ORDER BY BUDID "
        End Select
        'Const cst_Budget_不補助 As String="不補助"
        'Const cst_Budget_不補助id As String="99"
        'Const cst_Budget_協助 As String="公務(ECFA)" '"協助"
        'Const cst_Budget_協助id As String="97" '"協助"
        'Const cst_Budget_特別預算 As String="特別預算"
        'Const cst_Budget_特別預算id As String="98"
        Const cst_Budget_無 As String = "無"
        Const cst_Budget_無id As String = "-1"
        Dim dt As DataTable = DbAccess.GetDataTable(sql, tConn)
        With obj
            .DataSource = dt
            .DataTextField = "BUDNAME"
            .DataValueField = "BUDID"
            .DataBind()
            If TypeOf obj Is DropDownList Then .Items.Insert(0, New ListItem(cst_ddl_PleaseChoose3, ""))
            Select Case isType
                Case 2 '(含 不補助 ECFA協助)
                    '.Items.Add(New ListItem(cst_Budget_協助, cst_Budget_協助id)) ' ECFA(協助)
                    '.Items.Add(New ListItem(cst_Budget_不補助, cst_Budget_不補助id))
                Case 22 '(含 不補助 ECFA協助)
                    .Items.Insert(0, New ListItem("不拘", cst_Budget_不拘id))
                Case 23
                    .Items.Insert(0, New ListItem("全部", ""))
                Case 3 '(含 特別預算 不補助 ECFA協助)
                    '.Items.Add(New ListItem(cst_Budget_協助, cst_Budget_協助id)) ' ECFA(協助)
                    '.Items.Add(New ListItem(cst_Budget_特別預算, cst_Budget_特別預算id))
                    '.Items.Add(New ListItem(cst_Budget_不補助, cst_Budget_不補助id))
                Case 33 '-預算來源，增加"無"的勾選項目
                    .Items.Add(New ListItem(cst_Budget_無, cst_Budget_無id))
            End Select
        End With
        Return obj
    End Function

