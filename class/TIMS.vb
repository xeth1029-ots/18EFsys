    '取得使用者輸入性別，並與身份証判斷是否正確
    Public Shared Function CheckMemberSex(ByVal IDNO As String, ByVal tmpSex As String) As Boolean
        Dim flag As Boolean = False
        If IDNO.Length > 1 Then
            Select Case IDNO.Substring(1, 1)
                Case "1", "A", "C", "8" '男@M
                    If tmpSex = "M" Then flag = True
                Case "2", "B", "D", "9" '女@F
                    If tmpSex = "F" Then flag = True
            End Select
        End If
        Return flag
    End Function

    ''' <summary> 檢查身分證號碼(中華民國) </summary>
    ''' <param name="IDNO"></param>
    ''' <returns></returns>
    Public Shared Function CheckIDNO(ByVal IDNO As String) As Boolean
        Dim ErrString As String = ""
        '非10個字元的身分號則退出檢驗
        If IDNO = "" OrElse IDNO.Length <> 10 Then Return False
        '將字串換成大寫
        If (IDNO <> IDNO.ToUpper) Then IDNO = IDNO.ToUpper

        Dim IDdigit As New ArrayList
        For i As Integer = 0 To 9
            IDdigit.Add(IDNO.Chars(i))
        Next

        Dim CharEng As String = "ABCDEFGHIJKLMNOPQRSTUVWXYZ"
        IDdigit(0) = CharEng.IndexOf(IDNO.Chars(0))
        '檢查第一個字是否為英文字
        If CharEng.IndexOf(IDNO.Chars(0)) = -1 Then Return False
        '檢查第二個字元是否為1或2
        If (IDNO.Chars(1) <> "1" AndAlso IDNO.Chars(1) <> "2") Then Return False

        Dim iWeight As Integer() = {1, 10, 19, 28, 37, 46, 55, 64, 39, 73, 82, 2, 11, 20, 48, 29, 38, 47, 56, 65, 74, 83, 21, 3, 12, 30}
        Dim Array1 As New ArrayList
        For i2 As Integer = 0 To iWeight.Length - 1
            Array1.Add(iWeight(i2))
        Next

        Dim result As String = Array1(IDdigit(0))
        For i As Integer = 1 To 9
            Dim Number As String = "0123456789"
            IDdigit(i) = Number.IndexOf(IDdigit(i))
            If IDdigit(i) = -1 Then Return False
            result += IDdigit(i) * (9 - i)
        Next
        result += 1 * IDdigit(9)
        If result Mod 10 <> 0 Then Return False
        Return True 'OK
    End Function

    ''' <summary>
    ''' 檢查身分證號碼/居留證號碼
    ''' </summary>
    ''' <param name="strIDNO">身分證號</param>
    ''' <param name="iKind">0:自動 1:國民身分證 2:居留證 3:護照號(暫無規則)長度應小於20(護照號碼正確) 4:居留證2(外來人口統一證號) 8: 居留證2/4 </param>
    ''' <returns></returns>
    Public Shared Function CheckIDNO2(ByVal strIDNO As String, ByVal iKind As Integer) As Boolean
        'http://www.blueshop.com.tw/board/FUM20041006152641OLG/BRD20050527171815HPF.html
        'http://www.blueshop.com.tw/board/show.asp?subcde=BRD20050527171815HPF
        Dim CharEng As String = "ABCDEFGHJKLMNPQRSTUVXYWZIO"
        Dim CharNumber As String = "0123456789"
        'Optional ByVal Kind As String="0"

        Dim rst As Boolean = False 'True: 驗証成功、False:驗証有誤 
        'Kind: 0:自動 1:國民身分證 2:居留證 3:護照號(暫無規則)長度應小於20(護照號碼正確)

        strIDNO = strIDNO.ToUpper
        Select Case iKind
            Case 0 '0:自動
                If strIDNO.Length >= 10 Then
                    Select Case Convert.ToString(strIDNO).Substring(1, 1)
                        Case "1", "2"
                            '國內身分證號
                            'If Not CheckIDNO(strIDNO) Then
                            '    rst &= "身分證號碼有誤(第2碼為 1、2 依國民身分證規則判斷)!!" & vbCrLf
                            'End If
                            rst = CheckIDNO(strIDNO)
                        Case "A", "C", "B", "D"
                            '居留證號碼
                            'rst += "居留號碼有誤(第2碼為 A、C、B、D 依國民居留號碼規則判斷)!!" & vbCrLf
                            rst = CheckIDNO2(strIDNO, 2)
                        Case "8", "9"
                            '4:居留證2(外來人口統一證號) 新式外來人口統一證號/居留證2021
                            rst = CheckIDNO2(strIDNO, 4)
                        Case Else
                            'rst += "身分證號碼或居留證號碼有誤，第2碼，應為(1.2或A.C.B.D或8.9)"
                            'rst=False
                    End Select
                End If
            Case 1 '1:國民身分證
                rst = CheckIDNO(strIDNO)

            Case 2 '2:居留證 (舊)
                If strIDNO.Length < 10 Then Exit Select
                If CharEng.IndexOf(strIDNO.Chars(0)) = -1 OrElse CharEng.IndexOf(strIDNO.Chars(1)) = -1 Then Exit Select
                For i As Integer = 0 + 2 To 10 - 1
                    If CharNumber.IndexOf(strIDNO.Chars(i)) = -1 Then Exit Select
                Next
                Dim intS As Integer = 0
                Dim strID As String = ""
                strID = ""
                strID &= Convert.ToString(CharEng.IndexOf(strIDNO.Chars(0)) + 10)
                strID &= Convert.ToString((CharEng.IndexOf(strIDNO.Chars(1)) + 10) Mod 10)
                For i As Integer = 0 + 2 To 10 - 1
                    strID &= Convert.ToString(strIDNO.Chars(i))
                Next
                intS += CInt(strID.Chars(0).ToString)
                intS += CInt(strID.Chars(1).ToString) * 9
                intS += CInt(strID.Chars(2).ToString) * 8
                intS += CInt(strID.Chars(3).ToString) * 7
                intS += CInt(strID.Chars(4).ToString) * 6
                intS += CInt(strID.Chars(5).ToString) * 5
                intS += CInt(strID.Chars(6).ToString) * 4
                intS += CInt(strID.Chars(7).ToString) * 3
                intS += CInt(strID.Chars(8).ToString) * 2
                intS += CInt(strID.Chars(9).ToString) * 1
                intS += CInt(strID.Chars(10).ToString) '(檢查碼)
                '居留證號碼正確
                If ((intS Mod 10) = 0) Then rst = True

            Case 3 '3:護照號
                '長度應小於20(護照號碼正確)
                If strIDNO.Length <= 20 AndAlso strIDNO.Length >= 9 Then rst = True

            Case 4 '4:居留證2(外來人口統一證號)／新式統一證號 
                If strIDNO.Length < 10 Then Exit Select
                If CharEng.IndexOf(strIDNO.Chars(0)) = -1 Then Exit Select
                For i As Integer = 0 + 1 To 10 - 1
                    If CharNumber.IndexOf(strIDNO.Chars(i)) = -1 Then Exit Select
                Next
                Dim strID As String = ""
                strID &= Convert.ToString(CharEng.IndexOf(strIDNO.Chars(0)) + 10)
                For i As Integer = 1 To (10 - 1)
                    strID &= Convert.ToString(strIDNO.Chars(i))
                Next

                Dim intS As Integer = 0
                intS += CInt(strID.Chars(0).ToString)
                intS += CInt(strID.Chars(1).ToString) * 9
                intS += CInt(strID.Chars(2).ToString) * 8
                intS += CInt(strID.Chars(3).ToString) * 7
                intS += CInt(strID.Chars(4).ToString) * 6
                intS += CInt(strID.Chars(5).ToString) * 5
                intS += CInt(strID.Chars(6).ToString) * 4
                intS += CInt(strID.Chars(7).ToString) * 3
                intS += CInt(strID.Chars(8).ToString) * 2
                intS += CInt(strID.Chars(9).ToString) * 1
                intS += CInt(strID.Chars(10).ToString) '(檢查碼)
                '居留證號碼正確
                If ((intS Mod 10) = 0) Then rst = True

            Case 8 '8:'居留證號碼 (新／舊)
                If strIDNO.Length >= 10 Then
                    Select Case Convert.ToString(strIDNO).Substring(1, 1)
                        Case "A", "C", "B", "D"
                            '居留證號碼
                            'rst += "居留號碼有誤(第2碼為 A、C、B、D 依國民居留號碼規則判斷)!!" & vbCrLf
                            rst = CheckIDNO2(strIDNO, 2)
                        Case "8", "9"
                            '4:居留證2(外來人口統一證號)／新式統一證號 
                            rst = CheckIDNO2(strIDNO, 4)
                    End Select
                End If

        End Select

        Return rst
    End Function

