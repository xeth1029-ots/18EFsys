        ' 返回最終生成的報告字串
        reportBuilder.AppendLine($"{DateTime.Now.ToString()}")
        Return reportBuilder.ToString()
    End Function

    ''' <summary>
    '''  計算你提供的目錄  下所有檔案（不包含子目錄，如果你需要包含，請調整 GetFiles 參數）的數量和總大小
    ''' </summary>
    ''' <param name="iRPT"></param>
    ''' <returns></returns>
    Public Shared Function GenerateFileReportX(iRPT As Integer) As String
        Const CST_Template_path2 As String = "\\isilontc.ejob.gov.tw\ojt\upojt1"
        Dim str_Template_path2_EXCLUDE As String = $"{CST_Template_path2}\Template"
        Const CST_Template_path3 As String = "\\isilontc.ejob.gov.tw\ojt"
        Const CST_Template_path4 As String = "H:\SVN\WDAIIP" '"H:\SVN\WDAIIP\branch\SYS.Net\WDAIIP.Net" '"C:\"
        Dim str_Template_path4_EXCLUDE As String = $"{CST_Template_path4}\branch"

        ' 設定要查詢的目錄路徑
        Dim fg_EXCLUDE As Boolean = False
        Dim targetDirectory As String = CST_Template_path2 '2,22
        Dim EXCLUDE_DIRECT_PATH As String = str_Template_path2_EXCLUDE
        If iRPT = 2 Then
            targetDirectory = CST_Template_path2
        ElseIf iRPT = 3 Then
            targetDirectory = CST_Template_path3
        ElseIf iRPT = 4 Then
            targetDirectory = CST_Template_path4
        ElseIf iRPT = 44 Then
            targetDirectory = CST_Template_path4
            EXCLUDE_DIRECT_PATH = str_Template_path4_EXCLUDE
        End If
        If iRPT = 22 OrElse iRPT = 44 Then fg_EXCLUDE = True
        ' 建立一個 StringBuilder 來建構報告內容
        Dim reportBuilder As New StringBuilder()
        reportBuilder.AppendLine($"{DateTime.Now.ToString()}")
        Dim fileCount As Long = 0
        Dim totalSize As Long = 0 ' 使用 Long 來存放總大小，避免溢位
        Dim fileCountE As Long = 0 '已排除目錄
        Dim totalSizeE As Long = 0 '已排除目錄
        Try
            If fg_EXCLUDE Then
                ' 1. 取得根目錄及所有子資料夾中的所有檔案路徑 ,使用 Directory.EnumerateFiles 比 GetFiles 更有效率，尤其是在處理大量檔案時
                Dim allFiles As IEnumerable(Of String) = Directory.EnumerateFiles(targetDirectory, "*.*", SearchOption.AllDirectories)
                ' 2. 使用 LINQ 進行篩選和計算 ' Where 函式：篩選掉路徑以 EXCLUDE 開頭的檔案 ' 確保比較時不區分大小寫
                Dim filteredFiles As IEnumerable(Of String) = allFiles.Where(Function(f) Not f.ToLower().StartsWith(EXCLUDE_DIRECT_PATH.ToLower()))
                ' 3. 遍歷篩選後的檔案列表，計算數量和總大小
                For Each filePath As String In filteredFiles
                    Dim fileInfo As New FileInfo(filePath)
                    ' 計算檔案數量
                    fileCount += 1
                    ' 累加檔案大小
                    totalSize += fileInfo.Length
                Next
                reportBuilder.AppendLine("-------------------------------")
                reportBuilder.AppendLine($"🚫 已排除目錄：{EXCLUDE_DIRECT_PATH}")
                ' 建立 DirectoryInfo 物件
                Dim dirInfoE As New DirectoryInfo(EXCLUDE_DIRECT_PATH)
                ' 檢查目錄是否存在
                If Not dirInfoE.Exists Then
                    reportBuilder.Append($"錯誤：已排除目錄不存在或無法存取：{targetDirectory}")
                    'Return reportBuilder.ToString() ' 返回
                Else
                    'Dim files As FileInfo() = dirInfo.GetFiles("*.*", SearchOption.TopDirectoryOnly)'不包含子目錄
                    ' 取得目錄下所有檔案 (不包含子目錄，如果要包含，請使用 SearchOption.AllDirectories)
                    Dim filesE As FileInfo() = dirInfoE.GetFiles("*.*", SearchOption.AllDirectories)
                    fileCountE = filesE.Length
                    ' 計算總資料大小
                    For Each file2 As FileInfo In filesE
                        totalSizeE += file2.Length
                    Next
                    ' 輸出結果
                    reportBuilder.AppendLine($"✅ 檔案總數量：{fileCountE:N0}")
                    reportBuilder.AppendLine($"💾 檔案總大小 (Bytes)：{totalSizeE:N0}") ' 輸出帶千分位的 Bytes 數
                    reportBuilder.AppendLine($"📏 檔案總大小 (可讀單位)：{FormatBytes(totalSizeE)}") ' 輸出可讀單位 (KB, MB, GB)
                End If
                reportBuilder.AppendLine("-------------------------------")
            Else
                ' 建立 DirectoryInfo 物件
                Dim dirInfo As New DirectoryInfo(targetDirectory)
                ' 檢查目錄是否存在
                If Not dirInfo.Exists Then
                    reportBuilder.Append($"錯誤：目錄不存在或無法存取：{targetDirectory}")
                    Return reportBuilder.ToString() ' 返回
                End If
                'Dim files As FileInfo() = dirInfo.GetFiles("*.*", SearchOption.TopDirectoryOnly)'不包含子目錄
                ' 取得目錄下所有檔案 (不包含子目錄，如果要包含，請使用 SearchOption.AllDirectories)
                Dim files As FileInfo() = dirInfo.GetFiles("*.*", SearchOption.AllDirectories)
                fileCount = files.Length
                ' 計算總資料大小
                For Each file As FileInfo In files
                    totalSize += file.Length
                Next
            End If

            ' 輸出結果
            reportBuilder.AppendLine("-------------------------------")
            reportBuilder.AppendLine($"🔍 目錄：{targetDirectory}")
            reportBuilder.AppendLine($"✅ 檔案總數量：{fileCount:N0}")
            reportBuilder.AppendLine($"💾 檔案總大小 (Bytes)：{totalSize:N0}") ' 輸出帶千分位的 Bytes 數
            reportBuilder.AppendLine($"📏 檔案總大小 (可讀單位)：{FormatBytes(totalSize)}") ' 輸出可讀單位 (KB, MB, GB)
        Catch ex As Exception
            reportBuilder.AppendLine("-------------------------------")
            reportBuilder.AppendLine($"🔍 目錄：{targetDirectory}")
            reportBuilder.AppendLine($"✅ 檔案總數量：{fileCount:N0}")
            reportBuilder.AppendLine($"💾 檔案總大小 (Bytes)：{totalSize:N0}") ' 輸出帶千分位的 Bytes 數
            reportBuilder.AppendLine($"📏 檔案總大小 (可讀單位)：{FormatBytes(totalSize)}") ' 輸出可讀單位 (KB, MB, GB)
            reportBuilder.AppendLine($"❌ 發生錯誤：{ex.Message}")
            reportBuilder.AppendLine("請檢查網路連線和權限是否足夠存取該網路路徑。")
        End Try
        ' 返回最終生成的報告字串
        reportBuilder.AppendLine("-------------------------------")
        reportBuilder.AppendLine($"{DateTime.Now.ToString()}")
        Return reportBuilder.ToString()
    End Function

    ''' <summary>格式化位元組大小為可讀的單位 (KB, MB, GB)。</summary>
    ''' <param name="bytes">要格式化的位元組數。</param>
    ''' <returns>格式化後的字串。</returns>
    Public Shared Function FormatBytes(ByVal bytes As Long) As String
        Const KB As Double = 1024
        Const MB As Double = KB * 1024
        Const GB As Double = MB * 1024

        Select Case bytes
            Case Is >= GB
                Return $"{Math.Round(bytes / GB, 2)} GB"
            Case Is >= MB
                Return $"{Math.Round(bytes / MB, 2)} MB"
            Case Is >= KB
                Return $"{Math.Round(bytes / KB, 2)} KB"
            Case Else
                Return $"{bytes} Bytes"
        End Select
    End Function

    ''' <summary>字數檢核</summary>
