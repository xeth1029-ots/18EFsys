    'Get OLEDB ConnectionString
    Public Shared Function Get_OleDbStr(ByVal Fullfilename As String) As String
        'Microsoft.Jet.OLEDB.4.0和Microsoft.ACE.OLEDB.12.0的區別
        Dim strConn1 As String = String.Format("Provider=Microsoft.ACE.OLEDB.12.0;Data Source={0};Extended Properties=Excel 8.0;", Fullfilename)
        Dim strConn2 As String = String.Format("Provider=Microsoft.Jet.OleDb.4.0;Data Source={0};Extended Properties=Excel 8.0;", Fullfilename)
        Dim rstConn As String = ""
        Dim errMsg1 As String = ""
        Dim flagOK As Boolean = True

        Dim objLock1 As New Object
        SyncLock objLock1
            Using MyConn As New OleDb.OleDbConnection(strConn1)
                Try
                    'Dim MyConn As New OleDb.OleDbConnection(strConn1)
                    MyConn.Open()
                    MyConn.Close() ' MyConn=Nothing
                    rstConn = strConn1
                    errMsg1 = ""
                Catch ex As Exception
                    'LOG.Warn("#Get_OleDbStr:," & ex.Message, ex)
                    errMsg1 = String.Concat("#Get_OleDbStr,strConn1:", strConn1, vbCrLf, ex.Message)
                    LOG.Warn(errMsg1, ex)
                End Try
                If MyConn IsNot Nothing AndAlso MyConn.State = ConnectionState.Open Then MyConn.Close()
                'If MyConn IsNot Nothing Then MyConn.Dispose()
            End Using
            If rstConn <> "" AndAlso errMsg1 = "" Then Return rstConn

            Using MyConn2 As New OleDb.OleDbConnection(strConn2)
                Try
                    MyConn2.Open()
                    MyConn2.Close() ' MyConn2=Nothing
                    rstConn = strConn2
                    errMsg1 = ""
                Catch ex As Exception
                    'LOG.Warn("#Get_OleDbStr:," + ex.Message, ex)
                    errMsg1 = String.Concat("#Get_OleDbStr,strConn2:", strConn2, vbCrLf, ex.Message)
                    LOG.Warn(errMsg1, ex)
                End Try
                If MyConn2 IsNot Nothing AndAlso MyConn2.State = ConnectionState.Open Then MyConn2.Close()
                'If MyConn2 IsNot Nothing Then MyConn2.Dispose()
            End Using
            If errMsg1 <> "" Then LOG.Error(String.Concat("#Get_OleDbStr: errMsg1: ", errMsg1))
            If rstConn <> "" AndAlso errMsg1 = "" Then Return rstConn

        End SyncLock

        Return strConn1
    End Function

