    '取分列字串，用逗點串連
    Public Shared Function GetArrayStr(ByVal arystr As String, Optional ByVal SplitStr As String = "/") As String
        Dim str As String = ""
        If arystr <> "" Then
            Dim ary As String() = arystr.Split(SplitStr)
            For i As Integer = 0 To ary.Length - 1
                str &= String.Concat(If(str <> "", ",", ""), "'", ary(i), "'")
            Next
        End If
        Return str
    End Function

