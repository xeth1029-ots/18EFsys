    ''' <summary> '1:檢查是否有今天的資料--今天如果有資料，不再重新勾稽/沒有:執行一次勾稽-true:(今天有資料)/false:(今天沒資料) </summary>
    ''' <param name="oConn"></param>
    ''' <param name="v_OCID"></param>
    ''' <returns></returns>
    Public Shared Function CHK_TRAINCLASS_Today(ByRef oConn As SqlConnection, ByVal v_OCID As String) As Boolean
        Dim sql As String = ""
        sql = " SELECT 1 FROM ADP_TRAINCLASS WHERE OCID=@OCID AND MODIFYDATE>=CONVERT(DATE,GETDATE())" & vbCrLf '今天有資料
        Dim sCmd As New SqlCommand(sql, oConn)
        Dim dt As New DataTable
        With sCmd
            .Parameters.Clear()
            .Parameters.Add("OCID", SqlDbType.Int).Value = CINT1(v_OCID)
            dt.Load(.ExecuteReader())
        End With
        If dt.Rows.Count > 0 Then Return True 'true:(今天有資料)/false:(今天沒資料)
        Return False 'true:(今天有資料)/false:(今天沒資料)
    End Function

