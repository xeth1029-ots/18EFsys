    Public Shared Function Get_TDeadline(ByVal dSTDate As DateTime, ByVal dFTDate As DateTime) As String
        '小於30:01 / 大於90:03 其它:02
        Dim rst As String = "02"
        Dim iDay2 As Long = DateDiff(DateInterval.Day, dSTDate, dFTDate)
        If iDay2 <= 30 Then rst = "01"
        If iDay2 > 90 Then rst = "03"
        Return rst
    End Function

    Public Shared Function Number7_Add1(ByVal numStr As String) As String
        'Dim intNum As Integer=0
        If numStr <> "" Then
            If IsNumeric(numStr) Then
                numStr = CStr(CInt(numStr) + 1)
                Select Case numStr.Length
                    Case 1
                        numStr = "000000" & numStr
                    Case 2
                        numStr = "00000" & numStr
                    Case 3
                        numStr = "0000" & numStr
                    Case 4
                        numStr = "000" & numStr
                    Case 5
                        numStr = "00" & numStr
                    Case 6
                        numStr = "0" & numStr
                    Case 7
                        numStr = "" & numStr
                    Case Else
                        Throw New ArgumentException("數值型態過大錯誤,請洽系統管理者!!!")
                        'Common.MessageBox(Me, "數值型態過大錯誤,請洽系統管理者!!!")
                        'Exit Function
                End Select
            Else
                Throw New ArgumentException("非數值型態錯誤,請洽系統管理者!!!")
                'Common.MessageBox(Me, "非數值型態錯誤,請洽系統管理者!!!")
                'Exit Function
            End If
        End If
        'Number7_Add1=numStr
        Return numStr
    End Function

