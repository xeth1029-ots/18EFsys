    ''' <summary>(顯示用)民國日期(年月日)格式優化 轉西元年(yyyy/MM/dd)</summary>
    ''' <returns></returns>
    Public Shared Function Cdate7(ByVal strDate1 As String) As String
        Dim rst As String = ""
        strDate1 = ClearSQM(strDate1)
        If strDate1 = "" OrElse strDate1.Split("/").Length < 3 Then Return rst
        'If strDate1.Split("/").Length < 3 Then Return rst
        '(年度異常)
        If CINT1(strDate1.Split("/")(0)) < 1 OrElse CINT1(strDate1.Split("/")(0)) > 333 Then Return rst
        '(月份異常)
        If CINT1(strDate1.Split("/")(1)) < 1 OrElse CINT1(strDate1.Split("/")(1)) > 12 Then Return rst
        '(日期異常)
        If CINT1(strDate1.Split("/")(2)) < 1 OrElse CINT1(strDate1.Split("/")(2)) > 31 Then Return rst
        '(西元年處置) 轉為 民國日(yyyy/MM/dd)
        rst = Cdate17($"{CINT1(strDate1.Split("/")(0)) + 1911}{Mid(strDate1, strDate1.IndexOf("/") + 1)}")
        Return rst
    End Function

    ''' <summary>(顯示用)將日期 西元年月日(yyyy/MM/dd) 轉 民國年月日(yyy/MM/dd)</summary>
    ''' <param name="strDate1"></param>
    ''' <returns></returns>
    Public Shared Function Cdate17(ByVal strDate1 As String) As String
        Dim rst As String = ""
        If strDate1 = "" OrElse strDate1.Length < 8 OrElse Not IsDate(strDate1) Then Return rst
        Try
            If CDate(strDate1).Year > 1911 Then
                rst = $"{CDate(strDate1).Year - 1911}{CDate(strDate1).ToString("/MM/dd")}"
            Else
                rst = $"{CDate(strDate1).Year}{CDate(strDate1).ToString("/MM/dd")}"
            End If
        Catch ex As Exception
            Dim V_GUID As String = Guid.NewGuid().ToString()
            LOG.Warn(ex.Message, ex) '取得錯誤資訊寫入
            Dim strErrmsg As String = $"ex.Message:{ex.Message}[{V_GUID}]{vbCrLf}"
            WriteTraceLog(strErrmsg, ex)
        End Try
        Return rst
    End Function

    ''' <summary>顯示用-將日期 西元年月日(yyyy/MM/dd) 轉民國年月日(yyy/MM/dd)</summary>
    ''' <param name="oDate1"></param>
    ''' <returns></returns>
    Public Shared Function Cdate17(ByVal oDate1 As Object) As String
        Dim rst As String = ""
        If oDate1 Is Nothing OrElse Convert.IsDBNull(oDate1) OrElse $"{oDate1}" = "" Then Return rst
        rst = Cdate17($"{oDate1}")
        Return rst
    End Function

    ''' <summary>顯示用-將日期轉為民國年月日(yyyy/MM/dd)(yyy/MM/dd) (含時間hh24:mi:ss)</summary>
    ''' <param name="oDate1"></param>
    ''' <returns></returns>
    Public Shared Function Cdate17t1(ByVal oDate1 As Object) As String
        Dim rst As String = ""
        If oDate1 Is Nothing OrElse Convert.IsDBNull(oDate1) Then Return rst
        Dim Roc_ymd As String = Cdate17($"{oDate1}")
        Dim Hms As String = CDate(oDate1).ToString("tt hh:mm:ss")
