    '取出鍵詞-身分別代碼
    Public Shared Function Get_Identity(ByRef obj As ListControl, ByVal i_type As Integer, ByVal s_TPlanID As String, ByVal Years As String, ByRef tConn As SqlConnection) As ListControl
        'Optional ByVal TPlanID As String="", Optional ByVal Years As String=""
        'type:1 '結訓學員資料卡登錄(SD_05_008_D) '非署(局)屬
        'type:11 '結訓學員資料卡登錄(SD_05_008_D) '署(局)屬
        'type:2 '(全部)不排除
        'type:3 '(全部)不排除 排序 '開訓、離退訓、結訓人數統計表(CM_03_008)
        'type:4 '產投報名作業 使用(SD_01_010_add)
        '6 '66:主要特定對象統計表 '67:特定對象統計表
        '5: 依計畫設定 dbo.PLAN_IDENTITY WITH(NOLOCK)  '5, 52, 53
        Dim sql As String = ""
        Select Case i_type
            Case 1
                '結訓學員資料卡登錄(SD_05_008_D) '2009/07/01排除負擔家計婦女
                sql = " SELECT IDENTITYID, NAME FROM dbo.KEY_IDENTITY WITH(NOLOCK) WHERE IDENTITYID <> '03' ORDER BY IDENTITYID"

            Case 11 '201607 
                '局屬使用身分別 (SD_05_008_D) '結訓學員資料卡登錄(SD_05_008_D)
                sql = ""
                sql &= " SELECT IDENTITYID, NAME FROM dbo.KEY_IDENTITY WITH(NOLOCK)"
                sql &= $" WHERE IDENTITYID IN ({cst_Ident_SD05008D}) ORDER BY IDENTITYID"

            Case 2 '(全部)不排除 '鍵詞維護使用(SYS_04_002)
                sql = " SELECT IDENTITYID, NAME FROM dbo.KEY_IDENTITY WITH(NOLOCK) ORDER BY IDENTITYID"

            Case 3 '(全部)不排除 排序
                '鍵詞維護使用(SYS_04_002) '開訓、離退訓、結訓人數統計表(CM_03_008) 'CheckBoxList (全部並排序)
                sql = " SELECT IDENTITYID, NAME FROM dbo.KEY_IDENTITY WITH(NOLOCK) ORDER BY IDENTITYID"

            Case 31
                sql = " SELECT IDENTITYID, NAME FROM dbo.KEY_IDENTITY WITH(NOLOCK)"
                If Cst_TPlanID06.IndexOf(s_TPlanID) > -1 Then
                    sql &= $" WHERE IDENTITYID IN ({Cst_Identity06_2019_11})" & vbCrLf
                Else
                    sql &= $" WHERE IDENTITYID IN ({Cst_Identity28_2019_11})" & vbCrLf
                End If
                sql &= " ORDER BY IDENTITYID"

            Case 4
                '產投報名作業 使用(SD_01_010_add)
                sql = ""
                sql &= " SELECT IDENTITYID" & vbCrLf
                sql &= $" ,CASE WHEN IDENTITYID='02' THEN CONVERT(NVARCHAR(30),'{cst_ILTleaversC}') "
                sql &= "  ELSE NAME END NAME"
                'sql &= " ,dbo.DECODE(IdentityID,'02','" & cst_ILTleaversC & "',CONVERT(NVARCHAR(30), Name)) Name" & vbCrLf
                sql &= " FROM dbo.KEY_IDENTITY WITH(NOLOCK)" & vbCrLf 'sql &= " WHERE 1=1 "
                'sql &= " AND IDENTITYID IN  (" & cst_Identity28 & ")" & vbCrLf
                If Cst_TPlanID06.IndexOf(s_TPlanID) > -1 Then
                    sql &= $" WHERE IDENTITYID IN ({Cst_Identity06_2019_11})" & vbCrLf
                Else
                    sql &= $" WHERE IDENTITYID IN ({Cst_Identity28_2019_11})" & vbCrLf
                End If

            Case 5, 52, 53
                '依TPLANID顯示 '學員資料維護(SD_03_002_add) '排除身分別表單 Plan_Identity
                'SELECT * FROM KEY_Plan WHERE ROWNUM <=20 'SELECT * FROM Plan_Identity WHERE ROWNUM <=10
                Dim sql_PLANNOTIN As String = $"SELECT IDENTITYID FROM dbo.PLAN_IDENTITY WITH(NOLOCK) WHERE TPlanID='{s_TPlanID}' AND ISENABLED='N'"

                sql = ""
                sql &= " SELECT IDENTITYID" & vbCrLf
                If Cst_TPlanID28AppPlan.IndexOf(s_TPlanID) > -1 Then
                    sql &= $" ,CASE WHEN IDENTITYID='02' THEN CONVERT(NVARCHAR(30),'{cst_ILTleaversC}') ELSE NAME END NAME"
                Else
                    sql &= " ,NAME" & vbCrLf
                End If
                Select Case i_type
                    Case 52, 53
                        sql &= " ,NOSHOWMI" & vbCrLf 'sqlserver null會先排
                End Select

                sql &= " FROM dbo.KEY_IDENTITY WITH(NOLOCK)" & vbCrLf
                sql &= $" WHERE IDENTITYID NOT IN ({sql_PLANNOTIN})" & vbCrLf
                If i_type = 52 Then
                    '52: 主要參訓身分別(增加排除) ',11:農漁民,13:外籍配偶,14:大陸配偶,31:單一中華民國國籍之無戶籍國民,32:取得居留身分之泰國、緬甸、印度或尼泊爾地區無國籍人民,44:跨國(境)人口販運被害人，並取得工作許可者
                    'Const CST_NO_SHOW_ID52 As String="'11','13','14','31','32','44'"
                    sql &= " AND ISNULL(NOSHOWMI,'N')='N'" & vbCrLf
                End If

                If Years <> "" Then
                    sql &= $" AND (UNUSEDYEAR IS NULL OR UNUSEDYEAR > '{Years}')" & vbCrLf
                End If
                Select Case i_type
                    Case 52, 53
                        sql &= " ORDER BY NOSHOWMI,IDENTITYID" & vbCrLf 'sqlserver null會先排
                    Case Else
                        sql &= " ORDER BY IDENTITYID" & vbCrLf
                End Select

            Case 6
                sql = ""
                sql &= " SELECT IDENTITYID, NAME FROM dbo.KEY_IDENTITY WITH(NOLOCK)" & vbCrLf
                sql &= $" WHERE IDENTITYID IN ({cst_IdentityM1}) AND IDENTITYID NOT IN ('03') ORDER BY IDENTITYID" & vbCrLf

            Case 66 '主要特定對象統計表/各分署各項計畫訓練人數-身分別，增加"無"的勾選項目
                '首頁>>訓練與需求管理>>統計分析>>主要特定對象統計表
                'Const cst_IdentityM1 As String="'01','02','03','04','05','06','07','09','10','13','14','17','20','27','28','29','33','35','36'"
                'CM_03_007 (報表)(局統計)
                sql = ""
                sql &= " SELECT IDENTITYID, NAME FROM dbo.KEY_IDENTITY WITH(NOLOCK)" & vbCrLf
                '03"負擔家計婦女"併入28"獨立負擔家計者"計算,並把"負擔家計婦女"項目拿掉.35:新增 自立少年 by 2012年08月 AMU '33:新增 中低收入戶 by 2013年05月 AMU
                sql &= $" WHERE IDENTITYID IN ({cst_IdentityM1}) AND IDENTITYID NOT IN ('03') ORDER BY IDENTITYID" & vbCrLf

            Case 67 '67:特定對象統計表
                sql = ""
                sql &= " SELECT IDENTITYID, NAME FROM dbo.KEY_IDENTITY WITH(NOLOCK)" & vbCrLf
                '03"負擔家計婦女"併入28"獨立負擔家計者"計算,並把"負擔家計婦女"項目拿掉.35:新增 自立少年 by 2012年08月 AMU '33:新增 中低收入戶 by 2013年05月 AMU
                sql &= $" WHERE IDENTITYID IN ({cst_IdentityM1}) AND IDENTITYID NOT IN ('03') ORDER BY IDENTITYID" & vbCrLf

            Case 7
                '就業追蹤統計表_依轄區 (TR_04_009_R_4)
                sql = ""
                sql &= " SELECT IDENTITYID, NAME FROM dbo.KEY_IDENTITY WITH(NOLOCK) "
                sql &= " WHERE IDENTITYID <> '03' ORDER BY IDENTITYID" & vbCrLf
                '2009/07/01排除負擔家計婦女
        End Select

        Dim dt As DataTable = DbAccess.GetDataTable(sql, tConn)
        With obj
            .DataSource = dt
            .DataTextField = "Name"
            .DataValueField = "IdentityID"
            .DataBind()
            If TypeOf obj Is DropDownList Then .Items.Insert(0, New ListItem(cst_ddl_PleaseChoose3, ""))
            Select Case i_type
                Case 3, 31
                    If TypeOf obj Is CheckBoxList Then
                        .Items.Insert(0, New ListItem("全部", ""))
                    End If
                Case 6
                    .Items.Insert(0, New ListItem("全部", ""))
                    .Items.Add(New ListItem("其他", "99"))
                Case 66 '主要特定對象統計表/各分署各項計畫訓練人數-身分別，增加"無"的勾選項目
                    .Items.Insert(0, New ListItem("全部", ""))
                    .Items.Add(New ListItem("其他", "99"))
                    .Items.Add(New ListItem("無", "-1"))
                Case 67 '67:特定對象統計表
                    .Items.Insert(0, New ListItem("全部", ""))
            End Select
        End With
        Return obj
    End Function

