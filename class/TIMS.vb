    ''' <summary>傳入郵遞區號，回傳(郵遞區號)+地區名稱</summary>
    ''' <param name="tConn"></param>
    ''' <param name="ZipCode">前3碼</param>
    ''' <param name="zipcodeNW">5.6碼.後2碼.後3碼</param>
    ''' <returns></returns>
    Public Shared Function GET_FullCCTName(ByRef tConn As SqlConnection, ByVal ZipCode As String, ByVal zipcodeNW As String) As String
        Dim rst As String = ""
        ZipCode = ClearSQM(ZipCode)
        If (String.IsNullOrEmpty(ZipCode)) Then Return rst
        If (Not IsNumeric(ZipCode)) Then Return rst
        Dim s_ZipName As String = Get_ZipName(ZipCode, tConn)
        Dim s_ZipLName As String = Get_ZipLName(ZipCode, tConn)
        zipcodeNW = ClearSQM(zipcodeNW)
        Dim flag_use_5w As Boolean = If(zipcodeNW.Length = 5, True, False)
        Dim flag_use_6w As Boolean = If(zipcodeNW.Length = 6, True, False)
        Dim flag_use_B2 As Boolean = If(zipcodeNW.Length = 2, True, False)
        Dim flag_use_B3 As Boolean = If(zipcodeNW.Length = 3, True, False)
        If flag_use_5w OrElse flag_use_6w Then
            rst = String.Concat("(", zipcodeNW, ")", s_ZipName, "[", s_ZipLName, "]")
        ElseIf flag_use_B2 OrElse flag_use_B3 Then
            rst = String.Concat("(", ZipCode, zipcodeNW, ")", s_ZipName, "[", s_ZipLName, "]")
        Else
            rst = String.Concat("(", ZipCode, ")", s_ZipName, "[", s_ZipLName, "]")
        End If
        Return rst
    End Function

