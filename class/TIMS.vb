LEFT JOIN PLAN_VERREPORT P2 ON P1.PlanID=P2.PlanID AND P1.ComIDNO=P2.ComIDNO AND P1.SeqNo=P2.SeqNo
LEFT JOIN VIEW_GOVCLASSCAST ig ON p1.GCID=ig.GCID
LEFT JOIN V_GOVCLASSCAST2 ig2 ON p1.GCID2=ig2.GCID2
LEFT JOIN V_GOVCLASSCAST3 ig3 ON p1.GCID3=ig3.GCID3
LEFT JOIN VIEW_TRAINTYPE d ON P1.TMID=d.TMID
LEFT JOIN KEY_CLASSCATELOG kc ON P1.ClassCate=kc.CCID
WHERE a.OCID=@OCID
"
        'WHERE vp.TPLANID='28' and vp.YEARS>='2023' and vp.DISTID='001'
        Dim sCmd As New SqlCommand(SQL_1, oConn)
