    ''' <summary> 取得-報名登錄最晚可作業日期-自辦在職計畫/企業委託 </summary>
    ''' <param name="SS1"></param>
    ''' <param name="sFEnterDate"></param>
    ''' <param name="sExamDate"></param>
    ''' <param name="tConn"></param>
    ''' <returns></returns>
    Public Shared Function GET_FENTERDATE2(ByVal SS1 As String,
                                           ByVal sFEnterDate As String,
                                           ByVal sExamDate As String,
                                           ByVal tConn As SqlConnection) As String
        Dim rst As String = ""
        '/* '且「甄試日期」最快得安排於報名截止當日起2日後。 '另因已有「報名結束日期」及「甄試日期」，可計算報名登錄可作業的最晚時間，
        '計算後帶出的項目「報名登錄最晚可作業日期」， '該日期邏輯為：報名截止日後3日內 或 甄試日前2日取其離報名截止日較近者。(均為日曆日)
        '「報名開始日期」、「報名結束日期」、「甄試日期」均由班級資料中帶入，不可修改，僅顯示。
        '(ex： '1.報名截止日：104/09/09，甄試日：104/09/11，則最晚可報名登錄作業：104/09/09 '2.報名截止日：104/09/09，甄試日：104/09/15，則最晚可報名登錄作業：104/09/12)。
        '班別資料內的「甄試日期」最快得安排於報名截止當日起2工作日後。 '*/
        Dim RID1 As String = GetMyValue(SS1, "RID1")
        If RID1 = "" Then Return rst
        Dim TPlanID As String = GetMyValue(SS1, "TPlanID")
        If TPlanID = "" OrElse sFEnterDate = "" OrElse sExamDate = "" Then Return rst

        Dim dFEnterdate As Date = Cdate2(Cdate3(sFEnterDate))
        Dim dFEnterdate3 As Date = dFEnterdate '報名結束日期 加3
        Dim dExamDate As Date = Cdate2(sExamDate)
        Dim dExamDate2 As Date = dExamDate '甄試日期 減2 

        If Cst_TPlanID_FENTERDATE2.IndexOf(TPlanID) > -1 Then
            Call OpenDbConn(tConn)
            Dim sql As String = ""
            sql = "SELECT 'X' FROM dbo.SYS_HOLIDAY WHERE RID=@RID AND HOLDATE=CONVERT(date,@HOLDATE)"
            Dim sCmd As New SqlCommand(sql, tConn)
            Dim i3 As Integer = 0
            Dim i3B As Integer = 0
            Do Until i3 >= 3 '達到3次可以離開迴圈
                dFEnterdate3 = dFEnterdate3.AddDays(1) '隔日計算
                Dim dt As New DataTable
                With sCmd
                    .Parameters.Clear()
                    .Parameters.Add("RID", SqlDbType.VarChar).Value = RID1
                    .Parameters.Add("HOLDATE", SqlDbType.VarChar).Value = Cdate3(dFEnterdate3)
                    dt.Load(.ExecuteReader())
                End With
                i3B += 1 '預計運算天數(最大工作日)
                If dt.Rows.Count = 0 Then i3 += 1 '達到3次可以離開迴圈(非假日)
            Loop

            Dim i2 As Integer = 0
            Dim i2B As Integer = 0
            Do Until i2 >= 2 '達到2次可以離開迴圈
                dExamDate2 = dExamDate2.AddDays(-1) '隔日計算
                Dim dt As New DataTable
                With sCmd
                    .Parameters.Clear()
                    .Parameters.Add("RID", SqlDbType.VarChar).Value = RID1
                    .Parameters.Add("HOLDATE", SqlDbType.VarChar).Value = Cdate3(dExamDate2)
                    dt.Load(.ExecuteReader())
                End With
                i2B += 1 '預計運算天數(最大工作日)
                If dt.Rows.Count = 0 Then i2 += 1 '達到2次可以離開迴圈(非假日)
            Loop
        End If

        '/* 計畫：自辦 / 企業委託 '1.報名登錄最晚可作業時間：報名結束日期 + 3 日曆天
        '於開班資料查詢功能， 開放報名登錄最晚可作業時間 "可修改"， '但此欄位仍需檢核有符合在 報名結束日期 ~ 報名結束日期 + 3 日曆天 這個區間內。 */
        If Cst_TPlanID_FENTERDATE2_b.IndexOf(TPlanID) > -1 Then
            dFEnterdate3 = dFEnterdate3.AddDays(3) '+3
            rst = dFEnterdate3.ToString("yyyy/MM/dd") & " 23:59"
            Return rst
        End If

        If DateDiff(DateInterval.Day, dFEnterdate3, dExamDate2) >= 0 Then
            rst = dFEnterdate3.ToString("yyyy/MM/dd") & " 23:59"
        Else
            rst = dExamDate2.ToString("yyyy/MM/dd") & " 23:59"
        End If
        Return rst
    End Function

