    '將SQL語法重組成分頁的寫法
    Public Shared Function Get_SQLPAGE(ByVal Mysql As String, ByVal PageIndex As Integer, ByVal PageSize As Integer, ByVal MyPrimaryKey As String, Optional ByVal MySort As String = "") As String
        Dim sql As String = ""
        Mysql = Mysql.ToUpper
        If Mysql <> "" And Mysql.IndexOf("SELECT") <> -1 And Mysql.IndexOf("FROM") <> -1 And MyPrimaryKey <> "" Then
            '抽取Order By的字眼
            If MySort <> "" AndAlso Mysql.IndexOf("ORDER BY") <> -1 Then
                Mysql = Left(Mysql, Mysql.IndexOf("ORDER BY"))
            End If
            If MySort = "" Then
                MySort = MyPrimaryKey
            ElseIf MySort.ToUpper.IndexOf(MyPrimaryKey.ToUpper) = -1 Then
                MySort = String.Concat(MySort, ",", MyPrimaryKey)
            End If

            'ORACLE 專用
            Dim iROW_NUMBER_UID_B As Integer = (PageSize * (PageIndex - 1)) + 1
            Dim iROW_NUMBER_UID_E As Integer = (PageSize * PageIndex)
            sql = ""
            sql &= $" SELECT * FROM (SELECT ROW_NUMBER() OVER(ORDER BY {MySort}) ROW_NUMBER_UID ,MyTable2.* FROM ( {Mysql} ) MyTable2 ) MyTable1"
            sql &= $" WHERE ROW_NUMBER_UID BETWEEN {iROW_NUMBER_UID_B} AND {iROW_NUMBER_UID_E}"
        End If
        Return sql
    End Function

    'SQL語法查詢的筆數算出
    Public Shared Function Get_SQLRecordCount(ByVal Mysql As String, Optional ByVal objconn As SqlConnection = Nothing) As Integer
        Dim Rst As Integer = 0
        Dim sql As String = ""
        Dim conn As SqlConnection = DbAccess.GetConnection()
        Try
            'Mysql=Mysql.ToUpper
            '抽取Order By的字眼
            If Mysql.ToUpper.IndexOf("ORDER BY") <> -1 Then Mysql = Left(Mysql, Mysql.ToUpper.IndexOf("ORDER BY"))
            sql = $"SELECT COUNT(1) CNT FROM ({Mysql}) MYTABLE" 'String.Concat()
            Call OpenDbConn(conn)
            Rst = CINT1(New SqlCommand(sql, conn).ExecuteScalar())
            Call CloseDbConn(conn)
        Catch ex As Exception
            Dim V_GUID As String = Guid.NewGuid().ToString()
            LOG.Warn(ex.Message, ex)
            Call CloseDbConn(conn)
            Dim strErrmsg As String = $"Get_SQLRecordCount Sql語法查詢資料數量異常!!{vbCrLf},ex.Message : {ex.Message}, [{V_GUID}]{vbCrLf}/* Get_SQLRecordCount */{vbCrLf}{sql}{vbCrLf}"
            Call WriteTraceLog(strErrmsg, ex)
            Throw New Exception($"Get_SQLRecordCount Sql語法查詢資料數量異常!!,{ex.Message},[{V_GUID}]")
        End Try
        Call CloseDbConn(conn)
        Return Rst
    End Function

