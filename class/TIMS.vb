    ''' <summary>將身分證號碼轉換UCASE</summary>
    ''' <param name="IDNO"></param>
    ''' <param name="SpaceConvert"></param>
    ''' <returns></returns>
    Public Shared Function ChangeIDNO(ByVal IDNO As String, ByVal SpaceConvert As String) As String
        'Optional ByVal SpaceConvert As String=""
        If IDNO Is Nothing OrElse String.IsNullOrEmpty(IDNO) Then Return ""
        IDNO = UCase(Trim(IDNO))
        If IDNO = "" Then Return ""
        IDNO = Replace(IDNO, " ", SpaceConvert) '空白鍵的轉換
        IDNO = Replace(IDNO, "　", SpaceConvert) '空白鍵的轉換
        IDNO = Replace(IDNO, "Ａ", "A")
        IDNO = Replace(IDNO, "Ｂ", "B")
        IDNO = Replace(IDNO, "Ｃ", "C")
        IDNO = Replace(IDNO, "Ｄ", "D")
        IDNO = Replace(IDNO, "Ｅ", "E")
        IDNO = Replace(IDNO, "Ｆ", "F")
