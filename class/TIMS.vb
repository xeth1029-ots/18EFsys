                Dim dr As DataRow = dt2.Rows(i)
                If DateDiff(DateInterval.Day, CDate(dr("BirthDay")), CDate(sBirth)) <> 0 Then
                    RstErrmsg &= $"{cst_errmsg1}(2):e網報名基本資料{vbCrLf}"
                    'Return RstErrmsg
                    Exit For
                End If
            Next
            dt2.Dispose()
        End If

        Dim parms3 As New Hashtable From {{"IDNO", sIDNO}}
        Dim objstr As String = "SELECT IDNO,CONVERT(varchar, BirthDay, 111) BirthDay FROM STUD_STUDENTINFO WHERE IDNO=@IDNO"
        Using dt3 As DataTable = DbAccess.GetDataTable(objstr, objconn, parms3)
            If dt3.Rows.Count > 0 Then
                For i As Integer = 0 To dt3.Rows.Count - 1
                    Dim dr As DataRow = dt3.Rows(i)
                    If DateDiff(DateInterval.Day, CDate(dr("BirthDay")), CDate(sBirth)) <> 0 Then
                        RstErrmsg &= $"{cst_errmsg1}(3):學員基本資料{vbCrLf}"
                        'Return RstErrmsg
                        Exit For
                    End If
                Next
                'dt3.Dispose()
            End If
        End Using

        Return RstErrmsg
    End Function

    Public Shared Function Get_IdentityIDSplitVal(IdentityID As String, SplitVal As String) As String
        'Dim tIdentityID As String=""
        If SplitVal = "" Then SplitVal = "，"
        Dim IdentityID_Ary As String() = Split(IdentityID, SplitVal)
        Dim tmpVal1 As String = ""
        Dim Rst As String = ""
        For i As Integer = 0 To IdentityID_Ary.Length - 1
            tmpVal1 = Convert.ToString(IdentityID_Ary(i))
            If tmpVal1 <> "" Then Rst &= $"{If(Rst <> "", ",", "")}{If(tmpVal1.Length < 2, "0", "")}{tmpVal1}"
        Next
        Return Rst
    End Function
    '重整整理分割字串。(回傳含單引號供IN使用)
    Public Shared Function Get_SplitValeu1(ByVal sName As String) As String
        Dim Rst As String = ""
        If sName <> "" Then
            '若有單引號應該清除
            'If sName.IndexOf("'") > -1 Then sName=sName.Replace("'", "''")
            If sName.IndexOf("'") > -1 Then sName = ClearSQM(sName) '.Replace("'", "''")
            '一律轉成大寫
            sName = UCase(sName) '轉大寫

            Rst = ""
            If sName.IndexOf(",") > -1 Then
                For Each ss1 As String In sName.Split(",")
                    If Rst <> "" Then Rst &= ","
                    Rst &= $"'{ClearSQM(ss1)}'"
                Next
            Else
                Rst = $"'{ClearSQM(sName)}'"
            End If
        End If
        Return Rst
    End Function

    '字串檢核在範圍內，可使用。
    Public Shared Function Chk_SplitValeu1(ByRef sValues As String, ByRef sVal As String) As Boolean
        Dim rst As Boolean = False
        If $",{sValues},".IndexOf($",{sVal},") > -1 Then
            rst = True
        End If
        Return rst
    End Function

