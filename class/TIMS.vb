            outParms.Add("ErrorMsg1", s_ErrorMsg1)
            Return rst
        End If
        If ItemVar2Value = "" Then
            rst = False
            'Common.MessageBox(Me, "系統尚未設定口試的參數,請聯絡系統管理員!!")
            s_ErrorMsg1 = "系統尚未設定口試的參數,請聯絡系統管理員!!"
            outParms.Add("ErrorMsg1", s_ErrorMsg1)
            Return rst
        End If
        outParms.Add("ItemVar1", ItemVar1Value)
        outParms.Add("ItemVar2", ItemVar2Value)
        'DataGridTable.Visible=True
        'ArgRole.Text="(筆試*" & ItemVar1.Value & "%)+(口試*" & ItemVar2.Value & "%)=總成績"
        outParms.Add("ArgRole", "(筆試*" & ItemVar1Value & "%)+(口試*" & ItemVar2Value & "%)=總成績")
        Return rst
    End Function

