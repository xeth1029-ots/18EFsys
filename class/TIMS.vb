    ''' <summary> 404NOTFOUND </summary>
    ''' <param name="MyPage"></param>
    ''' <param name="oConn"></param>
    Public Shared Sub sUtl_404NOTFOUND(ByRef MyPage As Page, ByRef oConn As SqlConnection, i_seconds As Integer)
        '例外狀況儲存變數
        Dim strErrmsg As String = String.Concat("#sUtl_404NOTFOUND: ", vbCrLf, GetErrorMsg()) '取得錯誤資訊寫入
        LOG.Warn(strErrmsg)
        Call CloseDbConn(oConn)
        'Public Const cst_404NotFound As String="404 Not Found"
        Dim oRan As New Random
        If i_seconds > 0 Then
            System.Threading.Thread.Sleep((i_seconds * 1000) + oRan.Next(oRan.Next(1, 2) * 1000))
        Else
            System.Threading.Thread.Sleep(oRan.Next(oRan.Next(1, 2) * 1000))
        End If
        With MyPage
            .Response.Status = cst_404NotFound
            If (.Response.StatusCode <> 404) Then .Response.StatusCode = 404
            .Response.End()
            Return
        End With
    End Sub

