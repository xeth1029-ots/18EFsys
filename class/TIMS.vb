    '個資法遮罩
    ''' <summary>
    ''' iMode : 1:身分證號 2:生日 3.地址 4.email '個資法遮罩
    ''' </summary>
    ''' <param name="sValue"></param>
    ''' <param name="iMode"></param>
    ''' <returns></returns>
    ''' <remarks></remarks>
    Public Shared Function strMask(ByVal sValue As String, ByVal iMode As Integer) As String
        'iMode : 1:身分證號 2:生日 3.地址 4.email
        'iMode : 1:身分證號 (前2後2) 2:只顯示西元年度 3.完全遮罩 4.email(前2後3)
        Select Case iMode
            Case 1 'IDNO顯示。
                If sValue.Length > 4 Then '長度超過4
                    sValue = Left(sValue, 2) & "******" & Right(sValue, 2)
                ElseIf sValue.Length > 1 Then '長度超過1
                    sValue = Left(sValue, 1) & "***"
                Else '長度不足1
                    sValue = "****"
                End If

            Case 2 '出生日期顯示。
                If sValue.Length < 6 Then Return "****" 'yy/M/d
                'Dim flag_ROC As Boolean=CHK_REPLACE2ROC_YEARS()
                '.ToString("yyyy/MM/dd") '日期格式正確(不出錯)
                Dim flag_isROC As Boolean = Chk_DateisRoc(sValue)
                If flag_isROC Then sValue = Cdate7(sValue) Else sValue = Cdate3(sValue)
                If sValue.Length > 4 Then '長度超過4
                    If sValue.IndexOf("/") > -1 Then
                        sValue = Left(sValue, sValue.IndexOf("/")) & "/**/**"
                    Else
                        sValue = Left(sValue, 1) & "***"
                    End If
                    'sValue=Left(sValue, 4) & "/**/**"
                ElseIf sValue.Length > 1 Then '長度超過1
                    sValue = Left(sValue, 1) & "***"
                Else '長度不足1
                    sValue = "****"
                End If

            Case 3 '地址
                sValue = "******"

            Case 4 'email(前2後3)
                If sValue.Length > 5 Then '長度超過5
                    sValue = Left(sValue, 2) & Str_Repeat("*", sValue.Length - 5) & Right(sValue, 3)
                ElseIf sValue.Length > 2 Then '長度超過2
                    sValue = Left(sValue, 1) & "*@*"
                ElseIf sValue.Length > 0 Then '長度超過0
                    sValue = "**"
                Else '長度不足
                    sValue = ""
                End If

            Case Else
                sValue = "******"
        End Select
        Return sValue
    End Function

