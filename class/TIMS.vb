    ''' <summary> 取得錯誤訊息 系統資訊 </summary>
    ''' <returns></returns>
    Public Shared Function GetErrorMsgSys() As String
        Dim pText1 As String = ""
        Dim sm As SessionModel = SessionModel.Instance()
        If sm Is Nothing Then Return pText1
        If sm.UserInfo Is Nothing Then Return pText1
        Try
            pText1 = vbCrLf
            pText1 &= String.Concat("UserID=", sm.UserInfo.UserID, vbCrLf)
            pText1 &= String.Concat("RoleID=", sm.UserInfo.RoleID, vbCrLf) '角色代碼
            pText1 &= String.Concat("LID=", sm.UserInfo.LID, vbCrLf)       '階層代碼
            pText1 &= String.Concat("OrgID=", sm.UserInfo.OrgID, vbCrLf)
            pText1 &= String.Concat("OrgName=", sm.UserInfo.OrgName, vbCrLf)
            pText1 &= String.Concat("RID=", sm.UserInfo.RID, vbCrLf)
            pText1 &= String.Concat("OrgLevel=", sm.UserInfo.OrgLevel, vbCrLf)
            pText1 &= String.Concat("DistID=", sm.UserInfo.DistID, vbCrLf)
            pText1 &= String.Concat("PlanID=", sm.UserInfo.PlanID, vbCrLf)
            pText1 &= String.Concat("TPlanID=", sm.UserInfo.TPlanID, vbCrLf)
            pText1 &= String.Concat("Years=", sm.UserInfo.Years, vbCrLf)
        Catch ex As Exception
            LOG.Error(ex.Message, ex)
        End Try
        Dim Enc_Text1 As String = ""
        If pText1 <> "" Then Enc_Text1 = EncryptAes(pText1) '加密-有資料
        Enc_Text1 &= vbCrLf '換行
        If sm.SessionID IsNot Nothing Then
            Try
                Enc_Text1 &= String.Concat("SessionID=", sm.SessionID, vbCrLf) 'SessionID 
            Catch ex As Exception
                LOG.Error(ex.Message, ex)
            End Try
        End If
        Return Enc_Text1 '回傳
    End Function

    ''' <summary>
    ''' 檢測此學員是否 屬於中高齡資格 45歲~65歲 中老年
    ''' 以班的開訓日期為主，比對生日後若滿於等於45年，則可使用中高齡者參訓身份 Gloria, Phaolin 2008-4-17
    ''' 以開訓日判斷報名者的生日,是否介於45歲至65歲之報名者,為是者,才可選中高齡 Phaolin 2011-08
    ''' </summary>
    ''' <param name="Birthday"></param>
    ''' <param name="OpenDate"></param>
    ''' <returns></returns>
    ''' <remarks></remarks>
    Public Shared Function Check_YearsOld45(ByVal Birthday As String, ByVal OpenDate As String) As Boolean
        'Optional ByVal OpenDate As String=""
        Dim flag As Boolean = False ''此學員沒有中高齡者參訓身份
        '學員資格 年齡非介於45歲~65歲之間 不符合中高齡資格！
        Const Cst_x45 As Integer = -45
        Const Cst_x65 As Integer = -65
        'Const Cst_x66 As Integer=-66

        Dim Date1 As Date '生日
        Dim Date2 As Date '開訓日比對生日(45歲)
        Dim Date3 As Date '開訓日比對生日(65歲)
        '出生日期為主
        If IsDate(Birthday) Then Date1 = CDate(Birthday)

        If OpenDate <> "" AndAlso IsDate(OpenDate) Then
            '有開訓日期採 開訓日期 計算
            Date2 = CDate(OpenDate)
            Date3 = CDate(OpenDate)
            Date2 = DateAdd(DateInterval.Year, Cst_x45, Date2)
            Date3 = DateAdd(DateInterval.Year, Cst_x65, Date3)
        Else
            '沒有開訓日期採當日計算
            Date2 = CDate(Now)
            Date3 = CDate(Now)
            Date2 = DateAdd(DateInterval.Year, Cst_x45, Date2)
            Date3 = DateAdd(DateInterval.Year, Cst_x65, Date3)
        End If

        If DateDiff(DateInterval.DayOfYear, Date1, Date2) >= 0 AndAlso DateDiff(DateInterval.DayOfYear, Date3, Date1) >= 0 Then
            flag = True ''此學員有中高齡者參訓身份
        End If
        Return flag
    End Function

    '檢測此學員是否 屬於六十五歲以上者資格 65歲以上 BY AMU 20121212
    Public Shared Function Check_YearsOld65(ByVal Birthday As String, ByVal OpenDate As String) As Boolean
        'Optional ByVal OpenDate As String=""
        Dim flag As Boolean = False ''此學員沒有 六十五歲以上者 參訓身份
        '學員資格 年齡非65歲以上 不符合 六十五歲以上者 資格！
        Const Cst_x65 As Integer = -65

        Dim Date1 As Date '生日
        Dim Date3 As Date '開訓日比對生日(65歲)
        '出生日期為主
        If IsDate(Birthday) Then Date1 = CDate(Birthday)

        If OpenDate <> "" AndAlso IsDate(OpenDate) Then
            '有開訓日期採 開訓日期 計算
            Date3 = CDate(OpenDate)
            Date3 = DateAdd(DateInterval.Year, Cst_x65, Date3)
        Else
            '沒有開訓日期採當日計算
            Date3 = CDate(Now)
            Date3 = DateAdd(DateInterval.Year, Cst_x65, Date3)
        End If

        If DateDiff(DateInterval.DayOfYear, Date1, Date3) > 0 Then
            flag = True ''此學員有 六十五歲以上者 參訓身份
        End If
        Return flag
    End Function

