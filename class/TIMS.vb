    ''' <summary>依課程取得OSID2</summary>
    ''' <param name="hPMS"></param>
    ''' <param name="tConn"></param>
    ''' <returns></returns>
    Public Shared Function GET_ORG_SCORING2_OSID2(hPMS As Hashtable, tConn As SqlConnection) As Integer
        Dim rst_OSID2 As Integer = -1
        Dim vCOMIDNO As String = GetMyValue2(hPMS, "COMIDNO")
        Dim vTPLANID As String = GetMyValue2(hPMS, "TPLANID")
        Dim vDISTID As String = GetMyValue2(hPMS, "DISTID")
        Dim vYEARS As String = GetMyValue2(hPMS, "YEARS")
        Dim vAPPSTAGE As String = GetMyValue2(hPMS, "APPSTAGE")
        If (vCOMIDNO = "" OrElse vTPLANID = "" OrElse vDISTID = "" OrElse vYEARS = "") Then Return rst_OSID2
        If (vAPPSTAGE <> "1" AndAlso vAPPSTAGE <> "2") Then Return rst_OSID2

        Dim iAPPSTAGE As Integer = CINT1(vAPPSTAGE)
        If iAPPSTAGE = 1 Then vYEARS = $"{CINT1(vYEARS) - 1}"  'vYEARS=If(iAPPSTAGE=1, Convert.ToString(Val(vYEARS) - 1), vYEARS)
        Dim vMONTHS As String = If(iAPPSTAGE = 1, "07", If(iAPPSTAGE = 2, "01", "")) '上半年／下半年 , 目前無政策性計分

        Call OpenDbConn(tConn)
        Dim dt As New DataTable
        Dim sql As String = ""
        sql &= " SELECT OSID2 FROM ORG_SCORING2 WITH(NOLOCK)" & vbCrLf
        sql &= " WHERE COMIDNO=@COMIDNO AND TPLANID=@TPLANID AND DISTID=@DISTID AND YEARS=@YEARS AND MONTHS=@MONTHS" & vbCrLf
        Dim sCmd As New SqlCommand(sql, tConn)
        With sCmd
            .Parameters.Clear() 'WHERE
            .Parameters.Add("COMIDNO", SqlDbType.VarChar).Value = vCOMIDNO
            .Parameters.Add("TPLANID", SqlDbType.VarChar).Value = vTPLANID
            .Parameters.Add("DISTID", SqlDbType.VarChar).Value = vDISTID
            .Parameters.Add("YEARS", SqlDbType.VarChar).Value = vYEARS
            .Parameters.Add("MONTHS", SqlDbType.VarChar).Value = vMONTHS
            dt.Load(.ExecuteReader())
        End With
        If dtNODATA(dt) Then Return rst_OSID2

        rst_OSID2 = dt.Rows(0)("OSID2") '取得
        Return rst_OSID2
    End Function

