        Dim strErrmsg As String = ""
        strErrmsg &= String.Concat("FUNCNAME:", s_FUNCNAME) & vbCrLf
        strErrmsg &= "sysname:" & s_sysname & vbCrLf
        strErrmsg &= "strUType:" & strUType & vbCrLf
        'strErrmsg &= "WDAIIP Partial Class SD_01_001_sch" & vbCrLf
        strErrmsg &= EncryptAes(String.Concat(",strIDNO:", strIDNO, vbCrLf, ",strBIRTH:", strBIRTH, vbCrLf, ",strCNAME:", strCNAME, vbCrLf))
