    ''' <summary>CSV-格式標準化</summary>
    ''' <param name="oVal"></param>
    ''' <returns></returns>
    Public Shared Function ChgCSV1(ByVal oVal As Object) As String
        Dim rst As String = ""
        '進行中的 CSV-格式標準化
        '「CSV」格式中大量變體的存在說明並沒有一個「CSV標準」。[5][6]在常見用法中，幾乎任何定界符分隔的文字資料都可以被統稱為「CSV」檔案。不同的CSV格式可能不會相容。
        '不過， RFC 4180是一個將CSV正式化的努力。它定義了網際網路媒體類型「text/csv」， 並且採用它的規則的CSV檔案將會具有廣泛的可移植性。它有如下要求
        '以（CR / LF）字元結束的DOS風格的行（最後一行可選）。
        '一條可選的表頭記錄（沒有可靠的方式來檢測它是否存在， 所以匯入時必須謹慎）。
        '每條記錄「應當」包含同樣數量的逗號分隔欄位。
        '任何欄位都可以被包裹（用雙引號）。
        '包含換行符、雙引號和/或逗號的欄位應當被包裹。（否則，檔案很可能不能被正確處理）。
        '欄位中的一個（雙）引號字元必須被表示為兩個（雙）引號字元。
        rst = If(oVal IsNot Nothing, Convert.ToString(oVal), "")
        If rst.IndexOf(",") > -1 Then rst = Replace(rst, ",", "，")
        If rst.IndexOf("""") > -1 Then rst = Replace(rst, """", """""")
        rst = String.Concat("""", rst, """")
        Return rst
    End Function

    ''' <summary> 檢核日期有誤 </summary>
    ''' <param name="htSS"></param>
    ''' <returns></returns>
    Public Shared Function CHK_DateRange1(ByRef htSS As Hashtable) As String
        Dim errMsg As String = ""

        Dim v_STDATE As String = GetMyValue2(htSS, "STDATE")
        Dim v_FTDATE As String = GetMyValue2(htSS, "FTDATE")
        Dim v_SEnterDate As String = GetMyValue2(htSS, "SEnterDate")
        Dim v_FEnterDate As String = GetMyValue2(htSS, "FEnterDate")
        Dim v_OnShellDate As String = GetMyValue2(htSS, "OnShellDate")

        '上架日期
        'If v_OnShellDate="" Then errMsg &= "[上架日期] 日期有誤!!" & vbCrLf 'Return False
        If v_STDATE = "" Then errMsg &= "[開訓日期] 日期有誤!!" & vbCrLf 'Return False
        If v_FTDATE = "" Then errMsg &= "[結訓日期] 日期有誤!!" & vbCrLf 'Return False

        '(_i 正確值比對)
        If v_SEnterDate <> "" AndAlso v_OnShellDate <> "" Then
            '有勾選且有填上架日期的資料，再進一步檢核設定結果不得超過報名日期
            If DateDiff(DateInterval.Minute, CDate(v_SEnterDate), CDate(v_OnShellDate)) > 0 Then
                errMsg &= "[上架日期]不能晚於[報名開始日期]!" & vbCrLf
            End If
        End If
        '(_i 正確值比對)
        If v_SEnterDate <> "" AndAlso v_FEnterDate <> "" Then
            '有勾選且有填上架日期的資料，再進一步檢核設定結果不得超過報名日期
            If DateDiff(DateInterval.Day, CDate(v_SEnterDate), CDate(v_FEnterDate)) <= 0 Then
                errMsg &= "[報名開始日期]不能晚於等於[報名結束日期]!" & vbCrLf
            End If
        End If
        '(_i 正確值比對)
        If v_FEnterDate <> "" AndAlso v_FTDATE <> "" Then
            If DateDiff(DateInterval.Day, CDate(v_FEnterDate), CDate(v_FTDATE)) < 0 Then
                errMsg &= "[報名結束日期]不能晚於[結訓日期]!" & vbCrLf
            End If
        End If

        Dim str_errMSG_FM1 As String = "報名結束日期 最晚可為開訓日後第14天，若為短期班，開訓後，14天內就結訓的班級，報名結束日期 最晚為結訓日期前一天。" & vbCrLf
        If v_FEnterDate <> "" AndAlso v_STDATE <> "" AndAlso v_FTDATE <> "" Then
            If (DateDiff(DateInterval.Day, CDate(DateAdd(DateInterval.Day, 15, CDate(v_STDATE))), CDate(v_FEnterDate)) >= 0) Then
                errMsg &= str_errMSG_FM1 & vbCrLf 'Return False
            Else
                If (DateDiff(DateInterval.Day, CDate(v_STDATE), CDate(v_FTDATE)) <= 14) Then
                    If (DateDiff(DateInterval.Day, CDate(v_FTDATE), CDate(v_FEnterDate)) >= 0) Then
                        errMsg &= str_errMSG_FM1 & vbCrLf 'Return False
                    End If
                End If
            End If
        End If
        Return errMsg
    End Function

