    ''' <summary>刪除Temp中的資料，加入10秒逾時判斷</summary>
    ''' <param name="filename"></param>
    Public Shared Sub MyFileDelete(ByVal filename As String)
        Const TimeoutSeconds As Integer = 10 ' 設定超時時間為 10 秒
        Dim TIMEOUT_MILLISECONDS As Integer = 1000 * TimeoutSeconds
        ' 創建一個 Task 來執行 File.Exists
        Dim existsTask As Task(Of Boolean) = Task.Run(Function()
                                                          Return File.Exists(filename)
                                                      End Function)
        Dim isCompletedSuccessfully As Boolean = existsTask.Wait(TIMEOUT_MILLISECONDS)
        If Not isCompletedSuccessfully Then
            Dim strErrmsgTimeout As String = $"/*MyFileDelete*/,File.Exists 逾時 {TimeoutSeconds} 秒, filename: {filename}"
            LOG.Warn(strErrmsgTimeout)
            Call WriteTraceLog(strErrmsgTimeout)
            Return '超時，跳離
        End If
        If Not existsTask.Result Then Return ' 檔案不存在，跳離 
        Try
            ' 取得檔案的屬性 ' 判斷檔案屬性是否包含唯讀 (ReadOnly) ' 如果是唯讀，則將屬性設定為一般 (Normal)
            If (File.GetAttributes(filename) And FileAttributes.ReadOnly) = FileAttributes.ReadOnly Then
                File.SetAttributes(filename, FileAttributes.Normal)
            End If
            ' 刪除Temp中的資料
            File.Delete(filename)
        Catch ex As Exception
            Dim strErrmsg As String = $"/*MyFileDelete*/,filename: {filename}, ex.Message: {ex.Message}"
            LOG.Warn(strErrmsg, ex)
            Call WriteTraceLog(strErrmsg, ex) 'Throw ex
        End Try
    End Sub

    ''' <summary>刪除Temp中的目錄，加入10秒逾時判斷</summary>
    ''' <param name="directoryPath"></param>
    Public Shared Sub MyDirDelete(directoryPath As String)
        Const TimeoutSeconds As Integer = 10 ' 設定超時時間為 10 秒
        Dim TIMEOUT_MILLISECONDS As Integer = 1000 * TimeoutSeconds
        ' 創建一個 Task 來執行 Directory.Exists
        Dim existsTask As Task(Of Boolean) = Task.Run(Function()
                                                          Return Directory.Exists(directoryPath)
                                                      End Function)
        Dim isCompletedSuccessfully As Boolean = existsTask.Wait(TIMEOUT_MILLISECONDS)
        If Not isCompletedSuccessfully Then
            Dim strErrmsgTimeout As String = $"/*MyDirDelete*/,Directory.Exists 逾時 {TimeoutSeconds} 秒, directoryPath: {directoryPath}"
            LOG.Warn(strErrmsgTimeout)
            Call WriteTraceLog(strErrmsgTimeout)
            Return '超時，跳離
        End If
        If Not existsTask.Result Then Return '目錄不存在，跳離 
        'String directoryPath=@"C:\path\to\your\empty\directory"; 'If Not Directory.Exists(directoryPath) Then Return
        Try
            'Directory.SetAccessControl()
            Directory.Delete(directoryPath, True)
        Catch ex As Exception
            Dim strErrmsg As String = $"/*MyDirDelete*/,directoryPath: {directoryPath}, ex.Message: {ex.Message}"
            LOG.Warn(strErrmsg, ex)
            Call WriteTraceLog(strErrmsg, ex) 'Throw ex
        End Try
    End Sub

    Public Shared Async Function MyDirDeleteAsync(directoryPath As String) As Task
        ' 檢查目錄是否存在，如果不存在就直接返回
        If Not Directory.Exists(directoryPath) Then Return
        ' 使用 Task.Run 在背景執行緒中執行同步的刪除操作 ' 這樣可以避免阻塞呼叫者執行緒
        Await Task.Run(Sub()
                           Try
                               Directory.Delete(directoryPath, True)
                           Catch ex As Exception
                               Dim strErrmsg As String = $"/*MyDirDeleteAsync*/,directoryPath: {directoryPath}, ex.Message: {ex.Message}"
                               LOG.Warn(strErrmsg, ex)
                               Call WriteTraceLog(strErrmsg, ex) 'Throw ex
                           End Try
                       End Sub)
    End Function
