    ''' <summary>查詢核銷代號查詢資料-依vOCID,vSEQ_ID,vCVOCID</summary>
    ''' <param name="oConn"></param>
    ''' <param name="vOCID"></param>
    ''' <param name="vSEQ_ID"></param>
    ''' <param name="vCVOCID"></param>
    ''' <returns></returns>
    Public Shared Function GET_CLASS_VERIFYONLINE(oConn As SqlConnection, vOCID As String, vSEQ_ID As String, vCVOCID As String) As DataRow
        Dim drVV As DataRow = Nothing
        vOCID = ClearSQM(vOCID)
        vSEQ_ID = ClearSQM(vSEQ_ID)
        vCVOCID = ClearSQM(vCVOCID)
        If vOCID = "" OrElse vSEQ_ID = "" OrElse vCVOCID = "" Then Return drVV
        If cst_NO = vCVOCID Then vCVOCID = ""

        Dim pms_1 As New Hashtable From {{"OCID", vOCID}, {"SEQ_ID", vSEQ_ID}}
        Dim sSql As String = ""
        sSql &= " SELECT a.CVOCID,a.OCID,a.SEQ_ID ,a.SENDACCT,a.SENDDATE,a.SENDSTATUS" & vbCrLf
        sSql &= " ,a.CREATEACCT,a.CREATEDATE ,a.MODIFYACCT,a.MODIFYDATE" & vbCrLf
        sSql &= " ,a.APPLIEDRESULT ,a.REASONFORFAIL,a.RESULTACCT,a.RESULTDATE,a.HISREVIEW" & vbCrLf
        sSql &= " ,cc.PLANID,cc.COMIDNO,cc.SEQNO,ip.YEARS,ip.TPLANID,ip.DISTID" & vbCrLf
        sSql &= " ,dbo.FN_GET_CLASSCNAME(cc.CLASSCNAME,cc.CYCLTYPE) CLASSCNAME2" & vbCrLf
        sSql &= " ,CASE oo.ORGKIND WHEN '10' THEN 'W' ELSE 'G' END COLLATE Chinese_Taiwan_Stroke_CS_AS ORGKINDGW"
        sSql &= " ,pp.APPSTAGE,CASE pp.APPSTAGE WHEN 1 THEN '上半年' WHEN 2 THEN '下半年' WHEN 3 THEN '政策性產業' WHEN 4 THEN '進階政策性產業' END APPSTAGE_N" & vbCrLf
        sSql &= " ,oo.ORGNAME" & vbCrLf
        sSql &= " FROM CLASS_VERIFYONLINE a" & vbCrLf
        sSql &= " JOIN CLASS_CLASSINFO cc on cc.OCID=a.OCID" & vbCrLf
        sSql &= " JOIN PLAN_PLANINFO pp ON cc.PLANID=pp.PLANID AND cc.COMIDNO=pp.COMIDNO AND cc.SEQNO=pp.SEQNO" & vbCrLf
        sSql &= " JOIN ID_PLAN ip on ip.PLANID=cc.PLANID" & vbCrLf
        sSql &= " JOIN ORG_ORGINFO oo on oo.COMIDNO=cc.COMIDNO" & vbCrLf
        sSql &= " WHERE a.OCID=@OCID AND a.SEQ_ID=@SEQ_ID" & vbCrLf
        If vCVOCID <> "" Then
            pms_1.Add("CVOCID", vCVOCID)
            sSql &= " AND a.CVOCID=@CVOCID" & vbCrLf
        End If
        drVV = DbAccess.GetOneRow(sSql, oConn, pms_1)
        Return drVV
    End Function

    Public Shared Sub ResponseZIPFile_CVO(sm As SessionModel, oConn As SqlConnection, MyPage As Page, rPMS As Hashtable)
        Dim vCVOCFID As String = GetMyValue2(rPMS, "CVOCFID")
