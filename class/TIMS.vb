    ''' <param name="oConn"></param>
    ''' <param name="PMS"></param>
    ''' <returns></returns>
    Public Shared Function GET_ORG_BIDCASEFL_TT_USELATESTVER_row(oConn As SqlConnection, ByRef PMS As Hashtable) As DataRow
        Dim drT2 As DataRow = Nothing
        'srPMS2.Add("COMIDNO", drPR("COMIDNO"))
        'srPMS2.Add("TECHID", vTECHID)
        'srPMS2.Add("ORGKINDGW", drKR("ORGKINDGW"))
        Dim v_TPLANID As String = GetMyValue2(PMS, "TPLANID")
        Dim v_TECHID As String = GetMyValue2(PMS, "TECHID")
        Dim v_COMIDNO As String = GetMyValue2(PMS, "COMIDNO")
        Dim v_ORGKINDGW As String = GetMyValue2(PMS, "ORGKINDGW")
        If v_TECHID = "" OrElse v_COMIDNO = "" OrElse v_ORGKINDGW = "" Then Return drT2
        Dim sPMS As New Hashtable From {
            {"TPLANID", v_TPLANID},
            {"TECHID", v_TECHID},
            {"COMIDNO", v_COMIDNO},
            {"ORGKINDGW", v_ORGKINDGW}
        }
        Dim sSql As String = ""
        sSql &= " SELECT a.BCID,f.BCFID,f.KBSID" & vbCrLf
        sSql &= " ,b.BCFTID,b.TECHID ,b.SRCFILENAME1,b.FILENAME1" & vbCrLf
        sSql &= " ,tt.TEACHCNAME,tt.TEACHERID" & vbCrLf
        sSql &= " ,a.YEARS,a.APPSTAGE,a.PLANID,a.RID,a.BCASENO" & vbCrLf
        sSql &= " FROM TEACH_TEACHERINFO tt" & vbCrLf
        sSql &= " JOIN ORG_BIDCASEFL_TT b on b.TECHID=tt.TECHID" & vbCrLf
        sSql &= " JOIN KEY_BIDCASE k on k.KBSID=b.KBSID AND k.ORGKINDGW=@ORGKINDGW AND k.TPLANID=@TPLANID" & vbCrLf
        sSql &= " JOIN ORG_BIDCASEFL f on f.BCFID=b.BCFID" & vbCrLf
        sSql &= " JOIN ORG_BIDCASE a on a.BCID=f.BCID" & vbCrLf
        sSql &= " JOIN ORG_ORGINFO oo on oo.ORGID=a.ORGID" & vbCrLf
        sSql &= " WHERE tt.TECHID=@TECHID and oo.COMIDNO=@COMIDNO AND b.MODIFYDATE>=GETDATE()-600" & vbCrLf
        sSql &= " ORDER BY b.MODIFYDATE DESC" & vbCrLf
        Dim dtT2 As DataTable = DbAccess.GetDataTable(sSql, oConn, sPMS)
        If dtT2 Is Nothing OrElse dtT2.Rows.Count = 0 Then Return drT2

        drT2 = dtT2.Rows(0)
        '上傳檔案 '年度／計畫ID／機構ID／caseno／kbsid
        Dim vYEARS As String = Convert.ToString(drT2("YEARS"))
        Dim vAPPSTAGE As String = Convert.ToString(drT2("APPSTAGE"))
        Dim vPLANID As String = Convert.ToString(drT2("PLANID"))
        Dim vRID As String = Convert.ToString(drT2("RID"))
        Dim vBCASENO As String = Convert.ToString(drT2("BCASENO"))
        Dim vKBSID As String = Convert.ToString(drT2("KBSID"))
        Dim vUploadPath As String = GET_UPLOADPATH1_BI(vYEARS, vAPPSTAGE, vPLANID, vRID, vBCASENO, vKBSID)
        SetMyValue2(PMS, "UploadPath", vUploadPath) 'PMS.Add("UploadPath", vUploadPath) 'sPMS.Add("UploadPath", vUploadPath)
        Return drT2
    End Function

