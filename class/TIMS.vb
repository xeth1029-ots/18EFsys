    ''' <returns></returns>
    Public Shared Function GetTrainingListS3(ByRef sm As SessionModel, ByRef sConn As SqlConnection, ByVal v_IDNOs As String) As DataTable
        'Const cst_all_column As String="IDNO,NAME,BIRTHDAY,DISTNAME,YEARS,TPLANID,PLANNAME,ORGNAME,TRAINNAME,CJOB_NAME,CLASSCNAME,THours,TRound,WEEKS,TFLAG,WorkSuppIdent,SumOfMoney,BudIDName,AppliedStatus,AppliedStatusM,MEMO1"
        Dim dt As DataTable = Utl_CreateITSWebcCDT()
        If v_IDNOs = "" Then Return dt

        Dim dtS1 As DataTable = Utl_CreateITSWebcCDT() 'SAVE ADP_TRAINING

        'Const cst_SYSNAME_1 As String="PSHTL001"
        Const cst_s_AUTH As String = "ce130f098d90e52491a8097fcd119b4d"

        Dim sw As New System.Diagnostics.Stopwatch() '引用stopwatch物件
        sw.Reset() '碼表歸零
        sw.Start() '碼表開始計時

        'WebRequest物件如何忽略憑證問題
        System.Net.ServicePointManager.ServerCertificateValidationCallback = New System.Net.Security.RemoteCertificateValidationCallback(AddressOf ValidateServerCertificate)
        'TLS 1.2-基礎連接已關閉: 傳送時發生未預期的錯誤 'HttpClient
        System.Net.ServicePointManager.SecurityProtocol = System.Net.SecurityProtocolType.Tls12 '3072
        'https://itsapi.etraining.gov.tw/ITSWebExport
        'https://itsapi.etraining.gov.tw/ITSWebExport/swagger/index.html?url=/ITSWebExport/swagger/v1/swagger.json
        'http://wltims.wda.gov.tw/ITSWebc/twsITSWebc.asmx
        'https://wltims.wda.gov.tw/ITSWebc/testDef2.aspx
        'Dim GTL_1 As New GetTraining.GetTrainingList
        Dim GTL_2 As New ITSWebc.twsITSWebc

        Dim s_log1 As String = ""
        s_log1 = String.Format("##GetTrainingListS3 v_IDNOs:{0} ", v_IDNOs)
        LOG.Debug(s_log1)
        v_IDNOs = CombiSQM2IN(v_IDNOs)

        '執行webservice前／需要有單引號
        Dim ITSrc1 As ITSWebc.ResultOfSTUDENT_TRAINING_HISTORY_VIEW
        ITSrc1 = GTL_2.GetStudHis2(cst_s_AUTH, v_IDNOs)
        If ITSrc1 Is Nothing Then Return dt
        If ITSrc1.Count = 0 Then Return dt

        Dim iROW As Integer = 0
        Dim iROW_S1 As Integer = 0

        For Each mlist As ITSWebc.STUDENT_TRAINING_HISTORY_VIEW In ITSrc1.Records
            iROW_S1 += 1
            Dim drS1 As DataRow = dtS1.NewRow()
            dtS1.Rows.Add(drS1)
            drS1("ROWNUM") = iROW_S1
            Dim oParmsS1 As New Hashtable
            UPD_ITSWebcDr(drS1, mlist, oParmsS1)
            LOG.Debug(String.Concat("(", iROW, "):", Replace(GetMyValue4(oParmsS1), vbCrLf, "")))
            oParmsS1.Clear()

            'If Cst_TPlanID28ApPlan5.IndexOf(mlist.TPLANID) > -1 Then Continue For '略過-計畫為在職
            'If Not flag_ALL AndAlso CHG_YESNO(mlist.WORKSUPPIDENT, "N")="N" Then Continue For '略過-非在職者 (若為全部時不略過)
            If CHG_YESNO(mlist.WORKSUPPIDENT, cst_NO) = cst_YES Then Continue For '略過-在職者

            iROW += 1
            Dim dr As DataRow = dt.NewRow()
            dt.Rows.Add(dr)
            dr("ROWNUM") = iROW
            UPD_ITSWebcDr(dr, mlist, Nothing)
        Next

        '新增-dtTra  ADP_TRAINING
        Call INSERT_TRAINING(sm, sConn, dtS1)

        sw.Stop() '碼錶停止

        '印出所花費的總豪秒數
        'Dim s_log1 As String
        s_log1 = String.Format("##GetTrainingListS3 v_IDNOs:{0} ,COUNT:{1} ,ms:{2}", v_IDNOs, iROW, sw.Elapsed.TotalMilliseconds.ToString())
        LOG.Debug(s_log1)

        Return dt
    End Function

    ''' <summary> 勾稽檢查學員是否參加職前課程機制-依dtITS </summary>
    ''' <param name="dtITS"></param>
    ''' <param name="oIDNO"></param>
    ''' <param name="oSTDATE"></param>
    ''' <param name="oFTDATE"></param>
    ''' <returns></returns>
    Public Shared Function CheckTrainITS(ByRef dtITS As DataTable, ByVal oIDNO As String, ByVal oSTDATE As String, ByVal oFTDATE As String) As Boolean
        '調整學員參訓功能頁面：(如下圖)
        '增修需求 OJT-21030203：<系統> 產投 -學員參訓：新增批次勾稽檢查學員是否參加職前課程機制
        '1、點選時，針對該班未完成報到學員，以身分證字號勾稽職前系統學員參訓歷史，比對這些學員於訓練期間是否同時參加職前課程。
        '2、完成勾稽後，系統彈出提示訊息"已完成檢核"，並於該學員勾選報到欄位顯示紅字*。 (如下圖)
        '3、若訓練單位勾選有出現*的學員，再點選完成報到，系統進行卡控不可報到，並跳出提示："因有學員同時參加職前課程，無法完成報到，請進行確認。"。
        '3、開訓後超過14日，該「檢核是否同時參加職前課程」按鈕反灰，不再提供查詢。

        '三、 增加備註文字，並以紅字顯示
        '1、於【報到日期】下方增加「*表該學員有同時參加職前課程」。(如下圖)
        '2、於「檢核是否同時參加職前課程」按鈕下方新增以下文字：
        '注意：「檢核是否同時參加職前課程」按鈕僅針對未完成報到的學員，且因批次勾稽職前系統會較為耗時，請耐心等候。
        Dim rst As Boolean = False
        If dtITS Is Nothing Then Return rst
        If dtITS.Rows.Count = 0 Then Return rst
        Dim S_str1 As String = String.Format("IDNO='{0}'", oIDNO)
        If dtITS.Select(S_str1).Length = 0 Then Return rst

        For Each dr1 As DataRow In dtITS.Select(S_str1)
            Dim flag_chk As Boolean = False
            If Not flag_chk Then
                If DateDiff(DateInterval.Day, CDate(dr1("STDATE")), CDate(oSTDATE)) >= 0 _
                AndAlso DateDiff(DateInterval.Day, CDate(oSTDATE), CDate(dr1("FTDATE"))) >= 0 Then
                    flag_chk = True
                End If
            End If
            If Not flag_chk Then
                If DateDiff(DateInterval.Day, CDate(dr1("STDATE")), CDate(oFTDATE)) >= 0 _
                AndAlso DateDiff(DateInterval.Day, CDate(oFTDATE), CDate(dr1("FTDATE"))) >= 0 Then
                    flag_chk = True
                End If
            End If
            If Not flag_chk Then
                If DateDiff(DateInterval.Day, CDate(oSTDATE), CDate(dr1("STDATE"))) >= 0 _
                AndAlso DateDiff(DateInterval.Day, CDate(dr1("STDATE")), CDate(oFTDATE)) >= 0 Then
                    flag_chk = True
                End If
            End If
            If Not flag_chk Then
                If DateDiff(DateInterval.Day, CDate(oSTDATE), CDate(dr1("FTDATE"))) >= 0 _
                AndAlso DateDiff(DateInterval.Day, CDate(dr1("FTDATE")), CDate(oFTDATE)) >= 0 Then
                    flag_chk = True
                End If
            End If
            If flag_chk Then
                rst = True
                Return rst
            End If
        Next
        Return rst  'Return True 'Return False
    End Function

    ''' <summary> 勾稽檢查學員是否參加職前課程機制 </summary>
