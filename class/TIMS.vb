    ''' <summary> TryCatch - Common.FormatDate </summary>
    ''' <param name="drw"></param>
    ''' <param name="sColname"></param>
    ''' <param name="s_ErrMsg"></param>
    ''' <param name="fg_isDate"></param>
    ''' <returns></returns>
    Public Shared Function TryFormatDate(ByRef drw As DataRow, ByRef sColname As String, ByRef s_ErrMsg As String, ByRef fg_isDate As String) As String
        fg_isDate = False
        Dim rst As String = s_ErrMsg
        If drw Is Nothing Then Return rst
        Try
            rst = Common.FormatDate(drw(sColname))
            fg_isDate = True
        Catch ex As Exception
            LOG.Warn(String.Concat("#TryFormatDate: sColname: ", sColname))
            LOG.Warn(String.Concat("#TryFormatDate: s_ErrMsg: ", s_ErrMsg))
            LOG.Warn(String.Concat("#TryFormatDate: ", ex.ToString()), ex)
        End Try
        Return rst
    End Function

