                        'First DataGrid
                        strSql = ""
                        '請注意 Excel中的 "名稱方塊" (插入-->名稱-->定義)
                        strSql &= " SELECT * From [" & SheetName & "$] "
                        strSql &= " WHERE [" & FirstCol & "] IS NOT NULL "
                        If SecondCol <> "" Then strSql &= " OR [" & SecondCol & "] IS NOT NULL "
                        If ThirdCol <> "" Then strSql &= " OR [" & ThirdCol & "] IS NOT NULL "
                        dt = GetDataTable(strSql, objOleConn)
                        If objOleConn.State = ConnectionState.Open Then objOleConn.Close()
                        'objOleConn.Dispose()
                        Return dt 'Exit Function
                    End If
                    'If objOleConn IsNot Nothing AndAlso objOleConn.State=ConnectionState.Open Then objOleConn.Close()
                    'If objOleConn IsNot Nothing Then objOleConn.Dispose()
                End Using
            Catch ex As Exception
                Dim V_GUID As String = Guid.NewGuid().ToString()
                LOG.Warn(ex.Message, ex) '取得錯誤資訊寫入
                Dim strErrmsg As String = String.Concat(GetErrorMsgSys(), "strSql:", strSql, vbCrLf, "ex.Message:", ex.Message, vbCrLf)
                WriteTraceLog(strErrmsg, ex)
                ErrFlag = True
                Errmsg = String.Format(" {0}表格名稱定義有誤：{1} [{2}] {3}", vbCrLf, SheetName, V_GUID, ex.Message)
            End Try
        End SyncLock

        Return dt
    End Function

    Public Shared Function Search_Stud_SubsidyCost(ByVal tmpIDNO As String, ByRef oConn As SqlConnection) As String
        Dim rst As String = ""
        tmpIDNO = ChangeIDNO(tmpIDNO)
        Dim sql As String = ""
        sql &= " SELECT b.OCID,e.ORGNAME" & vbCrLf
        sql &= " ,dbo.FN_GET_CLASSCNAME(d.CLASSCNAME,d.CYCLTYPE) CLASSCNAME" & vbCrLf
        sql &= " ,d.STDATE ,d.FTDATE" & vbCrLf
        sql &= " ,a.SUMOFMONEY" & vbCrLf
        sql &= " ,case a.APPLIEDSTATUSM when 'N' then'審核不通過' when 'Y' then '審核通過' when 'R' then '退件修正' else '審核中' end APPLIEDSTATUSM" & vbCrLf
        sql &= " ,concat(DATEPART(YEAR, d.STDATE),e.ORGNAME,'-'" & vbCrLf
        sql &= " ,dbo.FN_GET_CLASSCNAME(d.CLASSCNAME,d.CYCLTYPE)" & vbCrLf
        sql &= " ,': ',case a.APPLIEDSTATUSM when 'N' then'審核不通過' when 'Y' then '審核通過' when 'R' then '退件修正' else '審核中' end" & vbCrLf
        sql &= " ,' $',a.SUMOFMONEY" & vbCrLf
        sql &= " ,' : ',case a.APPLIEDSTATUS when 0 then '不撥款' when 1 then '已撥款' else '待撥款' end) TITLE" & vbCrLf
        sql &= " FROM STUD_SUBSIDYCOST a WITH(NOLOCK)" & vbCrLf
        sql &= " JOIN CLASS_STUDENTSOFCLASS b WITH(NOLOCK) ON a.SOCID=b.SOCID" & vbCrLf
        sql &= " JOIN STUD_STUDENTINFO c WITH(NOLOCK) ON b.SID=c.SID" & vbCrLf
        sql &= " JOIN CLASS_CLASSINFO d WITH(NOLOCK) ON b.OCID=d.OCID" & vbCrLf
        sql &= " JOIN VIEW_RIDNAME e ON d.RID=e.RID" & vbCrLf
        sql &= " WHERE d.STDate >= DATEADD(year,-3,GETDATE())" & vbCrLf
        sql &= " AND c.IDNO='" & tmpIDNO & "'" & vbCrLf

        Dim sCmd As New SqlCommand(sql, oConn)
        Call OpenDbConn(oConn)
        Dim dt As New DataTable
        With sCmd
            .Parameters.Clear()
            dt.Load(.ExecuteReader())
        End With

        rst = ""
        If dt.Rows.Count > 0 Then
            For i As Integer = 0 To dt.Rows.Count - 1
                rst += Convert.ToString(dt.Rows(i)("title")) & vbCrLf
            Next
        End If
        Return rst
    End Function

