    Private Shared ReadOnly dictLock As New Object()

    ''' <summary>dirConfig(重新)填入值</summary>
    ''' <param name="oConn"></param>
    Public Shared Sub Utl_SetConfigVAL(oConn As SqlConnection)
        SyncLock dictLock
            Dim hostname As String = System.Net.Dns.GetHostName()
            Call SET_First_CFG_RELOAD_TIME_DB(oConn, hostname)

            Dim SQL_1 As String = "SELECT ITEMNAME,ITEMVALUE FROM SYS_VAR WITH(NOLOCK) WHERE SPAGE='Config'"
            OpenDbConn(oConn)
            Dim dt1 As New DataTable
            Dim oCmd As New SqlCommand(SQL_1, oConn)
            dt1.Load(oCmd.ExecuteReader())
            'Dim dt1 As DataTable = DbAccess.GetDataTable(sql, oConn) '取得
            If TIMS.dtNODATA(dt1) Then Return   '無資料-不太可能，除非DB異常
            '(CACHE-全部清理)
            If dirConfig IsNot Nothing Then dirConfig.Clear() '清理
            dirConfig = New Dictionary(Of String, String) '重設CACHE(清除)
            '(CACHE-重新設定)
            For Each dr1 As DataRow In dt1.Rows
                If Not dirConfig.ContainsKey(dr1("ITEMNAME")) Then
                    dirConfig.Add(dr1("ITEMNAME"), dr1("ITEMVALUE")) '重設CACHE(填入)
                Else
                    'CACHE-資料重複
                    LOG.Warn($"#2153,#Utl_SetConfigVAL,資料重複:{dr1("ITEMNAME")},{dr1("ITEMVALUE")}")
                End If
            Next

            Call SET_Last_CFG_RELOAD_TIME_DB(oConn, hostname)
        End SyncLock
    End Sub

