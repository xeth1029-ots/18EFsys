    Public Shared Function GET_iPROGRESS_OA(sm As SessionModel, oConn As SqlConnection, ByRef showMsg As String, vTBCID As String, vORGKINDGW As String) As Integer
        Dim iProgress As Integer = 0
        showMsg = ""

        Dim PMS_FL As New Hashtable From {{"TBCID", CINT1(vTBCID)}}
        Dim SQL_FL As String = " SELECT 1 FROM CLASS_STD14OAFL WHERE TBCID=@TBCID" & vbCrLf
        Dim dtFL As DataTable = DbAccess.GetDataTable(SQL_FL, oConn, PMS_FL)

        'NOPROCESD  Y:排除計算完成度
        Dim rParmsA As New Hashtable From {{"TPLANID", sm.UserInfo.TPlanID}, {"ORGKINDGW", vORGKINDGW}}
        Dim sSqlA As String = "SELECT 1 FROM KEY_STD14TH WHERE TPLANID=@TPLANID AND ORGKINDGW=@ORGKINDGW AND NOPROCESD IS NULL"
        Dim dtA As DataTable = DbAccess.GetDataTable(sSqlA, oConn, rParmsA)
        If dtNODATA(dtA) Then Return iProgress '0分

        Dim rParms As New Hashtable From {{"TBCID", CINT1(vTBCID)}, {"TPLANID", sm.UserInfo.TPlanID}, {"ORGKINDGW", vORGKINDGW}}
        Dim rsSql As String = "
SELECT 1 FROM CLASS_STD14OAFL a
JOIN KEY_STD14TH kb ON kb.KTSEQ=a.KTSEQ AND kb.NOPROCESD IS NULL
JOIN CLASS_STD14OA oa ON oa.TBCID=a.TBCID
JOIN CLASS_CLASSINFO CC ON CC.OCID=oa.OCID
WHERE a.TBCID=@TBCID AND kb.TPLANID=@TPLANID AND kb.ORGKINDGW=@ORGKINDGW"
        Dim dt As DataTable = DbAccess.GetDataTable(rsSql, oConn, rParms)
        If dtNODATA(dtA) Then Return iProgress '0分

        Dim iDATA1 As Integer = If(dtHaveDATA(dt), dt.Rows.Count, 0) '(已完成)
        Dim iDATAA As Integer = If(dtHaveDATA(dtA), dtA.Rows.Count, 0) '(總共要完成項)
        Dim iCNT1 As Double = iDATA1 '(已完成)
        Dim iCNTA As Double = iDATAA '(總共要完成項)
        iProgress = If(iCNTA > 0, (iCNT1 / iCNTA * 100), 0)

        If iProgress > 30 AndAlso iProgress < 100 Then
            Dim rParms2 As New Hashtable From {{"TBCID", CINT1(vTBCID)}, {"TPLANID", sm.UserInfo.TPlanID}, {"ORGKINDGW", vORGKINDGW}}
            Dim sSql2 As String = "SELECT OA.TBCID,KB.KTID,KB.KTNAME,KB.ORGKINDGW
,CONCAT(KB.KTID,'.',KB.KTNAME) KTNAME2,A.WAIVED
,CASE WHEN A.TBCFID IS NULL THEN 'Y' END TBCFIDNG
FROM CLASS_STD14OA OA
JOIN CLASS_CLASSINFO CC ON CC.OCID=OA.OCID
JOIN KEY_STD14TH KB ON KB.TPLANID=@TPLANID AND KB.ORGKINDGW=@ORGKINDGW AND KB.NOPROCESD IS NULL
LEFT JOIN CLASS_STD14OAFL A ON A.TBCID=OA.TBCID AND A.KTSEQ=KB.KTSEQ"
            sSql2 &= " WHERE OA.TBCID=@TBCID"
            Dim dt2 As DataTable = DbAccess.GetDataTable(sSql2, oConn, rParms2)
            If dt2.Rows.Count = 0 Then Return iProgress

            For Each dr2 As DataRow In dt2.Rows
                If ($"{dr2("TBCFIDNG")}" = "Y") Then showMsg &= $"{If(showMsg <> "", "、", "")}{dr2("KTNAME2")}"
            Next
        End If
        Return iProgress 'labProgress.Text=String.Concat(iProgress, "%")
    End Function

