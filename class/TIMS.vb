            usSql &= " WHERE SFCID=@SFCID AND KSFID=@KSFID AND WAIVED=@WAIVED" & vbCrLf
            DbAccess.ExecuteNonQuery(usSql, oConn, uParms)
            Return iSFCFID
        End If
        Return iSFCFID
    End Function

