    ''' <summary> 整理時間格式 </summary>
    ''' <param name="strDate"></param>
    ''' <returns></returns>
    Public Shared Function CssFormatDate(ByVal strDate As Date) As String
        Dim tmpStr As String = ""
        Dim tmpStrLongTime1 As String = ""
        tmpStrLongTime1 = strDate.ToLongTimeString

        tmpStr = strDate.ToShortDateString
        Select Case Left(tmpStrLongTime1, 2)
            Case "上午"
                If Left(Right(tmpStrLongTime1, 8), 2) = 12 Then
                    tmpStr &= " 00" & Right(tmpStrLongTime1, 6)
                Else
                    tmpStr &= " " & Right(tmpStrLongTime1, 8)
                End If
            'tmpStr &= " AM"
            Case "下午"
                If (CInt(Left(Right(tmpStrLongTime1, 8), 2)) + 12) >= 24 Then
                    tmpStr &= " " & Left(Right(tmpStrLongTime1, 8), 2)
                Else
                    tmpStr &= " " & CStr(CInt(Left(Right(tmpStrLongTime1, 8), 2)) + 12)
                End If
                tmpStr += Right(tmpStrLongTime1, 6)
                'tmpStr &= " PM"
        End Select

        Return tmpStr
    End Function

