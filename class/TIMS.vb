    Public Shared Function CHK_ROCYEARS(oConn As SqlConnection, o_YEARS As Object) As Boolean
        Dim rst As Boolean = False
        If o_YEARS Is Nothing OrElse Convert.ToString(o_YEARS) = "" OrElse Not IsNumeric(o_YEARS) Then Return rst
        'Dim s_YEARS As String=Convert.ToString(o_YEARS)  'If s_YEARS="" Then Return rst
