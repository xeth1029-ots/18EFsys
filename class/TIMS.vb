    ''' <summary> 記錄系統 Exception Log 寄信</summary>
    ''' <param name="MyPage"></param>
    ''' <param name="ex"></param>
    ''' <param name="sErrMsg1"></param>
    Public Shared Sub WriteTraceLog(ByRef MyPage As Page, ByRef ex As Exception, ByVal sErrMsg1 As String, ByRef content As String, ByRef fileFormat As String)
        If IsNothing(ex) Then
            LOG.Error(sErrMsg1)
        Else
            LOG.Error(sErrMsg1, ex)
        End If
        Dim sMailBody As String = GetErrorMsg(MyPage, ex)
        '取得頁面及錯誤資訊寫入
        If sMailBody <> "" Then LOG.Error(sMailBody)
        'SendMailTest
        sMailBody &= $"{vbCrLf}{sErrMsg1}"
        If content <> "" AndAlso fileFormat <> "" Then
            Call SendMailTest($"{sMailBody}{vbCrLf}{content}{vbCrLf}{fileFormat}")
            Return
        End If
        Call SendMailTest(sMailBody)
    End Sub

