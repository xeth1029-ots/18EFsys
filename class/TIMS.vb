    Public Shared Sub Insert_Auth_AccRWClass(ByRef sm As SessionModel, ByVal OCID As String, ByVal PlanID As Integer, ByRef tConn As SqlConnection)
        If OCID = "" Then Exit Sub '無OCID 不動作
        'Dim sm As SessionModel=SessionModel.Instance()
        Dim s_Account As String = sm.UserInfo.UserID
        If PlanID = -1 Then
            'PlanID: -1:限定Session.PlanID
            PlanID = sm.UserInfo.PlanID
        End If
        Dim RID As String = sm.UserInfo.RID
        Dim RID_1 As String = Left(sm.UserInfo.RID, 1)

        Call OpenDbConn(tConn)

        Dim pms1 As New Hashtable From {{"ACCOUNT", s_Account}}
        Dim sql As String = " SELECT * FROM AUTH_ACCRWCLASS WHERE ACCOUNT=@ACCOUNT"
        Dim dt As DataTable = DbAccess.GetDataTable(sql, tConn, pms1)

        Dim iSql As String = ""
        iSql &= " INSERT INTO AUTH_ACCRWCLASS( ACID,ACCOUNT,OCID,MODIFYACCT,MODIFYDATE )" & vbCrLf
        iSql &= " VALUES ( @ACID,@ACCOUNT,@OCID,@MODIFYACCT,GETDATE() )" & vbCrLf

        '已經將承辦人新增
        Dim flagsave As Boolean = False
        Dim iACID As Integer = 0
        Dim ff3 As String = "OCID='" & OCID & "'"

        If dt.Select(ff3).Length = 0 Then
            iACID = DbAccess.GetNewId(tConn, "AUTH_ACCRWCLASS_ACID_SEQ,AUTH_ACCRWCLASS,ACID")
            Dim parms As New Hashtable From {{"ACID", iACID}, {"ACCOUNT", s_Account}, {"OCID", OCID}, {"MODIFYACCT", sm.UserInfo.UserID}}
            DbAccess.ExecuteNonQuery(iSql, tConn, parms)
            flagsave = True
        End If

        'RoleID: 1	系統管理者
        Dim Accdt As DataTable = Get_Account(PlanID, RID_1, "1", tConn)
        'Accdt=Get_Account(PlanID, RID_1, "1")
        If Accdt.Rows.Count > 0 Then
            For i As Integer = 0 To Accdt.Rows.Count - 1
                Dim SysAccount As String = Accdt.Rows(i).Item("Account")

                Dim pms2 As New Hashtable From {{"ACCOUNT", SysAccount}}
                Dim sql2 As String = " SELECT * FROM AUTH_ACCRWCLASS WHERE ACCOUNT=@ACCOUNT"
                Dim dt2 As DataTable = DbAccess.GetDataTable(sql2, tConn, pms2)
                '已經將承辦人新增
                ff3 = "OCID='" & OCID & "'"
                If dt2.Select(ff3).Length = 0 Then
                    iACID = DbAccess.GetNewId(tConn, "AUTH_ACCRWCLASS_ACID_SEQ, AUTH_ACCRWCLASS, ACID")
                    Dim parms As New Hashtable From {{"ACID", iACID}, {"ACCOUNT", SysAccount}, {"OCID", OCID}, {"MODIFYACCT", sm.UserInfo.UserID}}
                    DbAccess.ExecuteNonQuery(iSql, tConn, parms)
                End If
            Next
