    ''' <summary>STUD_ENTERTYPE2,ESERNUM,序號(自辦)-STUD_ENTERTYPE2_ESERNUM_SEQ2</summary>
    ''' <param name="trans"></param>
    ''' <returns></returns>
    Public Shared Function GETMAX_ESERNUM_SEQ2(ByRef trans As SqlTransaction) As Integer
        Dim iRst As Integer = -1
        Dim maxRetries As Integer = 3
        Dim retries As Integer = 0
        While retries < maxRetries
            iRst = DbAccess.GetAutoNum(trans.Connection, trans, "STUD_ENTERTYPE2_ESERNUM_SEQ2")
            Dim sql As String = $"SELECT COUNT(1) CT FROM STUD_ENTERTYPE2 WITH(NOLOCK) WHERE ESERNUM={iRst}"
            Using sCmd As New SqlCommand(sql, trans.Connection, trans)
                Dim vCNT As Integer = sCmd.ExecuteScalar()
                If vCNT = 0 Then Return iRst
            End Using
            retries += 1
        End While
        ' 如果超過最大重試次數，拋出例外
        Throw New Exception($"無法取得唯一的序號,請檢查資料庫或序號產生機制,GETMAX_ESERNUM_SEQ2 , {iRst}") 'Return iRst
    End Function

