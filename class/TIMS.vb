        'If Request("RoleID")=Cst_二級 Then '二級
        '    Acct="acct2" '二級使用者帳號
        '    AcctOther="acct1" '承辦人帳號
        'ElseIf Request("RoleID")=Cst_承辦人 Then '承辦人
        '    Acct="acct1" '承辦人帳號
        '    AcctOther="acct2" '二級使用者帳號
        'End If

        Dim i_sql As String = ""
        i_sql &= " INSERT INTO AUTH_ACCTORG( CID,PLANID,RID,ACCT1,ACCT2,MODIFYACCT,MODIFYDATE )" & vbCrLf
        i_sql &= " VALUES ( @CID,@PLANID,@RID,@ACCT1,@ACCT2, @MODIFYACCT,GETDATE() )" & vbCrLf

        Dim d_sql As String = " DELETE AUTH_ACCTORG WHERE CID=@CID" & vbCrLf

        For i As Integer = 0 To cbl_OrgList.Items.Count - 1 '迴圈目前的所有機構
            'Dim fff3 As String="" 'fff3=String.Format("RID='{0}'", cbl_OrgList.Items(i).Value) '搜尋機構值，無此值時新增(PlanID, RID)'要新增的帳號
