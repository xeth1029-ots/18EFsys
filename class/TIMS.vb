        Const Cst_承辦人 As Integer = 5
        'Const Cst_一般使用者 As Integer=99

        Select Case iRoleID
            Case Cst_二級
            Case Cst_承辦人
            Case Else
                errMsg = "使用者權限有誤-限定 二級 或 承辦人!"
                Return rst
        End Select

        Dim s_Acct As String = ""
        Dim s_AcctOther As String = ""
