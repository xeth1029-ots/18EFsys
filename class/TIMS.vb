    Public Shared Function getItemVar23(ByRef sm As SessionModel, ByRef MyPage As Page, ByRef oConn As SqlConnection, ByRef inParms As Hashtable, ByRef outParms As Hashtable) As Boolean
        Call OpenDbConn(oConn)

        Dim flag_LID_0 As Boolean = False 'true:登入者為署
        If sm.UserInfo.LID = 0 Then flag_LID_0 = True

        Dim rst As Boolean = True '正常為True 異常為False '並顯示訊息
        'inParms
        Dim RIDValue As String = GetMyValue2(inParms, "RIDValue")
        Dim s_PlanID As String = GetMyValue2(inParms, "PlanID")
        Dim sDistID As String = GetMyValue2(inParms, "DistID")
        Dim sTPLANID As String = GetMyValue2(inParms, "TPLANID")

        'outParms
        outParms = New Hashtable
        outParms.Clear()
        Dim s_ErrorMsg1 As String = ""
        Dim ItemVar1Value As String = "" 'ClearSQM(ItemVar1.Value)
        Dim ItemVar2Value As String = "" 'ClearSQM(ItemVar2.Value)
        '查詢開放設定
        Dim gvid23 As String = If(flag_LID_0, GetGlobalVar(sDistID, sTPLANID, "23", "1", oConn), GetGlobalVar(MyPage, "23", "1", oConn))
        If gvid23 = "Y" Then
            '開放設定,取機構設定資料

            Dim sql As String = ""
            sql &= " WITH WC1 AS (" & vbCrLf
            sql &= "   SELECT a.orgid" & vbCrLf
            sql &= "   FROM auth_relship a" & vbCrLf
            sql &= "   JOIN org_orginfo b ON b.orgid=a.orgid" & vbCrLf
            sql &= "   WHERE a.rid=@rid )" & vbCrLf
            sql &= " SELECT writeresult ,oralresult ,ocid" & vbCrLf
            sql &= " FROM org_writeoral" & vbCrLf
            sql &= " WHERE planid=@planid" & vbCrLf
            sql &= " AND orgid IN (SELECT ORGID FROM WC1)" & vbCrLf
            sql &= " ORDER BY ocid DESC" & vbCrLf
            Dim sCmd As New SqlCommand(sql, oConn)
            Dim dt As New DataTable
            With sCmd
                .Parameters.Clear()
                .Parameters.Add("planid", SqlDbType.VarChar).Value = s_PlanID
                .Parameters.Add("rid", SqlDbType.VarChar).Value = RIDValue '.Value
                'dt.Load(.ExecuteReader())
                dt = DbAccess.GetDataTable(sCmd.CommandText, oConn, sCmd.Parameters)
