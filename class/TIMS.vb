    ''' <summary> 年度設計去年與今年 (2018開始)</summary>
    ''' <param name="obj"></param>
    ''' <param name="tConn"></param>
    ''' <returns></returns>
    Public Shared Function Get_ROCYEARS2(ByVal obj As ListControl, ByVal tConn As SqlConnection) As ListControl
        Dim sql As String = ""
        sql &= " SELECT DISTINCT YEARS, RIGHT('000' + CONVERT(VARCHAR, CONVERT(INT, YEARS)-1911), 3) ROC_YEARS" & vbCrLf
        sql &= " FROM ID_PLAN WITH(NOLOCK)" & vbCrLf
        sql &= " WHERE YEARS>='2018'" & vbCrLf
        sql &= " ORDER BY YEARS DESC" & vbCrLf
        Dim dt As DataTable = DbAccess.GetDataTable(sql, tConn)
        With obj
            .DataSource = dt
            .DataTextField = "ROC_YEARS"
            .DataValueField = "YEARS"
            .DataBind()
            .AppendDataBoundItems = True
        End With
        Return obj
    End Function

    ''' <summary>取得系統日期資訊-年／月</summary>
    ''' <returns></returns>
    Public Shared Function Get_drYMVALUE1(tConn As SqlConnection) As DataRow
        Dim sql As String = ""
        sql &= " SELECT convert(varchar,YEAR(GETDATE())) YEARS" & vbCrLf
        sql &= " ,CASE WHEN DATEPART(MONTH, GETDATE())>=1 AND DATEPART(MONTH, GETDATE())<=6 THEN '01' ELSE '07' END MONTHS" & vbCrLf
        Return DbAccess.GetOneRow(sql, tConn)
    End Function

