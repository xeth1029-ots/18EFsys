    '產生 SqlDataAdapter ,可不傳 objConn
    Public Shared Function GetOneDA(ByVal objConn As SqlConnection) As SqlDataAdapter
        Dim da As New SqlDataAdapter With {.SelectCommand = New SqlCommand}
        If objConn Is Nothing Then objConn = DbAccess.GetConnection()
        da.SelectCommand.Connection = objConn
        Return da
    End Function

    ''' <summary>'利用 SqlCommand 產生 DataRow</summary>
    ''' <param name="sCmd"></param>
    ''' <param name="objconn"></param>
    ''' <returns></returns>
    Public Shared Function GetOneRow(ByRef sCmd As SqlCommand, ByRef objconn As SqlConnection) As DataRow
        Dim rst As DataRow = Nothing
        If sCmd Is Nothing Then Return rst
        Call OpenDbConn(objconn)
        Using dt1 As New DataTable
            With sCmd
                dt1.Load(.ExecuteReader())
                If dtHaveDATA(dt1) Then rst = dt1.Rows(0)
            End With
        End Using
        Return rst
    End Function

    '依Sql,SqlDataAdapter 填入DataTable 
    Public Shared Sub Fill(ByRef strSql As String, ByRef daObj As SqlDataAdapter, ByRef dtObj As DataTable)
        dtObj = New DataTable
        If daObj Is Nothing Then Return
        With daObj
            Dim isCloseConnFlag As Boolean = False
            If .SelectCommand.Connection.State = ConnectionState.Closed Then
                isCloseConnFlag = True
                .SelectCommand.Connection.Open()
            End If
            .SelectCommand.CommandText = strSql
            Try
                'dtObj.Load(.SelectCommand.ExecuteReader())
                .Fill(dtObj)
            Catch ex As Exception
                Dim V_GUID As String = Guid.NewGuid().ToString()
                LOG.Warn(ex.Message, ex)
                '==== 追錯email ==== 
                Dim strErrmsg As String = String.Concat("/* 追錯Email,strSql: */", "[", V_GUID, "]", vbCrLf, strSql, vbCrLf)
                For i As Integer = 0 To daObj.SelectCommand.Parameters.Count - 1
                    Dim xName As String = daObj.SelectCommand.Parameters(i).ParameterName
                    Dim xValue As String = Convert.ToString(daObj.SelectCommand.Parameters(i).Value)
                    strErrmsg &= String.Concat(" AND ", xName, "='", xValue, "'", vbCrLf)
                Next
                strErrmsg &= String.Concat("/* ex.Message : ", ex.Message, "*/", vbCrLf)
                Call WriteTraceLog(strErrmsg, ex)
                '==== 追錯email ==== 
                Throw New Exception($"[{V_GUID}]{vbCrLf},Fill Error: {ex.Message}")
            End Try
            If isCloseConnFlag Then
                If .SelectCommand.Connection.State = ConnectionState.Open Then .SelectCommand.Connection.Close()
            End If
        End With
    End Sub

