        ItemVar1Value = ClearSQM(ItemVar1Value)
        ItemVar2Value = ClearSQM(ItemVar2Value)
        If ItemVar1Value = "" Then
            rst = False
            'Common.MessageBox(MyPage, "系統尚未設定筆試的參數,請聯絡系統管理員!!")
