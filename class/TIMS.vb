    Public Shared Function Chk_MasterEnter(ByVal IDNO As String, ByVal OCID1 As String,
                                           ByVal objconn As SqlConnection) As String
        Call OpenDbConn(objconn) 'OpenDbConn(objconn)

        Dim rst As String = ""
        Dim sql As String = ""
        sql &= " SELECT 'X'" & vbCrLf
        sql &= " FROM STUD_ENTERTEMP a" & vbCrLf
        sql &= " JOIN STUD_ENTERTYPE b on b.SETID=a.SETID" & vbCrLf
        sql &= " WHERE b.CMASTER1='Y'" & vbCrLf
        sql &= " AND ISNULL(b.CMASTER1NT,'N')!='Y'" & vbCrLf '已切結
        sql &= " AND a.IDNO=@IDNO AND b.OCID1=@OCID1" & vbCrLf
        Dim dt As New DataTable
        Using sCmd As New SqlCommand(sql, objconn)
            With sCmd
                .Parameters.Clear()
                .Parameters.Add("IDNO", SqlDbType.VarChar).Value = IDNO
                .Parameters.Add("OCID1", SqlDbType.VarChar).Value = OCID1
                dt.Load(.ExecuteReader())
            End With
        End Using
        If dtHaveDATA(dt) Then
            rst = "Y"
            Return rst
        End If

        Dim sql2 As String = ""
        sql2 &= " SELECT 'X'" & vbCrLf
        sql2 &= " FROM STUD_ENTERTEMP2 a" & vbCrLf
        sql2 &= " JOIN STUD_ENTERTYPE2 b on b.eSETID=a.eSETID" & vbCrLf
        'signUpStatus-0:收件完成 1:報名成功 2:報名失敗 3:正取(Key_SelResult) 4:備取 5:未錄取
        sql2 &= " WHERE b.signUpStatus<>0" & vbCrLf
        sql2 &= " AND b.CMASTER1='Y'" & vbCrLf
        sql2 &= " AND ISNULL(b.CMASTER1NT,'N')!='Y'" & vbCrLf '已切結
        sql2 &= " AND a.IDNO=@IDNO AND b.OCID1=@OCID1" & vbCrLf
        Dim dt2 As New DataTable
        Using sCmd2 As New SqlCommand(sql2, objconn)
            With sCmd2
                .Parameters.Clear()
                .Parameters.Add("IDNO", SqlDbType.VarChar).Value = IDNO
                .Parameters.Add("OCID1", SqlDbType.VarChar).Value = OCID1
                dt2.Load(.ExecuteReader())
            End With
        End Using
        If dtHaveDATA(dt2) Then
            rst = "Y"
            Return rst
        End If
        Return rst
    End Function

