    ''' <returns></returns>
    Public Shared Function IsNumberStr(obj As Object) As Boolean
        Dim strVal As String = If(obj IsNot Nothing, Convert.ToString(obj), "")
        If String.IsNullOrEmpty(strVal) Then Return False
        For Each CH1 As Char In strVal
