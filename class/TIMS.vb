    ''' <param name="vKIND"></param>
    ''' <param name="oConn"></param>
    Public Shared Sub GET_KEYMAJORKIND(ByRef oCBL As ListControl, vKIND As String, oConn As SqlConnection)
        Dim dtC1 As New DataTable
        Dim sSql As String = " SELECT CONVERT(VARCHAR(3),MKNSEQ) MKNSEQ,KNAME,KIND,SORT FROM KEY_MAJORKIND WHERE KIND=@KIND ORDER BY SORT"
