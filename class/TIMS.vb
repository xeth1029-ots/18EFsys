    ''' <summary>
    ''' 回傳變數
    ''' </summary>
    ''' <param name="STR1"></param>
    ''' <returns></returns>
    Public Shared Function CHG_YESNO(ByVal STR1 As String) As String
        Return CHG_YESNO(STR1, "N")
    End Function

    ''' <summary> 返回Y/N </summary>
    ''' <param name="STR1"></param>
    ''' <param name="DEF1"></param>
    ''' <returns></returns>
    Public Shared Function CHG_YESNO(ByVal STR1 As String, ByVal DEF1 As String) As String
        Dim RST As String = ""
        STR1 = ClearSQM(STR1)
        If STR1 = "" AndAlso DEF1 <> "" Then Return DEF1 '使用預設值

        Select Case STR1
            Case "Y", "N"
                RST = STR1
            Case "是"
                RST = cst_YES
            Case "否"
                RST = cst_NO
            Case Else
                RST = "ERR-" & STR1
                Dim sErrMsg As String = ""
                sErrMsg = ""
                sErrMsg &= "##Function CHG_YESNO(ByVal STR1 As String) As String" & vbCrLf
                If STR1 <> "" Then sErrMsg &= String.Format(" ,STR1:[{0}]", STR1)
                If DEF1 <> "" Then sErrMsg &= String.Format(" ,DEF1:[{0}]", DEF1)
                If RST <> "" Then sErrMsg &= String.Format(" ,RST:[{0}]", RST)
                WriteTraceLog(sErrMsg)
        End Select
        Return RST
    End Function

