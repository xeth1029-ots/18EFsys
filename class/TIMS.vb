    ''' <summary>
    ''' 開班計畫場地檔 (學科)-sci-1/(術科)-tec-2-datarow
    ''' </summary>
    ''' <param name="COMIDNO"></param>
    ''' <param name="PlaceID"></param>
    ''' <param name="i_CIFICAT">(學科)-sci-1/(術科)-tec-2-</param>
    ''' <param name="oConn"></param>
    ''' <returns></returns>
    Public Shared Function Get_SciTechDR(ByVal COMIDNO As String, ByVal PlaceID As String, ByVal i_CIFICAT As Integer, ByRef oConn As SqlConnection) As DataRow
        Dim dr As DataRow = Nothing
        'i_CIFICAT  (學科)-sci-1/(術科)-tec-2-
        Dim parms As New Hashtable From {{"COMIDNO", COMIDNO}, {"PlaceID", PlaceID}, {"CIFICAT", Get_CIFICAT(i_CIFICAT)}}
        Dim sql As String = ""
        sql &= " SELECT a.PlaceID" & vbCrLf
        sql &= " ,concat(a.PlaceNAME,' (',dbo.FN_GZIP33(a.ZipCode,a.ZIP6W),')',b.ZipName,a.Address) Name" & vbCrLf
        sql &= " ,a.CLASSIFICATION" & vbCrLf
        sql &= " ,a.PTID,a.PlaceNAME" & vbCrLf
        sql &= " FROM dbo.PLAN_TRAINPLACE a" & vbCrLf
        sql &= " JOIN dbo.VIEW_ZIPNAME b ON a.ZipCode=b.ZipCode" & vbCrLf
        sql &= " WHERE a.CLASSIFICATION IN (@CIFICAT,3)" & vbCrLf
        sql &= " AND a.ModifyType IS NULL AND a.COMIDNO=@COMIDNO AND a.PlaceID=@PlaceID" & vbCrLf
        dr = DbAccess.GetOneRow(sql, oConn, parms)
        Return dr
    End Function

