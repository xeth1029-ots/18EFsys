    Public Shared Function IsNumeric2(ByVal obj As Object) As Boolean
        'Dim Rst As Boolean=False
        If (obj Is Nothing) OrElse Not IsNumeric(obj) Then Return False
        If (CINT1(obj) = Val(obj)) AndAlso (Val(obj) > 0) Then '須為整數'須大於0
