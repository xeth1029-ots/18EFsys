    '用來檢驗帳號是否已經存在Auth_Account與Auth_AccountTemp
    'Type為Adop時，搜尋正式帳號資料Auth_Account
    'Type為Temp時，搜尋申請待審帳號資料Auth_AccountTemp
    '當帳號存在時，返回True反之False
    Public Shared Function Chk_Account(ByVal tmpAcct As String, ByVal type As String, ByRef oConn As SqlConnection) As Boolean
        'Dim rst As Boolean = True
        'Optional ByVal type As String="Adop"
        If type = "" Then type = "ADOP"
        Dim MtmpAcct As String = ClearSQM(tmpAcct)
        Select Case UCase(type)
            Case "ADOP"
                Dim PMS1 As New Hashtable From {{"Account", MtmpAcct}}
                Dim sqlStr As String = "SELECT ACCOUNT FROM AUTH_ACCOUNT WHERE Account=@Account "
                Dim obj1 As Object = DbAccess.ExecuteScalar(sqlStr, oConn, PMS1)
                If obj1 Is Nothing OrElse IsDBNull(obj1) OrElse $"{obj1}" = "" Then Return False
            Case "TEMP"
                Dim PMS1 As New Hashtable From {{"Account", MtmpAcct}}
                Dim sqlStr As String = "SELECT ACCOUNT FROM AUTH_ACCOUNTTEMP WHERE Account=@Account and AuditStatus is null"
                Dim obj1 As Object = DbAccess.ExecuteScalar(sqlStr, oConn, PMS1)
                If obj1 Is Nothing OrElse IsDBNull(obj1) OrElse $"{obj1}" = "" Then Return False
        End Select
        Return True
    End Function

