    '差異年度功能 1年之內:2009/9/1~2010/8/31:0 ; 1年以上:2009/9/1~2010/9/1:1 ; 2年:2009/9/1~2011/9/1:2
    Public Shared Function DateDiffYears(ByVal StartDate As Date, ByVal EndDate As Date) As Integer
        Dim int_Year As Integer = 0
        Dim NextStartDate As Date = DateAdd(DateInterval.Year, 1, StartDate)
        If DateDiff(DateInterval.Day, NextStartDate, EndDate) < 0 Then
            int_Year = 0
        Else
            While (NextStartDate <= EndDate)
                int_Year += 1
                NextStartDate = NextStartDate.AddYears(1)
            End While
        End If
        Return int_Year
    End Function

    '取得傳入年月之最後一日
    Public Shared Function YearsMonth_GetDate(ByVal Year1 As String, ByVal Month1 As String) As Date
        Dim YMD1 As String = $"{Year1}-{Month1}-1"
        If Not IsDate(YMD1) Then Throw New Exception($"組合日期格式有誤!,{YMD1},[{Guid.NewGuid().ToString()}]")

        Dim StartDate As Date = CDate(YMD1)
        Dim NextStartDate As Date = DateAdd(DateInterval.Day, -1, DateAdd(DateInterval.Month, 1, StartDate))
        Return NextStartDate
    End Function

