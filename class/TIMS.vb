    ''' <summary>
    ''' 檢核攻擊xml
    ''' </summary>
    ''' <param name="unparsedXml"></param>
    ''' <returns></returns>
    ''' <remarks></remarks>
    Public Shared Function Check_xml(ByRef unparsedXml As String) As Boolean
        Dim rst As Boolean = False '異常
        If unparsedXml Is Nothing Then Return rst '異常
        If unparsedXml = "" Then Return rst '異常
        Const cst_excep As String = "CommunicationException,WebException,IOException,XmlException"
        For Each s_v As String In cst_excep.Split(",")
            If (unparsedXml.IndexOf(s_v) > -1) Then Return rst '異常
        Next
        Try
            'https://blogs.msdn.microsoft.com/tomholl/2009/05/21/protecting-against-xml-entity-expansion-attacks/
            '為Xml驗證準備文本閱讀器和設置
            Using textReader As New StringReader(unparsedXml)
                'settings.MaxCharactersInDocument=10000
                Dim settings As New XmlReaderSettings With {
                    .XmlResolver = Nothing,
                    .MaxCharactersInDocument = unparsedXml.Length * 2
                }
                '成功解析文件，否則XmlException將被拋出
                Using reader As XmlReader = XmlReader.Create(textReader, settings)
                    While (reader.Read())
                    End While
                End Using
            End Using

            rst = True '正常為true
        Catch ex As Exception
            Dim errmsg1 As String = ""
            errmsg1 &= String.Format("##check_xml ex.Message: {0}", ex.Message) & vbCrLf
            errmsg1 &= String.Format("##check_xml unparsedXml: {0}", unparsedXml) & vbCrLf
            errmsg1 &= String.Format("##check_xml ex.ToString: {0}", ex.ToString) & vbCrLf
            WriteTraceLog(errmsg1, ex)
            Return rst
        End Try
        Return rst
    End Function

    '檢核日期時間是否在期限之內
    Public Shared Function Chk_DateTime3(ByVal YMDH24MISS1 As String, ByVal YMDH24MISS2 As String,
                                         ByRef oConn As SqlConnection) As Boolean
        Dim rst As Boolean = False 'false:不是 'true:是
        'YMDH24MISS: yyyy/MM/dd hh24:mi:ss
        Dim sql As String = ""
        sql &= " SELECT CASE WHEN convert(datetime, @YMDH24MISS1)<=GETDATE()" & vbCrLf
        sql &= " AND convert(datetime, @YMDH24MISS2)>=GETDATE() then 'Y' END MSG1" & vbCrLf
        Dim sCmd As New SqlCommand(sql, oConn)
        Call OpenDbConn(oConn)
        Dim dt1 As New DataTable
        With sCmd
            .Parameters.Clear()
            .Parameters.Add("YMDH24MISS1", SqlDbType.VarChar).Value = YMDH24MISS1
            .Parameters.Add("YMDH24MISS2", SqlDbType.VarChar).Value = YMDH24MISS2
            dt1.Load(.ExecuteReader())
        End With
        If dt1.Rows.Count = 0 Then Return False '無值(預設為未在期限之內)(此情況應不可能產生)
        If Convert.ToString(dt1.Rows(0)("MSG1")) = "Y" Then Return True '有值(目前在期限之內)
        Return rst
    End Function

    ''' <summary> 判斷當前是否為網站停機期間 </summary>
    ''' <param name="Mypage"></param>
    ''' <param name="oConn"></param>
    ''' <returns></returns>
    Public Shared Function Stop1(ByRef MyPage As Page, ByRef oConn As SqlConnection) As Boolean
        Dim stop_stime As String = Utl_GetConfigSet("stop_stime")
        Dim stop_etime As String = Utl_GetConfigSet("stop_etime")
        Dim stop_url As String = Utl_GetConfigSet("stop_url")

        Dim isStop As Boolean = False 'false:不停機 true:停機

        '沒停機設定 (3缺1不可)
        If stop_stime = "" Then Return isStop
        If stop_etime = "" Then Return isStop
        If stop_url = "" Then Return isStop
        If Not IsDate1(stop_stime) Then Return isStop '設定日期有誤，非日期格式
        If Not IsDate1(stop_etime) Then Return isStop '設定日期有誤，非日期格式

        '若時間順序有誤，修正時間順序
        If DateDiff(DateInterval.Second, CDate(stop_stime), CDate(stop_etime)) < 0 Then
            Dim tmp_time As String = stop_stime
            stop_stime = stop_etime
            stop_etime = tmp_time
        End If
        'Dim iDay As Integer=DateDiff(DateInterval.Day, CDate(stop_stime), CDate(stop_etime))
        '超過60天的停機，似乎有些異常，將離開
        'If iDay > 60 Then Exit Sub

        'https://jira.turbotech.com.tw/browse/TIMSC-47
        Try
            '檢核日期時間是在期限之內
            isStop = Chk_DateTime3(stop_stime, stop_etime, oConn)
        Catch ex As Exception
            LOG.Warn("Stop1: " & ex.ToString(), ex)
            '檢核日期時間失敗, 可能是資料庫異常
            isStop = True
        End Try

        '導向停機頁面
        If isStop Then Call Utl_Redirect(MyPage, oConn, stop_url)

        Return isStop
    End Function

    ''' <summary>  網站停止功能2(只能使用在後台停止-login) </summary>
    ''' <param name="Mpg"></param>
    ''' <param name="oConn"></param>
    Public Shared Sub Stop2(ByRef Mpg As Page, ByRef oConn As SqlConnection)
        Dim sRePwd As String = ClearSQM(Mpg.Request("repwd")) '增加密碼安全性(ENC)(輸入當日yyyyMMdd)
        Dim sReurl As String = ClearSQM(Mpg.Request("reurl")) 'Y:繼續使用後台登入

        Select Case sReurl
            Case "Y"
                '日曆顯示功能
                Dim aNow As DateTime = GetSysDateNow(oConn)
                Dim sRePwd2 As String = RSA20031.AesDecrypt2(sRePwd)
                'flag_pwdOK : false:密碼有誤 / true:密碼正確
                Dim flag_pwdOK As Boolean = (sRePwd2 <> "" AndAlso sRePwd2 = aNow.ToString("yyyyMMdd")) '密碼正確
                If Not flag_pwdOK Then
                    LOG.WarnFormat("##Stop2 Reurl:{0}", sReurl)
                    LOG.WarnFormat("##Stop2 repwd:{0}", sRePwd)
                    '密碼有誤
                    Call CloseDbConn(oConn)
                    With Mpg
                        .Response.Status = cst_404NotFound
                        If (.Response.StatusCode <> 404) Then .Response.StatusCode = 404
                        .Response.End()
                        Return
                    End With
                    '條件達成 (關閉後台) 啟用自然人憑證登入
                    'Call TIMS.Utl_Redirect(Me, objconn, Login_url)
                End If

            Case Else
                Dim s_BackLogin As String = Utl_GetConfigSet("BackLogin") 'Y:啟用 / N:關閉 (後台登入)
                'Dim Login_url As String=Utl_GetConfigSet("MOICA_Login") '自然人憑證頁面
                Dim s_Bk_Stop_Stime As String = Utl_GetConfigSet("Bk_Stop_Stime") '關閉後台開始時間
                Dim s_Bk_Stop_Etime As String = Utl_GetConfigSet("Bk_Stop_Etime") '關閉後台時間結束
                Dim fg_IsDate1_Stime As Boolean = IsDate1(s_Bk_Stop_Stime) '設定日期有誤，非日期格式
                Dim fg_IsDate1_Etime As Boolean = IsDate1(s_Bk_Stop_Etime) '設定日期有誤，非日期格式
                If fg_IsDate1_Stime AndAlso fg_IsDate1_Etime Then
                    '停止類型'(含有時間功能)
                    '若時間順序有誤，修正時間順序
                    If DateDiff(DateInterval.Second, CDate(s_Bk_Stop_Stime), CDate(s_Bk_Stop_Etime)) < 0 Then
                        Dim tmp_time As String = s_Bk_Stop_Stime
                        s_Bk_Stop_Stime = s_Bk_Stop_Etime
                        s_Bk_Stop_Etime = tmp_time
                    End If
                    Dim FlagGotoErr As Boolean = False 'go to 網站維護 true:停止
                    Try
                        '檢核日期時間是在期限之內
                        Dim flagBln1 As Boolean = Chk_DateTime3(s_Bk_Stop_Stime, s_Bk_Stop_Etime, oConn)
                        If flagBln1 Then FlagGotoErr = True 'true:停止
                    Catch ex As Exception
                        LOG.Warn("Stop2: " & ex.ToString(), ex)
                        '檢核日期時間是在期限之內
                        FlagGotoErr = True 'true:停止
                    End Try

                    If FlagGotoErr Then
                        LOG.WarnFormat("##Stop2 Bk_Stop_Stime:{0}", s_Bk_Stop_Stime)
                        LOG.WarnFormat("##Stop2 Bk_Stop_Etime:{0}", s_Bk_Stop_Etime)
                        '檢核日期時間是在期限之內
                        Call CloseDbConn(oConn)
                        With Mpg
                            .Response.Status = cst_404NotFound
                            If (.Response.StatusCode <> 404) Then .Response.StatusCode = 404
                            .Response.End()
                            Return
                        End With
                    End If
                End If

                'If sReurl <> "Y" AndAlso BackLogin="N" AndAlso Login_url <> "" Then
                If s_BackLogin = "N" Then
                    LOG.WarnFormat("##Stop2 BackLogin:{0}", s_BackLogin)
                    Call CloseDbConn(oConn)
                    With Mpg
                        .Response.Status = cst_404NotFound
                        If (.Response.StatusCode <> 404) Then .Response.StatusCode = 404
                        .Response.End()
                        Return
                    End With
                    '3個條件達成 (關閉後台) 啟用自然人憑證登入
                    'Call TIMS.Utl_Redirect(Me, objconn, Login_url)
                End If

                Call TIMS.Stop4(Mpg, oConn)
        End Select

    End Sub

    '網站停止功能3(只能使用在後台停止) false:(正常繼續) true:(異常中斷)
    Public Shared Function Stop3(ByRef Mpg As Page, ByRef oConn As SqlConnection) As Boolean
        'Dim rst As Boolean=False
        Dim blnRC As Boolean = Not (sUtl_ChkTest()) '正式環境為TRUE'測試環境為FALSE
        Dim RNUM As String = Utl_GetConfigSet("RNUM")
        Dim rqR As String = ClearSQM(Mpg.Request("rqR"))
        If blnRC AndAlso RNUM <> "" AndAlso UCase(RNUM) <> UCase(rqR) Then
            LOG.WarnFormat("##Stop3 RNUM:{0}", RNUM)
            LOG.WarnFormat("##Stop3 rqR:{0}", rqR)
            Mpg.Session.RemoveAll()
            Mpg.Session.Abandon()
            Call sUtl_404NOTFOUND(Mpg, oConn)
            Return True
        End If
        Return False
    End Function

    ''' <summary> 依系統參數 MOICA_LOGIN/USE_TIME/USE_TIME_BEGIN/USE_TIME_END 停止網站 </summary>
    ''' <param name="Mpg"></param>
    ''' <param name="oConn"></param>
    Public Shared Sub Stop4(ByRef Mpg As Page, ByRef oConn As SqlConnection)
        Const cst_sv_MOICA_LOGIN As String = "MOICA_LOGIN"
        Dim fg_stop_web As Boolean = False
        Dim s_USE_TIME_BEGIN As String = GetSystemValue(cst_sv_MOICA_LOGIN, "USE_TIME_BEGIN", oConn)
        Dim s_USE_TIME_END As String = GetSystemValue(cst_sv_MOICA_LOGIN, "USE_TIME_END", oConn)
        Dim s_USE_TIME As String = GetSystemValue(cst_sv_MOICA_LOGIN, "USE_TIME", oConn)
        Dim s_TIMENOW_HHmm As String = DateTime.Now.ToString("HH:mm")
        If s_USE_TIME = "Y" AndAlso s_USE_TIME_BEGIN <> "" AndAlso s_USE_TIME_END <> "" Then
            fg_stop_web = Not (s_USE_TIME_BEGIN <= s_TIMENOW_HHmm AndAlso s_TIMENOW_HHmm <= s_USE_TIME_END)
        End If
        If fg_stop_web Then
            LOG.WarnFormat("##Stop4 TIMENOW_HHmm:{0}", s_TIMENOW_HHmm)
            LOG.WarnFormat("##Stop4 USE_TIME_BEGIN:{0}", s_USE_TIME_BEGIN)
            LOG.WarnFormat("##Stop4 USE_TIME_END:{0}", s_USE_TIME_END)
            LOG.WarnFormat("##Stop4 USE_TIME:{0}", s_USE_TIME)
            Call CloseDbConn(oConn)
            With Mpg
                .Response.Status = cst_404NotFound
                If (.Response.StatusCode <> 404) Then .Response.StatusCode = 404
                .Response.End()
                Return
            End With
        End If
    End Sub

