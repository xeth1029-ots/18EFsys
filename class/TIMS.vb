    ''' <param name="oConn"></param>
    ''' <returns></returns>
    Public Shared Function GET_Duplicate_Student(ByVal OCID As String, ByVal iTYPE As Integer, ByRef oConn As SqlConnection) As DataTable
        'Dim DTRST As DataTable = Nothing '若查無資料將輸出NOTHING '32305
        OCID = ClearSQM(OCID)
        If OCID = "" Then Return Nothing

        Dim sql As String = ""
        sql &= " WITH WS1 AS ( SELECT ss.Name,ss.IDNO" & vbCrLf
        sql &= " ,ss.DISTNAME,ss.planname,ss.OrgName" & vbCrLf
        sql &= " ,ss.planid ,ss.comidno, ss.seqno" & vbCrLf
        sql &= " ,ss.OCID,ss.CLASSCNAME2" & vbCrLf
        'sql &= " ,ss.OCID,ss.CLASSCNAME,ss.CYCLTYPE" & vbCrLf
        sql &= " ,ss.STDATE,ss.FTDATE" & vbCrLf
        sql &= " ,concat(format(ss.STDate,'yyyy/MM/dd'),' ~ ',format(ss.FTDate,'yyyy/MM/dd')) SFDATE,ss.STUDSTATUS,ss.STUDSTATUS2" & vbCrLf
        sql &= " FROM dbo.V_STUDENTINFO ss" & vbCrLf
        '1年內的資料 
        sql &= " WHERE ss.stdate >= dateadd(year,-1,getdate())" & vbCrLf
        sql &= String.Concat(" and ss.OCID=", OCID) & vbCrLf
        sql &= " )" & vbCrLf

        sql &= " ,WS2 AS ( SELECT ss.Name,ss.IDNO" & vbCrLf
        sql &= " ,ss.DISTNAME,ss.planname,ss.OrgName" & vbCrLf
        sql &= " ,ss.planid ,ss.comidno, ss.seqno" & vbCrLf
        sql &= " ,ss.OCID,ss.CLASSCNAME2" & vbCrLf
        'sql &= " ,ss.OCID,ss.CLASSCNAME,ss.CYCLTYPE" & vbCrLf
        sql &= " ,ss.STDATE,ss.FTDATE" & vbCrLf
        sql &= " ,concat(format(ss.STDate,'yyyy/MM/dd'),' ~ ',format(ss.FTDate,'yyyy/MM/dd')) SFDATE,ss.STUDSTATUS,ss.STUDSTATUS2" & vbCrLf
        sql &= " FROM dbo.V_STUDENTINFO ss" & vbCrLf
        '1年內的資料 
        sql &= " WHERE ss.stdate >= dateadd(year,-1,getdate())" & vbCrLf
        sql &= String.Concat(" and ss.OCID<>", OCID) & vbCrLf
        sql &= " AND EXISTS (SELECT 'X' FROM WS1 X WHERE X.IDNO=SS.IDNO)" & vbCrLf
        '排除產學訓計畫 (重複問題)
        If iTYPE = 1 Then sql &= " and ss.TPLANID <> '28'" & vbCrLf
        sql &= " )" & vbCrLf

        sql &= " ,WS3 AS ( SELECT WS1.Name" & vbCrLf
        sql &= " ,WS1.IDNO" & vbCrLf
        sql &= " ,WS1.DISTNAME" & vbCrLf
        sql &= " ,WS1.planname" & vbCrLf
        sql &= " ,WS1.OrgName" & vbCrLf
        sql &= " ,WS1.OCID,WS1.CLASSCNAME2 CLASSNAME" & vbCrLf
        sql &= " ,WS1.Sfdate,WS1.STUDSTATUS2 STUDSTATUS_N1" & vbCrLf
        sql &= " ,dbo.FN_GET_PLAN_ONCLASS(WS1.PlanID,WS1.ComIDNO,WS1.SeqNo,'WEEKTIME') WEEKS" & vbCrLf

        sql &= " ,WS2.DISTNAME DISTNAME2" & vbCrLf
        sql &= " ,WS2.planname planname2" & vbCrLf
        sql &= " ,WS2.OrgName OrgName2" & vbCrLf
        sql &= " ,WS2.OCID OCID2,WS2.CLASSCNAME2 CLASSNAME2" & vbCrLf
        sql &= " ,WS2.Sfdate Sfdate2" & vbCrLf
        sql &= " ,dbo.FN_GET_PLAN_ONCLASS(WS2.PlanID,WS2.ComIDNO,WS2.SeqNo,'WEEKTIME') WEEKS2" & vbCrLf

        sql &= " ,case when (WS2.STDate <= WS1.STDate and WS1.STDate <= WS2.FTDate)" & vbCrLf
        sql &= "  OR (WS2.STDate <= WS1.FTDate and WS1.FTDate <= WS2.FTDate)" & vbCrLf
        sql &= "  OR (WS1.STDate <= WS2.STDate and WS1.FTDate >= WS2.FTDate) then 1 end CHKR123" & vbCrLf
        sql &= " FROM WS1" & vbCrLf
        sql &= " JOIN WS2 ON WS1.IDNO=WS2.IDNO" & vbCrLf
        sql &= " )" & vbCrLf

        sql &= " SELECT WS3.Name" & vbCrLf
        sql &= " ,WS3.IDNO" & vbCrLf
        sql &= " ,WS3.DISTNAME" & vbCrLf
        sql &= " ,WS3.planname" & vbCrLf
        sql &= " ,WS3.OrgName" & vbCrLf
        sql &= " ,WS3.OCID,WS3.CLASSNAME" & vbCrLf
        sql &= " ,WS3.Sfdate,WS3.STUDSTATUS_N1" & vbCrLf
        sql &= " ,WS3.WEEKS" & vbCrLf

        sql &= " ,WS3.DISTNAME2" & vbCrLf
        sql &= " ,WS3.planname2" & vbCrLf
        sql &= " ,WS3.OrgName2" & vbCrLf
        sql &= " ,WS3.OCID2,WS3.CLASSNAME2" & vbCrLf
        sql &= " ,WS3.Sfdate2" & vbCrLf
        sql &= " ,WS3.WEEKS2" & vbCrLf
        sql &= " ,WS3.CHKR123" & vbCrLf
        sql &= " FROM WS3" & vbCrLf
        sql &= " WHERE 1=1" & vbCrLf 'AND WS3.CHKR123=1 '因為效能關係，所以不查此值

        Dim ff3 As String = "CHKR123=1"
        Dim ss3 As String = "IDNO"
        Dim DTRST As DataTable = DbAccess.GetDataTable(sql, oConn)
        If DTRST.Rows.Count > 0 Then
            If DTRST.Select(ff3, ss3).Length = 0 Then
                DTRST = Nothing
                Return DTRST
            End If
            DTRST = DTRST.Select(ff3, ss3).CopyToDataTable().Copy
        End If

        If TIMS.dtNODATA(DTRST) Then DTRST = Nothing '若查無資料將輸出NOTHING
        Return DTRST
    End Function

    Public Shared Function GET_OnlyOne_OCID(ByRef MyPage As Page, ByVal s_RIDValue As String, ByVal tConn As SqlConnection) As DataRow
        Dim rst As DataRow = Nothing
        If s_RIDValue = "" Then Return rst
        Dim sm As SessionModel = SessionModel.Instance()

        Dim sql As String = ""
        sql &= " WITH WR1 AS ( SELECT d.OrgID,d.RID FROM Auth_Relship d" & vbCrLf
        sql &= "   JOIN Org_OrgInfo e on e.OrgID=d.OrgID" & vbCrLf
        sql &= "   WHERE d.RID=@RID)" & vbCrLf
        sql &= " SELECT ISNULL(r.total,0) total" & vbCrLf
        sql &= " ,a.OCID" & vbCrLf
        sql &= " ,a.STDate" & vbCrLf
        sql &= " ,a.FTDate" & vbCrLf
        sql &= " ,a.TMID" & vbCrLf
        sql &= " ,ISNULL(b.JobID,b.TrainID) TrainID" & vbCrLf
        sql &= " ,ISNULL(b.JobName,b.TrainName) TrainName" & vbCrLf
        sql &= " ,dbo.FN_GET_CLASSCNAME(a.CLASSCNAME,a.CYCLTYPE) CLASSNAME" & vbCrLf
        sql &= " ,a.CLASSCNAME" & vbCrLf
        sql &= " ,a.CYCLTYPE" & vbCrLf
        sql &= " ,CASE WHEN a.FTDate >= GETDATE() THEN 1 ELSE 0 END ClassRoundIndex" & vbCrLf
        sql &= " FROM CLASS_CLASSINFO a" & vbCrLf
        sql &= " JOIN Key_TrainType b on b.TMID=a.TMID" & vbCrLf
        sql &= " JOIN ID_PLAN ip on ip.PlanID=a.PlanID" & vbCrLf
        sql &= " JOIN WR1 d on d.RID=a.RID" & vbCrLf
        sql &= " JOIN ( SELECT a.RID,COUNT(1) total" & vbCrLf
        sql &= "   from CLASS_CLASSINFO a" & vbCrLf
        sql &= "   JOIN ID_PLAN ip on ip.PlanID=a.PlanID" & vbCrLf
        sql &= "   JOIN WR1 d on d.RID=a.RID" & vbCrLf
        sql &= "   WHERE a.RID=@RID AND ip.Years=@Years AND ip.TPlanID=@TPlanID" & vbCrLf
        sql &= "   GROUP BY a.RID" & vbCrLf
        sql &= " ) r on a.rid=r.rid" & vbCrLf
        sql &= " WHERE a.RID=@RID" & vbCrLf
        sql &= " AND ip.Years=@Years" & vbCrLf
        sql &= " AND ip.TPlanID=@TPlanID" & vbCrLf
        Dim sCmd As New SqlCommand(sql, tConn)
        Call OpenDbConn(tConn)
        Dim dt As New DataTable
        With sCmd
            .Parameters.Clear()
            .Parameters.Add("RID", SqlDbType.VarChar).Value = s_RIDValue
            .Parameters.Add("Years", SqlDbType.VarChar).Value = sm.UserInfo.Years
            .Parameters.Add("TPlanID", SqlDbType.VarChar).Value = sm.UserInfo.TPlanID
            dt.Load(.ExecuteReader())
        End With
        If dt.Rows.Count > 0 Then rst = dt.Rows(0)
        Return rst
    End Function

