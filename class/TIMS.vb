    ''' <summary>
    ''' 判斷是否為有效日期(西元) (空白不是正確的日期格式) yyyy  > 1753
    ''' </summary>
    ''' <param name="strday"></param>
    ''' <returns></returns>
    Public Shared Function IsDate1(ByVal strday As String) As Boolean
        Dim FLAG As Boolean = False
        'Errmsg += "開訓區間 起始日期格式有誤" & vbCrLf
        If strday Is Nothing Then Return FLAG
        If strday = "" Then Return FLAG
        If strday.Length < 8 Then Return FLAG
        If Not IsDate(strday) Then Return FLAG
        If CDate(strday).Year > 1753 Then Return True
        Return FLAG
    End Function

    ''' <summary>
    ''' 若有時間資料TRUE
    ''' </summary>
    ''' <param name="strday"></param>
    ''' <returns></returns>
    Public Shared Function IsDateTime1(ByVal strday As String) As Boolean
        Dim FLAG As Boolean = IsDate1(strday)
        If Not FLAG Then Return FLAG '都非日期了，當然也非時間
        Const cst_datetimef1 As String = "HH:mm:ss"
        Const cst_datetimef2 As String = "00:00:00" 'DateTime 為0 返回FALSE
        If CDate(strday).ToString(cst_datetimef1) = cst_datetimef2 Then Return False '是日期，且時間為0
        Return FLAG '時間不為0'TRUE
    End Function

    ''' <summary>
