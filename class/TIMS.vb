    ''' <summary>使用 PLAN_REVISESUBFL計算 取得線上送件進度</summary>
    ''' <param name="oConn"></param>
    ''' <param name="showMsg"></param>
    ''' <param name="rPMS"></param>
    ''' <returns></returns>
    Public Shared Function GET_iPROGRESS_PR(oConn As SqlConnection, ByRef showMsg As String, ByRef rPMS As Hashtable) As Integer
        Dim iProgress As Integer = 0
        showMsg = ""

        Dim rORGKINDGW As String = GetMyValue2(rPMS, "ORGKINDGW")
        Dim rALTDATAID As String = GetMyValue2(rPMS, "ALTDATAID")
        Dim rPLANID As String = GetMyValue2(rPMS, "PLANID")
        Dim rCOMIDNO As String = GetMyValue2(rPMS, "COMIDNO")
        Dim rSEQNO As String = GetMyValue2(rPMS, "SEQNO")
        Dim rSCDATE As String = GetMyValue2(rPMS, "CDATE")
        Dim rSUBSEQNO As String = GetMyValue2(rPMS, "SUBSEQNO")

        '(任一錯誤不可儲存)
        If rALTDATAID = "" OrElse rORGKINDGW = "" Then Return -1 '(異常)
        If rPLANID = "" OrElse rCOMIDNO = "" OrElse rSEQNO = "" Then Return -1 '(異常)
        If rSCDATE = "" OrElse rSUBSEQNO = "" Then Return -1 '(異常)

        Dim rParmsA As New Hashtable From {{"ORGKINDGW", rORGKINDGW}, {"ALTDATAID", rALTDATAID}}
        Dim sSqlA As String = "SELECT 1 FROM KEY_REVISESUB WHERE ORGKINDGW=@ORGKINDGW AND ALTDATAID=@ALTDATAID"
        Dim dtA As DataTable = DbAccess.GetDataTable(sSqlA, oConn, rParmsA)
        If dtA Is Nothing Then Return iProgress

        Dim rParms As New Hashtable From {{"PLANID", CINT1(rPLANID)}, {"COMIDNO", rCOMIDNO}, {"SEQNO", CINT1(rSEQNO)},
            {"CDATE", Cdate3(rSCDATE)}, {"SUBSEQNO", CINT1(rSUBSEQNO)}, {"ALTDATAID", CINT1(rALTDATAID)}, {"ORGKINDGW", rORGKINDGW}}
        Dim rsSql As String = ""
        rsSql &= " SELECT 1 FROM PLAN_REVISESUBFL a" & vbCrLf
        rsSql &= " JOIN KEY_REVISESUB kb on kb.RVSID=a.RVSID" & vbCrLf
        rsSql &= " JOIN PLAN_REVISE r on r.PLANID=a.PLANID AND r.COMIDNO=a.COMIDNO AND r.SEQNO=a.SEQNO AND r.CDATE=a.CDATE AND r.SUBSEQNO=a.SUBSEQNO" & vbCrLf
        rsSql &= " WHERE a.PLANID=@PLANID AND a.COMIDNO=@COMIDNO AND a.SEQNO=@SEQNO AND a.CDATE=@CDATE AND a.SUBSEQNO=@SUBSEQNO" & vbCrLf
        rsSql &= " AND kb.ORGKINDGW=@ORGKINDGW AND kb.ALTDATAID=@ALTDATAID" & vbCrLf
        Dim dt As DataTable = DbAccess.GetDataTable(rsSql, oConn, rParms)
        If dt Is Nothing Then Return iProgress

        Dim iCNT1SC As Double = dt.Rows.Count
        Dim iCNT1AL As Double = dtA.Rows.Count
        iProgress = If(iCNT1AL > 0, (iCNT1SC / iCNT1AL * 100), 0)

        If iProgress > 30 AndAlso iProgress < 100 Then
            Dim rParms2 As New Hashtable From {{"PLANID", CINT1(rPLANID)}, {"COMIDNO", rCOMIDNO}, {"SEQNO", CINT1(rSEQNO)},
                {"CDATE", Cdate3(rSCDATE)}, {"SUBSEQNO", CINT1(rSUBSEQNO)}, {"ALTDATAID", CINT1(rALTDATAID)}, {"ORGKINDGW", rORGKINDGW}}
            Dim sSql2 As String = ""
            sSql2 &= " SELECT kb.RVID,kb.RVNAME,kb.ORGKINDGW" & vbCrLf
            sSql2 &= " ,concat(kb.RVID,'.',kb.RVNAME) RVNAME2" & vbCrLf
            sSql2 &= " ,CASE WHEN a.BVFID IS NULL THEN 'Y' END BVFID_NG" & vbCrLf
            sSql2 &= " FROM PLAN_REVISE r" & vbCrLf
            sSql2 &= " JOIN KEY_REVISESUB kb ON kb.ALTDATAID=r.ALTDATAID AND kb.ALTDATAID=@ALTDATAID AND kb.ORGKINDGW=@ORGKINDGW" & vbCrLf
            sSql2 &= " LEFT JOIN PLAN_REVISESUBFL a ON a.PLANID=r.PLANID AND a.COMIDNO=r.COMIDNO AND a.SEQNO=r.SEQNO AND a.CDATE=r.CDATE AND a.SUBSEQNO=r.SUBSEQNO AND a.RVSID=kb.RVSID" & vbCrLf
            sSql2 &= " WHERE r.PLANID=@PLANID AND r.COMIDNO=@COMIDNO AND r.SEQNO=@SEQNO AND r.CDATE=@CDATE AND r.SUBSEQNO=@SUBSEQNO" & vbCrLf
            Dim dt2 As DataTable = DbAccess.GetDataTable(sSql2, oConn, rParms2)
            If dt2.Rows.Count = 0 Then Return iProgress
            For Each dr2 As DataRow In dt2.Rows
                If (Convert.ToString(dr2("BVFID_NG")) = "Y") Then
                    showMsg &= String.Concat(If(showMsg <> "", "、", ""), dr2("RVNAME2"))
                End If
            Next
        End If
        Return iProgress
        'labProgress.Text=String.Concat(iProgress, "%")
    End Function

    ''' <summary>取得 PLAN_REVISESUBFL_TT</summary>
    ''' <param name="objconn"></param>
    ''' <param name="rPMS"></param>
    ''' <returns></returns>
    Public Shared Function GET_dtPLAN_REVISESUBFL_TT(objconn As SqlConnection, rPMS As Hashtable) As DataTable
        Dim vPLANID As String = GetMyValue2(rPMS, "PLANID")
        Dim vCOMIDNO As String = GetMyValue2(rPMS, "COMIDNO")
        Dim vSEQNO As String = GetMyValue2(rPMS, "SEQNO")
        Dim vCDATE As String = GetMyValue2(rPMS, "CDATE")
        Dim vSUBSEQNO As String = GetMyValue2(rPMS, "SUBSEQNO")
        Dim vALTDATAID As String = GetMyValue2(rPMS, "ALTDATAID")

        Dim hPMS As New Hashtable From {{"PLANID", CINT1(vPLANID)}, {"COMIDNO", vCOMIDNO}, {"SEQNO", CINT1(vSEQNO)},
            {"CDATE", Cdate2(vCDATE)}, {"SUBSEQNO", CINT1(vSUBSEQNO)}, {"ALTDATAID", CINT1(vALTDATAID)}}
        Dim sSql As String = ""
        sSql &= " SELECT b.BVFTID,b.BVFID,b.FILENAME1,b.FILEPATH1,k.RVID" & vbCrLf
        sSql &= " ,concat(k.ORGKINDGW,k.RVID,'x',k.RVNAME) RVNAME3" & vbCrLf
        sSql &= " ,t.TEACHERID,t.TEACHCNAME" & vbCrLf
        sSql &= " ,a.PLANID,a.COMIDNO,a.SEQNO,a.CDATE,a.SUBSEQNO,a.ALTDATAID" & vbCrLf
        sSql &= " FROM PLAN_REVISESUBFL_TT b" & vbCrLf
        sSql &= " JOIN PLAN_REVISESUBFL a on a.BVFID=b.BVFID" & vbCrLf
        sSql &= " JOIN KEY_REVISESUB k on k.RVSID=b.RVSID" & vbCrLf
        sSql &= " JOIN TEACH_TEACHERINFO t on t.TECHID=b.TECHID" & vbCrLf
        sSql &= " WHERE b.FILENAME1 IS NOT NULL" & vbCrLf
        sSql &= " and a.PLANID=@PLANID and a.COMIDNO=@COMIDNO and a.SEQNO=@SEQNO" & vbCrLf
        sSql &= " and a.CDATE=@CDATE and a.SUBSEQNO=@SUBSEQNO and a.ALTDATAID=@ALTDATAID" & vbCrLf
        sSql &= " ORDER BY k.RVID" & vbCrLf
        Dim dt As DataTable = DbAccess.GetDataTable(sSql, objconn, hPMS)
        Return dt
    End Function

