    Public Shared Function GET_OnlyOne_OCID(ByVal RIDValue As String, ByRef oConn As SqlConnection) As DataRow
        Dim rst As DataRow = Nothing
        RIDValue = ClearSQM(RIDValue)
        If RIDValue = "" Then Return rst
        Dim rPMS As New Hashtable From {{"RID", RIDValue}}
        Dim sql As String = ""
        sql &= " SELECT ISNULL(t.TOTAL,0) total" & vbCrLf
        sql &= " ,t.OCID ,t.STDate ,t.FTDate ,t.TMID" & vbCrLf
        'BY AMU 20140402 因為太多隻程式要改了，所以只能跟著錯。不應該是TrainID 應該是TMID 
        '有機會再修回TMID
        sql &= " ,t.TMID TrainID ,'['+t.TrainID +']' + t.TrainName TrainName" & vbCrLf
        sql &= " ,t.ClassName" & vbCrLf
        sql &= " FROM ( SELECT r.total" & vbCrLf '該業務單位 開班數。
        sql &= "  ,a.ocid ,a.STDate ,a.FTDate ,a.TMID" & vbCrLf
        sql &= "  ,IsNull(b.JobID,b.TrainID) TrainID" & vbCrLf
        sql &= "  ,IsNull(b.JobName,b.TrainName) TrainName" & vbCrLf
        'sql &= "  ,CASE when b.JobID is null then b.TrainID else b.JobID end TrainID" & vbCrLf
        'sql &= "  ,CASE when b.JobID is null then b.trainName else b.JobName end TrainName" & vbCrLf
        sql &= " ,dbo.FN_GET_CLASSCNAME(a.CLASSCNAME,a.CYCLTYPE) CLASSNAME" & vbCrLf
        sql &= " FROM CLASS_CLASSINFO a" & vbCrLf
        sql &= " JOIN ( SELECT RID,COUNT(1) total FROM CLASS_CLASSINFO" & vbCrLf
        sql &= "   WHERE RID=@RID GROUP BY RID) r on a.rid=r.rid " ' and a.rid='" & RIDValue & "'" & vbCrLf
        sql &= " JOIN Key_TrainType b on a.TMID=b.TMID" & vbCrLf
        sql &= " JOIN Auth_Relship d on a.RID=d.RID" & vbCrLf
        sql &= " JOIN Org_OrgInfo e on e.OrgID=d.OrgID" & vbCrLf
        sql &= " WHERE a.RID=@RID ) t" & vbCrLf
        'Call OpenDbConn(oConn)
        rst = DbAccess.GetOneRow(sql, oConn, rPMS)
        Return rst
    End Function

    'by AMU 2009-02-20(201607) '依登入者 RID/PlanID/UserID
    Private Shared Function GET_OnlyOne_OCID(ByRef MyPage As Page, ByRef oConn As SqlConnection) As DataRow
        Dim dr As DataRow = Nothing
        ' (直接在 AuthBasePage 處理, 不用個別檢查 Session) If TIMS.ChkSession(MyPage) Then Return dr
        Dim sm As SessionModel = SessionModel.Instance()

        Dim RIDValue As String = sm.UserInfo.RID
        Dim PlanID As String = sm.UserInfo.PlanID
        Dim UserID As String = sm.UserInfo.UserID

        Dim sql As String = ""
        sql &= " SELECT c.OCID,c.ClassCName,c.CyclType,c.LevelType,c.CTName,c.FTDate" & vbCrLf
        sql &= " ,c.RID,c.TMID" & vbCrLf
        sql &= " ,'[' + CASE when k1.JobID is null then k1.TrainID else k1.JobID end + ']'" & vbCrLf
        sql &= " + CASE when k1.JobID is null then k1.trainName else k1.JobName end TrainName" & vbCrLf
        sql &= " ,dbo.FN_GET_CLASSCNAME(c.CLASSCNAME,c.CYCLTYPE) CLASSNAME" & vbCrLf
        sql &= " ,oo.OrgID" & vbCrLf
        sql &= " ,oo.OrgName Center" & vbCrLf
        sql &= " FROM CLASS_CLASSINFO c" & vbCrLf
        sql &= " JOIN Key_TrainType k1 on c.TMID=k1.TMID" & vbCrLf
        sql &= " JOIN Auth_Relship ar on c.RID=ar.RID" & vbCrLf
        sql &= " JOIN Org_OrgInfo oo on ar.OrgID=oo.OrgID" & vbCrLf
        sql &= " WHERE c.IsSuccess='Y'" & vbCrLf
        sql &= " AND c.RID=@RIDValue" & vbCrLf
        sql &= " AND c.PlanID=@PlanID" & vbCrLf
        sql &= " AND c.OCID IN (SELECT OCID FROM Auth_AccRWClass WHERE Account=@UserID)" & vbCrLf
        Dim sCmd As New SqlCommand(sql, oConn)
        Call OpenDbConn(oConn)
        Dim dt As New DataTable
        With sCmd
            .Parameters.Clear()
            .Parameters.Add("RIDValue", SqlDbType.VarChar).Value = RIDValue
            .Parameters.Add("PlanID", SqlDbType.VarChar).Value = PlanID
            .Parameters.Add("UserID", SqlDbType.VarChar).Value = UserID
            dt.Load(.ExecuteReader())
        End With
        If dt.Rows.Count = 1 Then dr = dt.Rows(0) '只有一班時才帶資料
        Return dr
    End Function

