        Const cst_col_bief As Integer = 12
        Const cst_col_biefDesc As Integer = 13
        Const cst_col_birth As Integer = 14
        Const cst_col_deptcode As Integer = 15
        'Const cst_col_itrmy As Integer=16
        'Const cst_col_itrmd As Integer=17
        'Const cst_col_tsMk As Integer=18
        'Const cst_col_birthday As Integer=19

        If Convert.ToString(xmlDoc) <> "" Then
            strMsg = xmlDoc.DocumentElement.FirstChild.InnerText
            '異常回傳錯誤碼！
            If Cst_OKmsg.IndexOf(Convert.ToString(strMsg)) = -1 Then Return strMsg
            '0:查詢成功
            If Cst_OKmsg.IndexOf(Convert.ToString(strMsg)) > -1 Then
                XmlNodes = xmlDoc.SelectNodes("/result/record")
                Dim iNodeCnt As Integer = XmlNodes.Count
                If iNodeCnt = 0 Then Return strMsg

                For Each itemNode As XmlNode In XmlNodes
