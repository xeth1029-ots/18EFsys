    ''' <summary> 系統自動發信 錯誤寄回 </summary>
    ''' <param name="sMailBody"></param>
    ''' <param name="strToEmail"></param>
    ''' <param name="strSubject"></param>
    Public Shared Sub SendMailTest(ByVal sMailBody As String, ByVal strToEmail As String, ByVal strSubject As String)
        Const Cst_FromName As String = "系統自動發信"
        'Const Cst_FromEmail As String="e7500021@evta.gov.tw"
        Const Cst_toName As String = "系統自動收信"
        Dim ErrorSendMail As String = Utl_GetConfigSet(cst_ErrorSendMail) 'ErrorSendMail
        Dim StopSendMail As String = Utl_GetConfigSet(cst_StopSendMail)  'StopSendMail:N

        Dim flag_debuginfo_can_email As Boolean = False
        If ErrorSendMail = cst_YES Then flag_debuginfo_can_email = True
        If Not flag_debuginfo_can_email Then
            '若沒有要寄送錯誤訊息
            If StopSendMail = cst_YES Then Return 'Exit Sub '有停止寄信的訊息
        End If

        Dim iMaxCanMailCount As Integer = cst_iMaxCanMailCount 'DEFALUT: (每天)最大寄信量
        Dim ugMaxCanMailCount As String = Utl_GetConfigSet(cst_MaxCanMailCount) 'MaxCanMailCount:7
        If ugMaxCanMailCount <> "" Then iMaxCanMailCount = CINT1(ugMaxCanMailCount)
