    Public Shared Function Get_JoblessID(ByVal obj As DropDownList, Optional ByVal dt As DataTable = Nothing, Optional ByVal years As String = "") As DropDownList
        If dt Is Nothing Then
            Dim sql As String
            If years <> "" Then
                If CInt(years) >= 2010 Then
                    sql = " SELECT * FROM KEY_JOBLESSWEEK WHERE JOBLESSID IN ('04','05','06') ORDER BY JOBLESSID "
                Else
                    sql = " SELECT * FROM KEY_JOBLESSWEEK WHERE JOBLESSID IN ('01','02','03') ORDER BY JOBLESSID "
