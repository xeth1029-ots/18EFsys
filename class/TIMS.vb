    ''' <summary> 清理時間格式 </summary>
    ''' <param name="s_Times"></param>
    Public Shared Function ClearTimesFMT(ByVal s_Times As String) As String
        s_Times = ClearSQM(s_Times)
        If s_Times = "" Then Return s_Times
        'If (s_Times.IndexOf("；") > -1) Then s_Times=Replace(s_Times, "；", ";")
        If (s_Times.IndexOf("：") > -1) Then s_Times = Replace(s_Times, "：", ":")
        If (s_Times.IndexOf("～") > -1) Then s_Times = Replace(s_Times, "～", "~")

        While (s_Times.IndexOf(";;") > -1)
            s_Times = Replace(s_Times, ";;", ";")
            'If (s_Times.IndexOf(";;")=-1) Then Exit While
        End While
        While (s_Times.IndexOf("::") > -1)
            s_Times = Replace(s_Times, "::", ":")
            'If (s_Times.IndexOf("::")=-1) Then Exit While
        End While
        While (s_Times.IndexOf("~~") > -1)
            s_Times = Replace(s_Times, "~~", "~")
            'If (s_Times.IndexOf("~~")=-1) Then Exit While
        End While
        Return s_Times
    End Function

