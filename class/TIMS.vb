        '刪除檔案 'IO.File.Delete(FullFileName1)
        MyFileDelete(FullFileName1)

        Reason = Chk_DTXLS1(dt_xls, flag_File1_xls, flag_File1_ods)
        If Reason <> "" Then Return dt_xls
        Return dt_xls
    End Function

