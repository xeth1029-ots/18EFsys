                sql &= " ,Q1.FARLEARN,Q1.OUTLEARN" & vbCrLf '遠距教學 FARLEARN/室外教學 OUTLEARN
                sql &= " ,P3.PLACENAME ,T1.TeachCName ,T2.TeachCName TeachCName2 ,Q1.TPERIOD28" & vbCrLf
                sql &= " FROM PLAN_PLANINFO p1" & vbCrLf
                sql &= " JOIN PLAN_TRAINDESC Q1 ON P1.PlanID=Q1.PlanID AND P1.ComIDNO=Q1.ComIDNO AND P1.SeqNo=Q1.SeqNo" & vbCrLf
                sql &= " LEFT JOIN PLAN_TRAINPLACE P3 ON p3.PTID=Q1.PTID" & vbCrLf
