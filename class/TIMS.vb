    Public Shared Sub UPDATE_STUDENTERTEMP(ByRef MyPage As Page, ByRef sm As SessionModel,
                                           ByVal IDNO2 As String, ByRef tmpConn As SqlConnection, ByRef tmpTrans As SqlTransaction)
        Dim BKID As Integer = 0
        If IDNO2 <> "" Then IDNO2 = ChangeIDNO(ClearSQM(IDNO2))
        If IDNO2.Length < 10 Then Return
        Dim itSETID As Integer = 0
        Dim itESETID As Integer = 0
        Dim fgTmpTrans As Boolean = (tmpTrans Is Nothing) '沒有 SqlTransaction
        If fgTmpTrans Then tmpTrans = DbAccess.BeginTrans(tmpConn) '啟用 SqlTransaction
