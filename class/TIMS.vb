    ''' <summary>郵遞區號 取得後2/3碼 (顯示用)</summary>
    ''' <param name="oZipCode6W"></param>
    ''' <returns></returns>
    Public Shared Function GetZIPCODEB3(ByRef oZipCode6W As Object) As String
        Dim rst As String = ""
        If oZipCode6W Is Nothing Then Return rst
        Dim zipcode6W As String = ClearSQM(oZipCode6W)
        If zipcode6W = "" Then Return rst

        If zipcode6W.Length = 1 Then
            rst = AddZero(zipcode6W, 2) '2位數
            Return rst
        ElseIf zipcode6W.Length = 5 Then
            rst = zipcode6W.Substring(3, 2)
            Return rst
        ElseIf zipcode6W.Length = 6 Then
            rst = zipcode6W.Substring(3, 3)
            Return rst
        ElseIf zipcode6W.Length = 2 OrElse zipcode6W.Length = 3 Then
            rst = zipcode6W
            Return rst
        Else
            rst = "" '異常不顯示
            Return rst
        End If
        Return rst
    End Function

    ''' <summary> 郵遞區號 取得 組合後5碼或6碼 (儲存用) </summary>
    ''' <param name="oZipCode"></param>
    ''' <param name="oZipCodeB3NW"></param>
    ''' <returns></returns>
    Public Shared Function GetZIPCODE6W(ByRef oZipCode As Object, ByRef oZipCodeB3NW As Object) As String
        Dim rst As String = ""
        If Convert.ToString(oZipCodeB3NW) = "" Then Return rst
        Dim ZipB3 As String = ClearSQM(oZipCodeB3NW)
        If ZipB3.Length = 6 Then Return ZipB3
        If ZipB3.Length = 5 Then Return ZipB3

        If oZipCode Is Nothing Then Return rst
        If Convert.ToString(oZipCode) = "" Then Return rst
        Dim ZipF3 As String = ClearSQM(oZipCode)
        If ZipF3.Length < 3 Then Return rst
        If ZipF3.Length = 6 Then Return ZipF3
        If ZipF3.Length = 5 Then Return ZipF3

        ZipF3 = ZipF3.Substring(0, 3)
        rst = ClearSQM(String.Concat(ZipF3, ZipB3))
        If rst.Length = 6 Then Return rst
        If rst.Length = 5 Then Return rst
        Return rst
    End Function

