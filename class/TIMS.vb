    ''' <summary>
    ''' 查詢目前計畫所有委訓單位 
    ''' </summary>
    ''' <param name="PLANID"></param>
    ''' <param name="RID"></param>
    ''' <param name="oConn"></param>
    ''' <returns></returns>
    Public Shared Function GET_OrgListdt(ByVal PLANID As String, ByVal RID As String, ByRef oConn As SqlConnection) As DataTable
        Dim dt As DataTable
        'Dim dr As DataRow
        Dim parms As New Hashtable From {{"RID", RID}, {"PLANID", PLANID}}
        Dim sql As String = ""
        sql &= " select a.PlanID,a.OrgID,a.RID, b.OrgName,ip.DISTID" & vbCrLf
        sql &= " FROM AUTH_RELSHIP a" & vbCrLf '業務關係檔
        sql &= " JOIN ORG_ORGINFO b on a.OrgID=b.OrgID" & vbCrLf '機構名稱
        sql &= " JOIN ID_PLAN ip on ip.planid=a.planid" & vbCrLf '分署年度計畫
        sql &= " where a.ORGLEVEL=2" & vbCrLf '委訓單位-層級
        sql &= " and a.DISTID IN (SELECT DISTID FROM AUTH_RELSHIP WHERE RID=@RID)" & vbCrLf
        sql &= " and a.PlanID=@PlanID" & vbCrLf '分署年度計畫-應該是產投
        dt = DbAccess.GetDataTable(sql, oConn, parms)
        Return dt
    End Function

