    ''' <summary>轉入年月yyyyMM 回傳 yyyy/MM/01</summary>
    ''' <param name="s_yyyyMM"></param>
    ''' <returns></returns>
    ''' <remarks></remarks>
    Public Shared Function Cdate4(ByVal s_yyyyMM As String) As String
        Dim rst As String = "" '其他狀況輸出 db用Null
        Try
            s_yyyyMM = Trim(s_yyyyMM) '文字清除空白
            If s_yyyyMM <> "" AndAlso s_yyyyMM.Length = 6 Then
                Dim yMd As String = String.Concat(s_yyyyMM.Substring(0, 4), "/", s_yyyyMM.Substring(4, 2), "/01")
                If IsDate(yMd) Then rst = CDate(yMd).ToString("yyyy/MM/dd") '轉成日期字串
            End If
        Catch ex As Exception
            Dim V_GUID As String = Guid.NewGuid().ToString()
            LOG.Warn(ex.Message, ex) '取得錯誤資訊寫入
            Dim strErrmsg As String = String.Concat("ex.Message:", ex.Message, "[", V_GUID, "]", vbCrLf)
            WriteTraceLog(strErrmsg, ex)
        End Try
        Return rst
    End Function

