    '回傳錯誤訊息，超過結訓日期n天，停用新增功能
    Public Shared Function Chk_StopUseDate(ByRef MyPage As Page,
                             ByVal Days1 As Integer, ByVal Days2 As Integer,
                             ByVal IsClosed As String, ByVal drFTDate As Date) As String
        Dim rst As String = "" '回傳錯誤訊息
        Dim sm As SessionModel = SessionModel.Instance()
        'rst = "" 'IsClosed : Y 'FTDate : 結訓日期 日期格式。
        If IsClosed = "Y" Then
            If sm.UserInfo.RoleID <= 1 Then
                '系統管理者以上權限
                '判斷計畫是否為補助辦理保母職業訓練(46)與辦理照顧服務員職業訓練(47)時,限製天數改成75天
                '暫時先改這樣,以後還會再改
                If Cst_TPlanID_StopUseDate.IndexOf(sm.UserInfo.TPlanID) > -1 Then
                    If DateDiff(DateInterval.Day, drFTDate, Now) > 75 Then
                        rst &= "超過結訓日期" & Days2 & "天，停用新增功能" & vbCrLf
                    End If
                Else
                    If DateDiff(DateInterval.Day, drFTDate, Now) > Days2 Then
                        rst &= "超過結訓日期" & Days2 & "天，停用新增功能" & vbCrLf
                    End If
                End If

            Else
                '非系統管理者以上權限
                '判斷計畫是否為補助辦理保母職業訓練(46)與辦理照顧服務員職業訓練(47)時,限製天數改成60天
                '暫時先改這樣,以後還會再改
                If Cst_TPlanID_StopUseDate.IndexOf(sm.UserInfo.TPlanID) > -1 Then
                    If DateDiff(DateInterval.Day, drFTDate, Now) > 60 Then
                        rst &= "超過結訓日期" & Days1 & "天，停用新增功能" & vbCrLf
                    End If
                Else
                    If DateDiff(DateInterval.Day, drFTDate, Now) > Days1 Then
                        rst &= "超過結訓日期" & Days1 & "天，停用新增功能" & vbCrLf
                    End If
                End If

            End If
        End If
        Return rst
    End Function

