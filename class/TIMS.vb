    '取出鍵詞-離退訓原因種類
    Public Shared Function Get_RejectTReason(ByRef MyPage As Page, ByRef obj As RadioButtonList,
                                             ByVal StudStatus As String, ByRef oConn As SqlConnection,
                                             ByVal OldRTReasonID As String) As RadioButtonList
        Dim sm As SessionModel = SessionModel.Instance()
        Dim sql As String = "" '2015 NEW 
        If CINT1(sm.UserInfo.Years) > 2014 Then
            Select Case StudStatus
                Case cst_reject_離 '"2" '離
                    'SELECT * FROM KEY_REJECTTREASON WHERE 1=1 AND SORT2 IS NOT NULL--07	奉召服兵役
                    sql &= " SELECT * FROM KEY_REJECTTREASON WHERE 1=1" & vbCrLf
                    If OldRTReasonID <> "" Then
                        sql &= $" AND (SORT2 IS NOT NULL OR RTReasonID='{OldRTReasonID}')" & vbCrLf
                    Else
                        sql &= " AND SORT2 IS NOT NULL" & vbCrLf
                    End If
                    sql &= " ORDER BY SORT2" & vbCrLf
                Case cst_reject_離2
                    'SELECT * FROM KEY_REJECTTREASON WHERE 1=1 AND SORT2 IS NOT NULL--07	奉召服兵役
                    sql &= " SELECT * FROM KEY_REJECTTREASON WHERE SORT22 IS NOT NULL" & vbCrLf
                    sql &= " ORDER BY SORT22" & vbCrLf
                Case cst_reject_離6
                    'SELECT * FROM KEY_REJECTTREASON WHERE 1=1 AND SORT2 IS NOT NULL--07	奉召服兵役
                    'SELECT * FROM KEY_REJECTTREASON WHERE 1=1 AND SORT06 IS NOT NULL ORDER BY SORT06
                    sql &= " SELECT * FROM KEY_REJECTTREASON WHERE SORT06 IS NOT NULL" & vbCrLf
                    sql &= " ORDER BY SORT06" & vbCrLf
                Case cst_reject_退 '"3" '退
                    sql &= " SELECT * FROM KEY_REJECTTREASON WHERE 1=1" & vbCrLf
                    If OldRTReasonID <> "" Then
                        sql &= $" AND (SORT3 IS NOT NULL OR RTReasonID='{OldRTReasonID}')" & vbCrLf
                    Else
                        sql &= " AND SORT3 IS NOT NULL" & vbCrLf
                    End If
                    sql &= " ORDER BY SORT3" & vbCrLf
                Case cst_reject_離退Old '舊版不分離退
                    sql &= " SELECT * FROM KEY_REJECTTREASON WHERE (SORT2 IS NOT NULL OR SORT3 IS NOT NULL)" & vbCrLf
                    sql &= " ORDER BY ISNULL(SORT2,SORT3)" & vbCrLf
                Case Else '未決定。
                    sql = "SELECT * FROM KEY_REJECTTREASON WHERE 1<>1 ORDER BY RTReasonID"
            End Select
        Else
            'OLD
            Select Case StudStatus
                Case cst_reject_離 '"2" '離
                    sql &= " SELECT * FROM KEY_REJECTTREASON WHERE RTREASONID IN ('02','03','04','05','07','08','09','10','11','12','99')" & vbCrLf
                    sql &= " ORDER BY RTReasonID" & vbCrLf
                Case cst_reject_退 '"3" '退
                    sql &= " SELECT * FROM KEY_REJECTTREASON WHERE RTREASONID IN ('01','06','13','99')" & vbCrLf
                    sql &= " ORDER BY RTREASONID" & vbCrLf
                Case cst_reject_離退Old '舊版不分離退
                    sql &= " SELECT * FROM KEY_REJECTTREASON WHERE RTREASONID IN ('02','03','04','05','07','08','09','10','11','12','99','01','06','13','99')" & vbCrLf
                    sql &= " ORDER BY RTREASONID" & vbCrLf
                Case Else '未決定。
                    sql = " SELECT * FROM KEY_REJECTTREASON WHERE 1<>1 ORDER BY RTREASONID "
            End Select
        End If

        Dim defValue As String = ""
        Dim dt As DataTable = DbAccess.GetDataTable(sql, oConn)
        If (dt.Rows.Count > 0) Then defValue = dt.Rows(0)("RTREASONID")
        'obj=New RadioButtonList
        With obj
            .ClearSelection()
            .Items.Clear()
            If defValue = "" Then Return obj
            '.AppendDataBoundItems=True
            .SelectedValue = defValue
            'If (.SelectedIndex <> -1) Then .SelectedIndex=-1 '已啟動的物件，設定為未啟動
            'If (.SelectedValue <> "") Then .SelectedValue="" '已啟動的物件，設定為未啟動
            .DataSource = dt
            .DataTextField = "REASON"
            .DataValueField = "RTREASONID"
            .DataBind()
        End With
        Return obj
    End Function

    '假日天數'SYS_HOLIDAY(假日數量比對) 計算遞補日期使用。 '年度行事曆
    Public Shared Function Get_SysHolidayDay(ByRef MyPage As Page, ByVal dSTDate As Date, ByVal dNow As Date, ByVal objconn As SqlConnection) As Integer
        Dim Rst As Integer = 0
        Dim sm As SessionModel = SessionModel.Instance()

        Dim RID_VAL As String = Convert.ToString(sm.UserInfo.RID)
        If Len(RID_VAL) < 1 Then Return -1 '異常離開
        If Len(RID_VAL) <> 1 Then RID_VAL = Left(RID_VAL, 1) '依分署假日執行

        If DateDiff(DateInterval.Day, dSTDate, dNow) >= 0 Then
            'Sys_Holiday(假日數量比對)
            Dim sql As String = " SELECT 1 FROM SYS_HOLIDAY WHERE RID=@RID AND HOLDATE>=@StDate AND HOLDATE<=@NowDate"
            Call OpenDbConn(objconn)
            Dim dtH As New DataTable
            Dim oCmd As New SqlCommand(sql, objconn)
            With oCmd
                .Parameters.Clear()
                .Parameters.Add("RID", SqlDbType.VarChar).Value = RID_VAL
                .Parameters.Add("StDate", SqlDbType.DateTime).Value = dSTDate
                .Parameters.Add("NowDate", SqlDbType.DateTime).Value = dNow
                dtH.Load(.ExecuteReader())
            End With
            Rst = dtH.Rows.Count
        End If
        Return Rst
    End Function

