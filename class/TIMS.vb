        iSql &= " ,@DistID,@PlanID,@TPlanID,@Years,@ModifyAcct,GETDATE())" & vbCrLf
        'Dim oCmd As New SqlCommand(sql, oConn)
        Dim fg_SAVE_OK As Boolean = False
