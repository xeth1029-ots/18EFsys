        Dim a_1t As String() = s_1t.Split(",")
        Dim a_1v As String() = s_1v.Split(",")
        With dlobj.Items
            For ii As Integer = 0 To a_1t.Length - 1
                .Add(New ListItem(a_1t(ii), a_1v(ii)))
            Next
        End With
        Return dlobj
    End Function

    ''' <summary>
    ''' 課程大綱-師資-師資授課時數-超過54小時 為 true
    ''' </summary>
    ''' <param name="dt"></param>
    ''' <returns></returns>
    Public Shared Function CHK_TEACHHOURS1(ByRef dt As DataTable) As Boolean
        Dim rst As Boolean = False
        If dt Is Nothing Then Return rst
        If dt.Rows.Count = 0 Then Return rst

        Dim s_TeachID As String = "" '師資ID收集
        For Each dr1 As DataRow In dt.Rows
            If Not (dr1.RowState = DataRowState.Deleted) Then
                Dim flag_can_add As Boolean = False
                Dim tmp_TechID As String = Convert.ToString(dr1("TECHID")) '取得師資id
                If tmp_TechID <> "" Then
                    If s_TeachID = "" Then
                        flag_can_add = True
                    Else
                        If s_TeachID.IndexOf(tmp_TechID) = -1 Then
                            flag_can_add = True
                        End If
                    End If
                End If
                If flag_can_add Then
                    'Convert.ToString(dr1("TECHID"))
                    s_TeachID &= String.Concat(If(s_TeachID <> "", ",", ""), tmp_TechID)
                End If
            End If
        Next

        If s_TeachID = "" Then Return rst
        Dim s_aTeachID As String() = s_TeachID.Split(",")
        For Each s_vTeachID1 As String In s_aTeachID
            rst = CHK_TEACHHOURSMAX1(dt, s_vTeachID1)
            If rst Then Return rst
        Next
        Return rst
    End Function

    ''' <summary>
    ''' 課程大綱-師資-師資授課時數-超過54小時 為 true
    ''' </summary>
    ''' <param name="dt"></param>
    ''' <param name="s_TeachID"></param>
    ''' <returns></returns>
    Public Shared Function CHK_TEACHHOURSMAX1(ByRef dt As DataTable, ByVal s_TeachID As String) As Boolean
        'Function xx(ByRef dt As DataTable, ByRef htSS As Hashtable) As Boolean
        Dim rst As Boolean = False
        If dt Is Nothing Then Return rst
        If dt.Rows.Count = 0 Then Return rst
        s_TeachID = ClearSQM(s_TeachID)
        If s_TeachID = "" Then Return rst
        '於【班級申請】功能，於基本儲存、正式儲存的時候
        '系統檢核： '檢查課程大綱內之 【授課師資】欄位(助教不用)，'同一位師資授課時數 於此班級 是否超過54小時，
        '如有(任一位)，則顯示提示訊息：「同一位師資授課時數已超過54小時，請確認是否為特殊情況。」以提示訓練單位是否修正。
        '但系統不阻擋， 仍能儲存。
        'Dim s_TeachID As String=GetMyValue2(htSS, "TeachID")
        Dim s_SCH1 As String = String.Format("TECHID={0}", s_TeachID)
        Dim i_MAX_HOURS_54 As Double = 54
        Dim i_TrainHours As Double = 0
        For Each dr1 As DataRow In dt.Select(s_SCH1)
            If Not (dr1.RowState = DataRowState.Deleted) Then
                i_TrainHours += If($"{dr1("PHOUR")}" <> "", Val(dr1("PHOUR")), Val(0))
                If i_TrainHours > i_MAX_HOURS_54 Then rst = True '大於54
                If rst Then Return rst
            End If
        Next
        If i_TrainHours > i_MAX_HOURS_54 Then rst = True
        If rst Then Return rst
        Return rst
    End Function

