    ''' <summary> 取得組合後日期文字，若有格式不符，則為空(yyyy/MM/dd HH:mm:ss) </summary>
    ''' <param name="s_YMD1"></param>
    ''' <param name="s_HH1"></param>
    ''' <param name="s_MM1"></param>
    ''' <returns></returns>
    Public Shared Function GET_YMDHM1(ByVal s_YMD1 As String, ByVal s_HH1 As String, ByVal s_MM1 As String) As String
        Dim rst As String = ""
        s_YMD1 = Cdate3(s_YMD1)
        If s_YMD1 = "" Then Return rst

        Dim v_HR_hid As String = ClearSQM(s_HH1).PadLeft(2, "0")
        Dim v_MI_hid As String = ClearSQM(s_MM1).PadLeft(2, "0")
        rst = String.Concat(s_YMD1, " ", v_HR_hid, ":", v_MI_hid, ":00")
        If Not IsDate1(rst) Then Return ""
        rst = CDate(rst).ToString("yyyy/MM/dd HH:mm:ss")
        Return rst
    End Function

