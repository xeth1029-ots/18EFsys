        Dim rst As String = ""
        sZIP = ClearSQM(sZIP)
        '判斷數字可能性，若不是數字就返回空白算了。
        If sZIP <> "" Then sZIP = If(IsNumeric2(sZIP), $"{CINT1(sZIP)}", "")
