                    JScript &= $"TechID['{dr("TeacherID")}']='{dr("TechID")}';TeachCName['{dr("TeacherID")}']='{dr("TeachCName")}';{vbCrLf}"
                End If
            Next
            'JScript &= "alert(TechID[UsedTechID]);"
            JScript &= " if(UsedTechID!=''){" & vbCrLf
            JScript &= "   if(TechID[UsedTechID]!=undefined){" & vbCrLf
