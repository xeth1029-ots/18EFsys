    ''' 提升在職勞工自主學習計畫 ,產業人才投資計畫,產業人才投資計畫,勞工在職進修計畫,勞工團體辦理勞工在職進修計畫
    ''' </summary>
    ''' <param name="MyPage"></param>
    ''' <param name="sVal"></param>
    ''' <param name="oConn"></param>
    ''' <returns></returns>
    ''' <remarks></remarks>
    Public Shared Function Get_PName28(ByRef MyPage As Page, ByVal sVal As String, ByRef oConn As SqlConnection) As String
        Dim rst As String = ""
        If sVal = "" Then Return rst
        sVal = UCase(sVal) 'G/W  'Get_PName28(Me, "G")
        Dim dt As DataTable = Get_V_ORGKINDdt(oConn)
        If dt Is Nothing OrElse dt.Rows.Count = 0 Then Return rst
        Dim filter As String = ""
        Select Case sVal
            Case "G", "1" '產業人才投資計畫
                filter = "VALUE='G'"
                If dt.Select(filter).Length > 0 Then
                    rst = dt.Select(filter)(0)("NAME").ToString
                End If
            Case "W", "2" '提升勞工自主學習計畫
                filter = "VALUE='W'"
                If dt.Select(filter).Length > 0 Then
                    rst = dt.Select(filter)(0)("NAME").ToString
                End If
        End Select
        Return rst
    End Function

