    ''' <summary>ICAP-課程單元tw.gov.wda.wltims1.Unit()</summary>
    ''' <param name="items"></param>
    ''' <returns></returns>
    Public Shared Function ToDataTableUnit(items As tw.gov.wda.wltims1.Unit()) As DataTable
        Dim tb As New DataTable(GetType(tw.gov.wda.wltims1.Unit).Name)
        Dim properties() As PropertyInfo = GetType(tw.gov.wda.wltims1.Unit).GetProperties()

        For Each prop As PropertyInfo In properties
            Dim propertyType As Type = Nullable.GetUnderlyingType(prop.PropertyType)
            If propertyType Is Nothing Then
                propertyType = prop.PropertyType
            End If
            tb.Columns.Add(prop.Name, propertyType)
        Next

        For Each item As tw.gov.wda.wltims1.Unit In items
            Dim values(properties.Length - 1) As Object ' Adjust array size for VB.NET
            For i As Integer = 0 To properties.Length - 1
                values(i) = properties(i).GetValue(item, Nothing) ' Use Nothing for optional parameter
            Next
            tb.Rows.Add(values)
        Next

        Return tb
    End Function

