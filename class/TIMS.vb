        Dim OCID1_Value As String = Val(GetMyValue2(htPP1, "OCIDValue1"))
        Dim ieSETID As Integer = CINT1(GetMyValue2(htPP1, "ieSETID"))
        Dim v_MODIFYACCT As String = GetMyValue2(htPP1, "MODIFYACCT")
        Dim iSETID As Integer = CINT1(GetMyValue2(htPP1, "iSETID"))
        Dim v_TMID As String = GetMyValue2(htPP1, "TMID")
        Dim v_RID As String = GetMyValue2(htPP1, "RID")
        Dim v_PLANID As String = GetMyValue2(htPP1, "PLANID")
        'Dim iSerNum As Integer=Val(GetMyValue2(htPP1, "iSerNum"))

        Dim sStr2 As String = $"SELECT * FROM dbo.STUD_ENTERTYPE2 WHERE eSETID={ieSETID} AND OCID1={OCID1_Value}"
        Dim dr2 As DataRow = DbAccess.GetOneRow(sStr2, oConn)
        If dr2 IsNot Nothing Then
            ieSERNUM = CINT1(dr2("eSERNUM"))
            Errmsg = " 報名失敗，您已經有報名此班級了!!!" & vbCrLf '\n\n
            Return ieSERNUM 'false:異常/true:正常
        End If

        Dim iSignNo As Integer = 0
        Dim iSerNum As Integer = 1

        Dim aNow As DateTime = GetSysDateNow(oConn)
        Dim dr As DataRow = Nothing
        Dim dt As DataTable = Nothing
        Dim da As SqlDataAdapter = Nothing
        Using tConn As SqlConnection = DbAccess.GetConnection()
            Dim trans As SqlTransaction = DbAccess.BeginTrans(tConn)
            Try
                iSignNo = TIMS.GetSignNoxEnterType3(trans, tConn, OCID1_Value)
            Catch ex As Exception
                LOG.Error(ex.Message, ex)
                iSignNo = -1
                Errmsg = "無法取得報名序號!" & vbCrLf '
                DbAccess.RollbackTrans(trans)
                CloseDbConn(tConn) '異常中止連線
                Return ieSERNUM 'False 'ieSETID
                'Dim excep As New Exception("無法取得報名序號!") Throw ex
            End Try

            Dim dt2 As DataTable = Nothing
            Try
                dt2 = DbAccess.GetDataTable(sStr2, da, trans)
                If dt2.Rows.Count > 0 Then
                    dr2 = dt2.Rows(0)
                    ieSERNUM = CINT1(dr2("eSERNUM"))
                    Errmsg = " 報名失敗，您已經有報名此班級了!!!" & vbCrLf
                    DbAccess.RollbackTrans(trans)
                    CloseDbConn(tConn) '異常中止連線
                    Return ieSERNUM 'false:異常/true:正常
                End If

                '新增
                dr = dt.NewRow()
                dt.Rows.Add(dr)
                ieSERNUM = GETMAX_ESERNUM_SEQ(trans)
                dr("eSerNum") = ieSERNUM 'PK
                dr("eSETID") = ieSETID 'FK
                dr("SETID") = If(iSETID > 0, iSETID, Convert.DBNull) 'FK
                dr("SerNum") = iSerNum
                dr("RelEnterDate") = aNow 'Now()
                dr("OCID1") = CINT1(OCID1_Value)
                dr("EnterDate") = Common.FormatDate(aNow) 'Today()
                dr("SIGNNO") = iSignNo '報名序號
                '=START=  取得班級資料，填入學員報名職類基本資料
                dr("TMID1") = CINT1(v_TMID) 'drCC1("TMID")
                dr("RID") = v_RID 'drCC1("RID")
                dr("PlanID") = CINT1(v_PLANID) 'drCC1("PLANID")
                dr("MIDENTITYID") = v_MIdentityID
                dr("IDENTITYID") = v_MIdentityID ' MIDENTITYID.SELECTEDVALUE 'IDENTITYID.SELECTEDVALUE
                dr("EnterPath") = "o" '產投外網(內部小寫o) by AMU 201212
                dr("ModifyAcct") = v_MODIFYACCT 'sm.UserInfo.UserID 'IDNOvalue
                dr("ModifyDate") = aNow 'Now()
                '=END=  取得班級資料，填入學員報名職類基本資料
                DbAccess.UpdateDataTable(dt, da, trans)
                DbAccess.CommitTrans(trans)
            Catch ex As Exception
                LOG.Warn(ex.Message, ex)
                Errmsg = "報名失敗，該學員報名資料異常 或 資料庫異常，請重試!" & vbCrLf
                Errmsg &= "請再試一次，造成您不便之處，還請見諒。" & vbCrLf
                Errmsg &= String.Concat("(若持續出現此問題，請聯絡系統管理者)!", vbCrLf, ex.Message)
                DbAccess.RollbackTrans(trans)
                CloseDbConn(tConn) '異常中止連線
                Return -1 'ieSERNUM 'false:異常/true:正常
            End Try
            'DbAccess.Close(tConn)
            DbAccess.CloseDbConn(tConn)
        End Using

        Return ieSERNUM
    End Function

