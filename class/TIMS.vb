    ''' <summary> 判斷ipV6 </summary>
    ''' <returns></returns>
    Public Shared Function IsIPV6() As Boolean
        Dim rst As Boolean = False
        Dim v_ip As String = ""
        If HttpContext.Current.Request Is Nothing Then Return v_ip
        Dim v_request As HttpRequest = HttpContext.Current.Request
        If v_request Is Nothing Then Return v_ip

        Const cst_HTTP_X_FORWARDED_FOR As String = "HTTP_X_FORWARDED_FOR"
        Const cst_REMOTE_ADDR As String = "REMOTE_ADDR"
        'Look for a proxy address first
        v_ip = v_request.ServerVariables(cst_HTTP_X_FORWARDED_FOR)
        'If there is no proxy, get the standard remote address
        If String.IsNullOrWhiteSpace(v_ip) OrElse String.Equals(v_ip, "unknown", StringComparison.OrdinalIgnoreCase) Then
            v_ip = v_request.ServerVariables(cst_REMOTE_ADDR)
            If v_ip.IndexOf(":") > -1 Then rst = True
            Return rst
        End If
        'extract first IP
        Dim i_Index As Integer = -1
        i_Index = v_ip.IndexOf(",")
        If (i_Index > 0) Then v_ip = v_ip.Substring(0, i_Index)
        'remove port
        i_Index = v_ip.LastIndexOf(":")
        If (i_Index > 0) Then v_ip = v_ip.Substring(0, i_Index)
        If v_ip.IndexOf(":") > -1 Then rst = True
        Return rst
    End Function

