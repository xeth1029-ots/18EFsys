        Dim SQL_1 As String = "
SELECT vp.PlanName ,vp.TPlanID ,V1.OrgKind,vp.DISTNAME2,V1.OrgKind2,V1.OrgName ,d.jobname ,kc.CCName
,dbo.FN_GET_CLASSCNAME(P1.ClassName,P1.CyclType) ClassName,P1.CyclType 
