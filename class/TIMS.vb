    '傳入CourID值 ，傳回該ID的CourseName
    Public Shared Function Get_CourseName(ByVal CourID As Object, ByVal dt As DataTable, ByRef tConn As SqlConnection) As String
        Dim Rst As String = Nothing
        Dim strCourID As String = ""
        If IsDBNull(CourID) Then Return Rst
        strCourID = ClearSQM(CourID)

        If strCourID <> "" AndAlso IsNumeric(strCourID) Then
            Dim ff As String = $" CourID='{strCourID}'"
            If dt IsNot Nothing Then
                If dt.Select(ff).Length = 0 Then
                    Rst = Nothing
                Else
                    Rst = dt.Select(ff)(0)("CourseName")
                End If
            Else
                Call OpenDbConn(tConn)
                Dim oStr As String = " SELECT CourseName FROM COURSE_COURSEINFO WHERE COURID=@COURID"
                Dim sCmd As New SqlCommand(oStr, tConn)
                With sCmd
                    .Parameters.Clear()
                    .Parameters.Add("COURID", SqlDbType.BigInt).Value = CINT1(strCourID)
                    Rst = .ExecuteScalar()
                End With
            End If
        End If

        Return Rst
    End Function

    '取得組合課程字串
    Public Shared Function Get_CourseName(ByRef htSS As Hashtable) As String
        Dim CourseName As String = GetMyValue2(htSS, "CourseName")
        Dim CourseID As String = GetMyValue2(htSS, "CourseID")
        Dim Classification1 As String = GetMyValue2(htSS, "Classification1")
        Dim Classification2 As String = GetMyValue2(htSS, "Classification2")

        'NewNode.Text=dr("CourseName")
        Dim strNewNode As String = ""
        'strNewNode=""
        'strNewNode=CourseName & " (" + CourseID + ")"
        Dim s_CLA As String = ""
        Select Case Classification1
            Case "1"
                s_CLA = "學科"
            Case "2"
                s_CLA = "術科"
        End Select
        Dim s_CLA2 As String = ""
        Select Case Classification2
            Case "0"
                s_CLA2 = "，共同"
            Case "1"
                s_CLA2 = "，一般"
            Case "2"
                s_CLA2 = "，專業"
        End Select
        strNewNode = String.Format("{0} ({1})({2}{3})", CourseName, CourseID, s_CLA, s_CLA2)
        Return strNewNode
    End Function

    '傳入TechID值，傳回該ID的TeacherName
    Public Shared Function Get_TeacherName(ByVal sTechID As Object, ByVal dt As DataTable) As String
        Dim Rst As String = Nothing
        Dim strTechID As String = ClearSQM($"{sTechID}")
        If strTechID = "" Then Return Rst
        strTechID = CINT1(strTechID) '怕有空白 '數字異常

        If strTechID <> "" AndAlso CINT1(strTechID) > 0 Then
            If dt IsNot Nothing Then
                Dim ff As String = "TechID='" & strTechID & "'"
                If dt.Select(ff).Length <> 0 Then
                    Rst = $"{dt.Select(ff)(0)("TeachCName")}"
                End If
            Else
                Using conn As SqlConnection = DbAccess.GetConnection()
                    Dim pms1 As New Hashtable From {{"TECHID", strTechID}}
                    Dim objstr As String = " SELECT TEACHCNAME FROM TEACH_TEACHERINFO WHERE TECHID=@TECHID"
                    Dim dt2 As DataTable = DbAccess.GetDataTable(objstr, conn, pms1)
                    If dtHaveDATA(dt2) Then Rst = $"{dt2.Rows(0)("TEACHCNAME")}" 'DbAccess.ExecuteScalar(objstr)   End If
                    Call CloseDbConn(conn)
                End Using
            End If
        End If
        Return Rst
    End Function

