    ''' <summary>'取得開訓日期班數資訊依PlanID 顯示該開訓日前三天與後三天的開訓班數</summary>
    ''' <param name="sCmdArg"></param>
    ''' <param name="oConn"></param>
    ''' <returns></returns>
    Public Shared Function Get_MemoD1(ByVal sCmdArg As String, ByRef oConn As SqlConnection) As String
        Dim rst As String = ""
        Dim PlanID As String = GetMyValue(sCmdArg, "PlanID")
        Dim STDate As String = GetMyValue(sCmdArg, "STDate")
        Dim STDate1 As String = Cdate3(DateAdd(DateInterval.Day, -3, CDate(STDate)))
        Dim STDate2 As String = Cdate3(DateAdd(DateInterval.Day, 3, CDate(STDate)))

        'https://jira.turbotech.com.tw/browse/TIMSC-148
        Dim sql As String = ""
        sql &= " select CONVERT(varchar, pp.stdate, 111) stdate" & vbCrLf
        sql &= " ,count(1) ccnt1" & vbCrLf
        sql &= " FROM VIEW2B pp" & vbCrLf
        '審核結果核定結果Y/N/M/O
        sql &= " where pp.AppliedResult='Y'" & vbCrLf
        sql &= " and pp.PlanID=@PlanID" & vbCrLf
        sql &= " and pp.stdate>=convert(datetime, @STDate1, 111)" & vbCrLf
        sql &= " and pp.stdate<=convert(datetime, @STDate2, 111)" & vbCrLf
        sql &= " group by CONVERT(varchar, pp.stdate, 111)" & vbCrLf
        sql &= " order by 1" & vbCrLf
        Dim sCmd As New SqlCommand(sql, oConn)
        Call OpenDbConn(oConn)
        Dim dt As New DataTable
        With sCmd
            .Parameters.Clear()
            .Parameters.Add("PlanID", SqlDbType.VarChar).Value = PlanID
            .Parameters.Add("STDate1", SqlDbType.VarChar).Value = STDate1
            .Parameters.Add("STDate2", SqlDbType.VarChar).Value = STDate2
            dt.Load(.ExecuteReader())
        End With
        If dt.Rows.Count = 0 Then Return rst
        For Each drv As DataRow In dt.Rows
            If Convert.ToString(drv("ccnt1")) <> "" Then
                rst &= String.Concat(If(rst <> "", "、", ""), Cdate3(drv("stdate"), "MM/dd"), ":", drv("ccnt1"), "班")
            End If
        Next
        Return rst
    End Function

