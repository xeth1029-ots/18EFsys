    '顯示快取的機構
    Public Shared Sub ShowHistoryRID(ByRef MyPage As Page, ByVal MyTable As Table,
                            ByVal SpanTabName As String, ByVal RIDField As String,
                            ByVal OrgNameField As String, Optional ByVal btn As String = "",
                            Optional ByVal blnSubmit As Boolean = False, Optional ByVal Func_Name As String = "")
        If MyTable Is Nothing Then Exit Sub

        Dim MyRow As TableRow
        Dim MyCell As TableCell
        MyTable.BackColor = System.Drawing.Color.FromName("#FFFFEC")
        MyTable.CssClass = "font"
        Dim dt As DataTable
        'Dim dr As DataRow

        MyTable.CellPadding = 1
        MyTable.CellSpacing = 0
        '顯示快取的資料
        Dim tConn As SqlConnection = DbAccess.GetConnection()
        dt = GetCookieTable(MyPage, tConn)
        Call CloseDbConn(tConn)
        If dt Is Nothing Then Exit Sub

        Const cst_SYS_01_001_FN As String = "SYS_01_001"
        Dim iMaxRow As Integer = 5
        'If MyTable.Rows.Count >= iMaxRow Then Return

        Select Case Func_Name
            Case cst_SYS_01_001_FN '"SYS_01_001"
                For i As Integer = iMaxRow To 1 Step -1
                    Dim v_ActOrgRID As String = If(dt.Select("ItemName='ActOrgRID" & i & "'").Length <> 0, dt.Select("ItemName='ActOrgRID" & i & "'")(0)("ItemValue"), "")
                    Dim v_ActOrgName As String = If(dt.Select("ItemName='ActOrgName" & i & "'").Length <> 0, dt.Select("ItemName='ActOrgName" & i & "'")(0)("ItemValue"), "")

                    If v_ActOrgRID <> "" AndAlso v_ActOrgName <> "" Then
                        MyRow = New TableRow
                        MyTable.Rows.Add(MyRow)
                        MyCell = New TableCell
                        MyRow.Cells.Add(MyCell)
                        MyRow.Attributes("onmouseover") = "this.style.backgroundColor='#F0F0F0';"
                        MyRow.Attributes("onmouseout") = "this.style.backgroundColor='';"
                        MyRow.Style("CURSOR") = "hand"

                        MyCell.BorderWidth = Unit.Pixel(1)
                        MyCell.BorderColor = System.Drawing.Color.FromName("E4E4E4")
                        MyCell.Text = v_ActOrgName
                        Dim s_onclickStr As String = ""
                        s_onclickStr &= String.Format("document.getElementById('{0}').value='{1}';", RIDField, v_ActOrgRID)
                        s_onclickStr &= String.Format("document.getElementById('{0}').value='{1}';", OrgNameField, v_ActOrgName)
                        s_onclickStr &= String.Format("document.getElementById('{0}').style.display='none';", SpanTabName)
                        If btn <> "" Then s_onclickStr &= String.Format("document.getElementById('{0}').click();", btn)
                        If blnSubmit Then s_onclickStr &= "document.forms[0].submit();"
                        MyCell.Attributes("onclick") = s_onclickStr 'String.Format("");
                    End If
                Next
            Case Else
                For i As Integer = iMaxRow To 1 Step -1
                    Dim v_LevOrgRID As String = If(dt.Select("ItemName='LevOrgRID" & i & "'").Length <> 0, dt.Select("ItemName='LevOrgRID" & i & "'")(0)("ItemValue"), "")
                    Dim v_LevOrgName As String = If(dt.Select("ItemName='LevOrgName" & i & "'").Length <> 0, dt.Select("ItemName='LevOrgName" & i & "'")(0)("ItemValue"), "")
                    If v_LevOrgRID <> "" AndAlso v_LevOrgName <> "" Then
                        MyRow = New TableRow
                        MyTable.Rows.Add(MyRow)
                        MyCell = New TableCell
                        MyRow.Cells.Add(MyCell)
