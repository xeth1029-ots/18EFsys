        'view-source:https://localhost:44383/TC/01/TC_01_021?ID=928
        '開放受理之申請階段／PLAN_APPSTAGE
        Dim rst As String = ""
        vYEARS = ClearSQM(vYEARS) '年度
        vPTYPE1 = ClearSQM(vPTYPE1) '"01", "02"
        Dim PTYPE1_AA As String() = {"01", "02"}
        If vYEARS = "" Then Return rst
        If Not PTYPE1_AA.Contains(vPTYPE1) Then Return rst '只能是01/02　

        '(打不開不使用)
        If Not OpenDbConn(oConn) Then Return rst
        Dim dt As New DataTable
        Dim sSql As String = ""
        sSql &= " SELECT a.YEARS,a.APPSTAGE,a.SACCEPTDATE,a.FACCEPTDATE" & vbCrLf
        sSql &= " FROM PLAN_APPSTAGE a" & vbCrLf
        sSql &= " WHERE DATEDIFF(MI,a.SACCEPTDATE,GETDATE())>=0 AND DATEDIFF(MI,GETDATE(),a.FACCEPTDATE)>0" & vbCrLf
        sSql &= " AND a.PTYPE1=@PTYPE1 AND a.YEARS=@YEARS AND a.APPSTAGE IS NOT NULL" & vbCrLf
        Dim sCmd As New SqlCommand(sSql, oConn)
        With sCmd
            .Parameters.Clear()
            .Parameters.Add("YEARS", SqlDbType.VarChar).Value = vYEARS
            .Parameters.Add("PTYPE1", SqlDbType.VarChar).Value = vPTYPE1
            dt.Load(.ExecuteReader())
        End With
        If dtNODATA(dt) Then Return rst
        rst = $"{dt.Rows(0)("APPSTAGE")}"
        Return rst
    End Function

