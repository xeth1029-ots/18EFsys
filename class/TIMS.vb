    '取得月份 (01~12)
    Public Shared Function Get_Month2(ByRef obj As ListControl, ByVal sTypeText As String) As ListControl
        Dim iMonthEnd As Integer = 12
        obj.Items.Clear()
        If sTypeText = "" Then sTypeText = cst_ddl_PleaseChoose '若為空白則為請選擇
        For i As Integer = 0 To iMonthEnd
            If i = 0 Then
                If sTypeText <> "" Then obj.Items.Insert(i, New ListItem(sTypeText, ""))
            Else
                Dim si1 As String = Right("0" & i, 2)
                Dim vi1 As String = Right("0" & i, 2)
                obj.Items.Add(New ListItem(si1, vi1))
            End If
        Next
        Return obj
    End Function

    '取得月份 (1~12)
    Public Shared Function Get_Month(ByRef obj As ListControl, ByVal sTypeText As String) As ListControl
        Dim iMonthEnd As Integer = 12
        obj.Items.Clear()
        If sTypeText = "" Then sTypeText = cst_ddl_PleaseChoose '若為空白則為請選擇
        For i As Integer = 0 To iMonthEnd
            If i = 0 Then
                If sTypeText <> "" Then
                    obj.Items.Insert(i, New ListItem(sTypeText, ""))
                End If
            Else
                obj.Items.Add(New ListItem(i, i))
            End If
        Next
        Return obj
    End Function

    '取得月份 (0~X)
    Public Shared Function Get_Month(ByRef obj As ListControl, ByVal sTypeText As String, ByVal iMonthEnd As Integer) As ListControl
        obj.Items.Clear()
        For i As Integer = 0 To iMonthEnd
            obj.Items.Add(New ListItem(i, i))
        Next
        If sTypeText = "" Then sTypeText = cst_ddl_PleaseChoose '若為空白則為請選擇
        If sTypeText <> "" Then obj.Items.Insert(0, New ListItem(sTypeText, ""))
        Return obj
    End Function

    '依計畫登入次數統計
    Public Shared Sub GetLoginCount(ByVal RID As String, ByVal PlanID As Integer, ByVal conn As SqlConnection)
        Dim sSql As String = ""
        sSql &= " INSERT INTO PLAN_COUNT( PCID,PlanID,RID,LoginCount,LoginDate)" & vbCrLf
        sSql &= " VALUES ( @PCID,@PlanID,@RID,1,convert(date,GETDATE()))" & vbCrLf
        Dim iCmd As New SqlCommand(sSql, conn)

        Dim sql As String = " UPDATE PLAN_COUNT SET LoginCount=CAST(ISNULL(LoginCount,0) as Int)+1 WHERE  PCID=@PCID" & vbCrLf
        Dim uCmd As New SqlCommand(sql, conn)

        sql = ""
        sql &= " SELECT PCID FROM PLAN_COUNT WHERE PlanID=@PlanID" & vbCrLf
        sql &= " and RID=@RID and convert(date,LOGINDATE)=convert(date,GETDATE())" & vbCrLf
        Dim oCmd As New SqlCommand(sql, conn)
        Call OpenDbConn(conn)
        Dim dt As New DataTable
        With oCmd
            .Parameters.Clear()
            .Parameters.Add("PlanID", SqlDbType.Int).Value = PlanID
            .Parameters.Add("RID", SqlDbType.VarChar).Value = RID
            dt.Load(.ExecuteReader())
        End With

        If dt.Rows.Count = 0 Then
            Dim iPCID As Integer = DbAccess.GetNewId(conn, "PLAN_COUNT_PCID_SEQ,PLAN_COUNT,PCID")
            With iCmd
                .Parameters.Clear()
                .Parameters.Add("PCID", SqlDbType.Int).Value = iPCID
                .Parameters.Add("PlanID", SqlDbType.Int).Value = PlanID
                .Parameters.Add("RID", SqlDbType.VarChar).Value = RID
                .ExecuteNonQuery()
            End With
        Else
            'Dim sPCID As String=Convert.ToString(dt.Rows(0)("PCID"))
            With uCmd
                .Parameters.Clear()
                .Parameters.Add("PCID", SqlDbType.Int).Value = CINT1(dt.Rows(0)("PCID"))
                .ExecuteNonQuery()
            End With
        End If
    End Sub

