    '取得登入帳號的登入資料。
    Public Shared Sub Get_LoginPlan(ByRef obj As ListControl,
                                    ByVal sAccount As String,
                                    ByVal sLID As String,
                                    ByVal sYears As String, ByRef objconn As SqlConnection)
        Dim sql As String = ""
        sql &= " SELECT * FROM VIEW_LOGINPLAN" & vbCrLf
        If IsNumeric(sLID) AndAlso CInt(sLID) = 2 Then
            '非局、非中心使用者鎖定結束時間、年度顯示計畫
            sql &= " WHERE PLANID IN (" & vbCrLf
            sql &= " SELECT PLANID FROM ID_PLAN WHERE YEARS=@Years" & vbCrLf
            sql &= " AND GETDATE()<= DATEADD(MONTH, 10, EDATE))" & vbCrLf
            sql &= " AND PLANID IN (SELECT PLANID FROM AUTH_ACCRWPLAN WHERE Account=@Account)" & vbCrLf
            sql &= " AND (CLSYEAR IS NULL OR CLSYEAR > @Years)" & vbCrLf
            sql &= " ORDER BY TPLANID, DISTID, SEQ, PLANID" & vbCrLf
        Else
            '局、中心不管結束時間、年度顯示計畫
            sql &= " WHERE PLANID IN (SELECT PLANID FROM AUTH_ACCRWPLAN WHERE ACCOUNT=@Account)" & vbCrLf
            sql &= " AND (CLSYEAR IS NULL OR CLSYEAR > @Years)" & vbCrLf
            sql &= " AND YEARS=@Years" & vbCrLf
            sql &= " ORDER BY TPLANID, DISTID, SEQ, PLANID" & vbCrLf
        End If
        Call OpenDbConn(objconn)
        Dim dt As New DataTable
        Dim oCmd As New SqlCommand(sql, objconn)
        With oCmd
            .Parameters.Clear()
            .Parameters.Add("Account", SqlDbType.VarChar).Value = sAccount
            .Parameters.Add("Years", SqlDbType.VarChar).Value = sYears
            dt.Load(.ExecuteReader())
        End With
        With obj
            If dt.Rows.Count > 0 Then
                .DataSource = dt
                .DataTextField = "PLANNAME"
                .DataValueField = "PLANID"
                .DataBind()
            Else
                .Items.Clear()
                If TypeOf obj Is DropDownList Then
                    .Items.Insert(0, New ListItem("此帳號無有效資料", ""))
                End If
            End If
        End With
    End Sub

    '取出DataTable-計劃別,RID的帳號群組
    Public Shared Function Get_Account(ByVal PlanID As String, ByVal RID As String, ByVal RoleID As String, ByRef tConn As SqlConnection) As DataTable
        Dim parms As New Hashtable From {{"PLANID", PlanID}, {"RID", RID}}
        Dim sql As String = ""
        sql &= " SELECT a.ACCOUNT ,concat(a.NAME,'(',b.NAME,')') NAME,a.ROLEID" & vbCrLf
        sql &= " FROM ID_ROLE b" & vbCrLf
        sql &= " JOIN AUTH_ACCOUNT a on a.ROLEID=b.ROLEID AND a.ISUSED='Y' and a.ROLEID <> 0" & vbCrLf
        sql &= " JOIN AUTH_ACCRWPLAN c ON c.ACCOUNT=a.ACCOUNT" & vbCrLf
        sql &= " WHERE c.PLANID=@PLANID AND c.RID=@RID" & vbCrLf
        If RoleID <> "" Then
            parms.Add("ROLEID", RoleID)
            sql &= " AND a.ROLEID=@ROLEID" & vbCrLf
        End If
        sql &= " ORDER BY a.ROLEID" & vbCrLf
        Dim dt As DataTable = DbAccess.GetDataTable(sql, tConn, parms)
        Return dt
    End Function

    '取出鍵詞-計劃別,RID的帳號群組
    Public Shared Function Get_Account(ByRef obj As ListControl, ByVal PlanID As String, ByVal RID As String, ByRef tConn As SqlConnection) As ListControl
        Dim parms As New Hashtable From {{"PLANID", PlanID}, {"RID", RID}}
        Dim sql As String = ""
        sql &= " SELECT a.ACCOUNT ,concat(a.NAME,'(',b.NAME,')') NAME,a.ROLEID" & vbCrLf
        sql &= " FROM dbo.ID_ROLE b" & vbCrLf
        sql &= " JOIN dbo.AUTH_ACCOUNT a on a.ROLEID=b.ROLEID AND a.ISUSED='Y' and a.ROLEID <> 0" & vbCrLf
        sql &= " JOIN dbo.AUTH_ACCRWPLAN c ON c.ACCOUNT=a.ACCOUNT" & vbCrLf
        sql &= " WHERE c.PLANID=@PLANID AND c.RID=@RID" & vbCrLf
        sql &= " ORDER BY a.ROLEID,a.NAME" & vbCrLf
        Dim dt As DataTable = DbAccess.GetDataTable(sql, tConn, parms)
        With obj
            .DataSource = dt
            .DataTextField = "NAME"
            .DataValueField = "ACCOUNT"
            .DataBind()
            If TypeOf obj Is DropDownList Then .Items.Insert(0, New ListItem(cst_ddl_PleaseChoose3, ""))
