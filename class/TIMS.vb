    ''' <summary>'職類課程人時成本分類檔2/3(無介面人工維護)</summary>
    ''' <param name="obj"></param>
    ''' <param name="GovClass"></param>
    ''' <param name="GCode1"></param>
    ''' <param name="oConn"></param>
    ''' <returns></returns>
    Public Shared Function Get_GCode2(ByVal obj As DropDownList, ByVal GovClass As String, ByVal GCode1 As String, ByRef oConn As SqlConnection) As DropDownList
        Dim sql As String = ""
        Dim hPMS As New Hashtable From {{"GOVCLASS", CINT1(GovClass)}, {"GCODE1", CINT1(GCode1)}}
        If GovClass <= 2 Then
            sql &= " SELECT GCID,concat('(',GCODE2,')',CNAME) NAME, GCODE2"
            sql &= " FROM ID_GOVCLASSCAST"
            sql &= " WHERE GCODE2 IS NOT NULL AND GOVCLASS=@GOVCLASS AND GCODE1=@GCODE1"
            sql &= " ORDER BY GCODE2"
        Else
            sql &= " SELECT GCID,concat('(',GCODE1,')',CNAME) NAME, GCODE1"
            sql &= " FROM ID_GOVCLASSCAST"
            sql &= " WHERE GOVCLASS=@GOVCLASS AND GCODE1=@GCODE1"
            sql &= " ORDER BY GCODE1"
        End If
        Dim dt As DataTable = DbAccess.GetDataTable(sql, oConn, hPMS)
        With obj
            .DataSource = dt
            .DataTextField = "NAME"
            .DataValueField = "GCID"
            .DataBind()
