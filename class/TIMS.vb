            sqlStr &= " ,Phone1=b.Phone1" & vbCrLf
            sqlStr &= " ,Phone2=b.Phone2" & vbCrLf
            sqlStr &= " ,CellPhone=b.CellPhone" & vbCrLf
            sqlStr &= " ,Email=b.Email" & vbCrLf
            sqlStr &= " ,IsAgree=b.IsAgree" & vbCrLf
            sqlStr &= " ,ModifyAcct=@ModifyAcct" & vbCrLf
            sqlStr &= " ,ModifyDate=GETDATE()" & vbCrLf
            '同IDNO同SETID 執行更新
            sqlStr &= " FROM STUD_ENTERTEMP a" & vbCrLf
            sqlStr &= " JOIN STUD_ENTERTEMP2 b ON a.IDNO=b.IDNO" & vbCrLf
            sqlStr &= " WHERE b.IDNO=@IDNO2 AND b.eSETID=@eSETID" & vbCrLf
            'sqlStr &= " WHERE IDNO=@IDNO1 " '同IDNO
            Dim uCmd As New SqlCommand(sqlStr, tmpConn, tmpTrans)
            With uCmd
                .Parameters.Clear()
                .Parameters.Add("@ModifyAcct", SqlDbType.VarChar).Value = sm.UserInfo.UserID
                .Parameters.Add("@IDNO2", SqlDbType.VarChar).Value = IDNO2
                .Parameters.Add("@eSETID", SqlDbType.Int).Value = itESETID
                '.Parameters.Add("@IDNO1", SqlDbType.VarChar).Value=IDNO2
                .ExecuteNonQuery()
            End With
            If fgTmpTrans Then DbAccess.CommitTrans(tmpTrans) '啟用 SqlTransaction
