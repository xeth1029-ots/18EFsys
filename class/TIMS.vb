            sqlStr &= " ,Address" & vbCrLf
            sqlStr &= " ,Phone1" & vbCrLf
            sqlStr &= " ,Phone2" & vbCrLf
            sqlStr &= " ,CellPhone" & vbCrLf
            sqlStr &= " ,Email" & vbCrLf
            sqlStr &= " ,IsAgree" & vbCrLf

            sqlStr &= " ,ModifyAcct" & vbCrLf
            sqlStr &= " ,ModifyDate" & vbCrLf
            sqlStr &= " FROM STUD_ENTERTEMP2" & vbCrLf
            sqlStr &= " WHERE IDNO=@IDNO2 AND SETID IS NOT NULL" & vbCrLf '有IDNO'SETID有值
            sqlStr &= " ORDER BY MODIFYDATE DESC" & vbCrLf '最新1筆料。
            Dim sCmd As New SqlCommand(sqlStr, tmpConn, tmpTrans)
            Dim dt As New DataTable
            With sCmd
                .Parameters.Clear()
                .Parameters.Add("IDNO2", SqlDbType.VarChar).Value = IDNO2
                dt.Load(.ExecuteReader())
            End With
            If dt.Rows.Count > 0 Then
                Dim dr As DataRow = dt.Rows(0)
                itSETID = dr("SETID")
                itESETID = dr("eSETID")
            End If
            If itSETID = 0 OrElse itESETID = 0 Then Exit Sub

            '將Stud_EnterTemp2的資料更新到Stud_EnterTemp
            sqlStr = ""
            sqlStr &= " UPDATE STUD_ENTERTEMP" & vbCrLf
            sqlStr &= " SET Name=b.Name" & vbCrLf
            sqlStr &= " ,Sex=b.Sex" & vbCrLf
            sqlStr &= " ,Birthday=b.Birthday" & vbCrLf
            sqlStr &= " ,PassPortNO=b.PassPortNO" & vbCrLf
            sqlStr &= " ,MaritalStatus=b.MaritalStatus" & vbCrLf
