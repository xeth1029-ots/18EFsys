    ''' <summary>確認序號與 HASH1 是有資料的 ADP_HASHLOG</summary>
    ''' <param name="oConn"></param>
    ''' <param name="s_parms"></param>
    ''' <returns></returns>
    Public Shared Function CHK_HASHLOG(ByRef oConn As SqlConnection, ByRef s_parms As Hashtable) As Boolean
        'HSEQ,HASH1
        Dim rst As Boolean = False
        Dim v_HSEQ As String = GetMyValue2(s_parms, "HSEQ")
        If v_HSEQ = "" Then Return rst
        If Not IsNumeric2(v_HSEQ) Then Return rst
        Dim v_HASH1 As String = GetMyValue2(s_parms, "HASH1")
        If v_HASH1 = "" Then Return rst

        Dim r_prams As New Hashtable From {{"HSEQ", CINT1(v_HSEQ)}, {"HASH1", v_HASH1}} 'r_prams.Clear()
        Dim sql As String = " SELECT * FROM dbo.ADP_HASHLOG WHERE HSEQ=@HSEQ AND HASH1=@HASH1"
        Dim dr1 As DataRow = DbAccess.GetOneRow(sql, objConn:=oConn, parms:=r_prams)
        If dr1 IsNot Nothing Then rst = True
        Return rst
    End Function

    ''' <summary>防止駭客攻擊(紀錄) 啟動-Login / true:攻擊異常達標 false:未達標</summary>
    ''' <param name="MyPage"></param>
    ''' <param name="oConn"></param>
    ''' <param name="sTxtIdUnchange"></param>
    ''' <returns></returns>
    Public Shared Function Utl_ChkHISTORY1(ByRef MyPage As Page, ByRef oConn As SqlConnection, ByVal sTxtIdUnchange As String) As Boolean
        Dim flag_ChkHISTORY1 As Boolean = TIMS.sUtl_ChkHISTORY1(oConn)
        If flag_ChkHISTORY1 Then
            Dim flag_use_httpcontext As Boolean = If(IsNothing(MyPage), True, False)
            Dim s_USERAGENT_INFO As String = ""
            Try
                s_USERAGENT_INFO = GetUserAgent(MyPage, flag_use_httpcontext)
            Catch ex As Exception
                LOG.Warn(ex.Message, ex)
            End Try
            'Url： https : //ojtims.wda.gov.tw/CP/01/CP_01_007_add.aspx?ID=380&OCID=148242&State=Add&Type=CT
            'RawUrl：/CP/01/CP_01_007_add.aspx?ID=380&OCID=148242&State=Add&Type=CT
            Dim strErrmsg1 As String = s_USERAGENT_INFO
            strErrmsg1 &= String.Concat("防止駭客攻擊(紀錄) 啟動-Login", vbCrLf, GetErrorMsg(MyPage))
            'strErrmsg1 &= GetErrorMsg(MyPage) '取得錯誤資訊寫入
            strErrmsg1 &= String.Concat("GetHTTP_HOST:", vbCrLf, TIMS.GetHTTP_HOST(MyPage), vbCrLf)
            Call WriteTraceLog(strErrmsg1)

            Dim sm As SessionModel = SessionModel.Instance()
            sm.LastErrorMessage = TIMS.cst_ErrorMsg1
            'AuthUtil.LoginLog(sTxtIdUnchange, False)
            '登出/ 重登
            AuthUtil.LogoutLog()
            '清除登入狀態
            sm.ClearSession()
        End If
        Return flag_ChkHISTORY1
    End Function
