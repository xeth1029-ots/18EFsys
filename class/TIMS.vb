    ''' <summary> 取出關鍵字 產業別鍵詞 KEY_BUSINESS KEY_DEPOT </summary>
    ''' <param name="DepID"></param>
    ''' <param name="KID"></param>
    ''' <param name="oConn"></param>
    ''' <returns></returns>
    Public Shared Function GetBUSINESSKEYS(ByVal DepID As String, ByVal KID As String, ByRef oConn As SqlConnection) As String
        Dim rst As String = ""
        If KID = "" Then Return rst
        Dim sql As String = ""
        sql &= " SELECT k.DepID ,k.KID ,d.DNAME ,d.Years ,b.KName ,k.KeyName" & vbCrLf
        sql &= " FROM dbo.KEY_BUSINESS b" & vbCrLf
        sql &= " JOIN dbo.KEY_DEPOT d ON d.DepID=b.DepID" & vbCrLf
        sql &= " JOIN dbo.KEY_BUSINESSKEYS k ON k.DepID=b.DepID AND k.KID=b.KID" & vbCrLf
        sql &= $" WHERE k.DepID='{DepID}' AND k.KID IN ({KID})" & vbCrLf
        Dim dt As DataTable = DbAccess.GetDataTable(sql, oConn)
        rst = ""
        For Each dr As DataRow In dt.Rows
            'edit，by:20181026
            If Not CHK_INDEX(rst, Convert.ToString(dr("KeyName"))) Then
                rst &= String.Concat(If(rst <> "", ",", ""), dr("KeyName"))
            End If
        Next
        Return rst
    End Function

