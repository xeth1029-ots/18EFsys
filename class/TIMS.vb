        Str1 = Replace(Replace(Replace(Replace(Str1, "'", ""), "--", ""), "*/", ""), "/*", "")

        While CHK_ENDSWITH1(Str1)
            Str1 = RemoveFromEnd(RemoveFromEnd(RemoveFromEnd(RemoveFromEnd(Str1, vbCrLf), vbLf), vbCr), vbTab)
            If Not CHK_ENDSWITH1(Str1) Then Exit While
        End While
        While CHK_STARTSWITH1(Str1)
            Str1 = RemoveFromStart(RemoveFromStart(RemoveFromStart(RemoveFromStart(Str1, vbCrLf), vbLf), vbCr), vbTab)
            If Not CHK_STARTSWITH1(Str1) Then Exit While
        End While
        Return Str1
    End Function

    Public Shared Function CHK_STARTSWITH1(str1 As String) As Boolean
        Return (str1.StartsWith(vbCrLf) OrElse str1.StartsWith(vbLf) OrElse str1.StartsWith(vbCr) OrElse str1.StartsWith(vbTab))
    End Function

    Public Shared Function RemoveFromStart(str1 As String, suffix As String) As String
        If String.IsNullOrEmpty(str1) OrElse String.IsNullOrEmpty(suffix) OrElse Not str1.StartsWith(suffix) Then Return str1
        Return str1.Substring(suffix.Length)
    End Function

    Public Shared Function CHK_ENDSWITH1(str1 As String) As Boolean
        Return (str1.EndsWith(vbCrLf) OrElse str1.EndsWith(vbLf) OrElse str1.EndsWith(vbCr) OrElse str1.EndsWith(vbTab))
    End Function

    Public Shared Function RemoveFromEnd(str1 As String, suffix As String) As String
        If String.IsNullOrEmpty(str1) OrElse String.IsNullOrEmpty(suffix) OrElse Not str1.EndsWith(suffix) Then Return str1
        Return str1.Substring(0, str1.Length - suffix.Length)
    End Function

