    ''' <summary>obj.GetType()</summary>
    ''' <param name="obj"></param>
    ''' <returns></returns>
    Public Shared Function ObjTypeGetMethods(obj As Object) As String
        Dim objType As Type = obj.GetType()
        Dim rst As String = String.Concat(obj.GetType.Name, ",#method.Name:")
        rst &= "<br><br>***GetMembers:***"
        For Each member As MemberInfo In objType.GetMembers
            rst &= String.Concat(If(rst <> "", "<br> ", ""), member.Name)
        Next
        rst &= "<br><br>***GetMethods:***"
        For Each method As MethodInfo In objType.GetMethods
            'Console.WriteLine(method.Name)
            rst &= String.Concat(If(rst <> "", "<br> ", ""), method.Name)
        Next
        Return rst
    End Function

    ''' <summary>比對 ToolTip 是否存在</summary>
    ''' <param name="obj"></param>
    ''' <returns></returns>
    Public Shared Function CheckToolTipInObjTypeGetMethods(obj As Object) As Boolean
        Dim objType As Type = obj.GetType()
        Const cst_ToolTip As String = "ToolTip"
        Dim rst As Boolean = False
        'Dim rst As String=String.Concat(obj.GetType.Name, ",#method.Name:")
        'rst &= "<br><br>***GetMembers:***"
        For Each member As MemberInfo In objType.GetMembers
            If cst_ToolTip.Equals(member.Name, StringComparison.OrdinalIgnoreCase) Then Return True
        Next
        Return rst
    End Function

    'Tooltip
    Public Shared Sub Tooltip(ByRef obj As Object, ByVal title As String, ByVal ClearFlag As Boolean)
        If obj Is Nothing Then Return
        'Optional ByVal ClearFlag As Boolean=False
        Dim oTypeName As String = ""
        Dim flag_title As Boolean = True 'title沒資料 :true
        '(下列沒有ToolTip 功能，直接跳過) 'Optional ByVal title As String="" 
        Dim NOSETobj As String() = {"HtmlInputText", "HtmlInputHidden", "HtmlTableRow", "HtmlTextArea", "HtmlInputFile", "HtmlInputButton", "HtmlInputCheckBox", "HtmlInputRadioButton", "HtmlTableCell", "ListItem"}
        If title = "" Then
            Try
                oTypeName = obj.GetType.Name
                If (NOSETobj.Contains(oTypeName)) Then Exit Try
                obj.ToolTip = title 'ClearFlag (清理／不組合)
            Catch ex As Exception
                LOG.Warn($"{oTypeName} : Tooltip, exMessage: {ex.Message}", ex)
            End Try
            obj.Attributes.Remove("title")
            Return
        End If

        Try
            oTypeName = obj.GetType.Name
            If Not ClearFlag Then
                If (NOSETobj.Contains(oTypeName)) Then Exit Try
                If obj.ToolTip <> "" Then
                    flag_title = False '有資料組合title :false
                    title = String.Concat(obj.ToolTip, "; ", title)
                    obj.ToolTip = Nothing
                End If
            Else
                If (NOSETobj.Contains(oTypeName)) Then Exit Try
                obj.ToolTip = title 'ClearFlag 
            End If
        Catch ex As Exception
            LOG.Warn($"{oTypeName} : Tooltip, exMessage: {ex.Message}", ex)
        End Try
        Try
            oTypeName = obj.GetType.Name
            If ClearFlag Then
                'ClearFlag (清理／不組合)
                obj.Attributes("title") = title
            ElseIf flag_title AndAlso obj.Attributes("title") IsNot Nothing Then
                '(有資料 組合前字串)
                obj.Attributes("title") = String.Concat(obj.Attributes("title"), "; ", title)
            Else
                '(直接使用)
                obj.Attributes("title") = title
            End If
        Catch ex As Exception
            LOG.Warn($"{oTypeName} : Tooltip, exMessage: {ex.Message}", ex)
        End Try
    End Sub

