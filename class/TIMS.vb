,ec.ECSEQ,ec.ECNAME,ec.FGUSE,e.FGUSE,a.ISUSED
FROM AUTH_ACCOUNT a
join AUTH_EMAILACCT e on e.ACCOUNT=a.ACCOUNT
join SYS_EMAILCODE ec on ec.ECSEQ=e.ECSEQ
