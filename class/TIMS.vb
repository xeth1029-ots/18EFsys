            sql &= " AND GETDATE()<=DATEADD(year, obYears, obSdate)" & vbCrLf '目前時間未結束
            sql &= $" AND ComIDNO='{ComIDNO}' AND OBTERMS='{OBTERMS}'" & vbCrLf
            Select Case iBlackType
                Case 1
                    '限定單1計畫
                    sql &= " and TPlanID='" & sTPlanID & "'" & vbCrLf
                Case 2
                    '限定(合並)計畫
                    If sBLACK2TPLANID <> "" Then
