    ''' <summary> 授課時間格式檢核 (填入範例：09:00~12:00) 有誤：false 正常:true </summary>
    ''' <param name="s_PNAME"></param>
    ''' <returns></returns>
    Public Shared Function Check_PName(ByVal s_PNAME As String) As Boolean
        Dim rst As Boolean = False
        s_PNAME = ChangeIDNO(ClearSQM(s_PNAME))
        If s_PNAME = "" Then Return rst
        If s_PNAME.Length <> "18:30~21:30".Length Then Return rst
        If s_PNAME.IndexOf("~") = -1 Then Return rst
        If s_PNAME.IndexOf(":") = -1 Then Return rst

        Dim as_PNAME As String() = s_PNAME.Split("~")
        If as_PNAME.Length <> 2 Then Return rst
        If as_PNAME(0).Length <> 5 Then Return rst '18:30
        If as_PNAME(1).Length <> 5 Then Return rst '21:30

        Dim as_PNAME_0 As String() = as_PNAME(0).Split(":")
        Dim as_PNAME_1 As String() = as_PNAME(1).Split(":")
        If as_PNAME_0.Length <> 2 Then Return rst
        If as_PNAME_1.Length <> 2 Then Return rst
        If as_PNAME_0(0).Length <> 2 OrElse Not IsNumeric1(as_PNAME_0(0)) Then Return rst
        If as_PNAME_0(1).Length <> 2 OrElse Not IsNumeric1(as_PNAME_0(1)) Then Return rst
        If as_PNAME_1(0).Length <> 2 OrElse Not IsNumeric1(as_PNAME_1(0)) Then Return rst
        If as_PNAME_1(1).Length <> 2 OrElse Not IsNumeric1(as_PNAME_1(1)) Then Return rst
        Dim HH1 As Integer = as_PNAME_0(0)
        Dim mm1 As Integer = as_PNAME_0(1)
        Dim HH2 As Integer = as_PNAME_1(0)
        Dim mm2 As Integer = as_PNAME_1(1)
        If HH1 < 0 OrElse HH1 > 23 Then Return rst
        If HH2 < 0 OrElse HH2 > 23 Then Return rst
        If mm1 < 0 OrElse mm1 > 59 Then Return rst
        If mm2 < 0 OrElse mm2 > 59 Then Return rst
        rst = True '應該可能錯誤的格式，都檢核了吧，放行
        Return rst
    End Function

