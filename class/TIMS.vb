    ''' <summary> 取得欄位值匯出含註解 </summary>
    ''' <param name="COLUMNs"></param>
    ''' <param name="dr1"></param>
    ''' <returns></returns>
    Public Shared Function Get_DataRowValues(ByRef COLUMNs As String, ByRef dr1 As DataRow) As String
        Dim s_Values As String = ""
        If dr1 Is Nothing OrElse COLUMNs Is Nothing OrElse COLUMNs = "" Then Return s_Values
        Dim aCOLUMNs As String() = COLUMNs.Split(",")
        Try
            For Each sV1 As String In aCOLUMNs
                If sV1 = "" Then Return s_Values
                If CheckColumnName(dr1, sV1) Then
                    s_Values &= String.Concat(If(s_Values <> "", ",", ""), If(IsDBNull(dr1(sV1)), "Null", String.Concat("'", dr1(sV1), "'")), " /*", sV1, "*/", vbCrLf)
                End If
            Next
        Catch ex As Exception
            LOG.Error(ex.Message, ex)
        End Try
        Return s_Values
    End Function

    ''' <summary> 比對 查詢成功true </summary>
    ''' <param name="dr1"></param>
    ''' <param name="s_ColumnName"></param>
    ''' <returns></returns>
    Public Shared Function CheckColumnName(ByRef dr1 As DataRow, ByVal s_ColumnName As String) As Boolean
        Dim rst As Boolean = False
        If dr1 Is Nothing Then Return rst
        'For Each col As DataColumn In dr1.ItemArray
        For Each col As DataColumn In dr1.Table.Columns
            If String.Compare(col.ColumnName, s_ColumnName, True) Then Return True
        Next
        Return rst
    End Function

    ''' <summary>欄位值匯出含註解</summary>
    ''' <param name="dr1"></param>
    ''' <returns></returns>
    Public Shared Function Get_DataRowValues(ByRef dr1 As DataRow) As String
        Dim s_Values As String = ""
        If dr1 Is Nothing Then Return s_Values
        'For Each col As DataColumn In dr1.ItemArray
        For Each col As DataColumn In dr1.Table.Columns
            If col.ColumnName = "" Then Continue For
            s_Values &= If(s_Values <> "", ",", "")
            s_Values &= String.Concat(If(IsDBNull(dr1(col.ColumnName)), "Null", String.Concat("'", dr1(col.ColumnName), "'")), " /*", col.ColumnName, "*/ ")
        Next
        Return s_Values
    End Function

