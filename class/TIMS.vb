    '刪除重複轉班資料。
    Public Shared Function sUtl_DeleteDoubleClassInfo(ByVal PlanID As String,
                                                      ByVal ComIDNO As String,
                                                      ByVal SeqNO As String,
                                                      ByRef objconn As SqlConnection) As Boolean
        Dim rst As Boolean = False '沒有重複false
        Dim sql As String = ""
        sql &= " SELECT PLANID,COMIDNO,SEQNO ,MAX(OCID) MAX_OCID" & vbCrLf
        sql &= " FROM CLASS_CLASSINFO" & vbCrLf
        sql &= " WHERE PlanID=@PlanID AND ComIDNO=@ComIDNO AND SeqNO=@SeqNO" & vbCrLf
