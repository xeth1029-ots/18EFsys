    ''' <summary>取得指定虛擬目錄下的檔案總數</summary>
    ''' <param name="virtualPath">虛擬路徑 (例如: "~/CO/01/Temp/")</param>
    ''' <returns>檔案數量，若目錄不存在則傳回 0</returns>
    Public Shared Function GetFileCount(MyPage As Page, ByVal virtualPath As String) As Integer
        Try
            ' 1. 將虛擬路徑轉換為實體路徑
            Dim physicalPath As String = MyPage.Server.MapPath(virtualPath)
            ' 2. 檢查目錄是否存在，避免例外狀況
            If Directory.Exists(physicalPath) Then
                ' 3. 取得檔案清單並回傳計數 ' SearchOption.TopDirectoryOnly 表示僅計算該層，不含子目錄
                Return Directory.GetFiles(physicalPath, "*.*", SearchOption.TopDirectoryOnly).Length
            Else
                Return 0
            End If
        Catch ex As Exception
            ' 實務上建議在此記錄 Log
            Return -1
        End Try
    End Function

    'Imports System.IO 'Imports System.Linq ' 必須引用 Linq 以便使用 Take 與 Join
    ''' <summary>
    ''' 取得目錄統計資訊：檔案總數與前10個檔名
    ''' </summary>
    ''' <param name="MyPage"></param>
    ''' <param name="virtualPath"></param>
    ''' <param name="totalCount"></param>
    Public Shared Function GetFolderSum(MyPage As Page, ByVal virtualPath As String, ByRef totalCount As Integer) As String
        Dim rstMsg As String = ""
        Try
            Dim physicalPath As String = MyPage.Server.MapPath(virtualPath)
            If Directory.Exists(physicalPath) Then
                ' 1. 取得所有檔案的列舉 (不直接載入記憶體)
                Dim allFiles As IEnumerable(Of String) = Directory.EnumerateFiles(physicalPath)
                ' 2. 計算總數
                totalCount = allFiles.Count()
                Dim N_CNT As Integer = 6 ' 3. 取得前 n個檔名 (僅檔名，不含路徑) ' 使用 LINQ 篩選前 n個，並透過 Path.GetFileName 轉換
                Dim fileList As IEnumerable(Of String) = allFiles.Take(N_CNT).Select(Function(f) Path.GetFileName(f))
                rstMsg = String.Join(", ", fileList)
            Else
                totalCount = 0
                rstMsg = $"目錄不存在 {virtualPath}"
            End If
        Catch ex As Exception
            totalCount = -1
            rstMsg = $"目錄: {virtualPath},錯誤: {ex.Message}"
        End Try
        Return rstMsg
    End Function

    ''' <summary>將 SqlCommand 的 Parameters 集合轉換為 Hashtable</summary>
    ''' <param name="parameters">SqlCommand.Parameters 集合</param>
    ''' <returns>包含參數名稱與數值的 Hashtable</returns>
    Public Shared Function CONVERTPAR2HASHTB(parameters As SqlParameterCollection) As Hashtable
        Dim ht As New Hashtable()
        ' 檢查集合是否為空
        If parameters Is Nothing OrElse parameters.Count = 0 Then Return ht
        For Each param As SqlParameter In parameters
            ' 建議處理 DBNull，確保在邏輯處理時不會發生轉型錯誤
            Dim V_STR1 As String = If(param.Value Is Nothing, "NULL", $"{param.Value}")
            ' Key: 參數名稱 (例如 @UserID), Value: 參數值 ' 若您希望 Key 不帶 @ 符號，可使用 param.ParameterName.Replace("@", "")
            If Not ht.ContainsKey(param.ParameterName) Then ht.Add(param.ParameterName, $"{V_STR1}")
        Next
        Return ht
    End Function

    Public Shared Function TruncateDecimal(value As Decimal, precision As Integer) As Decimal
        Dim stepValue As Decimal = CDec(Math.Pow(10, precision))
        Return Math.Truncate(value * stepValue) / stepValue
    End Function

End Class
