    ''' <summary> 登入最新時間更新-last_loginDate </summary>
    ''' <param name="UserName"></param>
    ''' <param name="conn"></param>
    Public Shared Function Update_Auth_Account(ByRef UserName As String, ByRef conn As SqlConnection) As Date
        Threading.Thread.Sleep(1) '假設處理某段程序需花費1毫秒 (避免機器不同步)
        Dim aNow As Date = GetSysDateNow1(conn)
        If UserName = "" Then Return aNow
        '登入最新時間更新
        'Dim sql As String="" 'sql=""
        Dim u_sql As String = " UPDATE AUTH_ACCOUNT SET LAST_LOGINDATE=@LLOGINDATE WHERE ACCOUNT=@ACCOUNT"
        Call OpenDbConn(conn)
        Dim u_cmd As New SqlCommand(u_sql, conn)
        With u_cmd
            .Parameters.Clear()
            .Parameters.Add("LLOGINDATE", SqlDbType.DateTime).Value = aNow
            .Parameters.Add("ACCOUNT", SqlDbType.VarChar).Value = UserName
            .ExecuteNonQuery()
        End With
        Return aNow
    End Function

    ''' <summary>檢查是否帳號已超過三個月未登入</summary>
    ''' <param name="UserID"></param>
    ''' <param name="ReturnMsg"></param>
    ''' <param name="objconn"></param>
    ''' <returns></returns>
    Public Shared Function Check_AccoutLoginDate(ByRef sm As SessionModel,
                                                 ByVal UserID As String,
                                                 ByRef ReturnMsg As String,
                                                 ByVal objconn As SqlConnection) As Boolean
        Const Cst_Errmsg1 As String = "*超過三個月未登入系統暫時停權"

        Dim rst As Boolean = False 'False:停權 'True:可登入
        If (String.IsNullOrEmpty(UserID)) Then Return rst '異常離開

        Dim strScript As String = ""
        Dim date_interval As Integer = 0 '(差距日) 如果沒有第1次登入日期，(interval)可能為null
        Dim note As String = ""
        Dim dr As DataRow = Nothing

        Call OpenDbConn(objconn)

        Dim dt As New DataTable
        Dim sql As String = ""
        sql = " SELECT Isused" & vbCrLf
        sql &= " ,DateDiff(day, last_loginDate, GETDATE()) interval" & vbCrLf '(差距日) 如果沒有第1次登入日期，可能為null/INT
        sql &= " ,note" & vbCrLf
        sql &= " ,ISNULL(Len(note),0) noteLen" & vbCrLf
        sql &= " ,convert(varchar, GETDATE(), 120) now_time_120" & vbCrLf
        sql &= " FROM AUTH_ACCOUNT" & vbCrLf
        sql &= " WHERE account=@account" & vbCrLf
        Dim cmd As New SqlCommand(sql, objconn)
        With cmd
            .Parameters.Clear()
            .Parameters.Add("account", SqlDbType.VarChar).Value = UserID
            dt.Load(.ExecuteReader())
        End With
        If dt.Rows.Count > 0 Then dr = dt.Rows(0)
        If dr Is Nothing Then Return rst '異常離開

        If IsDBNull(dr("interval")) Then
            '(差距日) 為null （第1次登入日期）
            sm.LAST_LOGINDATE = Update_Auth_Account(UserID, objconn)
            LOG.Info(String.Format("#LAST_LOGINDATE: {0}/{1}", UserID, sm.LAST_LOGINDATE.ToString("yyyy-MM-dd HH:mm:ss.fff")))
            rst = True
            Return rst
        End If

        date_interval = dr("interval") '差距日
        If date_interval > 90 Then
            '090804 andy edit  由於欄位字數不斷append可能會超過限制，改為使用取代的方式
            note = $"{dr("note")}"
            While InStr(note, Cst_Errmsg1) <> 0
                Dim mydate As DateTime
                Dim oldStr As String = ""
                Dim newStr As String = ""
                Dim DateStr As String = ""
                Dim i_Index16 As Int16 = 0
                Dim i_Len19 As Integer = 19 'convert(varchar, GETDATE(), 120) 
                i_Index16 = InStr(note, Cst_Errmsg1) + (Cst_Errmsg1.Length - 1)
                DateStr = note.Substring(i_Index16, i_Len19) '取出時間字串(後面19個字元)
                Try
                    oldStr = If(mydate.GetType Is Convert.ToDateTime(DateStr).GetType, (Cst_Errmsg1 & DateStr), Cst_Errmsg1)
                Catch ex As Exception
                    LOG.Warn(ex.Message, ex)
                    oldStr = Cst_Errmsg1
                End Try
                note = Replace(note, oldStr, newStr)
            End While

            '" & Cst_Errmsg1 & "' + convert(varchar, GETDATE(), 120) + '" & note & "'
            Dim s_note As String = String.Format("{0}{1}{2}", Cst_Errmsg1, dr("now_time_120"), note)
            'u_parms.Clear()
            Dim u_parms As New Hashtable From {{"note", s_note}, {"Account", UserID}}
            Dim u_sql As String = " UPDATE AUTH_ACCOUNT SET IsUsed='N',note=@note WHERE Account=@Account"
            DbAccess.ExecuteNonQuery(u_sql, objconn, u_parms)

            ReturnMsg = "登入帳號超過三個月未登入已暫時停權，請洽系統管理員!!!"
            rst = False
        Else
            If Convert.ToString(dr("Isused")) = "Y" Then
                sm.LAST_LOGINDATE = Update_Auth_Account(UserID, objconn)
                LOG.Info(String.Format("#LAST_LOGINDATE: {0}/{1}", UserID, sm.LAST_LOGINDATE.ToString("yyyy-MM-dd HH:mm:ss.fff")))
                rst = True
            Else
                '登入帳號已暫時停權，請洽系統管理員!!!
                ReturnMsg = "登入帳號已暫時停權，請洽系統管理員!!!"
                rst = False
            End If
        End If

        Return rst
    End Function

