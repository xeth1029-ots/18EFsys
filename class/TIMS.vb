    ''' <summary>取得 CheckBoxList 的文字 從0開始</summary>
    ''' <param name="chkobj"></param>
    ''' <returns></returns>
    Public Shared Function GetCblText(ByRef chkobj As CheckBoxList) As String
        Dim rst As String = ""
        If chkobj Is Nothing Then Return rst '異常

        For i As Integer = 0 To chkobj.Items.Count - 1
            If chkobj.Items(i).Selected AndAlso chkobj.Items(i).Value <> "" Then
                If chkobj.Items(i).Value.Equals("%") Then
                    rst = ""
                    Return rst 'Exit For
                Else
                    rst &= String.Concat(If(rst <> "", ",", ""), chkobj.Items(i).Text)
                End If
            End If
        Next
        Return rst
    End Function

