    ''' <summary>
    ''' 開班計畫場地檔 (學科)-sci
    ''' </summary>
    ''' <param name="obj"></param>
    ''' <param name="ComIDNO"></param>
    ''' <param name="i_type"></param>
    ''' <param name="i_CIFICAT"></param>
    ''' <param name="oConn"></param>
    ''' <returns></returns>
    Public Shared Function Get_SciTechPTID(ByRef obj As ListControl, ByVal ComIDNO As String, ByVal i_type As Integer, ByVal i_CIFICAT As Integer, ByRef oConn As SqlConnection) As ListControl
        Dim sql As String = ""
        Dim parms As New Hashtable()

        Select Case i_type
            Case 1 '依 ComIDNO
                sql = ""
                sql &= " SELECT a.PTID, a.PLACENAME NAME" & vbCrLf
                sql &= " FROM dbo.V_TRAINPLACE a" & vbCrLf
                sql &= " WHERE a.CLASSIFICATION IN (@CIFICAT,3)" & vbCrLf
                sql &= " AND a.MODIFYTYPE IS NULL" & vbCrLf '不保留刪除資料。
                sql &= " AND a.COMIDNO=@COMIDNO" & vbCrLf
                sql &= " ORDER BY a.PLACEID" & vbCrLf

                parms.Add("COMIDNO", ComIDNO)
                parms.Add("CIFICAT", Get_CIFICAT(i_CIFICAT))
            Case 2 '依 ComIDNO 排除刪除資料
                sql = ""
                sql &= " SELECT a.PTID, a.NAME" & vbCrLf
                sql &= " FROM dbo.V_TRAINPLACE a" & vbCrLf
                sql &= " WHERE a.CLASSIFICATION IN (@CIFICAT,3)" & vbCrLf
                sql &= " AND a.MODIFYTYPE IS NULL" & vbCrLf '不保留刪除資料。
                sql &= " AND a.COMIDNO=@COMIDNO" & vbCrLf
                sql &= " ORDER BY a.PLACEID" & vbCrLf

                parms.Add("COMIDNO", ComIDNO)
                parms.Add("CIFICAT", Get_CIFICAT(i_CIFICAT))
            Case 3 '依 PlaceID、ComIDNO
                sql = ""
                sql &= " SELECT a.PTID" & vbCrLf
                sql &= " ,concat(case when a.MODIFYTYPE='D' THEN '(已停用) ' ELSE '' END,a.PLACENAME) NAME" & vbCrLf
                sql &= " FROM dbo.V_TRAINPLACE a" & vbCrLf
                sql &= " WHERE a.CLASSIFICATION IN (@CIFICAT,3)" & vbCrLf
                'sql &= " AND (a.MODIFYTYPE IS NULL OR PLACEID='" & PlaceID & "')" & vbCrLf '保留一刪除資料。
                '保留刪除資料**sql &= " AND a.MODIFYTYPE IS NULL" & vbCrLf '不保留刪除資料。
                sql &= " AND a.COMIDNO=@COMIDNO" & vbCrLf
                sql &= " ORDER BY a.PLACEID" & vbCrLf

                parms.Add("COMIDNO", ComIDNO)
                parms.Add("CIFICAT", Get_CIFICAT(i_CIFICAT))
        End Select
        If sql = "" Then Return obj

        Dim dt As DataTable = DbAccess.GetDataTable(sql, oConn, parms)
        With obj
            .DataSource = dt
            .DataTextField = "NAME"
            .DataValueField = "PTID"
            .DataBind()
            If TypeOf obj Is DropDownList Then .Items.Insert(0, New ListItem(cst_ddl_PleaseChoose3, ""))
        End With
        Return obj
    End Function

