    ''' <summary>查詢課程上課日期與其它詳細資料(未來時間排除)</summary>
    ''' <param name="OCID"></param>
    ''' <param name="tConn"></param>
    ''' <returns></returns>
    Public Shared Function GET_TRAINDESCdt1(OCID As String, tConn As SqlConnection) As DataTable
        Dim oDt As New DataTable
        OCID = ClearSQM(OCID)
        If OCID = "" Then Return oDt
        Call OpenDbConn(tConn)
        Dim sSql As String = ""
        sSql &= " SELECT Q1.PTDID ,Q1.STRAINDATE ,Q1.PNAME ,Q1.PCONT" & vbCrLf
        sSql &= " ,CASE Q1.Classification1 WHEN '1' THEN '學科' WHEN '2' THEN '術科' END Classification1" & vbCrLf
        sSql &= " ,Q1.PHOUR ,Q1.EHOUR ,Q1.TPERIOD28" & vbCrLf
        sSql &= " ,SUBSTRING(Q1.TPERIOD28,1,1) TPERIOD28_1" & vbCrLf
        sSql &= " ,SUBSTRING(Q1.TPERIOD28,2,1) TPERIOD28_2" & vbCrLf
        sSql &= " ,SUBSTRING(Q1.TPERIOD28,3,1) TPERIOD28_3" & vbCrLf
        sSql &= " ,Q1.FARLEARN,Q1.OUTLEARN,Q1.TECHID,Q1.TECHID2" & vbCrLf
        sSql &= " FROM CLASS_CLASSINFO CC WITH(NOLOCK)" & vbCrLf
        sSql &= " JOIN PLAN_TRAINDESC Q1 WITH(NOLOCK) ON CC.PLANID=Q1.PLANID AND CC.COMIDNO=Q1.COMIDNO AND CC.SEQNO=Q1.SEQNO" & vbCrLf
        sSql &= " WHERE Q1.TPERIOD28 IS NOT NULL AND CC.OCID=@OCID AND Q1.STRAINDATE<=GETDATE()" & vbCrLf
        Dim oCmd As New SqlCommand(sSql, tConn)
        With oCmd
            .Parameters.Clear()
            .Parameters.Add("OCID", SqlDbType.Int).Value = CINT1(OCID)
            oDt.Load(.ExecuteReader())
        End With
        Return oDt
    End Function

