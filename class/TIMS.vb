    '備份資料 LogTableName
    Public Shared Sub InsertDelTableLog(ByVal s_LogTableName As String, ByRef dt As DataTable, ByRef conn As SqlConnection)
        Dim daLog As New SqlDataAdapter
        Dim dtLog As DataTable = Nothing
        Dim sql As String = $"SELECT * FROM {s_LogTableName} WHERE 1<>1"
        dtLog = DbAccess.GetDataTable(sql, daLog, conn)
        For Each dr As DataRow In dt.Rows '(資料筆數)
            Dim drLog As DataRow = dtLog.NewRow
            dtLog.Rows.Add(drLog)
            For Each dc1 As DataColumn In dt.Columns '(所有欄位)
                '將值轉移。
                drLog(dc1.ColumnName) = dr(dc1.ColumnName)
            Next
        Next
        DbAccess.UpdateDataTable(dtLog, daLog) '更新
        If daLog IsNot Nothing Then daLog.Dispose()
        If daLog IsNot Nothing Then daLog = Nothing
    End Sub

