    ''' <summary> 取得 Parameter 所有值 convert</summary>
    ''' <param name="parms"></param>
    ''' <returns></returns>
    Public Shared Function GetMyValue4(ByVal parms As Hashtable) As String
        Dim rst As String = ""
        If parms Is Nothing Then Return rst
        Dim i As Integer = 0
        For Each key As String In parms.Keys
            Dim pValue As Object = parms(key)
            Dim pType As Type = If(pValue Is Nothing, Type.EmptyTypes.GetType(), pValue.GetType())
            Dim dbType As SqlDbType = If(pValue IsNot Nothing, DbAccess.GetDBType(pType), Nothing)
            i += 1
            rst &= vbCrLf & If(rst <> "", ",", " ")
            rst &= String.Format("{0}> {1}=", i, key) & String.Format("convert({0},'{1}')", dbType, pValue)
            'sCmd.Parameters.Add(key, dbType).Value=parms(key)
        Next
        Return rst
    End Function

    ''' <summary>取得 Parameter 組合DECLARE</summary>
    ''' <param name="parms"></param>
    ''' <returns></returns>
    Public Shared Function GetMyValue5(parms As Hashtable) As String
        Dim rst As String = ""
        If parms Is Nothing Then Return rst
        Dim i As Integer = 0
        For Each key As String In parms.Keys
            Dim pValue As Object = parms(key)
            Dim pType As Type = If(pValue Is Nothing, Type.EmptyTypes.GetType(), pValue.GetType())
            Dim dbType As SqlDbType = If(pValue IsNot Nothing, DbAccess.GetDBType(pType), Nothing)
            i += 1
            rst &= vbCrLf
            Dim s_LEN2 As String = ""
            Dim s_dbType As String = dbType.ToString().ToLower() ' Convert.ToString(dbType).ToLower()
            Dim s_VALCVR As String = $"=convert({dbType},'{pValue}');/*{i}*/"
            If s_dbType.IndexOf("text") > -1 OrElse s_dbType.IndexOf("char") > -1 Then
                s_VALCVR = $"='{pValue}';/*{i}*/"
                s_LEN2 = If(pValue IsNot Nothing, $"({$"{pValue}".Length})", "")
            ElseIf s_dbType.IndexOf("datetime") > -1 Then
                s_VALCVR = $"='{Cdate3t(pValue)}';/*{i}*/"
            End If
            rst &= $"DECLARE @{key} {dbType}{s_LEN2}{s_VALCVR}"
        Next
        Return rst
    End Function

