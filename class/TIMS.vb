    ''' <summary> 加密-Base64-MD5 </summary>
    ''' <param name="plainText"></param>
    ''' <returns></returns>
    Public Shared Function CypherText(ByVal plainText As String) As String
        '密碼加密: 先做 baseEncode 再做 md5Encode
        Dim strResult As String = String.Empty
        strResult = System.Convert.ToBase64String(System.Text.UTF8Encoding.UTF8.GetBytes(plainText))
        '限定長度匯出-應該是32
        strResult = System.Web.Security.FormsAuthentication.HashPasswordForStoringInConfigFile(strResult, "MD5").ToLower().Substring(0, 32)
        Return strResult
    End Function

    ''' <summary> 加密-SHA1 </summary>
    ''' <param name="plainText"></param>
    ''' <returns></returns>
    Public Shared Function CreateHash(ByVal plainText As String) As String
        Dim Algorithm As SHA1 = SHA1.Create()
        Dim Data As Byte() = Algorithm.ComputeHash(Encoding.UTF8.GetBytes(plainText))
        Dim Hashed As String = ""
        For i As Integer = 0 To Data.Length - 1
            Hashed &= Data(i).ToString("x2").ToLowerInvariant()
        Next
        '限定長度匯出-應該是40
        Return Hashed.Substring(0, 40)
    End Function

