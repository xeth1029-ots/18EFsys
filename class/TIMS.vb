        Dim vFILENAME1 As String = GetMyValue2(rPMS, "FILENAME1")
        Dim vFILEPATH1 As String = GetMyValue2(rPMS, "FILEPATH1")

        Dim drCV As DataRow = GET_CLASS_VERIFYONLINE(oConn, vOCIDVal, vSEQ_ID, vCVOCID)
        If drCV Is Nothing Then Return
        Dim drFL As DataRow = GET_CLASS_VERIFYONLINE_FL(oConn, vCVOCID, vKVSID)
        If drFL Is Nothing Then Return
        Dim vTPLANID As String = Convert.ToString(drCV("TPLANID"))
