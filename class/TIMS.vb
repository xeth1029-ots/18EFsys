    ''' <param name="vIDNO"></param>
    ''' <returns></returns>
    Public Shared Function GetTrainingListS(ByVal vIDNO As String) As DataTable
        Dim dt As New DataTable '= Nothing
        If vIDNO = "" Then Return dt
        If vIDNO.Length = 0 Then Return dt

        Const flag_ALL As Boolean = True '不略過非在職者

        If vIDNO.IndexOf(",") = -1 Then
            '單筆 'IDNO,NAME,BIRTHDAY,DISTNAME,YEARS,TPLANID,PLANNAME,ORGNAME,TRAINNAME,CJOB_NAME,CLASSCNAME,THours,TRound,WEEKS,TFLAG,WorkSuppIdent,SumOfMoney,BudIDName,AppliedStatus,AppliedStatusM,MEMO1
            dt = GetTrainingList(vIDNO, flag_ALL)
            Return dt
        End If

        '多筆 vIDNO.IndexOf(",") > -1 
        Dim xvIDNO As String() = vIDNO.Split(",")
        For Each strIDNO As String In xvIDNO
            'IDNO,NAME,BIRTHDAY,DISTNAME,YEARS,TPLANID,PLANNAME,ORGNAME,TRAINNAME,CJOB_NAME,CLASSCNAME,THours,TRound,WEEKS,TFLAG,WorkSuppIdent,SumOfMoney,BudIDName,AppliedStatus,AppliedStatusM,MEMO1
            If strIDNO <> "" Then
                Dim dt1 As DataTable = GetTrainingList(strIDNO, flag_ALL)
                CopyDATATABLE(dt, dt1)
            End If
        Next
        Return dt
    End Function

