    ''' <summary>查詢指定目錄，並依異動日期分類檔案數量，產生文字報告</summary>
    ''' <returns>包含檔案報告的字串。</returns>
    Public Shared Function GenerateFileReportByDate() As String
        Const CST_Template_path1 As String = "\\isilontc.ejob.gov.tw\ojt\upojt1\Template"
        Const CST_Template_test_path1 As String = "C:\Users\muwo\Downloads" '"C:\Users\user4\Downloads"
        Dim DIRECTORY_PATH As String = If(sUtl_ChkTest(), CST_Template_test_path1, CST_Template_path1)
        '/login.aspx?test1=RPT1 ' 檢查目錄是否存在
        If Not Directory.Exists(DIRECTORY_PATH) Then Return $"錯誤：找不到指定的目錄 {DIRECTORY_PATH}"

        ' 建立一個 StringBuilder 來建構報告內容
        Dim reportBuilder As New StringBuilder()
        reportBuilder.AppendLine($"檔案異動日期報告 - {DateTime.Now.ToString()}")
        reportBuilder.AppendLine($"查詢目錄：{DIRECTORY_PATH}")
        reportBuilder.AppendLine("--------------------------------------------------")

        Try
            ' 計算 30 天前的日期，用於篩選檔案
            Dim thirtyDaysAgo As Date = Date.Today.AddDays(-30)

            ' 取得目錄下所有檔案的資訊
            Dim files As FileInfo() = New DirectoryInfo(DIRECTORY_PATH).GetFiles("*", SearchOption.AllDirectories)

            ' 執行 LINQ 查詢，將結果轉換為 List(Of GroupedFiles)。
            Dim GroupedFiles As List(Of GroupedFiles) = files.
            Where(Function(f) f.LastWriteTime.Date >= thirtyDaysAgo). ' 篩選出近 30 天內的檔案
            GroupBy(Function(f) f.CreationTime.Date).
            OrderBy(Function(g) g.Key).
            Select(Function(g) New GroupedFiles With {
                .GroupDate = g.Key,
                .Files = g.ToList(),
                .TotalSizeKB = Convert.ToInt64(Math.Round(g.Sum(Function(f) f.Length) / 1024.0)) ' 新增：計算每個分組的總檔案大小 (位元組)，並轉換為 KB
            }).ToList()

            ' 使用 LINQ 進行分組和排序
            'Dim groupedFiles As Object = files.
            '        GroupBy(Function(f) f.LastWriteTime.Date). ' 按檔案異動日期分組
            '        OrderBy(Function(g) g.Key) ' 按日期升序排序

            ' 遍歷每個分組，將結果加入報告
            For Each group As GroupedFiles In GroupedFiles
                ' 格式化日期為 YYYY/MM/DD
                Dim dateString As String = group.GroupDate.ToString("yyyy/MM/dd") ' CDate(group.Key).ToString("yyyy/MM/dd")
                ' 計算該日期的檔案數量
                Dim fileCount As Integer = group.Files.Count
                'Dim fileCount As Integer = DirectCast(group, System.Linq.Lookup(Of Date, System.IO.FileInfo).Grouping).count
                ' 將結果加入報告
                reportBuilder.AppendLine($"異動日期: {dateString}，檔案數量: {fileCount} 個，大小: {group.TotalSizeKB.ToString("N0")} KB")
            Next
            Dim xfilesCnt1 As Integer = GroupedFiles.Sum(Function(g) g.Files.Count)
            Dim xfilesSize1 As Long = GroupedFiles.Sum(Function(g) g.TotalSizeKB)
            reportBuilder.AppendLine("--------------------------------------------------")
            reportBuilder.AppendLine($"總計查詢檔案數量: {files.Length},,{xfilesCnt1} 個")
            reportBuilder.AppendLine($"檔案大小: {xfilesSize1.ToString("N0")} KB, {FormatBytes(xfilesSize1 * 1024)}")
            reportBuilder.AppendLine($"{DateTime.Now.ToString()}")
            Return reportBuilder.ToString()
        Catch ex As UnauthorizedAccessException
            ' 處理權限不足的錯誤
            reportBuilder.AppendLine($"錯誤：沒有權限存取 {DIRECTORY_PATH} 目錄。")
