    '產投補助金 顯示提示字元
    Public Shared Function Get_StudSubSidyCostTooltip(ByVal aIDNO As String, ByVal sdate As String, ByVal edate As String, ByVal tmpConn As SqlConnection) As String
        Dim rst As String = ""
        Dim sqlStr As String = String.Empty
        sdate = Cdate3(sdate) : edate = Cdate3(edate)
        If (sdate = "") OrElse (edate = "") Then Return rst
        'Dim dt As DataTable=Nothing
        aIDNO = ChangeIDNO(ClearSQM(aIDNO))
        If (aIDNO = "") Then Return rst

        sqlStr = ""
        sqlStr &= " SELECT ip.Years ,e.OrgName" & vbCrLf
        sqlStr &= " ,dbo.FN_GET_CLASSCNAME(d.CLASSCNAME,d.CYCLTYPE) CLASSCNAME2" & vbCrLf
        sqlStr &= " ,d.ClassCName ,d.CyclType" & vbCrLf
        sqlStr &= " ,a.AppliedStatusM" & vbCrLf
        sqlStr &= " ,a.SumOfMoney" & vbCrLf
        sqlStr &= " ,a.AppliedStatus" & vbCrLf
        sqlStr &= " from dbo.Stud_SubSidyCost a" & vbCrLf
        sqlStr &= " join dbo.Class_StudentsOfClass b on b.SOCID=a.SOCID" & vbCrLf
        sqlStr &= " join dbo.Stud_StudentInfo c on c.SID=b.SID" & vbCrLf
        sqlStr &= " join dbo.CLASS_CLASSINFO d on d.OCID=b.OCID" & vbCrLf
        sqlStr &= " join dbo.id_plan ip on ip.planid=d.planid" & vbCrLf
        sqlStr &= " join dbo.Org_OrgInfo e on e.ComIDNO=d.ComIDNO" & vbCrLf
        sqlStr &= $" WHERE c.IDNO='{aIDNO}' and d.STDate>={To_date(sdate)} and d.STDate<={To_date(edate)}" & vbCrLf
        Dim dt As DataTable = Nothing
        dt = DbAccess.GetDataTable(sqlStr, tmpConn)
        If dt.Rows.Count > 0 Then
            For Each dr As DataRow In dt.Rows
                rst &= "(" & Convert.ToString(dr("Years")) & ")" & Convert.ToString(dr("OrgName")) & "-"
                rst &= Convert.ToString(dr("CLASSCNAME2"))
                Select Case Convert.ToString(dr("AppliedStatusM"))
                    Case "Y"
                        rst &= "審核通過"
                    Case "N"
                        rst &= "審核失敗"
                    Case "R"
                        rst &= "退件修正"
                    Case Else
                        rst &= cst_str_審核中 '"審核中"
                End Select
                rst &= " $" & Convert.ToString(dr("SumOfMoney")) & " :"
                rst &= If(IsDBNull(dr("AppliedStatus")), "待撥款", If(Convert.ToString(dr("AppliedStatus")) = "1", "已撥款", "撥款失敗"))
                rst &= vbCrLf
            Next
        End If
        Return rst
    End Function

