    ''' <summary> 顯示年度下拉選單5 </summary>
    ''' <param name="obj"></param>
    ''' <param name="iSYears">開始年/0為自動</param>
    ''' <param name="iEYears">結束年/0為自動</param>
    ''' <param name="Optional_Choice_flag">包含請選擇</param>
    ''' <param name="str_ChoiceAll">請選擇文字/空白自動</param>
    ''' <returns></returns>
    Public Shared Function GetSyear(ByRef obj As DropDownList, ByVal iSYears As Integer, ByVal iEYears As Integer, ByVal Optional_Choice_flag As Boolean, ByVal str_ChoiceAll As String) As DropDownList
        'Return GetSyear(obj, 0, 0, True)  '=2003 'Optional_Choice_flag As Boolean=True
        If str_ChoiceAll = "" Then str_ChoiceAll = cst_ddl_PleaseChoose3
        Dim j As Integer = 0 '起始值
        obj.Items.Clear()
        If Optional_Choice_flag Then
            obj.Items.Add(New ListItem(str_ChoiceAll, ""))
        End If
        '若為0 則 自動改為預設值
        If iSYears = 0 Then iSYears = cst_GetSyear_minyears
        'EYears結束年 ，若為0 則自動計算結束年
        If iEYears <> 0 Then j = Math.Abs(iEYears)
        If iEYears = 0 Then j = If(Month(Now) >= 7, Year(Now) + 1, Year(Now))
        Dim flag_ROC As Boolean = CHK_REPLACE2ROC_YEARS()
        With obj.Items
            For i As Integer = j To iSYears Step -1
                Dim vText As String = If(flag_ROC, $"{(i - 1911)}", $"{i}")
                .Add(New ListItem(vText, CStr(i)))
            Next
        End With
        Return obj
    End Function

    ''' <summary>'取出鍵詞-指定年度/訓練計畫--訓練計畫代碼</summary>
    ''' <param name="obj"></param>
    ''' <param name="strYear"></param>
    ''' <param name="vTPLANID"></param>
    ''' <param name="strType"></param>
    ''' <param name="oConn"></param>
    ''' <returns></returns>
    Public Shared Function Get_YearTPlan(ByRef obj As ListControl, ByVal strYear As String, ByVal vTPLANID As String, ByVal strType As String, ByRef oConn As SqlConnection) As ListControl
        Dim pms1 As New Hashtable From {{"CLSYEAR", strYear}}
        Dim sSql As String = ""
        sSql &= " SELECT a.TPLANID,a.PLANNAME ,concat('(',a.TPLANID,')',a.PLANNAME) TPLANIDPLANNAME" & vbCrLf
        sSql &= " FROM KEY_PLAN a WHERE (a.CLSYEAR IS NULL OR a.CLSYEAR>@CLSYEAR)" & vbCrLf
        If vTPLANID <> "" Then
            pms1.Add("TPLANID ", vTPLANID)
            sSql &= " AND a.TPLANID=@TPLANID" & vbCrLf
        End If
        sSql &= " ORDER BY a.TPLANID" & vbCrLf
        Dim dt As DataTable = DbAccess.GetDataTable(sSql, oConn, pms1)
        With obj
            .DataSource = dt
            Select Case strType
                Case cst_NO
                    .DataTextField = "TPLANIDPLANNAME"
                Case Else
                    .DataTextField = "PLANNAME"
            End Select
            .DataValueField = "TPLANID"
            .DataBind()
            If TypeOf obj Is DropDownList Then .Items.Insert(0, New ListItem(cst_ddl_PleaseChoose3, ""))
        End With
        Return obj
