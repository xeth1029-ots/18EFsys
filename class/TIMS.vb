    Public Shared Function FmtCyclType(ByRef vCyclType As Object) As String
        If vCyclType Is Nothing Then Return "" '(異常)'回傳空白
        Dim rst As String = ChangeIDNO(ClearSQM(vCyclType))
        If rst Is Nothing OrElse rst.Length = 0 OrElse Not IsNumberStr(rst) Then Return "" '(異常)'回傳空白／'(空白)／非數字組成'回傳空白
        If (rst.Length = 1) Then Return String.Concat("0", rst) '補0'回傳
        Return rst '回傳(其它狀況直接回傳)
    End Function

    ''' <summary>http/https-另開視窗</summary>
    ''' <param name="sPage"></param>
    ''' <returns></returns>
    Public Shared Function CHK_FUNCSPAGE2(ByRef sm As SessionModel, ByRef sPage As String) As Boolean
        'Dim sm As SessionModel=SessionModel.Instance()
        '連線系統本身功能
        Dim flag_new_windows As Boolean = False
        If sPage Is Nothing Then Return flag_new_windows
        If sPage = "" Then Return flag_new_windows
        Const cst_https_txt As String = "https" 'http/https
        Const cst_http_txt As String = "http" 'http/https
        If sPage.ToLower.IndexOf(cst_https_txt) > -1 Then
            '含有https字眼另開視窗
            flag_new_windows = True
        ElseIf sPage.ToLower.IndexOf(cst_http_txt) > -1 Then
            '含有http字眼另開視窗
            flag_new_windows = True
        End If
        If flag_new_windows Then
            If Not IsDate1(sm.LAST_LOGINDATE) Then sm.LAST_LOGINDATE = DateTime.Now.AddDays(-1)
            Dim s_DATE1 As String = sm.LAST_LOGINDATE.ToString("yyyy-MM-dd HH:mm:ss.fff")
            Dim s_DATE2 As String = CDate(sm.LAST_LOGINDATE).AddHours(1).ToString("yyyy-MM-dd HH:mm:ss")
            Dim tk As String = String.Format("{0}#{1}#{2}", sm.UserInfo.UserID, s_DATE1, s_DATE2)
            sPage = String.Format("{0}?tk={1}", sPage, EncryptAes(tk))
        End If
        Return flag_new_windows
    End Function

