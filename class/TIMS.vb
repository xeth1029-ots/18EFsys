        '        dr("ModifyAcct")=sm.UserInfo.UserID
        '        dr("ModifyDate")=Now
        '    Next
        'End If
        'DbAccess.UpdateDataTable(dt, da) 'dttemp 暫存-->最後要更新dt
        rst = True

        Return rst
    End Function

    ''' <summary> 委訓單位歸屬全選-依sAccount </summary>
    ''' <param name="iRoleID"></param>
    ''' <param name="iPlanID"></param>
    ''' <param name="sAccount"></param>
    ''' <param name="sRIDValue"></param>
    ''' <param name="oConn"></param>
    Public Shared Sub Update_AUTH_ACCTORG(ByVal iRoleID As Integer, ByVal iPlanID As Integer, ByVal sAccount As String, ByVal sRIDValue As String, ByRef oConn As SqlConnection)
        If sAccount = "" Then Return

        'Dim rst As Boolean=True
        'ByRef dtOrgList As DataTable
        Const Cst_二級 As Integer = 4
        Const Cst_承辦人 As Integer = 5

        Dim s_Acct As String = ""
        Dim s_AcctOther As String = ""
        'SELECT Case Request("RoleID") '配合上頁所傳來的使用者權限
        Select Case iRoleID  '配合上頁所傳來的使用者權限
            Case Cst_二級
                s_Acct = "ACCT2" '二級使用者帳號
                s_AcctOther = "ACCT1" '承辦人帳號
            Case Cst_承辦人
                s_Acct = "ACCT1" '承辦人帳號
                s_AcctOther = "ACCT2" '二級使用者帳號
            Case Else
                '限定權限 二級 與 承辦人 可做委訓單位歸屬!
                Return '退出
        End Select

        'Dim PLANID As String=GetMyValue2(htSS, "PLANID")
        '1.功能：系統管理>>帳號維護管理>>帳號-計畫賦予
        '當系統管理者替各分署帳號，勾選該年度產業人才投資計畫權限時(如圖一)，
        '於儲存時，預設系統自動勾選該分署下所有單位 (如同由系統按下【委訓單位歸屬全選】按鈕一樣)，免除分署需每個帳號再去按【委訓單位歸屬】(圖二)。
        '但仍保留【委訓單位歸屬】【委訓單位歸屬全選】兩個按鈕功能，以供分署可做特例手動調整。

        'sql &= "計畫 業務 機構" & vbCrLf
        Dim dtOrgList As DataTable = GET_OrgListdt(iPlanID, sRIDValue, oConn)
        If dtOrgList.Rows.Count = 0 Then Return '查無-機構-退出

        Dim sm As SessionModel = SessionModel.Instance()
        Call OpenDbConn(oConn) 'DbAccess.Open(oConn)
        Dim i_sql As String = ""
        i_sql &= " INSERT INTO AUTH_ACCTORG( CID,PLANID,RID,ACCT1,ACCT2,MODIFYACCT,MODIFYDATE )" & vbCrLf
        i_sql &= " VALUES ( @CID,@PLANID,@RID,@ACCT1,@ACCT2, @MODIFYACCT,GETDATE() )" & vbCrLf
        Dim iCmd As New SqlCommand(i_sql, oConn)

        Dim sql As String = $"SELECT * FROM AUTH_ACCTORG WHERE PLANID=@PLANID AND {s_Acct}=@ACCT"
        Dim sCmd As New SqlCommand(sql, oConn)
        Dim dtAO As New DataTable
        With sCmd
            .Parameters.Clear()
            .Parameters.Add("PLANID", SqlDbType.Int).Value = iPlanID
            .Parameters.Add("ACCT", SqlDbType.VarChar).Value = sAccount '依帳號計畫查詢
            dtAO.Load(.ExecuteReader())
        End With

        For Each dr As DataRow In dtOrgList.Rows
            Dim fff3 As String = $"RID='{dr("RID")}'"
            If dtAO.Select(fff3).Length = 0 Then
                '查無資料新增
                Dim iCID As Integer = DbAccess.GetNewId(oConn, "AUTH_ACCTORG_CID_SEQ,AUTH_ACCTORG,CID")
                With iCmd
                    .Parameters.Clear()
                    .Parameters.Add("CID", SqlDbType.Int).Value = iCID
                    .Parameters.Add("PLANID", SqlDbType.Int).Value = iPlanID
                    .Parameters.Add("RID", SqlDbType.VarChar).Value = dr("RID").ToString()
                    .Parameters.Add(s_Acct, SqlDbType.VarChar).Value = sAccount
                    .Parameters.Add(s_AcctOther, SqlDbType.VarChar).Value = " "
                    .Parameters.Add("MODIFYACCT", SqlDbType.VarChar).Value = sm.UserInfo.UserID
                    .ExecuteNonQuery()
                End With

            End If
        Next
        'Return rst
    End Sub

