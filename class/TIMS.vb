    ''' <summary>比對副檔名與真實解析檔案類型</summary>
    ''' <param name="fileExtension"></param>
    ''' <param name="s_ReadlFileType"></param>
    ''' <returns></returns>
    Public Shared Function CHK_fileExtension(fileExtension As String, s_ReadlFileType As String) As Boolean
        'https://en.wikipedia.org/wiki/List_of_file_signatures
        Select Case s_ReadlFileType 'unknown
            Case "jpg", "png"
                Return (fileExtension = "png" OrElse fileExtension = "jpg" OrElse fileExtension = "jpeg")
            Case "zip"
                'zip:'Also used by DOCX, XLSX, PPTX zip,aar,apk,docx,epub,ipa,jar,kmz,maff,msix,odp,ods,odt,pk3,pk4,pptx,usdz,vsdx,xlsx,xpi,
                Return (fileExtension = "zip" OrElse fileExtension = "docx" OrElse fileExtension = "xlsx" OrElse fileExtension = "pptx" OrElse fileExtension = "ods")
            Case "doc"
                'doc: doc,xls,ppt,msi,msg, 
                Return (fileExtension = "doc" OrElse fileExtension = "xls")
        End Select
        Return (fileExtension = s_ReadlFileType)
    End Function

    ''' <summary>Function to check if file type matches its extension</summary>
    ''' <param name="filePath"></param>
    ''' <returns></returns>
    Public Shared Function IsFileTypeValid(filePath As String) As Boolean
        Dim s_ReadlFileType As String = GetActualFileType(filePath)
        Dim fileExtension As String = Path.GetExtension(filePath).TrimStart(".").ToLowerInvariant()
        '比對副檔名與真實解析檔案類型
        Return CHK_fileExtension(fileExtension, s_ReadlFileType)
    End Function

