    ''' <summary>顯示系統-TABLE-COLNAME</summary>
    ''' <param name="parms"></param>
    ''' <param name="sConn"></param>
    ''' <returns></returns>
    Public Shared Function GetColumnKey2(ByVal parms As Hashtable, ByRef sConn As SqlConnection) As DataTable
        'ByVal yTABLENAME As String, ByVal UCOLNAME As String
        Dim dt As DataTable = Nothing
        'Dim yTABLENAME As String=UCase(ClearSQM(yTABLENAME))
        'Dim UCOLNAME As String=UCase(ClearSQM(UCOLNAME))
        Dim yTABLENAME As String = UCase(GetMyValue2(parms, "tTABLENAME"))
        Dim UCOLNAME As String = UCase(GetMyValue2(parms, "tCOLUMN"))
        Dim vCHECK_NOTLIKE As String = GetMyValue2(parms, "vCHECK_NOTLIKE")
        If yTABLENAME = "" AndAlso UCOLNAME = "" Then Return dt
        'COLLATE Chinese_Taiwan_Stroke_CS_AS 
        Dim vCHKB_COLLATE_CS As String = GetMyValue2(parms, "vCHKB_COLLATE_CS") 'Y/N-Chinese_Taiwan_Stroke_CS_AS (多)
        Dim vCHKB_COLLATE_CI As String = GetMyValue2(parms, "vCHKB_COLLATE_CI") 'Y/N-Chinese_Taiwan_Stroke_CI_AS
        Dim s_COLLATE_w As String = ""
        If vCHKB_COLLATE_CS = "Y" AndAlso vCHKB_COLLATE_CI = "Y" Then s_COLLATE_w = " and c.COLLATION_NAME is not null"

        If vCHKB_COLLATE_CS = "Y" AndAlso vCHKB_COLLATE_CI = "N" Then s_COLLATE_w = " and c.COLLATION_NAME='Chinese_Taiwan_Stroke_CS_AS'"

        If vCHKB_COLLATE_CS = "N" AndAlso vCHKB_COLLATE_CI = "Y" Then s_COLLATE_w = " and c.COLLATION_NAME='Chinese_Taiwan_Stroke_CI_AS'"

        Dim sql As String = ""
        sql &= " Select '/*' REM1" & vbCrLf
        sql &= " ,a.NAME TABLENAME" & vbCrLf
        'sql &= " ,c.NAME COLNAME" & vbCrLf
        sql &= " ,UPPER(c.NAME) UCOLNAME" & vbCrLf
        sql &= " ,UPPER(t.NAME) DTYPE" & vbCrLf
        sql &= " ,c.MAX_LENGTH MAXLENGTH" & vbCrLf
        sql &= " ,c.PRECISION P" & vbCrLf
        sql &= " ,c.SCALE S" & vbCrLf
        sql &= " ,c.IS_NULLABLE ISNULLABLE" & vbCrLf
        sql &= " ,c.IS_IDENTITY ISIDENTITY" & vbCrLf
        sql &= " ,c.COLLATION_NAME COLLATE_N" & vbCrLf
        'sql &= " ,a.NAME TABLENAME" & vbCrLf
        sql &= " FROM SYS.COLUMNS c" & vbCrLf
        sql &= " JOIN SYS.TYPES t ON c.user_type_id=t.user_type_id" & vbCrLf
        sql &= " JOIN SYSOBJECTS a ON a.id=c.OBJECT_ID And a.xtype IN ('U')" & vbCrLf
        sql &= " WHERE 1=1" & vbCrLf
        If s_COLLATE_w <> "" Then sql &= s_COLLATE_w
        If yTABLENAME <> "" Then
            If yTABLENAME.IndexOf(",") > -1 Then
                sql &= " and (1!=1" & vbCrLf
                For Each s_tb As String In yTABLENAME.Split(",")
                    If vCHECK_NOTLIKE <> "Y" Then
                        If s_tb <> "" Then sql &= " or UPPER(a.NAME) LIKE '%" & s_tb & "%'" & vbCrLf
                    Else
                        If s_tb <> "" Then sql &= " or UPPER(a.NAME)='" & s_tb & "'" & vbCrLf
                    End If
                Next
                sql &= " )" & vbCrLf
            Else
                'sql &= " And c.OBJECT_ID=OBJECT_ID('" & yTABLENAME & "')" & vbCrLf
                If vCHECK_NOTLIKE <> "Y" Then
                    sql &= " And UPPER(a.NAME) LIKE '%" & yTABLENAME & "%'" & vbCrLf
                Else
                    sql &= " And UPPER(a.NAME)='" & yTABLENAME & "'" & vbCrLf
                End If
            End If
        End If
        If UCOLNAME <> "" Then
            If UCOLNAME.IndexOf(",") > -1 Then
                sql &= " and (1!=1" & vbCrLf
                For Each s_uc As String In UCOLNAME.Split(",")
                    If vCHECK_NOTLIKE <> "Y" Then
                        If s_uc <> "" Then sql &= " or UPPER(c.NAME) LIKE '%" & s_uc & "%'" & vbCrLf
                    Else
                        If s_uc <> "" Then sql &= " or UPPER(c.NAME)='" & s_uc & "'" & vbCrLf
                    End If
                Next
                sql &= " )" & vbCrLf
            Else
                If vCHECK_NOTLIKE <> "Y" Then
                    sql &= " and UPPER(c.NAME) LIKE '%" & UCOLNAME & "%'" & vbCrLf
                Else
                    sql &= " and UPPER(c.NAME)='" & UCOLNAME & "'" & vbCrLf
                End If
            End If
        End If

        'If sUtl_ChkTest() Then
        '    Dim xPage As New System.Web.UI.Page
        '    WriteLog(xPage, String.Concat("--", vbCrLf, GetMyValue5(parms), vbCrLf, "--##GetColumnKey2, sql:", vbCrLf, sql))
        'End If
        dt = DbAccess.GetDataTable(sql, sConn)
        If dt Is Nothing Then Return dt

        dt.Columns.Add("DTYPE2")
        If dt.Rows.Count = 0 Then Return dt
        For Each drv As DataRow In dt.Rows
            Dim vTABLE As String = Convert.ToString(drv("TABLENAME")) 'TABLENAME
            Dim vCOLUMN As String = Convert.ToString(drv("UCOLNAME")) 'UCOLNAME
            Dim vDTYPE2 As String = Convert.ToString(drv("DTYPE"))
            Dim flag_ISNULLABLE As Boolean = drv("ISNULLABLE")
            Dim vCOLLATE_N As String = Convert.ToString(drv("COLLATE_N"))

            Select Case Convert.ToString(drv("DTYPE"))
                Case "VARCHAR", "CHAR", "NVARCHAR", "NCHAR"
                    If Convert.ToString(drv("MAXLENGTH")) <> "" Then
                        If drv("MAXLENGTH") = -1 Then
                            vDTYPE2 = String.Format("[{0}](MAX)", drv("DTYPE"))
                        Else
                            vDTYPE2 = String.Format("[{0}]({1})", drv("DTYPE"), drv("MAXLENGTH"))
                        End If
                    End If
                Case "NUMERIC"
                    vDTYPE2 = String.Format("[{0}]({1},{2})", drv("DTYPE"), drv("P"), drv("S"))
                Case Else
                    vDTYPE2 = String.Format("[{0}]", drv("DTYPE"))
            End Select

            If (vCOLLATE_N <> "") Then vDTYPE2 &= " COLLATE " & vCOLLATE_N
            vDTYPE2 &= If(flag_ISNULLABLE, " NULL", " NOT NULL")

            'String.Format("ALTER TABLE {0} ALTER COLUMN {1} {2}", vTABLE, vCOLUMN, vDTYPE2)
            drv("DTYPE2") = String.Format("*/ ALTER TABLE {0} ALTER COLUMN {1} {2};", vTABLE, vCOLUMN, vDTYPE2) 'vDTYPE2
        Next
        Return dt
    End Function

    ''' <summary>只顯示系統-TABLE-'DDL_CHECK_1 (1:只要TABLE NAME /2:目前 DB 所有 TABLE NAME /3:NO PK-TABLE NAME)</summary>
    ''' <param name="parms"></param>
    ''' <param name="sConn"></param>
    ''' <returns></returns>
    Public Shared Function GetColumnKey3(ByVal parms As Hashtable, ByVal sConn As SqlConnection) As DataTable
        'ByVal yTABLENAME As String, ByVal UCOLNAME As String
        Dim dt As DataTable = Nothing
        'Dim yTABLENAME As String=UCase(ClearSQM(yTABLENAME))
        'Dim UCOLNAME As String=UCase(ClearSQM(UCOLNAME))
        Dim yTABLENAME As String = UCase(GetMyValue2(parms, "tTABLENAME"))
        Dim UCOLNAME As String = UCase(GetMyValue2(parms, "tCOLUMN"))
        Dim vCHECK_1 As String = UCase(GetMyValue2(parms, "vCHECK_1"))
        Dim vCHECK_NOTLIKE As String = GetMyValue2(parms, "vCHECK_NOTLIKE")
        'Dim c_CHKBOX_1 As Boolean=GetMyValue2(parms, "c_CHKBOX_1")
        If yTABLENAME = "" AndAlso UCOLNAME = "" And vCHECK_1 = "" Then Return dt

        Dim vCHKB_COLLATE_CS As String = GetMyValue2(parms, "vCHKB_COLLATE_CS") 'Y/N-Chinese_Taiwan_Stroke_CS_AS (多)
        Dim vCHKB_COLLATE_CI As String = GetMyValue2(parms, "vCHKB_COLLATE_CI") 'Y/N-Chinese_Taiwan_Stroke_CI_AS
        Dim s_COLLATE_w As String = ""
        If vCHKB_COLLATE_CS = "Y" AndAlso vCHKB_COLLATE_CI = "Y" Then
            s_COLLATE_w = " and c.COLLATION_NAME is not null"
        End If
        If vCHKB_COLLATE_CS = "Y" AndAlso vCHKB_COLLATE_CI = "N" Then
            s_COLLATE_w = " and c.COLLATION_NAME='Chinese_Taiwan_Stroke_CS_AS'"
        End If
        If vCHKB_COLLATE_CS = "N" AndAlso vCHKB_COLLATE_CI = "Y" Then
            s_COLLATE_w = " and c.COLLATION_NAME='Chinese_Taiwan_Stroke_CI_AS'"
        End If

        Dim sql As String = ""
        sql &= " SELECT DISTINCT a.NAME TABLENAME" & vbCrLf
        sql &= " FROM SYS.COLUMNS c" & vbCrLf
        sql &= " JOIN SYS.TYPES t ON c.user_type_id=t.user_type_id" & vbCrLf
        sql &= " JOIN SYSOBJECTS a ON a.id=c.OBJECT_ID And a.xtype IN ('U')" & vbCrLf
        sql &= " WHERE 1=1" & vbCrLf
        If s_COLLATE_w <> "" Then sql &= s_COLLATE_w

        If yTABLENAME.IndexOf(",") > -1 Then
            sql &= " and (1!=1" & vbCrLf
            For Each s_tb As String In yTABLENAME.Split(",")
                If vCHECK_NOTLIKE <> "Y" Then
                    If s_tb <> "" Then sql &= " or UPPER(a.NAME) LIKE '%" & s_tb & "%'" & vbCrLf
                Else
                    If s_tb <> "" Then sql &= " or UPPER(a.NAME)='" & s_tb & "'" & vbCrLf
                End If
            Next
            sql &= " )" & vbCrLf
        Else
            'sql &= " And c.OBJECT_ID=OBJECT_ID('" & yTABLENAME & "')" & vbCrLf
            If vCHECK_NOTLIKE <> "Y" Then
                sql &= " And UPPER(a.NAME) LIKE '%" & yTABLENAME & "%'" & vbCrLf
            Else
                sql &= " And UPPER(a.NAME)='" & yTABLENAME & "'" & vbCrLf
            End If
        End If
        If UCOLNAME <> "" Then
            If UCOLNAME.IndexOf(",") > -1 Then
                sql &= " and (1!=1" & vbCrLf
                For Each s_uc As String In UCOLNAME.Split(",")
                    If vCHECK_NOTLIKE <> "Y" Then
                        If s_uc <> "" Then sql &= " or UPPER(c.NAME) LIKE '%" & s_uc & "%'" & vbCrLf
                    Else
                        If s_uc <> "" Then sql &= " or UPPER(c.NAME)='" & s_uc & "'" & vbCrLf
                    End If
                Next
                sql &= " )" & vbCrLf
            Else
                If vCHECK_NOTLIKE <> "Y" Then
                    sql &= " and UPPER(c.NAME) LIKE '%" & UCOLNAME & "%'" & vbCrLf
                Else
                    sql &= " and UPPER(c.NAME)='" & UCOLNAME & "'" & vbCrLf
                End If
            End If
        End If

        If vCHECK_1 = "2" Then
            sql &= " ORDER BY 1" & vbCrLf
        End If

        'If sUtl_ChkTest() Then
        '    Dim xPage As New System.Web.UI.Page
        '    WriteLog(xPage, String.Concat("--", vbCrLf, GetMyValue5(parms), vbCrLf, "--##GetColumnKey3, sql:", vbCrLf, sql))
        'End If
        dt = DbAccess.GetDataTable(sql, sConn)

        Const cst_DELETE1 As String = "DELETE1"
        'NO PK
        If vCHECK_1 = "3" Then
            dt.Columns.Add(cst_DELETE1) 'DELETE1
            For Each dr1 As DataRow In dt.Rows
                Dim dtPk As DataTable = TIMS.GetPrimaryKey(CStr(dr1("TABLENAME")), sConn)
                If dtPk.Rows.Count > 0 Then
                    dr1(cst_DELETE1) = cst_DELETE1
                End If
            Next
            Dim ff3 As String = cst_DELETE1 & "='" & cst_DELETE1 & "'"
            If dt.Select(ff3).Length > 0 Then
                For Each dr1 As DataRow In dt.Select(ff3)
                    dr1.Delete()
                Next
                dt.AcceptChanges()
            End If
            dt.Columns.Remove(cst_DELETE1)
        End If

        If dt Is Nothing Then Return dt
        'If dt.Rows.Count=0 Then Return dt
        Return dt
    End Function

    ''' <summary>'取出Table的主鍵</summary>
    ''' <param name="MyTableName"></param>
    ''' <param name="sConn"></param>
    ''' <returns></returns>
    Public Shared Function GetPrimaryKey(ByVal MyTableName As String, sConn As SqlConnection) As DataTable
        MyTableName = ClearSQM(MyTableName)
        Dim sql As String = ""
        sql &= " SELECT b.name PkName" & vbCrLf
        sql &= " ,a2.name PkName2" & vbCrLf
        sql &= " ,b.status" & vbCrLf
        sql &= " ,b.type" & vbCrLf
        sql &= " FROM sysobjects a" & vbCrLf
        sql &= " JOIN syscolumns b ON a.id=b.id" & vbCrLf
        sql &= " JOIN sysindexkeys c ON c.indid=1 AND b.id=c.id AND b.colid=c.colid" & vbCrLf
        sql &= " JOIN sysobjects a2 on a.id=a2.parent_obj AND a2.xtype='PK'" & vbCrLf
        sql &= " WHERE a.xtype IN ('U') AND a.name='" & MyTableName & "'" & vbCrLf
        Return DbAccess.GetDataTable(sql, sConn)
    End Function

    '取出Table的所有欄位鍵
    Public Shared Function GetColumnKey(ByVal MyTableName As String, sConn As SqlConnection) As DataTable
        MyTableName = ClearSQM(MyTableName)
        Dim sql As String = ""
        sql &= " SELECT b.name colName" & vbCrLf
        sql &= " ,b.colid ,b.id" & vbCrLf
        sql &= " ,b.status" & vbCrLf
        sql &= " FROM sysobjects a" & vbCrLf
        sql &= " JOIN syscolumns b ON a.id=b.id AND (a.xtype='U')" & vbCrLf
        sql &= " WHERE a.name='" & MyTableName & "'" & vbCrLf
        Return DbAccess.GetDataTable(sql, sConn)
    End Function

