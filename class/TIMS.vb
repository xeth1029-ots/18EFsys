    ''' <summary>取得當前 Request 的功能路徑</summary>
    ''' <returns></returns>
    Public Shared Function Get_RequestPath() As String
        Dim appPath As String = HttpContext.Current.Request.ApplicationPath
        Dim reqPath As String = HttpContext.Current.Request.Path

        If reqPath.StartsWith(appPath, StringComparison.OrdinalIgnoreCase) Then reqPath = reqPath.Substring(appPath.Length)

        If reqPath.StartsWith("/") Then reqPath = reqPath.Substring(1)

        Return reqPath
    End Function

    ''' <summary>設定 TitleLab1、TitleLab2 </summary>
    ''' <param name="conn"></param>
    ''' <param name="strFunID"></param>
    ''' <param name="TitleLab1"></param>
    ''' <param name="TitleLab2"></param>
    Public Shared Sub Get_TitleLab(ByRef conn As SqlConnection, ByVal strFunID As String, ByRef TitleLab1 As Label, ByRef TitleLab2 As Label)
        Dim flag_continue As Boolean = False 'false:特殊-動作
        Select Case strFunID
            Case cst_FunID_報名登錄 '報名登錄(SD_01_001_add)
            Case cst_FunID_專案核定報名登錄 '專案核定報名登錄
            Case cst_FunID_特例專案核定報名登錄 '專案核定報名登錄
            Case cst_FunID_參訓學員投保狀況檢核表_產投 '參訓學員投保狀況檢核表_產投
            Case cst_FunID_參訓學員投保狀況檢核表_在職 '參訓學員投保狀況檢核表_在職
            Case Else
                flag_continue = True 'false:一般-動作(依 SPAGE )
        End Select

        ' 2018.08.08, eric, 配合 RouteConfig 不再於 URL 中傳入 ID 參數,
        ' 改由當前功能路徑,去DB中抓對應
        Dim reqPath As String = Get_RequestPath()
        If String.IsNullOrEmpty(reqPath) Then Call CloseDbConn(conn) : Return ' Exit Sub 

        Dim s_parms As New Hashtable
        Dim sql As String = ""
        If Not flag_continue Then
            '特殊-動作
            sql = "SELECT TOP 1 FUNID FROM dbo.ID_FUNCTION WHERE FUNID=@FUNID"
            s_parms.Add("FUNID", strFunID)
        Else
            If strFunID <> "" AndAlso IsNumeric2(strFunID) Then
                sql = "SELECT TOP 1 FUNID FROM dbo.ID_FUNCTION WHERE FUNID=@FUNID"
                s_parms.Add("FUNID", strFunID)
            ElseIf reqPath <> "" Then
                sql = "SELECT TOP 1 FUNID FROM dbo.ID_FUNCTION WHERE SPAGE LIKE @SPAGE+'%'"
                s_parms.Add("SPAGE", reqPath)
            End If
        End If
        strFunID = DbAccess.ExecuteScalar(sql, conn, s_parms)
        If strFunID <> "" Then
            TitleLab1.Text = Get_TitleLab1(strFunID, conn)
            TitleLab2.Text = Get_TitleLab2(strFunID, conn)
            'TitleLab2.ForeColor=System.Drawing.Color.Brown '#990000
        End If
    End Sub

    Public Shared Sub Get_TitleLab(ByVal strFunID As String, ByRef TitleLab1 As Label, ByRef TitleLab2 As Label)
        'Get_TitleLab(Request("ID"), TitleLab1, TitleLab2)
        Using conn As SqlConnection = DbAccess.GetConnection()
            If Not OpenDbConn(conn) Then Return ' Exit Sub
            Get_TitleLab(conn, strFunID, TitleLab1, TitleLab2)
            Call CloseDbConn(conn)
        End Using
    End Sub

    Shared Function Get_TitleLab2(ByVal sFunID As String, ByVal conn As SqlConnection) As String
        Dim rst As String = ""
        sFunID = ClearSQM(sFunID)
        If sFunID = "" Then Return rst

        Dim hPMS As New Hashtable From {{"FUNID", sFunID}}
        Dim sql As String = "SELECT NAME FROM dbo.ID_FUNCTION WHERE FUNID=@FUNID"
        rst = DbAccess.ExecuteScalar(sql, conn, hPMS)
        Return rst
    End Function

    Shared Function Get_TitleLab1(ByVal FunID As String, ByRef conn As SqlConnection) As String
        Dim rst As String = ""
        FunID = ClearSQM(FunID)
        If FunID = "" OrElse Not IsNumeric(FunID) Then Return rst

        Dim pms1 As New Hashtable From {{"FUNID", FunID}}
        Dim sql As String = "SELECT NAME,KIND FROM dbo.ID_FUNCTION WHERE FUNID IN (SELECT PARENT FROM dbo.ID_FUNCTION WHERE FUNID=@FUNID)"
        Dim drNK As DataRow = DbAccess.GetOneRow(sql, conn, pms1)

        Dim lab1 As String = If(drNK IsNot Nothing, Convert.ToString(drNK("NAME")), "")
        Dim lab2 As String = If(drNK IsNot Nothing, Convert.ToString(drNK("KIND")), "")

        If lab1 <> "" Then
            Dim strMMN As String = Get_MainMenuName(lab2)
            If lab2 <> "" AndAlso strMMN = lab2 Then
                lab2 = $"首頁>>{lab2}>>{lab1}>>"
            ElseIf lab1 <> "" Then
                lab2 = $"首頁>>{If(strMMN <> "", $"{strMMN}>>", "")}{lab1}>>"
            End If
        Else
            Dim pms2 As New Hashtable From {{"FUNID", FunID}}
            sql = " SELECT KIND FROM dbo.ID_FUNCTION WHERE FUNID=@FUNID"
            lab2 = DbAccess.ExecuteScalar(sql, conn, pms2)
            Dim strMMN As String = Get_MainMenuName(lab2)
            If lab2 <> "" AndAlso strMMN = lab2 Then
                lab2 = $"首頁>>{lab2}>>"
            Else
                lab2 = $"首頁>>{If(strMMN <> "", $"{strMMN}>>", "")}"
            End If
        End If
        rst = lab2
        Return rst
    End Function

    ''' <summary> (測試)dt 資料 寫入log檔案查看 </summary>
    ''' <param name="MyPage"></param>
    ''' <param name="dt_xls"></param>
    Public Shared Sub TestLogWrite(ByRef MyPage As Page, ByRef dt_xls As DataTable)
        If dt_xls Is Nothing Then Return

        Dim s_COLUMN3 As String = Get_DataTableCOLUMN3(dt_xls)
        WriteLog2(MyPage, String.Concat("#s_COLUMN3: ", s_COLUMN3))

        Dim s_COLUMN As String = Get_DataTableCOLUMN2(dt_xls)
        'LOG.Debug(String.Concat("#s_COLUMN: ", s_COLUMN))
        WriteLog2(MyPage, String.Concat("#s_COLUMN: ", s_COLUMN))
        If dt_xls.Rows.Count = 0 Then Return

        Dim a_s_COLUMN As String() = s_COLUMN.Split(",")
        Dim iRow As Integer = 0
        For Each dr As DataRow In dt_xls.Rows
            iRow += 1
            'LOG.Debug(String.Format("#{0}", iRow))
            WriteLog2(MyPage, String.Format("#{0}", iRow))

            Dim jRow As Integer = 0
            Dim s_row As String = ""
            For Each colname As String In a_s_COLUMN
                Dim colval As String = If(Not Convert.IsDBNull(dr(colname)), String.Concat("'", dr(colname), "'"), "null")
                'LOG.Debug(String.Concat(If(jRow <> 0, ",", ""), String.Format("[{0}]='{1}'", colname, colval)))
                'LOG.Debug(String.Concat(jRow, ".", String.Format("{0}: {1}", colname, colval)))
                'WriteLog2(MyPage, String.Concat(jRow, ".", String.Format("{0}: {1}", colname, colval)))
                'If (colval.Length > 254) Then
                '    Dim collenVal As String=String.Concat("LEN:", colval.Length)
                '    WriteLog2(MyPage, String.Concat(jRow, ".", String.Format("{0}: {1}", colname, collenVal)))
                'End If
                Dim collenVal As String = String.Concat("LEN:", colval.Length)
                s_row &= String.Concat(If(jRow <> 0, ",", ""), String.Format("{0}: {1}", colname, collenVal))
                jRow += 1
            Next
            WriteLog2(MyPage, String.Concat(jRow, ".", s_row))
            'LOG.Debug(vbCrLf)
        Next
    End Sub
