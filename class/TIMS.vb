    ''' <summary>'產投補助金，3年可領取金額(三年補助額)，每年度有所有不同(依登入年度判斷)
    ''' '可用補助額 (2007年3年3萬)(2008年3年5萬)(2012年3年7萬)(2025年3年10萬)</summary>
    ''' <returns></returns>
    Public Shared Function Get_3Y_SupplyMoney() As Integer
        Dim sm As SessionModel = SessionModel.Instance()
        Dim i_RST As Integer = 70000
        '可用補助金額 2007年前(2萬)'2007年(3年3萬)'2008年(3年5萬)'2012年(3年7萬)'2025(3年10萬) (最新)
        Dim fg_test As Boolean = CHK_IS_TEST_ENVC() 'fg_test OrElse fg_use1 
        Dim fg_use1 As Boolean = CanUse3Y10WCost()
        Try
            'C# 型別/關鍵字	範圍 大小 'short -32,768 至32,767	帶正負號的16 位元整數
            Dim iYears As Integer = sm.UserInfo.Years 'CInt(sm.UserInfo.Years) '登入年度
            If fg_test OrElse fg_use1 Then i_RST = 100000 : Return i_RST '100000
            If iYears >= 2012 Then i_RST = 70000 : Return i_RST '70000
            If iYears >= 2008 Then i_RST = 50000 : Return i_RST '50000
            If iYears = 2007 Then i_RST = 30000 : Return i_RST '30000
            If iYears < 2007 Then i_RST = 20000 : Return i_RST '20000
        Catch ex As Exception
            LOG.Error(ex.Message, ex) '錯誤的話取 (預設)的金額
        End Try
        Return i_RST
    End Function

