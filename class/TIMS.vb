    ''' <summary>下載檔案</summary>
    ''' <param name="MyPage"></param>
    ''' <param name="rPMS"></param>
    Public Shared Sub ResponseZIPFile_BI(sm As SessionModel, ByRef oConn As SqlConnection, ByRef MyPage As Page, ByRef rPMS As Hashtable)
        Dim vORGKINDGW As String = GetMyValue2(rPMS, "ORGKINDGW")
        Dim vKBID As String = GetMyValue2(rPMS, "KBID")
        Dim vKBSID As String = GetMyValue2(rPMS, "KBSID")

        Dim vBCFP3ID As String = GetMyValue2(rPMS, "BCFP3ID") 'iCap課程原始申請資料
        Dim vBCFPID As String = GetMyValue2(rPMS, "BCFPID") '訓練班別計畫表
        Dim vBCFEID As String = GetMyValue2(rPMS, "BCFEID") '教學環境資料表
        Dim vBCFT2ID As String = GetMyValue2(rPMS, "BCFT2ID") '授課師資學經歷證書影本
        Dim vBCFTID As String = GetMyValue2(rPMS, "BCFTID") '師資／助教基本資料表
        Dim vBCRTID As String = GetMyValue2(rPMS, "BCRTID") '混成課程教學環境資料表

        Dim vFILENAME1 As String = GetMyValue2(rPMS, "FILENAME1")

        Dim vBCID As String = GetMyValue2(rPMS, "BCID") ' ClearSQM(Hid_BCID.Value)
        Dim vBCASENO As String = GetMyValue2(rPMS, "BCASENO") ' ClearSQM(Hid_BCASENO.Value)
        Dim vRID As String = GetMyValue2(rPMS, "RID") ' ClearSQM(Hid_RID.Value)

        Dim drOB As DataRow = GET_ORG_BIDCASE(oConn, vRID, vBCID, vBCASENO)
        If drOB Is Nothing Then Return
        Dim drKB As DataRow = GET_KEY_BIDCASE(sm, oConn, vKBSID, vORGKINDGW)
        If drKB Is Nothing Then Return

        Dim vYEARS_ROC As String = GET_YEARS_ROC(drOB("YEARS"))
        Dim vAPPSTAGE_S As String = Get_APPSTAGE_S(Convert.ToString(drOB("APPSTAGE")))
        Dim vORGNAME As String = GET_ORGNAME(Convert.ToString(drOB("ORGID")), oConn)
        Dim vKBNAME2 As String = String.Concat(vORGKINDGW, vKBID, drKB("KBNAME"))

        Dim oYEARS As String = Convert.ToString(drOB("YEARS"))
        Dim oAPPSTAGE As String = Convert.ToString(drOB("APPSTAGE"))
        Dim oPLANID As String = Convert.ToString(drOB("PLANID"))
        Dim oRID As String = Convert.ToString(drOB("RID"))
        Dim oBCASENO As String = Convert.ToString(drOB("BCASENO"))

        Dim Template_ZipPath1 As String = GET_Template_ZipPath1(vBCID)
        '判斷是否有資料夾
        If Not Directory.Exists(MyPage.Server.MapPath(Template_ZipPath1)) Then
            Directory.CreateDirectory(MyPage.Server.MapPath(Template_ZipPath1))
        End If

        Dim tryFIND As String = ""
        Select Case String.Concat(vORGKINDGW, vKBID)
            Case cst_W08_訓練班別計畫表, cst_G08_訓練班別計畫表
                Dim dtFLPI As DataTable = GET_ORG_BIDCASEFL_PI(oConn, vBCID)
                If dtFLPI Is Nothing OrElse dtFLPI.Rows.Count = 0 Then
                    'Common.MessageBox(Me, "(訓練班別計畫表)查無資料!")
                    Common.MessageBox(MyPage, String.Concat("(", vKBNAME2, ")查無資料!"))
                    Return
                End If
                tryFIND = If(vBCFPID <> "" AndAlso vFILENAME1 <> "", String.Concat("BCFPID=", vBCFPID, " AND FILENAME1='", vFILENAME1, "'"), "")
                If tryFIND <> "" Then
                    If dtFLPI.Select(tryFIND).Length = 0 Then
                        Common.MessageBox(MyPage, String.Concat("(", vKBNAME2, ")查無資料!"))
                        Return
                    End If
                    For Each drFLPI As DataRow In dtFLPI.Select(tryFIND)
                        Dim vPSNO28 As String = "" 'Convert.ToString(drFLPI("PSNO28"))
                        Dim oFILENAME1 As String = "" 'Convert.ToString(drFLPI("FILENAME1"))
                        Dim oUploadPath As String = "" 'Get_UPLOADPATH1(oYEARS, oAPPSTAGE, oPLANID, oRID, oBCASENO, vKBSID)
                        Dim s_FilePath1 As String = "" 'MyPage.Server.MapPath(Path.Combine(oUploadPath, oFILENAME1))
                        '年度申請階段_班級課程流水號_項目編號+項目名稱
                        Dim t_FILENAME_PI As String = "" 'String.Concat(vYEARS_ROC, vAPPSTAGE_S, "_", vORGNAME, "_", vKBNAME2, "_", vPSNO28, ".pdf")
                        Dim t_FilePath1 As String = "" 'MyPage.Server.MapPath(Path.Combine($"{Template_ZipPath1}/", t_FILENAME_PI))
                        Try
                            vPSNO28 = Convert.ToString(drFLPI("PSNO28"))
                            oFILENAME1 = Convert.ToString(drFLPI("FILENAME1"))
                            oUploadPath = GET_UPLOADPATH1_BI(oYEARS, oAPPSTAGE, oPLANID, oRID, oBCASENO, vKBSID)
                            s_FilePath1 = MyPage.Server.MapPath(Path.Combine(oUploadPath, oFILENAME1))
                            '年度申請階段_班級課程流水號_項目編號+項目名稱
                            t_FILENAME_PI = TIMS.GetValidFileName(String.Concat(vYEARS_ROC, vAPPSTAGE_S, "_", vORGNAME, "_", vKBNAME2, "_", vPSNO28, ".pdf"))
                            t_FilePath1 = MyPage.Server.MapPath(Path.Combine($"{Template_ZipPath1}/", t_FILENAME_PI))
                            If IO.File.Exists(s_FilePath1) Then
                                Dim dbyte As Byte() = File.ReadAllBytes(s_FilePath1)
                                File.WriteAllBytes(t_FilePath1, dbyte)
                            End If
                        Catch ex As Exception
                            Dim strErrmsg As String = "/*Public Shared Sub ResponseZIPFile*/" & vbCrLf
                            strErrmsg &= String.Concat("vPSNO28: ", vPSNO28, vbCrLf, "oFILENAME1: ", oFILENAME1, vbCrLf, "oUploadPath: ", oUploadPath, vbCrLf)
                            strErrmsg &= String.Concat("s_FilePath1: ", s_FilePath1, vbCrLf)
                            strErrmsg &= String.Concat("t_FILENAME_PI: ", t_FILENAME_PI, vbCrLf)
                            strErrmsg &= String.Concat("t_FilePath1: ", t_FilePath1, vbCrLf)
                            strErrmsg &= String.Concat("ex.Message: ", ex.Message, vbCrLf)
                            Call WriteTraceLog(strErrmsg, ex) 'Throw ex
                        End Try
                    Next
                Else
                    For Each drFLPI As DataRow In dtFLPI.Rows
                        Dim vPSNO28 As String = "" ' Convert.ToString(drFLPI("PSNO28"))
                        Dim oFILENAME1 As String = "" 'Convert.ToString(drFLPI("FILENAME1"))
                        Dim oUploadPath As String = "" 'Get_UPLOADPATH1(oYEARS, oAPPSTAGE, oPLANID, oRID, oBCASENO, vKBSID)
                        Dim s_FilePath1 As String = "" 'MyPage.Server.MapPath(Path.Combine(oUploadPath, oFILENAME1))
                        '年度申請階段_班級課程流水號_項目編號+項目名稱
                        Dim t_FILENAME_PI As String = "" 'String.Concat(vYEARS_ROC, vAPPSTAGE_S, "_", vORGNAME, "_", vKBNAME2, "_", vPSNO28, ".pdf")
                        Dim t_FilePath1 As String = "" 'MyPage.Server.MapPath(Path.Combine($"{Template_ZipPath1}/", t_FILENAME_PI))
                        Try
                            vPSNO28 = Convert.ToString(drFLPI("PSNO28"))
                            oFILENAME1 = Convert.ToString(drFLPI("FILENAME1"))
                            oUploadPath = GET_UPLOADPATH1_BI(oYEARS, oAPPSTAGE, oPLANID, oRID, oBCASENO, vKBSID)
                            s_FilePath1 = MyPage.Server.MapPath(Path.Combine(oUploadPath, oFILENAME1))
                            '年度申請階段_班級課程流水號_項目編號+項目名稱
                            t_FILENAME_PI = TIMS.GetValidFileName(String.Concat(vYEARS_ROC, vAPPSTAGE_S, "_", vORGNAME, "_", vKBNAME2, "_", vPSNO28, ".pdf"))
                            t_FilePath1 = MyPage.Server.MapPath(Path.Combine($"{Template_ZipPath1}/", t_FILENAME_PI))
                            If IO.File.Exists(s_FilePath1) Then
                                Dim dbyte As Byte() = File.ReadAllBytes(s_FilePath1)
                                File.WriteAllBytes(t_FilePath1, dbyte)
                            End If
                        Catch ex As Exception
