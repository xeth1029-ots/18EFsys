    '取出下拉資料
    Public Shared Function Get_KeyControl2(ByRef obj As ListControl, ByVal selectSql As String,
                                           ByVal TextField As String, ByVal ValueField As String,
                                           ByVal tConn As SqlConnection) As ListControl
        Call OpenDbConn(tConn)
        Dim dt As New DataTable
        Using sCmd As New SqlCommand(selectSql, tConn)
            With sCmd
                dt.Load(.ExecuteReader()) '.Parameters.Clear()
            End With
        End Using
