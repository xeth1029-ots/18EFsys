    Public Shared Function GET_ORG_BIDCASEFL_iBCFID(sm As SessionModel, oConn As SqlConnection, iBCID As Integer, iKBSID As Integer,
                                                    ByVal vWAIVED As String, drOB As DataRow) As Integer
        Dim iBCFID As Integer = 0
        If iBCID <= 0 OrElse iKBSID <= 0 Then Return iBCFID
        If drOB Is Nothing Then Return iBCFID

        Dim vYEARS As String = Convert.ToString(drOB("YEARS"))
        Dim vAPPSTAGE As String = Convert.ToString(drOB("APPSTAGE"))
        Dim vRID As String = Convert.ToString(drOB("RID"))
        Dim fPMS As New Hashtable From {{"BCID", iBCID}, {"KBSID", iKBSID}}
        Dim fSql As String = "SELECT BCFID FROM ORG_BIDCASEFL WHERE BCID=@BCID AND KBSID=@KBSID"
        Dim drFL As DataRow = DbAccess.GetOneRow(fSql, oConn, fPMS)
        'If drFL IsNot Nothing Then Return iBCFID '(有資料不儲存)
        If drFL IsNot Nothing Then
            iBCFID = CINT1(drFL("BCFID")) 'Return iBCFID '(有資料不儲存)
            Dim uParms As New Hashtable From {{"MODIFYACCT", sm.UserInfo.UserID}, {"BCFID", iBCFID}}
            Dim usSql As String = ""
            usSql &= " UPDATE ORG_BIDCASEFL" & vbCrLf
            usSql &= " SET MODIFYACCT=@MODIFYACCT,MODIFYDATE=GETDATE()" & vbCrLf
            usSql &= " WHERE BCFID=@BCFID" & vbCrLf
            DbAccess.ExecuteNonQuery(usSql, oConn, uParms)
        Else
            '"WAIVED"
            Dim isSql As String = ""
            isSql &= " INSERT INTO ORG_BIDCASEFL(BCFID,YEARS,APPSTAGE,RID,BCID,KBSID,WAIVED,MODIFYACCT,MODIFYDATE)" & vbCrLf
            isSql &= " VALUES (@BCFID,@YEARS,@APPSTAGE,@RID,@BCID,@KBSID,@WAIVED,@MODIFYACCT,GETDATE())" & vbCrLf

            iBCFID = DbAccess.GetNewId(oConn, "ORG_BIDCASEFL_BCFID_SEQ,ORG_BIDCASEFL,BCFID")
            Dim iParms As New Hashtable
            iParms.Add("BCFID", iBCFID)
            iParms.Add("YEARS", vYEARS)
            iParms.Add("APPSTAGE", If(vAPPSTAGE <> "", vAPPSTAGE, Convert.DBNull))
            iParms.Add("RID", vRID)
            iParms.Add("BCID", iBCID)
            iParms.Add("KBSID", iKBSID)
            iParms.Add("WAIVED", If(vWAIVED <> "", vWAIVED, Convert.DBNull))
            iParms.Add("MODIFYACCT", sm.UserInfo.UserID)
            DbAccess.ExecuteNonQuery(isSql, oConn, iParms)
        End If
        Return iBCFID
    End Function

