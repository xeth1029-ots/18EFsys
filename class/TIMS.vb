        '有資料新增
        '新增'sql &= " /* IDENTITY(1,1):  */" & vbCrLf
        Dim iSql As String = ""
        iSql &= " INSERT INTO ADP_TRAINING( TRID,IDNO,BIRTHDAY,STDNAME,TPLANID,PLANNAME,DISTNAME,TRAINNAME,CJOB_NAME,THOURS,TFLAG,STUDSTATUS" & vbCrLf
        iSql &= " ,WorkSuppIdent,YEARS,COMIDNO,STDATE,FTDATE,ORGNAME,CLASSCNAME,SUMOFMONEY,PAYMONEY,APPLIEDSTATUS,APPLIEDNOTE" & vbCrLf
        iSql &= " ,SUPPLYID,BUDID,APPLIEDSTATUSM,ALLOTDATE,MEMO1,MODIFYDATE,MODIFYACCT)" & vbCrLf
        iSql &= " VALUES ( @TRID,@IDNO,@BIRTHDAY,@STDNAME,@TPLANID,@PLANNAME,@DISTNAME,@TRAINNAME,@CJOB_NAME,@THOURS,@TFLAG,@STUDSTATUS" & vbCrLf
        iSql &= " ,@WorkSuppIdent,@YEARS,@COMIDNO,@STDATE,@FTDATE,@ORGNAME,@CLASSCNAME,@SUMOFMONEY,@PAYMONEY,@APPLIEDSTATUS,@APPLIEDNOTE" & vbCrLf
        iSql &= " ,@SUPPLYID,@BUDID,@APPLIEDSTATUSM,@ALLOTDATE,@MEMO1,GETDATE(),@MODIFYACCT)" & vbCrLf
        Dim iCmd As New SqlCommand(iSql, sConn)

        'IDNO NAME BIRTHDAY DISTNAME YEARS TPLANID PLANNAME ORGNAME TRAINNAME CJOB_NAME CLASSCNAME THours TRound WEEKS TFLAG WorkSuppIdent SumOfMoney MEMO1 
        ' Const cst_int_column As String="YEARS,THours,SumOfMoney"
        For Each drv As DataRow In dtTra.Rows
            Dim iTRID As Integer = DbAccess.GetNewId(sConn, "ADP_TRAINING_TRID_SEQ,ADP_TRAINING,TRID")
