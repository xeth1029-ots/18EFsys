    ''' <summary>取得開班計畫相關資料 PLAN_PLANINFO</summary>
    ''' <param name="PlanID"></param>
    ''' <param name="ComIDNO"></param>
    ''' <param name="SeqNo"></param>
    ''' <param name="oConn"></param>
    ''' <returns></returns>
    Public Shared Function GetPCSDate(ByVal PlanID As String, ByVal ComIDNO As String, ByVal SeqNo As String, ByRef oConn As SqlConnection) As DataRow
        Dim rst As DataRow = Nothing
        If PlanID = "" OrElse ComIDNO = "" OrElse SeqNo = "" Then Return rst
        PlanID = GetValue2(PlanID) '(必為整數)
        SeqNo = GetValue2(SeqNo) '(必為整數)

        Call OpenDbConn(oConn)
        Dim sSql As String = ""
        sSql &= " SELECT ip.TPLANID,ip.DISTID" & vbCrLf
        sSql &= " ,pp.PLANID,pp.COMIDNO,pp.SEQNO" & vbCrLf
        sSql &= " ,cc.OCID,pp.TMID,pp.RID,pp.PlanYear" & vbCrLf
        sSql &= " ,pp.CLASSNAME,pp.CYCLTYPE,pp.CJOB_UNKEY" & vbCrLf
        sSql &= " ,pp.CAPMILITARY,pp.CAPSEX,pp.CAPAGE1,pp.CAPAGE2,pp.CAPDEGREE" & vbCrLf
        sSql &= " ,pp.TransFlag,pp.ISAPPRPAPER,pp.AppliedResult,pp.RESULTBUTTON" & vbCrLf
        sSql &= " ,pp.AdmPercent,pp.TaxPercent" & vbCrLf
        sSql &= " ,pp.OVERDUE4MTH" & vbCrLf
        'DISTANCE 遠距教學 1.申請整班為遠距教學", 2."申請部分課程為遠距/實體教學", 3."申請整班為實體教學 FARLEARN
        sSql &= " ,pp.DISTANCE" & vbCrLf
        '申請階段 APPSTAGE '1：上半年、2：下半年、3：政策性產業 /4:進階政策性產業
        sSql &= " ,pp.APPSTAGE" & vbCrLf
        sSql &= " ,pp.PointYN" & vbCrLf
        sSql &= " ,pp.STDATE,pp.FDDATE,dbo.FN_CDATE1B(pp.STDATE) STDATE_ROC" & vbCrLf
        sSql &= " ,FORMAT(pp.modifydate,'mmssdd') MSD" & vbCrLf
        sSql &= " ,tt.JOBID,tt.JOBNAME" & vbCrLf
        sSql &= " ,tt.TRAINID,tt.TRAINNAME" & vbCrLf
        sSql &= " ,(SELECT ORGNAME FROM dbo.ORG_ORGINFO WHERE COMIDNO=pp.COMIDNO) ORGNAME" & vbCrLf
        sSql &= " ,(SELECT ORGKINDGW FROM dbo.VIEW_RIDNAME WHERE RID=pp.RID) ORGKINDGW" & vbCrLf
        sSql &= " FROM dbo.PLAN_PLANINFO pp WITH(NOLOCK)" & vbCrLf
        sSql &= " JOIN dbo.ID_PLAN ip WITH(NOLOCK) ON ip.PLANID=pp.PLANID" & vbCrLf
        sSql &= " JOIN dbo.VIEW_TRAINTYPE tt ON tt.TMID=pp.TMID" & vbCrLf
        sSql &= " LEFT JOIN dbo.CLASS_CLASSINFO cc WITH(NOLOCK) ON cc.PLANID=pp.PLANID AND cc.COMIDNO=pp.COMIDNO AND cc.SEQNO=pp.SEQNO" & vbCrLf
        sSql &= " WHERE pp.PLANID=@PLANID AND pp.COMIDNO=@COMIDNO AND pp.SEQNO=@SEQNO"
        Dim sCmd As New SqlCommand(sSql, oConn)
        Dim dt As New DataTable
        With sCmd
            .Parameters.Clear()
            .Parameters.Add("PLANID", SqlDbType.Int).Value = CINT1(PlanID)
            .Parameters.Add("COMIDNO", SqlDbType.VarChar).Value = ComIDNO
            .Parameters.Add("SEQNO", SqlDbType.Int).Value = CINT1(SeqNo)
            dt.Load(.ExecuteReader())
        End With
        If dt.Rows.Count = 1 Then rst = dt.Rows(0)
        Return rst
    End Function

