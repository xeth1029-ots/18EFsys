    ''' <summary>
    ''' 格式化null成空白文字
    ''' </summary>
    ''' <param name="colArray"></param>
    ''' <returns></returns>
    Public Shared Function ChangeColArray(ByRef colArray As Array) As Array
        If colArray.Length > 0 Then
            For i As Integer = 0 To colArray.Length - 1
                If colArray(i) Is Nothing Then
                    colArray(i) = ""
                Else
                    If Convert.ToString(colArray(i)) <> "" Then
                        colArray(i) = Trim(Convert.ToString(colArray(i)))
                    End If
                End If
            Next
        End If
        Return colArray
    End Function

