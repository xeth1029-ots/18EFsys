    '用來取得 後送階層的下一階
    Public Shared Function Get_ParentFAQID(ByVal tmpFAQID As String, ByRef objconn As SqlConnection) As String
        Dim rst As String = "0"

        Call OpenDbConn(objconn)
        Dim dt As New DataTable
        Dim sqlStr As String = ""
        sqlStr = "SELECT ISNULL(PARENTFAQID,'0') PARENTFAQID FROM ID_FAQLEVEL WHERE FAQID=@FAQID"
        Dim oCmd As New SqlCommand(sqlStr, objconn)
        With oCmd
            .Parameters.Clear()
            .Parameters.Add("FAQID", SqlDbType.Char).Value = tmpFAQID
            dt.Load(.ExecuteReader())
