    Public Shared Function Get_TechListPlanRdt2(ByVal rPlanID As String, ByVal rComIDNO As String, ByVal rSeqNo As String, ByVal tConn As SqlConnection) As DataTable
        Dim pms_1 As New Hashtable From {{"PLANID", rPlanID}, {"COMIDNO", rComIDNO}, {"SEQNO", rSeqNo}}
        Dim SQL1 As String = ""
        SQL1 &= " SELECT DISTINCT t.TECHID,CONCAT(t.TEACHCNAME,CASE t.WORKSTATUS WHEN '2' THEN '(x)' END) TEACHCNAME" & vbCrLf
        SQL1 &= " FROM PLAN_TRAINDESC a WITH(NOLOCK)" & vbCrLf
        SQL1 &= " JOIN TEACH_TEACHERINFO t WITH(NOLOCK) ON t.TECHID=a.TECHID2" & vbCrLf
        SQL1 &= " WHERE a.PLANID=@PLANID AND a.COMIDNO=@COMIDNO AND a.SEQNO=@SEQNO" & vbCrLf
        SQL1 &= " ORDER BY CONCAT(t.TEACHCNAME,CASE t.WORKSTATUS WHEN '2' THEN '(x)' END)" & vbCrLf
        Dim dt As DataTable = DbAccess.GetDataTable(SQL1, tConn, pms_1)
        Return dt
    End Function

    Shared Function Get_TEACHdt(ByVal TechIDSS As String, ByRef oConn As SqlConnection) As DataTable
        TechIDSS = ClearSQM(TechIDSS)
        If (TechIDSS = "") Then Return dtNew()

        Dim sql As String = ""
        sql &= " SELECT t.TECHID, t.TEACHCNAME FROM dbo.TEACH_TEACHERINFO t" & vbCrLf
        sql &= " WHERE t.TECHID IN (" & TechIDSS & ") ORDER BY t.TEACHCNAME" & vbCrLf
        Dim dt As DataTable = DbAccess.GetDataTable(sql, oConn)
        Return dt
    End Function

    '20080702 andy add 取得申請變更後的課程大網師資名單(一定要取得教師名稱)
    Public Shared Function Get_TechListPlanR2(ByRef obj As ListControl, ByVal TechIDxS As String, ByRef dt As DataTable, ByRef tConn As SqlConnection) As ListControl
        obj.Items.Clear()
        If dt Is Nothing Then Return obj
        Try
            TechIDxS = ClearSQM(TechIDxS)
            If TechIDxS <> "" Then
                Dim dtTT As DataTable = Get_TEACHdt(TechIDxS, tConn)
                '一定要取得教師名稱
                With obj
                    For Each drTT As DataRow In dtTT.Rows
                        Dim ff4 As String = "TechID=" & drTT("TechID") & ""
                        If dt.Select(ff4).Length = 0 Then
                            '資料不在存加入資料
                            .Items.Add(New ListItem(drTT("TeachCName"), drTT("TechID")))
                        End If
                    Next
                    For Each drV As DataRow In dt.Rows
                        .Items.Add(New ListItem(drV("TeachCName"), drV("TechID")))
                    Next
                    .Items.Insert(0, New ListItem(cst_ddl_PleaseChoose3, ""))
                End With
                Return obj
            End If
            With obj
                For Each drV As DataRow In dt.Rows
                    .Items.Add(New ListItem(drV("TeachCName"), drV("TechID")))
                Next
                .Items.Insert(0, New ListItem(cst_ddl_PleaseChoose3, ""))
            End With
        Catch ex As Exception
            LOG.Warn(ex.Message, ex)
            Dim strErrmsg As String = ""
            strErrmsg &= "* Public Shared Function Get_TechListPlanR2(ByRef obj As ListControl, ByVal TechIDx1 As String, ByRef dt As DataTable, ByRef tConn As SqlConnection) As ListControl" & vbCrLf
            strErrmsg &= String.Concat("* ex.Message: ", ex.Message, vbCrLf)
            strErrmsg &= String.Concat("* TechIDxS: ", TechIDxS, vbCrLf)
            'strErrmsg += GetErrorMsg(MyPage) '取得錯誤資訊寫入
            Call WriteTraceLog(strErrmsg, ex)
        End Try
        Return obj
    End Function

