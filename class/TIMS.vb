    '判斷是否是受ECFA影響之投保單位''該功能正式上線為2011年8月份 測試上線為2011年6月份
    Public Shared Function CheckIsECFA(ByRef MyPage As Page, ByVal ActNo As String, ByVal FOfficeYM1 As String,
                                       ByVal STDate As String, ByRef oConn As SqlConnection) As Boolean
        Dim sm As SessionModel = SessionModel.Instance()
        Dim Rst As Boolean = False 'true 是/false 不是
        ActNo = ClearSQM(ActNo)
        If ActNo = "" OrElse Len(ActNo) < 8 Then Return Rst 'False(長度不足異常)
        Dim sType As Integer = 9 '一般保險號長度(含檢查碼) sType = 9 '一般保險號長度(含檢查碼)
        If Len(ActNo) = 8 Then sType = 8 '少了檢查碼 

        Call OpenDbConn(oConn)
        '產投加碼
        If Cst_TPlanID28AppPlan2.IndexOf(sm.UserInfo.TPlanID) > -1 Then
            Dim f_use_STDate As Boolean = (STDate <> "" AndAlso IsDate1(STDate))
            '產投 '產投加碼1 (匯入檔。)
            If Not Rst Then
                Dim sql As String = " SELECT oe.Ubno FROM ORG_ECFA28 oe" & vbCrLf
                Select Case sType
                    Case 8 '少了檢查碼
                        sql &= " WHERE LEFT(oe.Ubno,8)=@ActNo" & vbCrLf '依保險證號判斷
                    Case Else '一般保險號長度(含檢查碼)
                        sql &= " WHERE oe.Ubno=@ActNo" & vbCrLf '依保險證號判斷
                End Select
                If f_use_STDate Then sql &= " AND oe.maintainDate<=@STDate" & vbCrLf '依開訓日 與產業認定日判斷  
                Dim dt As New DataTable
                Call OpenDbConn(oConn)
                Dim sCmd As New SqlCommand(sql, oConn)
                With sCmd
                    .Parameters.Clear()
                    .Parameters.Add("ActNo", SqlDbType.VarChar).Value = ActNo
                    If f_use_STDate Then .Parameters.Add("STDate", SqlDbType.DateTime).Value = CDate(STDate) '.ToString("yyyy/MM/dd")
                    dt.Load(.ExecuteReader())
                End With
                Rst = (dt.Rows.Count > 0)
            End If
            '產投加碼2 (光碟檔。)
            If Not Rst Then
                Dim sql As String = " SELECT bb.bUbno FROM V_ORGECFA28 bb" & vbCrLf
                Select Case sType
                    Case 8 '少了檢查碼  
                        sql &= " WHERE LEFT(bb.bUbno,8)=@ActNo" & vbCrLf '依保險證號判斷
                    Case Else '一般保險號長度(含檢查碼)
                        sql &= " WHERE bb.bUbno=@ActNo" & vbCrLf '依保險證號判斷
                End Select
                If f_use_STDate Then sql &= " AND bb.maintainDate<=@STDate" & vbCrLf '依開訓日 與產業認定日判斷 
                Dim dt As New DataTable
                Call OpenDbConn(oConn)
                Dim sCmd As New SqlCommand(sql, oConn)
                With sCmd
                    .Parameters.Clear()
                    .Parameters.Add("ActNo", SqlDbType.VarChar).Value = ActNo
                    If f_use_STDate Then .Parameters.Add("STDate", SqlDbType.DateTime).Value = CDate(STDate) '.ToString("yyyy/MM/dd")
                    dt.Load(.ExecuteReader())
                End With
                Rst = (dt.Rows.Count > 0)
            End If
        Else
            Dim f_use_FOfficeYM1 As Boolean = (FOfficeYM1 <> "" AndAlso IsDate1(FOfficeYM1))
            '職前 職前加碼1 (匯入檔。)
            If Not Rst Then
                Dim Sql As String = " SELECT oe.Ubno FROM ORG_ECFA28 oe" & vbCrLf
                Select Case sType
                    Case 8 '少了檢查碼
                        Sql &= " WHERE LEFT(oe.Ubno,8)=@ActNo" & vbCrLf '依保險證號判斷
                    Case Else '一般保險號長度(含檢查碼)
                        Sql &= " WHERE oe.Ubno=@ActNo" & vbCrLf '依保險證號判斷
                End Select
                If f_use_FOfficeYM1 Then Sql &= " AND oe.judgmentdate<=@FOfficeYM1" & vbCrLf '依離職判斷日判斷 
                Dim dt As New DataTable
                Call OpenDbConn(oConn)
                Dim sCmd As New SqlCommand(Sql, oConn)
                With sCmd
                    .Parameters.Clear()
                    .Parameters.Add("ActNo", SqlDbType.VarChar).Value = ActNo
                    If f_use_FOfficeYM1 Then .Parameters.Add("FOfficeYM1", SqlDbType.DateTime).Value = CDate(FOfficeYM1) '.ToString("yyyy/MM/dd") 
                    dt.Load(.ExecuteReader())
                End With
                Rst = (dt.Rows.Count > 0)
            End If
            '職前加碼2 (光碟檔。)
            If Not Rst Then
                Dim Sql As String = " SELECT bb.bUbno FROM V_ORGECFA28 bb" & vbCrLf
                Select Case sType
                    Case 8 '少了檢查碼
                        Sql &= " WHERE LEFT(bb.bUbno,8)=@ActNo" & vbCrLf '依保險證號判斷
                    Case Else '一般保險號長度(含檢查碼)
                        Sql &= " WHERE bb.bUbno=@ActNo" & vbCrLf '依保險證號判斷
                End Select
                If f_use_FOfficeYM1 Then Sql &= " AND bb.judgmentdate <=@FOfficeYM1" & vbCrLf '依離職判斷日判斷 
                Dim dt As New DataTable
                Call OpenDbConn(oConn)
                Dim sCmd As New SqlCommand(Sql, oConn)
                With sCmd
                    .Parameters.Clear()
                    .Parameters.Add("ActNo", SqlDbType.VarChar).Value = ActNo
                    If f_use_FOfficeYM1 Then .Parameters.Add("FOfficeYM1", SqlDbType.DateTime).Value = CDate(FOfficeYM1) '.ToString("yyyy/MM/dd")
                    dt.Load(.ExecuteReader())
                End With
                Rst = (dt.Rows.Count > 0)
            End If
        End If
        Return Rst
