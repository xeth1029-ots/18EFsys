    '錯誤動作呼叫執行。(寄信提醒。)
    Public Shared Sub sUtl_ErrorAction(ByRef MyPage As Page, ByVal Me1 As PageControler,
                                       ByVal _PageDataTable As DataTable, ByVal vsSql As String, ByVal ex As Exception)

        Dim strErrmsg As String = ""
        strErrmsg += "/*  ex.ToString: */" & vbCrLf
        strErrmsg += ex.ToString & vbCrLf
        If Convert.ToString(MyPage) <> "" Then
            strErrmsg += "/*  MyPage: */" & vbCrLf
            strErrmsg += Convert.ToString(MyPage) & vbCrLf
        End If
        If Convert.ToString(Me1.PageDataGrid.ClientID) <> "" Then
            strErrmsg += "/*  ClientID: */" & vbCrLf
            strErrmsg += Convert.ToString(Me1.PageDataGrid.ClientID) & vbCrLf
        End If
        If Not _PageDataTable.DefaultView Is Nothing Then
            If _PageDataTable.DefaultView.Table.Rows.Count > 0 Then
                Dim xdt As DataTable = _PageDataTable.DefaultView.Table
                Dim tmpStr1 As String = ""
                For i As Integer = 0 To xdt.Columns.Count - 1
                    Dim ColumnName As String = xdt.Columns(i).ColumnName
                    If tmpStr1 <> "" Then tmpStr1 &= ","
                    tmpStr1 &= ColumnName
                Next
                If tmpStr1 <> "" Then
                    strErrmsg += "/*  ColumnName: */" & vbCrLf
                    strErrmsg += tmpStr1 & vbCrLf
                End If
            End If
        End If
        If Me1.SqlString <> "" Then strErrmsg += "/*  SqlString: */" & vbCrLf : strErrmsg += Me1.SqlString & vbCrLf
        If Me1.PrimaryKey <> "" Then strErrmsg += "/*  PrimaryKey: */" & vbCrLf : strErrmsg += Me1.PrimaryKey & vbCrLf
        If Me1.Sort <> "" Then strErrmsg += "/*  Sort: */" & vbCrLf : strErrmsg += Me1.Sort & vbCrLf
        If vsSql <> "" Then strErrmsg += "/*  SQL: */" & vbCrLf : strErrmsg += vsSql & vbCrLf

        strErrmsg &= GetErrorMsg(MyPage) '取得錯誤資訊寫入
        Call WriteTraceLog(strErrmsg)
    End Sub

    ''' <summary> 解決中文檔名亂碼問題 </summary>
    ''' <param name="sFileName"></param>
    ''' <returns></returns>
    Public Shared Function GetUTF8Str(ByVal sFileName As String) As String
        'Dim someRandomText As String=sFileName '""
        Dim encoder As UTF8Encoding = New UTF8Encoding()
        Dim bytes As Byte() = Encoding.UTF8.GetBytes(sFileName)
        Dim utf8ReturnString As String = encoder.GetString(bytes)
        Return utf8ReturnString
    End Function

    ''' <summary>ConvertXLS / response.End()</summary>
    ''' <param name="ds"></param>
    ''' <param name="sfilename"></param>
    ''' <param name="response"></param>
    Public Shared Sub ConvertXLS(ByVal ds As DataSet, ByVal sfilename As String, ByVal response As HttpResponse)
        'first let's clean up the response.object
        response.Clear()
        response.Charset = ""
        'set the response mime type for excel
        response.ContentType = "application/vnd.ms-excel"
        '解決中文檔名亂碼問題
        response.AddHeader("Content-Disposition", String.Concat("attachment;filename=", System.Web.HttpUtility.UrlEncode(sfilename, System.Text.Encoding.UTF8), ".xls"))
        'create a string writer
        Dim stringWrite As New System.IO.StringWriter
        'create an htmltextwriter which uses the stringwriter
        Dim htmlWrite As New System.Web.UI.HtmlTextWriter(stringWrite)
        'instantiate a datagrid
        'set the datagrid datasource to the dataset passed in
        Dim dg As New DataGrid With {.DataSource = ds.Tables(0)}
        'bind the datagrid
        dg.DataBind()
        'tell the datagrid to render itself to our htmltextwriter
        dg.RenderControl(htmlWrite)
        'all that's left is to output the html
        response.Write(stringWrite.ToString())
        response.End()
    End Sub

