    Public Shared Sub Get_STUDBLIGATEDATA4_sch1(ByRef MyPage As Page, ByVal strIDNO As String, ByVal strBIRTH As String, ByVal strCNAME As String, ByRef s_ERRMSG As String, ByVal oConn As SqlConnection)
        Call Del_Old_Bli4(oConn, strIDNO)
        Dim blIsExists As Boolean = CheckBliIsExists(strIDNO, strBIRTH, oConn)
        If blIsExists Then Exit Sub

        'Const cst_gSysName As String="TRA001"
        Dim strXML As String = String.Empty
        'Dim blIsExists As Boolean=False

        '勞保+就保A、勞保L、自願職災保險V、農保F、農民自願職災保險FV
        'Const cst_勞保就保 As String="A" 'Const cst_自願職災保險 As String="V" 'Const cst_農保 As String="F" 'Const cst_農民自願職災保險 As String="FV"
        Dim s_Bli_TYPE As String = "A,V,F,FV"
        Dim aBli_TYPE As String() = s_Bli_TYPE.Split(",")
        'For Each strUType As String In aBli_TYPE

        Dim strMsg As String = ""
        'Dim strUType As String=""
        Dim strIName As String = "" 'String.Empty '投保人姓名
        Dim strBIRTH_2 As String = GetReqDate(strBIRTH)
        Dim strBDate As String = strBIRTH_2
        Dim strEDate As String = DateTime.Now.ToString("yyyyMMdd")

        Dim htSS As New Hashtable '= Nothing
        's_FUNCNAME
        If MyPage IsNot Nothing AndAlso MyPage.Request IsNot Nothing Then htSS.Add("s_FUNCNAME", MyPage.Request.RawUrl)
        htSS.Add("sysname", cst_gSysName)
        htSS.Add("strIDNO", strIDNO)
        htSS.Add("strBIRTH", strBIRTH)
        htSS.Add("strCNAME", strCNAME)
        htSS.Add("strIName", strIName)
        htSS.Add("strBIRTH_2", strBIRTH_2)
        htSS.Add("strBDate", strBDate)
        htSS.Add("strEDate", strEDate)
        htSS.Add("strUType", "")
        htSS.Add("strXML", "")

        'WebRequest物件如何忽略憑證問題
        System.Net.ServicePointManager.ServerCertificateValidationCallback = New System.Net.Security.RemoteCertificateValidationCallback(AddressOf TIMS.ValidateServerCertificate)
        'TLS 1.2-基礎連接已關閉: 傳送時發生未預期的錯誤 'HttpClient
        System.Net.ServicePointManager.SecurityProtocol = Net.SecurityProtocolType.Tls12
        Dim strUType As String = ""
        Try
            'https://wltims.wda.gov.tw/bli_wsv4/get_data2.asmx
            'https://wltims.wda.gov.tw/bli_wsv4/get_data3.asmx
            Dim bliWs As New bli_wsv4.get_data3
            For Each strUType In aBli_TYPE
                'strUType=s_UType 'cst_勞保就保 '查詢勞保+就保勾稽資料
                '呼叫勞保勾稽webservice
                strXML = bliWs.get_detail(cst_gSysName, strIDNO, strIName, strBIRTH_2, strUType, strBDate, strEDate)
                htSS("strUType") = strUType
                htSS("strXML") = strXML
                strMsg = parseXML(MyPage, htSS, oConn) '解析xml內容
                Select Case strMsg
                    Case "-1"
                        s_ERRMSG = "勾稽時產生錯誤!!"
                        SetMyValue2(htSS, "ERRMSG", s_ERRMSG)
                        Return
                    Case "7"
                        If strCNAME = "" Then Exit Select
                        strIName = strCNAME '(使用姓名重新勾稽)
                        'strUType=s_UType 'cst_勞保就保 '查詢勞保+就保勾稽資料
                        '呼叫勞保勾稽webservice
                        strXML = bliWs.get_detail(cst_gSysName, strIDNO, strIName, strBIRTH_2, strUType, strBDate, strEDate)
                        htSS("strUType") = strUType
                        htSS("strXML") = strXML
                        strMsg = parseXML(MyPage, htSS, oConn) '解析xml內容
                End Select
            Next

            bliWs = Nothing
        Catch ex As Exception
            Dim strErrmsg As String = ""
            strErrmsg &= "##Get_STUDBLIGATEDATA4:" & vbCrLf
            strErrmsg &= String.Concat("ex.Message:", ex.Message, vbCrLf)
            strErrmsg &= ",sysname:" & cst_gSysName & vbCrLf
            strErrmsg &= ",strUType:" & strUType & vbCrLf
            strErrmsg &= EncryptAes(String.Concat(",strIDNO:", strIDNO, vbCrLf, ",strBIRTH:", strBIRTH, vbCrLf, ",strCNAME:", strCNAME, vbCrLf))
            strErrmsg &= ",strIName:" & strIName & vbCrLf
            strErrmsg &= ",strBIRTH_2:" & strBIRTH_2 & vbCrLf
            strErrmsg &= ",strBDate:" & strBDate & vbCrLf
            strErrmsg &= ",strEDate:" & strEDate & vbCrLf
            strErrmsg &= ",strXML:" & strXML & vbCrLf
            'strErrmsg &= GetErrorMsg(MyPage) '取得錯誤資訊寫入
            Call WriteTraceLog(strErrmsg, ex)
            Throw ex
        End Try
    End Sub

