    ''' <summary>取得線上簽到退紀錄使用 LINEAT.Wdaline 依日期</summary>
    ''' <param name="sm"></param>
    ''' <param name="oConn"></param>
    ''' <param name="s_OCID"></param>
    ''' <param name="s_CourseDate"></param>
    ''' <param name="rPMS"></param>
    Public Shared Sub UPDATE_ADP_STUDATTEND(sm As SessionModel, oConn As SqlConnection, s_OCID As String, s_CourseDate As String, rPMS As Hashtable)
        '檢核今天有無執行，True:有執行(True) False:尚未執行
        '"HP", 2 : 取得線上簽到退紀錄使用 LINEAT.Wdaline 依班級
        Dim rPMS2 As New Hashtable From {{"HP", 2}, {"OCID", s_OCID}}
        If CHK_ADP_STUDATTEDNHP(oConn, rPMS2) Then Return
        If CHK_ADP_STUDATTEDNHP(oConn, rPMS) Then Return

        Dim dtTecher As DataTable = GET_TECHERDATA(s_OCID, oConn)
        Dim dtStd As DataTable = Get_StudData2(s_OCID, oConn)
        If dtStd Is Nothing OrElse dtStd.Rows.Count = 0 Then Return
        Dim dtTrain As DataTable = GET_TRAINDESCdt1(s_OCID, oConn)
        If dtTrain Is Nothing OrElse dtTrain.Rows.Count = 0 Then Return '(查無課程資訊)

        'WebRequest物件如何忽略憑證問題
        System.Net.ServicePointManager.ServerCertificateValidationCallback = New System.Net.Security.RemoteCertificateValidationCallback(AddressOf TIMS.ValidateServerCertificate)
        'TLS 1.2-基礎連接已關閉: 傳送時發生未預期的錯誤 
        System.Net.ServicePointManager.SecurityProtocol = Net.SecurityProtocolType.Tls12 '3072
        'TeacherSchedules.asmx 'https://wltims.wda.gov.tw/WdaLine/TeacherSchedules.asmx
        Using rws1t As New tw.gov.wda.wltims2.TeacherSchedules
            'StudentSchedules.asmx 'https://wltims.wda.gov.tw/WdaLine/StudentSchedules.asmx?op=SearchAttendance
            Using rws1 As New tw.gov.wda.wltims.StudentSchedules
                Dim rst2t As tw.gov.wda.wltims2.ResultOfListOfTeacherAttendanceResponse = rws1t.SearchAttendance(s_OCID, s_CourseDate) '(群組資料)
                '(查無資料) 'If rst2t Is Nothing OrElse rst2t.Results Is Nothing OrElse rst2t.Results.Length=0 Then Return
                Dim fg_NODATA As Boolean = (rst2t Is Nothing OrElse rst2t.Results Is Nothing OrElse rst2t.Results.Length = 0)
                If Not fg_NODATA Then
                    For Each res As tw.gov.wda.wltims2.TeacherAttendanceResponse In rst2t.Results
                        UPD_ADP_TEACHERATTEND(sm, oConn, dtTrain, dtTecher, res, rPMS)
                    Next
                End If
                Dim rst2 As tw.gov.wda.wltims.ResultOfResultsAttendanceResponse = rws1.SearchAttendance(s_OCID, s_CourseDate) '(群組資料)
                Dim fg_NODATA2 As Boolean = (rst2 Is Nothing OrElse rst2.Results Is Nothing OrElse rst2.Results.Length = 0)
                'If Not fg_NODATA2 Then Return '(查無資料離開)
                If Not fg_NODATA2 Then
                    For Each res As tw.gov.wda.wltims.ResultsAttendanceResponse In rst2.Results
                        UPD_ADP_STUDATTEND(sm, oConn, dtTrain, dtStd, res, rPMS)
                    Next
                End If
            End Using
        End Using
        UPD_ADP_STUDATTENDHP(sm, oConn, rPMS)
    End Sub

    Private Shared Function GET_TECHERDATA(OCID As String, tConn As SqlConnection) As DataTable
        OpenDbConn(tConn)
        Dim oDt As New DataTable
        Dim sSql As String = ""
        sSql &= " SELECT cc.OCID,a.PLANID,a.COMIDNO,a.SEQNO,a.TECHID,t.IDNO,a.TECHTYPE" & vbCrLf
        sSql &= " FROM CLASS_CLASSINFO cc WITH(NOLOCK)" & vbCrLf
        sSql &= " JOIN PLAN_TEACHER a WITH(NOLOCK) ON a.PLANID=cc.PLANID AND a.COMIDNO=cc.COMIDNO AND a.SEQNO=cc.SEQNO" & vbCrLf
        sSql &= " JOIN TEACH_TEACHERINFO t WITH(NOLOCK) ON t.TECHID=a.TECHID" & vbCrLf
        sSql &= " WHERE cc.OCID=@OCID" & vbCrLf
        Dim oCmd As New SqlCommand(sSql, tConn)
        With oCmd
            .Parameters.Clear()
            .Parameters.Add("OCID", SqlDbType.Int).Value = CINT1(OCID)
            oDt.Load(.ExecuteReader())
        End With
        Return oDt
    End Function

    ''' <summary>取得線上簽到退紀錄使用 LINEAT.Wdaline 全部日期</summary>
    ''' <param name="sm"></param>
    ''' <param name="oConn"></param>
    ''' <param name="s_OCID"></param>
    ''' <param name="rPMS"></param>
    Public Shared Sub UPDATE_ADP_STUDATTEND(sm As SessionModel, oConn As SqlConnection, s_OCID As String, rPMS As Hashtable)
        '檢核今天有無執行，True:有執行(True) False:尚未執行
        If CHK_ADP_STUDATTEDNHP(oConn, rPMS) Then Return

        Dim dtTecher As DataTable = GET_TECHERDATA(s_OCID, oConn)
        Dim dtStd As DataTable = Get_StudData2(s_OCID, oConn)
        If dtStd Is Nothing OrElse dtStd.Rows.Count = 0 Then Return
        Dim dtTrain2 As DataTable = GET_TRAINDESCdt2(s_OCID, oConn)
        If dtTrain2 Is Nothing OrElse dtTrain2.Rows.Count = 0 Then Return  '(查無課程資訊)
        Dim dtTrain As DataTable = GET_TRAINDESCdt1(s_OCID, oConn)
        If dtTrain Is Nothing OrElse dtTrain.Rows.Count = 0 Then Return  '(查無課程資訊)

        'WebRequest物件如何忽略憑證問題
        System.Net.ServicePointManager.ServerCertificateValidationCallback = New System.Net.Security.RemoteCertificateValidationCallback(AddressOf TIMS.ValidateServerCertificate)
        'TLS 1.2-基礎連接已關閉: 傳送時發生未預期的錯誤 
        System.Net.ServicePointManager.SecurityProtocol = Net.SecurityProtocolType.Tls12 '3072
        'TeacherSchedules.asmx 'https://wltims.wda.gov.tw/WdaLine/TeacherSchedules.asmx
        Using rws1t As New tw.gov.wda.wltims2.TeacherSchedules
            'https://wltims.wda.gov.tw/WdaLine/StudentSchedules.asmx?op=SearchAttendance
            Using rws1 As New tw.gov.wda.wltims.StudentSchedules
                For Each drTrain2 As DataRow In dtTrain2.Rows
                    Dim s_CourseDate As String = Cdate3(drTrain2("STRAINDATE")) '(群組資料)

                    Dim rst2t As tw.gov.wda.wltims2.ResultOfListOfTeacherAttendanceResponse = rws1t.SearchAttendance(s_OCID, s_CourseDate)
                    '(查無資料) 'If rst2t Is Nothing OrElse rst2t.Results Is Nothing OrElse rst2t.Results.Length=0 Then Return
                    Dim fg_NODATA As Boolean = (rst2t Is Nothing OrElse rst2t.Results Is Nothing OrElse rst2t.Results.Length = 0)
                    If Not fg_NODATA Then
                        For Each res As tw.gov.wda.wltims2.TeacherAttendanceResponse In rst2t.Results
                            UPD_ADP_TEACHERATTEND(sm, oConn, dtTrain, dtTecher, res, rPMS)
                        Next
                    End If
                    Dim rst2 As tw.gov.wda.wltims.ResultOfResultsAttendanceResponse = rws1.SearchAttendance(s_OCID, s_CourseDate)
                    '(查無資料離開)
                    Dim fg_NODATA2 As Boolean = (rst2 Is Nothing OrElse rst2.Results Is Nothing OrElse rst2.Results.Length = 0)
                    If Not fg_NODATA2 Then
                        For Each res As tw.gov.wda.wltims.ResultsAttendanceResponse In rst2.Results
                            UPD_ADP_STUDATTEND(sm, oConn, dtTrain, dtStd, res, rPMS)
                        Next
                    End If
                Next
            End Using
        End Using

        UPD_ADP_STUDATTENDHP(sm, oConn, rPMS)

    End Sub

    ''' <summary>新增不修改 ADP_TEACHERATTEND</summary>
    ''' <param name="sm"></param>
    ''' <param name="oConn"></param>
    ''' <param name="dtTrain"></param>
    ''' <param name="dtTecher"></param>
    ''' <param name="res"></param>
    ''' <param name="rPMS"></param>
    Public Shared Sub UPD_ADP_TEACHERATTEND(sm As SessionModel, oConn As SqlConnection, dtTrain As DataTable, dtTecher As DataTable,
                                            res As tw.gov.wda.wltims2.TeacherAttendanceResponse, rPMS As Hashtable)
        '(查無資料離開)
        If res Is Nothing Then Return

        If dtNODATA(dtTrain) Then Return
        Dim fff2 As String = String.Concat("PTDID=", CInt(res.CourseSerialNumber))
        '(查無資料離開)
        If dtTrain.Select(fff2).Length = 0 Then Return
        Dim drTrain As DataRow = dtTrain.Select(fff2)(0)

        If dtNODATA(dtTecher) Then Return
        Dim fff3 As String = String.Concat("IDNO='", res.TeacherIdentity, "'")
        '(查無資料離開)
        If dtTecher.Select(fff3).Length = 0 Then Return
        Dim drTecher As DataRow = dtTecher.Select(fff3)(0)

        Dim iOCID As Integer = drTecher("OCID") ' CInt(res.ClassCode)
        Dim iTECHID As Integer = drTecher("TECHID")
        Dim vTECHTYPE As String = drTecher("TECHTYPE")
        Dim iPTDID As Integer = CInt(res.CourseSerialNumber)
        Dim dSTRAINDATE As DateTime = CDate(Cdate3(res.SignedTime))
        Dim tSIGNEDTIME As DateTime = CDate(Cdate3t(res.SignedTime))
        Dim iSIGNMETHOD As Integer = res.SignMethod 'SignMethod: 簽到退方式 (1: QR Code掃描, 2: 線上註記)
        Dim iSIGNTYPE As Integer = res.SignType 'SignType: 簽到退類型 (1: 簽到, 2: 簽退)
        Dim iTPERIOD3 As Integer = If(Convert.ToString(drTrain("TPERIOD28_1")) = "Y", 1, If(Convert.ToString(drTrain("TPERIOD28_2")) = "Y", 2, 3)) '(1:早2:午3:晚)
        '(資料不批配離開)
        If iOCID <> CInt(res.ClassCode) Then Return
        'Line@簽到勾稽資料
        Dim oDt As New DataTable
        Dim sql As String = ""
        sql &= " SELECT TATID FROM ADP_TEACHERATEND WITH(NOLOCK)" & vbCrLf
        sql &= " WHERE OCID=@OCID AND TECHID=@TECHID AND PTDID=@PTDID AND SIGNEDTIME=@SIGNEDTIME AND SIGNTYPE=@SIGNTYPE" & vbCrLf
        Dim oCmd As New SqlCommand(sql, oConn)
        With oCmd
            .Parameters.Clear()
            .Parameters.Add("OCID", SqlDbType.Int).Value = iOCID
            .Parameters.Add("TECHID", SqlDbType.Int).Value = iTECHID
            .Parameters.Add("PTDID", SqlDbType.Int).Value = iPTDID
            .Parameters.Add("SIGNEDTIME", SqlDbType.DateTime).Value = tSIGNEDTIME
            .Parameters.Add("SIGNTYPE", SqlDbType.Int).Value = iSIGNTYPE
            oDt.Load(.ExecuteReader())
        End With
        '(已有資料 不新增)
        If oDt.Rows.Count = 0 Then
            Dim iTATID As Integer = DbAccess.GetNewId(oConn, "ADP_TEACHERATEND_TATID_SEQ,ADP_TEACHERATEND,TATID")
            Dim sSqli As String = ""
            sSqli &= " INSERT INTO ADP_TEACHERATEND(TATID,OCID,TECHID,PTDID,STRAINDATE,SIGNEDTIME,SIGNMETHOD,SIGNTYPE,TPERIOD3,TECHTYPE,MODIFYACCT,MODIFYDATE)" & vbCrLf
            sSqli &= " VALUES (@TATID,@OCID,@TECHID,@PTDID,@STRAINDATE,@SIGNEDTIME,@SIGNMETHOD,@SIGNTYPE,@TPERIOD3,@TECHTYPE,@MODIFYACCT,GETDATE())" & vbCrLf
            Dim iParms As New Hashtable From {{"TATID", iTATID}, {"OCID", iOCID}, {"TECHID", iTECHID},
                {"PTDID", iPTDID}, {"STRAINDATE", dSTRAINDATE},
                {"SIGNEDTIME", tSIGNEDTIME}, {"SIGNMETHOD", iSIGNMETHOD}, {"SIGNTYPE", iSIGNTYPE},
                {"TPERIOD3", iTPERIOD3}, {"TECHTYPE", vTECHTYPE}, {"MODIFYACCT", sm.UserInfo.UserID}}
            ExecuteNonQuery(sSqli, oConn, iParms)
        End If
    End Sub

    ''' <summary>新增不修改 ADP_STUDATTEND</summary>
    ''' <param name="sm"></param>
    ''' <param name="oConn"></param>
    ''' <param name="dtTrain"></param>
    ''' <param name="dtStd"></param>
    ''' <param name="res"></param>
    ''' <param name="rPMS"></param>
    Public Shared Sub UPD_ADP_STUDATTEND(sm As SessionModel, oConn As SqlConnection, dtTrain As DataTable, dtStd As DataTable,
                                         res As tw.gov.wda.wltims.ResultsAttendanceResponse, rPMS As Hashtable)
        '(查無資料離開)
        If res Is Nothing Then Return

        If dtNODATA(dtStd) Then Return
        Dim fff As String = String.Concat("IDNO='", res.StudentIdentity, "'")
        '(查無資料離開)
        If dtStd.Select(fff).Length = 0 Then Return
        Dim drStd As DataRow = dtStd.Select(fff)(0)

        If dtNODATA(dtTrain) Then Return
        Dim fff2 As String = String.Concat("PTDID=", CInt(res.CourseSerialNumber))
        '(查無資料離開)
        If dtTrain.Select(fff2).Length = 0 Then Return
        Dim drTrain As DataRow = dtTrain.Select(fff2)(0)

        Dim iOCID As Integer = drStd("OCID") ' CInt(res.ClassCode)
        Dim iSOCID As Integer = drStd("SOCID")
        Dim iPTDID As Integer = CInt(res.CourseSerialNumber)
        Dim dSTRAINDATE As DateTime = CDate(Cdate3(res.SignedTime))
        Dim tSIGNEDTIME As DateTime = CDate(Cdate3t(res.SignedTime))
        Dim iSIGNMETHOD As Integer = res.SignMethod 'SignMethod: 簽到退方式 (1: QR Code掃描, 2: 線上註記)
        Dim iSIGNTYPE As Integer = res.SignType 'SignType: 簽到退類型 (1: 簽到, 2: 簽退)
        Dim iTPERIOD As Integer = 0
        If (iSIGNTYPE = 1) Then '簽到計算排位(1.3:簽到, 2.4:簽退)
            iTPERIOD = If(Convert.ToString(drTrain("TPERIOD28_1")) = "Y", 1, 3)
        ElseIf (iSIGNTYPE = 2) Then '簽退計算排位(1.3:簽到, 2.4:簽退)
            iTPERIOD = If(Convert.ToString(drTrain("TPERIOD28_1")) = "Y", 2, 4)
        End If
        '(資料不批配離開)
        If iOCID <> CInt(res.ClassCode) Then Return

        'Line@簽到勾稽資料
        Dim oDt As New DataTable
        Dim sql As String = ""
        sql &= " SELECT SATID FROM ADP_STUDATTEND WITH(NOLOCK)" & vbCrLf
        sql &= " WHERE OCID=@OCID AND SOCID=@SOCID AND PTDID=@PTDID AND SIGNEDTIME=@SIGNEDTIME AND SIGNTYPE=@SIGNTYPE" & vbCrLf
        Dim oCmd As New SqlCommand(sql, oConn)
        With oCmd
            .Parameters.Clear()
            .Parameters.Add("OCID", SqlDbType.Int).Value = iOCID
            .Parameters.Add("SOCID", SqlDbType.Int).Value = iSOCID
            .Parameters.Add("PTDID", SqlDbType.Int).Value = iPTDID
