    ''' <summary>報表用協助組合字串-加入 單引號 逗號分格</summary>
    ''' <param name="VALL1"></param>
    ''' <param name="V1"></param>
    ''' <returns></returns>
    Public Shared Function ADD_PAR1(ByVal VALL1 As String, ByVal V1 As String) As String
        If V1 = "" Then Return VALL1
        Dim ff3 As String = String.Concat("'", V1, "'")
        If VALL1.IndexOf(ff3) = -1 Then
            VALL1 &= $"{If(VALL1 <> "", ",", "")}{ff3}" 'js esc 字元
        End If
        Return VALL1
    End Function

    Public Shared Sub ADD_PAR2(ByRef VALL1 As String, ByRef s_V1 As String)
        If s_V1 = "" Then Return 'VALL1
        VALL1 &= $"{If(VALL1 <> "", ",", "")}{s_V1}" 'js esc 字元 'Return VALL1
    End Sub

    ''' <summary>整理下拉，只留選擇值</summary>
    ''' <param name="o_NewDDL1"></param>
    ''' <param name="v_NewData"></param>
    Public Shared Sub GET_NewListItemVal(ByRef o_NewDDL1 As DropDownList, ByVal v_NewData As String)
        Dim o_CopyDDL1 As New DropDownList '複製-下拉物件 
        If o_NewDDL1.SelectedIndex = -1 Then Return '該物件(-1)未啟動 / 已啟動的物件，不做處理
        For Each LiN1 As ListItem In o_NewDDL1.Items
            o_CopyDDL1.Items.Add(LiN1) '複製-下拉物件 
        Next
        For Each LiN1 As ListItem In o_CopyDDL1.Items '使用-複製-下拉物件 
            If LiN1.Value <> "" AndAlso (LiN1.Value <> v_NewData) Then
                o_NewDDL1.Items.Remove(o_NewDDL1.Items.FindByValue(LiN1.Value)) '移除(原)無效物件 
            End If
        Next
        o_CopyDDL1 = Nothing '複製-下拉物件-使用完畢清除
        Common.SetListItem(o_NewDDL1, v_NewData) '新的值為下拉物件 
    End Sub

