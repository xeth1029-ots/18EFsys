    ''' <summary>分署名稱-可多筆</summary>
    ''' <param name="oConn"></param>
    ''' <param name="DistID"></param>
    ''' <returns></returns>
    Public Shared Function GET_DISTNAME(ByRef oConn As SqlConnection, ByVal DistID As String) As String
        Dim tmpstr As String = ""
        Dim dt As DataTable
        Dim sql As String = ""
        If DistID Is Nothing OrElse DistID = "" Then Return tmpstr

        If DistID.IndexOf(",") > -1 AndAlso DistID.IndexOf("'") > -1 Then
            DistID = CombiSQM2IN(DistID)
            If DistID = "" Then Return tmpstr
            sql = String.Concat("SELECT NAME FROM ID_DISTRICT WITH(NOLOCK) WHERE DISTID IN (", DistID, ")")
            dt = DbAccess.GetDataTable(sql, oConn)
            If dt.Rows.Count > 0 Then
                For i As Integer = 0 To dt.Rows.Count - 1
                    tmpstr &= String.Concat(If(tmpstr <> "", ",", ""), dt.Rows(i)("Name"))
                Next
            End If
        Else
            '(異常)
            If DistID = "" OrElse DistID.IndexOf(",") > -1 Then Return tmpstr
            DistID = ClearSQM(DistID)
            sql = "SELECT NAME FROM ID_DISTRICT WITH(NOLOCK) WHERE DISTID='" & DistID & "'"
            tmpstr = DbAccess.ExecuteScalar(sql, oConn)
        End If
        Return tmpstr
    End Function

