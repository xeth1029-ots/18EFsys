    '取得目前處分型態 (機構)iBlackType
    Public Shared Function Chk_OrgBlackType(ByRef MyPage As Page, ByVal objConn As SqlConnection) As Integer
        Dim rst As Integer = 0 '0:未設定
        Dim sm As SessionModel = SessionModel.Instance()

        '0：未設定
        '1：各計畫自行限制處分紀錄
        '2：跨計畫合併限制處分紀錄，因跨計畫合併限制處分紀錄可能會有不同組合，需要另外一個欄位紀錄組合喔
        '3：所有計畫合併限制處分紀錄
        '4：無處分限制(停用處分)
        Dim sTPlanID As String = sm.UserInfo.TPlanID '判斷該計畫是否啟用黑名單功能。
        'Dim sDistID As String=sm.UserInfo.DistID
        Dim sql As String = ""
        sql = ""
        sql &= " SELECT DISTINCT TPlanID"
        sql &= " ,BLACKTYPE ,','+BLACK2TPLANID+',' BLACK2TPLANID"
        sql &= " FROM KEY_PLAN"
        sql &= " WHERE BLACKTYPE IS NOT NULL"
        Dim sCmd As New SqlCommand(sql, objConn)
        Call OpenDbConn(objConn)
        Dim dt As New DataTable
        With sCmd
            .Parameters.Clear()
            dt.Load(.ExecuteReader())
        End With
        If dt.Rows.Count = 0 Then Return rst '0:未設定
        Dim sff As String = ""
        sff = "BLACKTYPE=4 AND TPlanID='" & sTPlanID & "'"
        If dt.Select(sff).Length > 0 Then Return 4 '4：無處分限制(停用處分)
        sff = "BLACKTYPE=1 AND TPlanID='" & sTPlanID & "'"
        If dt.Select(sff).Length > 0 Then Return 1 '1：各計畫自行限制處分紀錄
        sff = "BLACKTYPE=3"
        If dt.Select(sff).Length > 0 Then Return 3 '3：所有計畫合併限制處分紀錄
        sff = "BLACKTYPE=2 AND BLACK2TPLANID LIKE '%," & sTPlanID & ",%'"
        If dt.Select(sff).Length > 0 Then Return 2 '2：跨計畫合併限制處分紀錄
        Return rst '0:未設定(其他狀況)
    End Function

    ''' <summary>
    ''' 確認機構是否在黑名單中 20090724 by AMU
    ''' 加入計畫_訓練單位處分功能是否啟用 20091106 by AMU '處分
    ''' '依iBlackType 201607 by AMU
    ''' </summary>
    ''' <param name="MyPage"></param>
