    ''' <summary> 多筆重新勾稽-依OCID (多筆-IDNO) </summary>
    ''' <param name="sConn"></param>
    ''' <param name="v_OCID"></param>
    ''' <param name="flag_ALL">false:略過-非在職者 (true:全部-不略過)</param>
    Public Shared Sub Utl_TrainingList2s(ByRef sm As SessionModel, ByRef sConn As SqlConnection, ByVal v_OCID As String, ByVal flag_ALL As Boolean)
        'As DataTable
        Dim dtS2 As DataTable = Get_STUDENTINFO2(sConn, v_OCID)
        Dim v_IDNOs As String = ""
        For Each drS2 As DataRow In dtS2.Rows
            Dim vIDNO As String = Convert.ToString(drS2("IDNO"))

            Dim flag_bak As Boolean = False 'True 'true:刪除前備份 false:刪除不備份
            '資料-刪除-整班的學員-For Each-逐筆刪除
            '查詢有資料-過去-全部刪除-(執行備份舊資料與刪除)
            Call Del_TRAININGLIST_Old(sConn, vIDNO, flag_bak)

            'Convert.ToString(drS2("idno"))
            v_IDNOs &= String.Concat(If(v_IDNOs <> "", ",", ""), vIDNO)
        Next

        'Const cst_all_column As String="IDNO,NAME,BIRTHDAY,DISTNAME,YEARS,TPLANID,PLANNAME,ORGNAME,TRAINNAME,CJOB_NAME,CLASSCNAME,THours,TRound,WEEKS,TFLAG,WorkSuppIdent,SumOfMoney,BudIDName,AppliedStatus,AppliedStatusM,MEMO1"
        Dim dt As DataTable = Utl_CreateITSWebcCDT()

        'Const cst_SYSNAME_1 As String="PSHTL001"
        Const cst_s_AUTH As String = "ce130f098d90e52491a8097fcd119b4d"
        'WebRequest物件如何忽略憑證問題
        System.Net.ServicePointManager.ServerCertificateValidationCallback = New System.Net.Security.RemoteCertificateValidationCallback(AddressOf ValidateServerCertificate)
        'TLS 1.2-基礎連接已關閉: 傳送時發生未預期的錯誤 'HttpClient
        System.Net.ServicePointManager.SecurityProtocol = System.Net.SecurityProtocolType.Tls12 '3072
        'https://itsapi.etraining.gov.tw/ITSWebExport
        'https://itsapi.etraining.gov.tw/ITSWebExport/swagger/index.html?url=/ITSWebExport/swagger/v1/swagger.json
        'http://wltims.wda.gov.tw/ITSWebc/twsITSWebc.asmx
        'Dim GTL_1 As New GetTraining.GetTrainingList
        Dim GTL_2 As New ITSWebc.twsITSWebc

        Dim s_log1 As String = ""
        s_log1 = String.Format("##Utl_TrainingList2s v_OCID:{0},flag_ALL:{1},v_IDNOs:{2} ", v_OCID, flag_ALL, v_IDNOs)
        LOG.Debug(s_log1)
        v_IDNOs = CombiSQM2IN(v_IDNOs)

        '執行webservice前／需要有單引號
        Dim ITSrc1 As ITSWebc.ResultOfSTUDENT_TRAINING_HISTORY_VIEW
        ITSrc1 = GTL_2.GetStudHis2(cst_s_AUTH, v_IDNOs)
        If ITSrc1.Count = 0 Then Return 'dt

        Dim iROW As Integer = 0
        For Each mlist As ITSWebc.STUDENT_TRAINING_HISTORY_VIEW In ITSrc1.Records
            'If Cst_TPlanID28ApPlan5.IndexOf(mlist.TPLANID) > -1 Then Continue For '略過-計畫為在職
            If Not flag_ALL AndAlso CHG_YESNO(mlist.WORKSUPPIDENT, "N") = "N" Then Continue For '略過-非在職者 (若為全部時不略過)

            iROW += 1
            Dim dr As DataRow = dt.NewRow()
            dt.Rows.Add(dr)
            dr("ROWNUM") = iROW
            UPD_ITSWebcDr(dr, mlist, Nothing)
        Next

        '新增-dtTra
        Call INSERT_TRAININGLIST(sm, sConn, dt)

        s_log1 = String.Format("##Utl_TrainingList2s v_OCID:{0},flag_ALL:{1},v_IDNOs:{2},COUNT:{3}", v_OCID, flag_ALL, v_IDNOs, iROW)
        LOG.Debug(s_log1)

        Return 'dt
    End Sub

