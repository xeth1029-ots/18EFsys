    '取得系統參數4-出缺勤警示 是否為百分比 1:依比例/2:依百分比
    Public Shared Function GetGlobalVar4rbl(ByRef MyPage As Page, ByVal ItemVar As String, ByRef tConn As SqlConnection) As String
        Dim rst As String = "1"
        Dim sm As SessionModel = SessionModel.Instance()
        ' (直接在 AuthBasePage 處理, 不用個別檢查 Session) If TIMS.ChkSession(MyPage) Then Return rst
        Dim sDistID As String = CStr(sm.UserInfo.DistID)
        Dim sTPlanID As String = CStr(sm.UserInfo.TPlanID)

        Select Case ItemVar
            Case ""
                Dim vItemVal_1 As String = GetGlobalVar(sDistID, sTPlanID, "4", "1", tConn)
                Dim iDb1_1 As Double = 0
                Dim iDb2_1 As Double = 0
                If vItemVal_1 <> "0" AndAlso vItemVal_1.IndexOf("/") > -1 Then
                    iDb1_1 = Val(Split(vItemVal_1, "/")(0))
                    iDb2_1 = Val(Split(vItemVal_1, "/")(1))
                End If
                Dim vItemVal_2 As String = GetGlobalVar(sDistID, sTPlanID, "4", "2", tConn)
                Dim iDb1_2 As Double = 0
                Dim iDb2_2 As Double = 0
                If vItemVal_2 <> "0" AndAlso vItemVal_2.IndexOf("/") > -1 Then
                    iDb1_2 = Val(Split(vItemVal_2, "/")(0))
                    iDb2_2 = Val(Split(vItemVal_2, "/")(1))
                End If
                rst = "1"
                If iDb2_1 = 100 AndAlso iDb2_2 = 100 Then rst = "2"
            Case "1"
                Dim vItemVal_1 As String = GetGlobalVar(sDistID, sTPlanID, "4", "1", tConn)
                Dim iDb1_1 As Double = 0
                Dim iDb2_1 As Double = 0
                If vItemVal_1 <> "0" AndAlso vItemVal_1.IndexOf("/") > -1 Then
                    iDb1_1 = Val(Split(vItemVal_1, "/")(0))
                    iDb2_1 = Val(Split(vItemVal_1, "/")(1))
                End If
                rst = CStr(iDb1_1) & "%"
            Case "2"
                Dim vItemVal_2 As String = GetGlobalVar(sDistID, sTPlanID, "4", "2", tConn)
                Dim iDb1_2 As Double = 0
                Dim iDb2_2 As Double = 0
                If vItemVal_2 <> "0" AndAlso vItemVal_2.IndexOf("/") > -1 Then
                    iDb1_2 = Val(Split(vItemVal_2, "/")(0))
                    iDb2_2 = Val(Split(vItemVal_2, "/")(1))
                End If
                rst = CStr(iDb1_2) & "%"
        End Select

        Return rst
    End Function

    '取得系統參數4-出缺勤警示 ItemVar:1/2/3:是否為百分比 1:依比例/2:依百分比
    Public Shared Function GetGlobalVar4(ByRef MyPage As Page, ByVal ItemVar As String, ByRef tConn As SqlConnection) As Double
        Dim rst As Double = 0
        Dim sm As SessionModel = SessionModel.Instance()
        ' (直接在 AuthBasePage 處理, 不用個別檢查 Session) If TIMS.ChkSession(MyPage) Then Return rst
        Dim sDistID As String = CStr(sm.UserInfo.DistID)
        Dim sTPlanID As String = CStr(sm.UserInfo.TPlanID)
        Dim vItemVal As String = GetGlobalVar(sDistID, sTPlanID, "4", ItemVar, tConn)
