    '建立教師Script('TeacherID,TechID,TeachCName)
    Public Shared Sub CreateTeacherScript(ByRef MyPage As Page, ByVal RID As String, ByVal dtTeach As DataTable)
        Dim JScript As String = ""
        JScript &= "<script>" & vbCrLf
        JScript &= "function GetTeacherId(UsedTechID,IDField,NameField){" & vbCrLf
        JScript &= " var TechID=new Array;" & vbCrLf
        JScript &= " var TeachCName=new Array;" & vbCrLf
        JScript &= " document.getElementById(IDField).value='';" & vbCrLf
        JScript &= " document.getElementById(NameField).value='';" & vbCrLf
        If dtTeach.Rows.Count <> 0 Then
