    ''' <summary>取得重點產業審核確認-中文'PLAN_DEPOT</summary>
    ''' <param name="DEPID"></param>
    ''' <param name="KID"></param>
    ''' <param name="oConn"></param>
    ''' <returns></returns>
    Public Shared Function Get_DEPOTNAME(ByVal DEPID As String, ByVal KID As String, ByRef oConn As SqlConnection) As String
        Dim rst As String = ""
        If DEPID = "" OrElse KID = "" Then Return rst

        KID = CombiSQM2IN(KID)

        Call OpenDbConn(oConn)
        Dim sql As String = $" SELECT KID,KNAME FROM dbo.KEY_BUSINESS WITH(NOLOCK) WHERE DEPID=@DEPID AND KID IN ({KID})"
        Dim dt As New DataTable
        Using sCmd As New SqlCommand(sql, oConn)
            With sCmd
                .Parameters.Clear()
                .Parameters.Add("DEPID", SqlDbType.VarChar).Value = DEPID
                '.Parameters.Add("KID", SqlDbType.VarChar).Value = KID
                dt.Load(.ExecuteReader())
            End With
        End Using
        If dtNODATA(dt) Then Return rst
        If dt.Rows.Count = 1 Then
            rst = $"{dt.Rows(0)("KNAME")}"
            Return rst
        ElseIf dt.Rows.Count > 1 Then
            '超過1筆資料 'rst = ""
            For Each dr1 As DataRow In dt.Rows
                rst &= $"{If(rst <> "", "、", "")}{dr1("KNAME")}"
            Next
            Return rst
        End If
        Return rst
    End Function

