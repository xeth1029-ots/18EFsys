    'SelHomeNewsS1
    ''' <summary>HOME_NEWS-sql查詢datatable</summary>
    ''' <param name="objconn"></param>
    ''' <param name="i_typeodo"></param>
    ''' <returns></returns>
    Public Shared Function Get_SelHomeNewsS1(ByRef objconn As SqlConnection, ByVal i_typeodo As Integer) As DataTable
        'Call OpenDbConn(objconn)
        'Today: yyyy/MM/dd
        Dim Rst As New DataTable
        Dim sql As String = ""
        sql &= " SELECT HNID,Type" & vbCrLf
        sql &= " ,CONVERT(varchar, POSTDATE, 111) PostDate" & vbCrLf
        sql &= " ,PostFDate" & vbCrLf
        sql &= " ,Subject" & vbCrLf
        sql &= " ,isShow" & vbCrLf
        sql &= " ,ModifyAcct,ModifyDate" & vbCrLf
        sql &= " ,MsgWeek" & vbCrLf
        sql &= " ,case when convert(date,GETDATE())  <= convert(date,POSTDATE + 7 * Msgweek) then 'Y' else 'N' end msg" & vbCrLf '訊息週數未結束
        sql &= " ,case when POSTFDATE >= GETDATE() then 'Y' end msg2" & vbCrLf '未到結束日期(時間)。(若為永久顯示，則無結束日)
        sql &= " ,case when convert(date,GETDATE())  <= convert(date,DATEADD(DAY,7,POSTDATE)) then 'Y' else 'N' end msg1" & vbCrLf '7天內的新訊息。
        sql &= " FROM HOME_NEWS WITH(NOLOCK)" & vbCrLf
        sql &= " WHERE 1=1" & vbCrLf
        If i_typeodo > 0 Then sql &= " AND Type=@Type" & vbCrLf
        sql &= " AND (1!=1" & vbCrLf
        '/*有開始結束日期顯示2週內的資訊*/
        sql &= " OR ( DATEDIFF(DAY, POSTDATE, convert(date,DATEADD(DAY, -14, GETDATE()))) <=0 and DATEDIFF(DAY, POSTDATE, convert(date,GETDATE()) ) >= 0)" & vbCrLf
        '/*永久顯示*/
        sql &= " OR (isShow='Y' and GETDATE() - POSTDATE >= 0)" & vbCrLf
        sql &= " )" & vbCrLf
        sql &= " ORDER BY MODIFYDATE DESC, POSTDATE DESC" & vbCrLf
        Call OpenDbConn(objconn)
        Dim oCmd As New SqlCommand(sql, objconn)
        With oCmd
            .Parameters.Clear()
            If i_typeodo > 0 Then .Parameters.Add("Type", SqlDbType.Int).Value = i_typeodo
            Rst.Load(.ExecuteReader()) '有資料。
        End With
        Return Rst
    End Function

