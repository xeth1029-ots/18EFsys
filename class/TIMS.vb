    '取出帳號的功能權限
    Public Shared Function GetAuthGroupFun(ByVal sAccount As String, ByRef objconn As SqlConnection) As DataTable
        Dim Rstdt As DataTable = Nothing
        Call OpenDbConn(objconn)
        If sAccount <> "" Then
            'tims1Sel180 '取出帳號的功能權限
            Dim parms As New Hashtable From {{"Account", sAccount}}
            Dim sql As String = ""
            sql &= " SELECT g.account,g.funid" & vbCrLf
            sql &= " ,dbo.DECODE(g.adds,'0','1','0') adds" & vbCrLf
            sql &= " ,dbo.DECODE(g.mod,'0','1','0') mod" & vbCrLf
            sql &= " ,dbo.DECODE(g.del,'0','1','0') del" & vbCrLf
            sql &= " ,dbo.DECODE(g.sech,'0','1','0') sech" & vbCrLf
            sql &= " ,dbo.DECODE(g.prnt,'0','1','0') prnt" & vbCrLf
            sql &= " from ( SELECT b.account ,a.funid" & vbCrLf
            sql &= " ,min(adds) adds" & vbCrLf
            sql &= " ,min(mod) mod" & vbCrLf
            sql &= " ,min(del) del" & vbCrLf
            sql &= " ,min(sech) sech" & vbCrLf
            sql &= " ,min(prnt) prnt" & vbCrLf
            sql &= " from AUTH_GROUPFUN a" & vbCrLf
            sql &= " join auth_groupacct b on b.gid=a.gid" & vbCrLf
            sql &= " WHERE b.Account=@Account" & vbCrLf
            sql &= " group by b.account,a.funid ) g" & vbCrLf
            Rstdt = DbAccess.GetDataTable(sql, objconn, parms)

            If Rstdt.Rows.Count = 0 Then
                'tims1Sel180B '取出帳號的功能權限
                Dim parms2 As New Hashtable From {{"Account", sAccount}}
                Dim sql2 As String = "SELECT ACCOUNT,FUNID,ADDS,MOD,DEL,SECH,PRNT FROM AUTH_ACCRWFUN WHERE Account=@Account"
                Rstdt = DbAccess.GetDataTable(sql2, objconn, parms2)
            End If
        End If
        Return Rstdt
    End Function

    '在SqlCommon (SYS_SQLCOMMON)
    Public Shared Sub SaveSqlCommon(ByVal sMemo100 As String, ByVal SQLStr As String)
        ''儲存 按鈕
        If Trim(sMemo100) <> "" Then sMemo100 = Trim(sMemo100) Else sMemo100 = ""
        If sMemo100.Length > 100 Then sMemo100 = Left(sMemo100, 100)
        Dim oConn As SqlConnection = DbAccess.GetConnection()
        Dim sql As String = ""
        sql &= " INSERT INTO SYS_SQLCOMMON( SEQID,Memo,SQLStr,Modifydate )" & vbCrLf
        sql &= " VALUES ( @SEQID,@Memo,@SQLStr,GETDATE())" & vbCrLf
        Dim iCmd As New SqlCommand(sql, oConn)

        Dim u_sql As String = ""
        u_sql &= " UPDATE SYS_SQLCOMMON" & vbCrLf
        u_sql &= " SET SQLStr=SQLStr+@SQLStr" & vbCrLf
        u_sql &= " WHERE SEQID=@SEQID" & vbCrLf
        Dim uCmd As New SqlCommand(u_sql, oConn)

        Call OpenDbConn(oConn)
        Dim iSEQID As Integer = DbAccess.GetNewId(oConn, "SYS_SQLCOMMON_SEQID_SEQ,SYS_SQLCOMMON,SEQID")
        Const cst_maxCount As Integer = 2000
        If SQLStr.Length > cst_maxCount Then
            Dim i As Integer = 0
            Dim SQLStr2000 As String = ""
            Do
                SQLStr2000 = Mid(SQLStr, 1, cst_maxCount)
                SQLStr = Mid(SQLStr, cst_maxCount + 1)
                If SQLStr2000 <> "" Then
                    If i = 0 Then
                        With iCmd
                            .Parameters.Clear()
                            .Parameters.Add("SEQID", SqlDbType.Int).Value = iSEQID
                            .Parameters.Add("Memo", SqlDbType.NVarChar).Value = sMemo100
                            .Parameters.Add("SQLStr", SqlDbType.NVarChar).Value = SQLStr2000
                            .ExecuteNonQuery()
                        End With
                    Else
                        With uCmd
                            .Parameters.Clear()
                            .Parameters.Add("SQLStr", SqlDbType.NVarChar).Value = SQLStr2000
                            .Parameters.Add("SEQID", SqlDbType.Int).Value = iSEQID
                            .ExecuteNonQuery()
                        End With
                    End If
                End If
                i += 1
            Loop Until SQLStr2000.Length <= 0
        Else
            With iCmd
                .Parameters.Clear()
                .Parameters.Add("SEQID", SqlDbType.Int).Value = iSEQID
                .Parameters.Add("Memo", SqlDbType.NVarChar).Value = sMemo100
                .Parameters.Add("SQLStr", SqlDbType.NVarChar).Value = SQLStr
                .ExecuteNonQuery()
            End With
        End If
        Call CloseDbConn(oConn)
    End Sub

