    ''' <summary> 重整，重組，重新組合加入欄位名-供SQL語法 OR LIKE 使用。</summary>
    ''' <param name="sVal"></param>
    ''' <param name="orlikeFieldName"></param>
    ''' <returns></returns>
    Public Shared Function CombiSqlInlikeSta(ByVal sVal As String, ByVal orlikeFieldName As String) As String
        Dim rst As String = ""
        If sVal = "" Then Return rst
        If sVal.IndexOf("\'") > -1 Then sVal = Replace(sVal, "\'", "'")
        sVal = ClearSQM(sVal)
        orlikeFieldName = ClearSQM(orlikeFieldName)

        If sVal <> "" Then
            If sVal.IndexOf(",") > -1 Then
                '依逗點分隔字串。
                Dim strA As String() = sVal.Split(",")
                For i As Integer = 0 To strA.Length - 1
                    'If strA(i) <> "" Then strA(i)=ChangeSQM(strA(i))
                    If strA(i) <> "" AndAlso rst.IndexOf($"'{strA(i)}'") = -1 Then
                        rst &= $"{If(rst <> "", " OR ", "")}{orlikeFieldName}  LIKE '%'+'{strA(i)}'+'%'"
                    End If
                Next
                If rst <> "" Then
                    '最後組成and語法
                    rst = $" AND ({rst}){vbCrLf}"
                End If
            Else
                '查無逗號
                rst = $" AND {orlikeFieldName} LIKE '%'+'{sVal}'+'%'"
            End If
        End If
        Return rst
    End Function

    ''' <summary>重整，重組，重新組合 (供儲存多值豆逗號分隔使用)</summary>
    ''' <param name="str"></param>
    ''' <param name="fgClearSQM">true</param>
    ''' <returns></returns>
    Public Shared Function CombiSQM2IN(ByVal str As String, fgClearSQM As Boolean) As String
        str = CombiSQM2IN(str)
        Return If(fgClearSQM, ClearSQM(str), str)
    End Function

    ''' <summary> 重整，重組，重新組合加入單引號 (排除空值及重複)(供SQL語法 IN 使用。) SQLIN </summary>
    ''' <param name="str"></param>
    ''' <returns></returns>
    Public Shared Function CombiSQM2IN(ByVal str As String) As String
        Dim rst As String = ""
        If str = "" Then Return rst '無值返回
        If str.IndexOf("\'") > -1 Then str = Replace(str, "\'", "'")
        str = ClearSQM(str)
        If str = "" Then Return rst '無值返回

        If str.IndexOf(",") > -1 Then
            '依逗點分隔字串。
            Dim strA As String() = str.Split(",")
            For i As Integer = 0 To strA.Length - 1
                Dim sVal As String = $"'{strA(i)}'"
                'If sVal <> "" AndAlso ff3 <> "''" AndAlso rst.IndexOf(ff3)=-1 Then '(排除無值)
                '(排除空值及重複)'AndAlso sVal <> "''"
                If sVal <> "" AndAlso rst.IndexOf(sVal) = -1 Then
                    rst &= $"{If(rst <> "", ",", "")}{sVal}"
                End If
            Next
            Return rst
        End If
        '查無逗號
        rst = String.Concat("'", str, "'")
        Return rst
    End Function

    ''' <summary> 重整，重組，重新組合 沒有單引號(數值)(排除空值及重複)(供SQL語法 IN 使用(轉數值)。) SQLIN </summary>
    ''' <param name="str"></param>
    ''' <returns></returns>
    Public Shared Function CombiSQLINM3(ByVal str As String) As String
        Dim rst As String = ""
        If str = "" Then Return rst '無值返回
        If str.IndexOf("\'") > -1 Then str = Replace(str, "\'", "'")
        If str <> "" Then str = ClearSQM(str)
        If str = "" Then Return rst '無值返回

        If str.IndexOf(",") > -1 Then
            '依逗點分隔字串。
            Dim strA As String() = str.Split(",")
            For i As Integer = 0 To strA.Length - 1
                'If strA(i) <> "" Then strA(i)=ChangeSQM(strA(i))
                If strA(i) = "" Then Continue For '(排除空值)
                Dim sVal As String = CINT1(strA(i)) '轉為數值 
                Dim ff3 As String = $",{sVal},"
                '(排除重複)
                If $",{rst},".IndexOf(ff3) = -1 Then
                    rst &= $"{If(rst <> "", ",", "")}{sVal}"
                End If
            Next
            Return rst
        End If
        '查無逗號
        rst = CINT1(str)
        Return rst
    End Function

    ''' <summary>重整，重組，重新組合(排除重複)(加入單引號)(供儲存多值逗號分隔使用) </summary>
    ''' <param name="sSTR"></param>
    ''' <param name="vRIGHTVAL"></param>
    ''' <returns></returns>
    Public Shared Function CombiSQM4IN(sSTR As String, vRIGHTVAL As String) As String
        Dim rst As String = ""
        '(排除重複／並且重組／清理)
        sSTR = CombiSQM2IN(sSTR)
        '(重新組合回傳)
        Dim iLEN1 As Integer = vRIGHTVAL.Length
        If sSTR.IndexOf(",") > -1 Then
            Dim strA As String() = sSTR.Split(",")
            For i As Integer = 0 To strA.Length - 1
                Dim sVal As String = strA(i)
                Dim ff3 As String = $"{vRIGHTVAL}{ClearSQM(sVal)}"
                rst &= $"{If(rst <> "", ",", "")}{ff3.Substring(ff3.Length - iLEN1, iLEN1)}"
            Next
            Return rst
        End If
        '(組合回傳)
        Dim ff4 As String = String.Concat(vRIGHTVAL, ClearSQM(sSTR))
        rst = ff4.Substring(ff4.Length - iLEN1, iLEN1)
        Return rst
    End Function

    ''' <summary>重整，重組，重新組合(排除空值及重複)(不加單引號)(供儲存多值逗號分隔使用) </summary>
    ''' <param name="sSTR"></param>
    ''' <returns></returns>
    Public Shared Function CombiSQM5IN(sSTR As String) As String
        Dim rst As String = ""
        sSTR = ClearSQM(sSTR)
        If sSTR = "" Then Return rst '無值返回

        If sSTR.IndexOf(",") > -1 Then
            '依逗點分隔字串。
            Dim strA As String() = sSTR.Split(",")
            For i As Integer = 0 To strA.Length - 1
                Dim sVal As String = strA(i)
                Dim ff3 As String = String.Concat(",", sVal, ",")
                '(排除空值及重複)
                If sVal <> "" AndAlso String.Concat(",", rst, ",").IndexOf(ff3) = -1 Then
                    rst &= String.Concat(If(rst <> "", ",", ""), sVal)
                End If
            Next
            Return rst
        End If
        '查無逗號
        Return sSTR
    End Function

