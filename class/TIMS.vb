    End Function

    ''' <summary>儲存轉換-將民國年月日 轉為 西元年月日(yyy/MM/dd)(yyyy/MM/dd)</summary>
    ''' <param name="strDate1"></param>
    ''' <returns></returns>
    Public Shared Function Cdate18(ByVal strDate1 As String) As String
        Dim rst As String = ""
        If strDate1 = "" OrElse strDate1.Length < 6 OrElse strDate1.IndexOf("/") = -1 Then Return rst

        Try
            rst = Cdate3($"{CINT1(strDate1.Split("/")(0)) + 1911}{Mid(strDate1, strDate1.IndexOf("/") + 1)}")
        Catch ex As Exception
            Dim V_GUID As String = Guid.NewGuid().ToString()
            LOG.Warn(ex.Message, ex) '取得錯誤資訊寫入
            Dim strErrmsg As String = $"ex.Message:{ex.Message}[{V_GUID}]{vbCrLf}"
            WriteTraceLog(strErrmsg, ex)
        End Try
        Return rst
    End Function

