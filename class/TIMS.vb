    Public Shared Function Chk_StudStatus(ByVal sIDNO As String, ByVal STDate As String, ByVal FTDate As String, ByVal OCID As String, ByRef tConn As SqlConnection) As Boolean
        Dim Rst As Boolean = False
        If sIDNO <> "" Then sIDNO = ChangeIDNO(ClearSQM(UCase(sIDNO)))
