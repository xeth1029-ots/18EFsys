    '障礙類別2
    Public Shared Function Get_HandTypeName2(ByVal HandTypeID2 As String) As String
        Dim Rst As String = ""
        HandTypeID2 = ClearSQM(HandTypeID2)
        Using conn As SqlConnection = DbAccess.GetConnection()
            If HandTypeID2.IndexOf(",") > -1 Then
                Dim sql As String = $" SELECT NAME,HANDTYPEID2 FROM KEY_HANDICATTYPE2 WHERE HANDTYPEID2 IN ({CombiSQLIN(HandTypeID2)}) ORDER BY HANDTYPEID2" & vbCrLf
                Dim dt As DataTable = DbAccess.GetDataTable(sql, conn)
                If dtNODATA(dt) Then Return Rst
                For Each dr1 As DataRow In dt.Rows
                    Dim NM1 As String = $"{dr1("NAME")}"
                    Rst &= $"{If(Rst <> "", ",", "")}{NM1}"
                Next
            Else
                Dim sql As String = $" SELECT NAME FROM KEY_HANDICATTYPE2 WHERE HANDTYPEID2='{HandTypeID2}' ORDER BY HANDTYPEID2" & vbCrLf
                Return $"{DbAccess.ExecuteScalar(sql, conn)}"
            End If
            Call CloseDbConn(conn)
        End Using
        Return Rst
    End Function

