    ''' <summary>清理電話關鍵字</summary>
    ''' <param name="str1"></param>
    ''' <returns></returns>
    Public Shared Function ChangePHONE123(ByVal str1 As String) As String
        str1 = ClearSQM(ChangeIDNO(str1))
        If str1 = "" Then Return str1
        If str1.IndexOf("-") > -1 Then str1 = Replace(str1, "-", "")
        If str1.IndexOf("#") > -1 Then str1 = Replace(str1, "#", "")
        Return str1
    End Function

    Public Shared Function ChangContactPhone(ByVal s_CtPhone_1 As String, ByVal s_CtPhone_2 As String, ByVal s_CtPhone_3 As String) As String
        s_CtPhone_1 = TIMS.ChangePHONE123(s_CtPhone_1)
        s_CtPhone_2 = TIMS.ChangePHONE123(s_CtPhone_2)
        s_CtPhone_3 = TIMS.ChangePHONE123(s_CtPhone_3)
        s_CtPhone_1 = Get_Substr1(s_CtPhone_1, 4)
        s_CtPhone_2 = Get_Substr1(s_CtPhone_2, 8)
        s_CtPhone_3 = Get_Substr1(s_CtPhone_3, 8)

        Dim rst As String = String.Concat(s_CtPhone_1, "-", s_CtPhone_2, "#", s_CtPhone_3)
        If rst = "-#" Then rst = ""
        If rst <> "" AndAlso rst.EndsWith("#") Then rst = rst.Remove(rst.Length - 1)
        If rst <> "" AndAlso rst.EndsWith("-") Then rst = rst.Remove(rst.Length - 1)
        Return rst
    End Function
    Public Shared Function ChangContactMobile(ByVal s_CtMobile_1 As String, ByVal s_CtMobile_2 As String) As String
        s_CtMobile_1 = TIMS.ChangePHONE123(s_CtMobile_1)
        s_CtMobile_2 = TIMS.ChangePHONE123(s_CtMobile_2)
        s_CtMobile_1 = Get_Substr1(s_CtMobile_1, 4)
        s_CtMobile_2 = Get_Substr1(s_CtMobile_2, 8)

        Dim rst As String = String.Concat(s_CtMobile_1, "-", s_CtMobile_2)
        If rst = "-" Then rst = ""
        If rst <> "" AndAlso rst.EndsWith("-") Then rst = rst.Remove(rst.Length - 1)
        Return rst
    End Function

    ''' <summary>只有檢核有誤才算異常:false, (其餘狀況)檢核正確為:true</summary>
    ''' <param name="dtDesc"></param>
    ''' <returns></returns>
    Public Shared Function CHK_WEEKDAY1(ByRef dtDesc As DataTable, ByRef dtOnClass As DataTable, ByRef hMsg1 As Hashtable) As Boolean
        '二、 為確認單位所選「課程大綱日期」與「上課時間之星期」是否正確，於基本儲存、正式儲存時，
        '增加「課程大綱日期」與「上課時間之星期」之卡控檢核，星期卡控
        '檢查上方課程大綱之所有選擇日期， 是否包含在下方所選的星期內(如圖二)
        '如有不同的， 增加提醒機制： 所選的「課程大綱日期」與「上課時段之星期」不符合。
        Dim rst As Boolean = True
        'If dtDesc Is Nothing OrElse dtOnClass Is Nothing Then Return rst '(任1資料不全，則沒有判斷的必要)
        If dtNODATA(dtDesc) OrElse dtNODATA(dtOnClass) Then Return rst '(任1資料不全，則沒有判斷的必要)
        TIMS.CHG_dtReadOnly(dtDesc)
        TIMS.CHG_dtReadOnly(dtOnClass)
        If hMsg1 Is Nothing Then hMsg1 = New Hashtable
        hMsg1.Clear()
        For Each drDesc As DataRow In dtDesc.Rows
            If Not drDesc.RowState = DataRowState.Deleted Then
                If $"{drDesc("STRAINDATE")}" <> "" AndAlso Not CHK_WEEKDAY2(drDesc("STRAINDATE"), dtOnClass) Then
                    Dim d_STRAIN As Date = drDesc("STRAINDATE")
                    hMsg1.Add("STRAINDATE", Cdate3(d_STRAIN))
                    hMsg1.Add("WEEKS", GetDayOfWeek(CInt(d_STRAIN.DayOfWeek)))
                    '(有任一筆資料比對有誤，返回false)
                    Return False
                End If
            End If
        Next
        Return rst
    End Function

    ''' <summary>檢核日期／星期是否包含，有包含:true 沒有:false</summary>
    ''' <param name="d_STRAIN"></param>
    ''' <param name="dtOnClass"></param>
    ''' <returns></returns>
    Public Shared Function CHK_WEEKDAY2(ByRef d_STRAIN As Date, ByRef dtOnClass As DataTable) As Boolean
        If dtOnClass Is Nothing OrElse dtOnClass.Rows.Count = 0 Then Return True '(查無比對資料為true)
        'If Convert.ToString(d_STRAIN)="" Then Return False '(傳入無用日期為false) '基本上不可能有空日期
        Dim iCHEKC As Integer = 0
        For Each drOnClass As DataRow In dtOnClass.Rows
            If Not drOnClass.RowState = DataRowState.Deleted Then
                iCHEKC += 1
                '(星期比對) 中文字的比對
                If $"{drOnClass("WEEKS")}" <> "" AndAlso GetDayOfWeek(CINT1(d_STRAIN.DayOfWeek)) = $"{drOnClass("WEEKS")}" Then
                    '非空白且比對成功有包含值 返回true
                    Return True
                End If
            End If
        Next
        '(查無符合資料，異常為false) '(沒有比對任何資料為TRUE'(有比對且不符合為FALSE)
        Return If(iCHEKC = 0, True, False)
    End Function

