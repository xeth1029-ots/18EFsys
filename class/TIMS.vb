        'SD_01_004_dbl.aspx
        'STUD_ENTERDOUBLE
        'http://163.29.199.211/TIMSWS/timsService1.asmx
        'Dim timsSer1 As New timsService1.timsService1

        'STUD_ENTERDOUBLE (排程產生)
        Dim sql As String = ""
        sql &= " SELECT DISTINCT b.NAME" & vbCrLf
        sql &= " FROM STUD_ENTERDOUBLE a" & vbCrLf
        sql &= " JOIN STUD_ENTERTEMP2 b on b.ESETID=a.ESETID and b.IDNO=a.IDNO" & vbCrLf
