    ''' <summary> 取得學員資料。依SOCID </summary>
    ''' <param name="SOCID"></param>
    ''' <param name="tConn "></param>
    ''' <returns></returns>
    Public Shared Function Get_StudData(ByVal SOCID As String, ByVal tConn As SqlConnection) As DataRow
        Dim Rst As DataRow = Nothing
        SOCID = ClearSQM(SOCID)
        If SOCID = "" Then Return Rst

        Call OpenDbConn(tConn)
        Dim oDt As New DataTable
        Dim sql As String = ""
        sql &= " SELECT S.PLANNAME, S.ORGNAME , S.CLASSCNAME, S.ORGID" & vbCrLf
        sql &= " ,S.RID, S.PLANID, S.COMIDNO, S.SEQNO, S.OCID" & vbCrLf
        sql &= " ,S.SOCID, S.IDNO, S.BIRTHDAY" & vbCrLf
        sql &= " ,s.NAME STDNAME ,s.STUDID2" & vbCrLf 'dbo.FN_CSTUDID2(CS.STUDENTID) STUDID2
        sql &= " FROM dbo.V_STUDENTINFO S WHERE s.SOCID=@SOCID" & vbCrLf
        Using oCmd As New SqlCommand(sql, tConn)
            With oCmd
                .Parameters.Clear()
                .Parameters.Add("SOCID", SqlDbType.Int).Value = CINT1(SOCID)
                oDt.Load(.ExecuteReader())
            End With
        End Using
        If dtHaveDATA(oDt) Then Rst = oDt.Rows(0)
        Return Rst
    End Function

