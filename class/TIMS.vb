    '取得此次個人訓練費用撥款數
    Public Shared Function Get_StudTrainCostT(ByVal SOCID As String, ByVal NoTimes As String, ByVal tConn As SqlConnection) As String
        Dim Post As String = ""
        Dim dt As DataTable
        Dim dr As DataRow
        Dim sql As String = ""
        sql &= " SELECT t.COST, t.TIMES, s.RATE" & vbCrLf
        sql &= " FROM STUD_TRAINCOSTT t" & vbCrLf
        sql &= " JOIN STUD_TRAINCOSTD d ON t.SOCID=d.SOCID" & vbCrLf
        sql &= " JOIN STUD_TRAINCOST s ON d.OCID=s.OCID AND t.Times=s.Times" & vbCrLf
        sql &= $" WHERE t.SOCID={SOCID} AND t.TIMES !={NoTimes}"
        sql &= " ORDER BY t.TIMES "
        dt = DbAccess.GetDataTable(sql, tConn)
        If dt.Rows.Count > 0 Then
            For i As Integer = 0 To dt.Rows.Count - 1
                dr = dt.Rows(i)
                If i = dt.Rows.Count - 1 Then
                    Post &= $"第{dr("TIMES")}次撥款:{dr("COST")} ( {dr("RATE")}% )"
                Else
                    Post &= $"第{dr("TIMES")}次撥款:{dr("COST")} ( {dr("RATE")}% ){vbCrLf}"
                End If
            Next
        End If
        Return Post
    End Function

    '取得此次個人訓練費用比率表撥款次數/百分比比率(參數為次數)
    Public Shared Function Get_StudTrainCostTimes(ByVal OCID As String, ByVal sTimes As String, ByVal tConn As SqlConnection) As String
        Dim CostTimes As String = ""
        Dim sql As String = ""
        Select Case sTimes
            Case "T"
                sql = $" SELECT * FROM STUD_TRAINCOST WHERE OCID={OCID} ORDER BY TIMES DESC "
                Dim dr As DataRow = DbAccess.GetOneRow(sql, tConn)
                If dr Is Nothing Then
                    CostTimes = "1"
                Else
                    If dr("APPLIED").ToString = cst_YES Then
                        CostTimes = CInt(dr("TIMES").ToString) + 1
                    Else
                        CostTimes = CInt(dr("TIMES").ToString)
                    End If
                End If
            Case Else
                sql = $" SELECT RATE FROM STUD_TRAINCOST WHERE OCID={OCID} AND Times='{sTimes}'"
                Dim oRate As Object = DbAccess.ExecuteScalar(sql, tConn)
                CostTimes = "0"
                If Not IsDBNull(oRate) Then CostTimes = Convert.ToString(oRate)
        End Select
        Return CostTimes
    End Function

    '取得學員連續參訓次數
    Public Shared Function Get_StudCount(IDNO As String, PlanYear As String, STdate1 As String, STdate2 As String, DistID As String, ByRef conn As SqlConnection) As String
        '參考 SD_01_001_old.aspx，請確認傳入參數 IDNO 為必填喔
        Dim AllCnt As Integer = 0
        Dim sCnt As String = ""
        Dim sql As String = ""
        sql = " SELECT COUNT(1) CNT FROM StdAll WHERE SID IN ('" & IDNO & "')" & vbCrLf
        If PlanYear <> "" Then sql &= " AND YEARS='" & PlanYear & "'" & vbCrLf
        If STdate1 <> "" Then sql &= " AND SDATE >= " & To_date(STdate1) & "" & vbCrLf
        If STdate2 <> "" Then sql &= " AND SDATE <= " & To_date(STdate2) & "" & vbCrLf
        If DistID <> "" Then sql &= " AND DISTID IN (" & GetArrayStr(DistID) & ")" & vbCrLf
        sCnt = DbAccess.ExecuteScalar(sql, conn)
        If Not sCnt Is Nothing Then AllCnt += sCnt

        sql = " SELECT COUNT(1) CNT FROM HISTORY_STUDENTINFO93 WHERE IDNO IN ('" & IDNO & "')" & vbCrLf
        If PlanYear <> "" Then sql &= " AND DATEPART(YEAR, SDATE)='" & PlanYear & "'" & vbCrLf
        If STdate1 <> "" Then sql &= " AND SDATE >= " & To_date(STdate1) & "" & vbCrLf
        If STdate2 <> "" Then sql &= " AND SDATE <= " & To_date(STdate2) & "" & vbCrLf
        If DistID <> "" Then sql &= " AND DISTID IN (" & GetArrayStr(DistID) & ")" & vbCrLf
        sCnt = DbAccess.ExecuteScalar(sql, conn)
        If Not sCnt Is Nothing Then AllCnt += sCnt

        sql = " SELECT COUNT(1) CNT FROM V_STUDENTINFO WHERE IDNO IN ('" & IDNO & "')" & vbCrLf
        If PlanYear <> "" Then sql &= " AND Years='" & PlanYear & "'" & vbCrLf
        If STdate1 <> "" Then sql &= " AND STdate >= " & To_date(STdate1) & "" & vbCrLf
        If STdate2 <> "" Then sql &= " AND STdate <= " & To_date(STdate2) & "" & vbCrLf
        If DistID <> "" Then sql &= " AND DistID IN (" & GetArrayStr(DistID) & ")" & vbCrLf
        sCnt = DbAccess.ExecuteScalar(sql, conn)
        If Not sCnt Is Nothing Then AllCnt += sCnt
        Return AllCnt
    End Function

