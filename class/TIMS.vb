    ''' <summary>當年度/申請階段之所有已送審班級清單(【審核狀態】：班級審核中) dt</summary>
    ''' <param name="oConn"></param>
    ''' <param name="S1Parms"></param>
    ''' <returns></returns>
    Public Shared Function GET_CLASS2S_BIdt(ByRef oConn As SqlConnection, ByRef S1Parms As Hashtable) As DataTable
        Dim dtPP As DataTable = Nothing
        If S1Parms Is Nothing Then Return dtPP

        Dim vBCID As String = GetMyValue2(S1Parms, "BCID")
        Dim vTPLANID As String = GetMyValue2(S1Parms, "TPLANID")
        Dim vRID As String = GetMyValue2(S1Parms, "RID")
        Dim vPLANID As String = GetMyValue2(S1Parms, "PLANID")

        '任1資訊為空異常
        If vTPLANID = "" OrElse vRID = "" OrElse vPLANID = "" Then Return dtPP

        If Cst_TPlanID54.IndexOf(vTPLANID) > -1 Then
            Dim vPCS_IN As String = GetMyValue2(S1Parms, "PCS_IN")
            Dim vPCS_NOT_IN As String = GetMyValue2(S1Parms, "PCS_NOT_IN")

            Dim sParms1 As New Hashtable From {{"TPLANID", vTPLANID}, {"RID", vRID}, {"PLANID", vPLANID}}
            Dim sSql_WC1 As String = ""
            If vBCID <> "" AndAlso IsNumeric2(vBCID) Then
                sParms1.Add("BCID", vBCID)
                sSql_WC1 = " WITH WC1 AS (SELECT b.PLANID,b.COMIDNO,b.SEQNO FROM ORG_BIDCASEPI b WHERE b.BCID=@BCID)" & vbCrLf
            End If

            Dim sSql As String = ""
            sSql = sSql_WC1
            sSql &= " SELECT pp.PLANID,pp.COMIDNO,pp.SEQNO,pp.ORGNAME,pp.DISTNAME,pp.RID" & vbCrLf
            sSql &= " ,pp.DISTANCE,pp.STDATE,pp.FTDATE" & vbCrLf
            sSql &= " ,dbo.FN_CDATE1B(pp.STDATE) STDATE_ROC" & vbCrLf
            sSql &= " ,dbo.FN_CDATE1B(pp.FTDATE) FTDATE_ROC" & vbCrLf
            sSql &= " ,pp.PSNO28,pp.PCS,pp.OCID,pp.DISTID,pp.APPSTAGE,pp.ORGID,pp.CLASSCNAME2" & vbCrLf
            sSql &= " ,CONCAT( pp.CLASSCNAME2,'(',dbo.FN_CDATE1B(pp.STDATE),'~',dbo.FN_CDATE1B(pp.FTDATE),')') CLASSCNAME3" & vbCrLf
            sSql &= " ,pp.TransFlag,pp.IsApprPaper,pp.AppliedResult,pp.RESULTBUTTON" & vbCrLf
            If sSql_WC1 <> "" AndAlso vBCID <> "" AndAlso IsNumeric2(vBCID) Then
                sSql &= " FROM WC1 bc" & vbCrLf
                sSql &= " JOIN VIEW2B pp ON pp.PLANID=bc.PLANID AND pp.COMIDNO=bc.COMIDNO AND pp.SEQNO=bc.SEQNO" & vbCrLf
                sSql &= " WHERE pp.IsApprPaper='Y'" & vbCrLf
            Else
                sSql &= " FROM VIEW2B pp" & vbCrLf
                sSql &= " WHERE pp.TransFlag='N' AND pp.IsApprPaper='Y' AND pp.AppliedResult IS NULL AND pp.RESULTBUTTON IS NULL" & vbCrLf
            End If
            sSql &= " AND pp.TPLANID=@TPLANID" & vbCrLf
            sSql &= " AND pp.RID=@RID" & vbCrLf
            sSql &= " AND pp.PLANID=@PLANID" & vbCrLf
            If vPCS_IN <> "" Then sSql &= String.Concat(" AND concat(pp.PLANID,'x',pp.COMIDNO,'x',pp.SEQNO) IN (", vPCS_IN, ")") & vbCrLf
            If vPCS_NOT_IN <> "" Then sSql &= String.Concat(" AND concat(pp.PLANID,'x',pp.COMIDNO,'x',pp.SEQNO) NOT IN (", vPCS_NOT_IN, ")") & vbCrLf
            sSql &= " ORDER BY pp.RID,pp.STDATE,pp.CLASSCNAME2" & vbCrLf
            dtPP = DbAccess.GetDataTable(sSql, oConn, sParms1)

        ElseIf Cst_TPlanID28.IndexOf(vTPLANID) > -1 Then
            Dim vAPPSTAGE As String = GetMyValue2(S1Parms, "APPSTAGE")
            If vAPPSTAGE = "" Then Return dtPP

            Dim sParms1 As New Hashtable From {{"TPLANID", vTPLANID}, {"RID", vRID}, {"PLANID", vPLANID}, {"APPSTAGE", vAPPSTAGE}}
            Dim sSql_WC1 As String = ""
            If vBCID <> "" AndAlso IsNumeric2(vBCID) Then
                sParms1.Add("BCID", CINT1(vBCID))
                sSql_WC1 = " WITH WC1 AS (SELECT b.PLANID,b.COMIDNO,b.SEQNO FROM ORG_BIDCASEPI b WHERE b.BCID=@BCID)" & vbCrLf
            End If

            Dim sSql As String = ""
            sSql = sSql_WC1
            sSql &= " SELECT pp.PLANID,pp.COMIDNO,pp.SEQNO,pp.ORGNAME,pp.DISTNAME,pp.RID" & vbCrLf
            sSql &= " ,pp.DISTANCE,pp.STDATE,pp.FTDATE" & vbCrLf
            sSql &= " ,dbo.FN_CDATE1B(pp.STDATE) STDATE_ROC" & vbCrLf
            sSql &= " ,dbo.FN_CDATE1B(pp.FTDATE) FTDATE_ROC" & vbCrLf
            sSql &= " ,pp.PCS,pp.OCID,pp.DISTID,pp.APPSTAGE,pp.ORGID,pp.CLASSCNAME2" & vbCrLf
            sSql &= " ,pp.TransFlag,pp.IsApprPaper,pp.AppliedResult,pp.RESULTBUTTON" & vbCrLf
            If sSql_WC1 <> "" AndAlso vBCID <> "" AndAlso IsNumeric2(vBCID) Then
                sSql &= " FROM WC1 bc" & vbCrLf
                sSql &= " JOIN VIEW2B pp ON pp.PLANID=bc.PLANID AND pp.COMIDNO=bc.COMIDNO AND pp.SEQNO=bc.SEQNO" & vbCrLf
                'sSql &= " WHERE pp.TransFlag='N' AND pp.IsApprPaper='Y' AND pp.AppliedResult IS NULL AND pp.RESULTBUTTON IS NULL" & vbCrLf
                sSql &= " WHERE pp.IsApprPaper='Y'" & vbCrLf
            Else
                sSql &= " FROM VIEW2B pp" & vbCrLf
                sSql &= " WHERE pp.TransFlag='N' AND pp.IsApprPaper='Y' AND pp.AppliedResult IS NULL AND pp.RESULTBUTTON IS NULL" & vbCrLf
            End If
            sSql &= " AND pp.TPLANID=@TPLANID AND pp.RID=@RID" & vbCrLf
            sSql &= " AND pp.PLANID=@PLANID AND pp.APPSTAGE=@APPSTAGE" & vbCrLf
            sSql &= " ORDER BY pp.RID,pp.STDATE,pp.CLASSCNAME2" & vbCrLf
            'sSql &= " WHERE pp.ISAPPRPAPER='Y' AND pp.AppliedResult IS NULL AND pp.RESULTBUTTON IS NULL" & vbCrLf
            'sSql &= " WHERE a.TPLANID=@TPlanID AND YEARS='2023' AND APPSTAGE=1 AND DISTID='001' AND ORGID=5321" & vbCrLf
            dtPP = DbAccess.GetDataTable(sSql, oConn, sParms1)

        End If
        Return dtPP
    End Function

    ''' <summary>帶入當年度/申請階段之所有已送審班級清單(【審核狀態】：班級審核中)。</summary>
    ''' <param name="dtPP"></param>
    ''' <param name="outTYPE"></param>
    ''' <returns></returns>
    Public Shared Function GET_CLASSNAME2S_BI(ByRef dtPP As DataTable, ByVal outTYPE As String) As String
        'outTYPE: CLSNM,PCSVAL,PP_DISTANCE
        Dim str_RST As String = ""
        'If oConn Is Nothing OrElse Not OpenDbConn(oConn) Then Return str_RST
        'Dim dtPP As DataTable=GET_CLASS2S_BIdt(oConn, S1Parms)
        If dtPP Is Nothing OrElse dtPP.Rows.Count = 0 Then Return ""
        For Each drP1 As DataRow In dtPP.Rows
            If outTYPE = cst_outTYPE_CLSNM Then
                str_RST &= String.Concat(If(str_RST <> "", vbCrLf, ""), drP1("CLASSCNAME2"), "(", drP1("STDATE_ROC"), ")")
            ElseIf outTYPE = cst_outTYPE_PCSVAL Then
                str_RST &= String.Concat(If(str_RST <> "", ",", ""), drP1("PCS"))
            ElseIf outTYPE = cst_outTYPE_PP_DISTANCE Then
                str_RST &= String.Concat(If(str_RST <> "", ",", ""), drP1("DISTANCE"))
            End If
        Next
        Return str_RST
    End Function

