    ''' <summary>審查幕僚意見開關機制(產業人才專用)／PLAN_STAFFOPINSWITCH</summary>
    ''' <param name="oConn"></param>
    ''' <param name="rPMS"></param>
    ''' <returns></returns>
    Public Shared Function CAN_STAFFOPINSWITCH_1(ByRef oConn As SqlConnection, ByRef rPMS As Hashtable) As Boolean
        'view-source:https://localhost:44383/TC/01/TC_01_021?ID=928
        '審查幕僚意見開關機制(產業人才專用)／PLAN_STAFFOPINSWITCH
        Dim vYEARS As String = GetMyValue2(rPMS, "YEARS")
        Dim vAPPSTAGE As String = GetMyValue2(rPMS, "APPSTAGE")
        If vYEARS = "" OrElse vAPPSTAGE = "" Then Return False

        OpenDbConn(oConn)
        Dim dt As New DataTable
        Dim sSql As String = ""
        sSql &= " SELECT a.YEARS,a.APPSTAGE,a.SOPENDATE,a.FOPENDATE" & vbCrLf
        sSql &= " ,concat(format(a.SOPENDATE,'yyyy/MM/dd HH:mm'),'~',format(a.FOPENDATE,'yyyy/MM/dd HH:mm')) SFOPENDATE" & vbCrLf
        sSql &= " ,concat(dbo.FN_CDATE1C(a.SOPENDATE),'~',dbo.FN_CDATE1C(a.FOPENDATE)) SFOPENDATE_ROC" & vbCrLf
        sSql &= " FROM PLAN_STAFFOPINSWITCH a" & vbCrLf
        sSql &= " WHERE DATEDIFF(MI,a.SOPENDATE,GETDATE())>=0 AND DATEDIFF(MI,GETDATE(),a.FOPENDATE)>0" & vbCrLf
        sSql &= " AND a.YEARS=@YEARS AND a.APPSTAGE=@APPSTAGE" & vbCrLf
        Dim sCmd As New SqlCommand(sSql, oConn)
        With sCmd
            .Parameters.Clear()
            .Parameters.Add("YEARS", SqlDbType.VarChar).Value = vYEARS
            .Parameters.Add("APPSTAGE", SqlDbType.VarChar).Value = vAPPSTAGE
            dt.Load(.ExecuteReader())
        End With
        If dt Is Nothing OrElse dt.Rows.Count = 0 Then Return False
        rPMS.Add("SFOPENDATE", dt.Rows(0)("SFOPENDATE"))
        rPMS.Add("SFOPENDATE_ROC", dt.Rows(0)("SFOPENDATE_ROC"))
        Return True
    End Function

