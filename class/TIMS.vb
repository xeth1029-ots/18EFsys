    ''' <summary> 取得 DataRow 文字檔案 </summary>
    ''' <param name="dt"></param>
    ''' <param name="dr"></param>
    ''' <returns></returns>
    Public Shared Function GetDataRowString(ByRef dt As DataTable, ByRef dr As DataRow) As String
        If dt Is Nothing Then Return ""
        If dr Is Nothing Then Return ""

        Const cst_datef1 As String = "yyyy-MM-dd HH:mm:ss.fff"
        Const cst_datef2 As String = "yyyy-MM-dd"
        '異動後資料
        Dim AfterValues As String = ""
        For i As Integer = 0 To dt.Columns.Count - 1 '所有欄位
            'flag_isEmpty=String.IsNullOrEmpty(dr(dt.Columns(i).ColumnName))
            Dim flag_isEmpty As Boolean = IsDBNull(dr(dt.Columns(i).ColumnName))
            Dim flag_isDate As Boolean = If(Not flag_isEmpty, IsDate1(dr(dt.Columns(i).ColumnName)), False) 'System.Type.GetType("System.DateTime") '"System.DateTime"
            Dim flag_isDateTime As Boolean = If(flag_isDate, IsDateTime1(dr(dt.Columns(i).ColumnName)), False)

            AfterValues &= String.Concat(If(AfterValues <> "", ",", ""), String.Format("{0}='{1}'", dt.Columns(i).ColumnName.ToUpper, If(flag_isDate, If(flag_isDateTime, Convert.ToDateTime(dr(dt.Columns(i).ColumnName)).ToString(cst_datef1), Convert.ToDateTime(dr(dt.Columns(i).ColumnName)).ToString(cst_datef2)), Convert.ToString(dr(dt.Columns(i).ColumnName)))), vbCrLf)
        Next
        Return AfterValues
    End Function

