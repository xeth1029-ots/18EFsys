    ''' <summary>
    ''' 讀取Excel文件並將其內容轉換為DataTable。
    ''' </summary>
    ''' <param name="FullfileNM">Excel文件的路徑。</param>
    ''' <returns>包含Excel資料的DataTable。</returns>
    Public Shared Function ReadExceldtT1(ByVal FullfileNM As String, ByRef Errmag As String) As DataTable
        Dim dtT1 As New DataTable()
        Dim workbook As IWorkbook = Nothing

        Try
            Using file As New FileStream(FullfileNM, FileMode.Open, FileAccess.Read)
                ' 自動識別Excel類型
                If FullfileNM.ToLower().EndsWith(".xlsx") Then 'xlsx文件
                    workbook = New XSSFWorkbook(file)
                ElseIf FullfileNM.ToLower().EndsWith(".xls") Then 'xls文件
                    workbook = New HSSFWorkbook(file)
                Else
                    Errmag &= "文件格式有誤。" & vbCrLf
                    Return Nothing
                End If

                ' 獲取第一個工作表
                Dim sheet As ISheet = workbook.GetSheetAt(0)
                If sheet Is Nothing Then Return dtT1

                ' 讀取標題行並建立 DataTable 的欄位
                Dim headerRow As IRow = sheet.GetRow(0)
                If headerRow IsNot Nothing Then
                    For col As Integer = 0 To headerRow.LastCellNum - 1
                        Dim cell As ICell = headerRow.GetCell(col)
                        If cell IsNot Nothing AndAlso Not String.IsNullOrWhiteSpace(cell.ToString()) Then
                            dtT1.Columns.Add(cell.ToString().Trim())
                        Else
                            ' 處理空標題欄位
                            dtT1.Columns.Add("Column" & (col + 1).ToString())
                        End If
                    Next
                End If

                ' 遍歷數據行（從第二行開始）和列
                For row As Integer = 1 To sheet.LastRowNum
                    Dim currentRow As IRow = sheet.GetRow(row)
                    If currentRow IsNot Nothing Then
                        Dim newRow As DataRow = dtT1.NewRow()
                        Dim fghasData As Boolean = False
                        For col As Integer = 0 To Math.Min(currentRow.LastCellNum - 1, dtT1.Columns.Count - 1)
                            Dim cell As ICell = currentRow.GetCell(col)
                            If cell IsNot Nothing Then
                                Select Case cell.CellType
                                    Case CellType.Numeric
                                        newRow(col) = cell.NumericCellValue.ToString()
                                        fghasData = True
                                    Case CellType.String
                                        newRow(col) = cell.StringCellValue
                                        fghasData = True
                                    Case CellType.Boolean
                                        newRow(col) = cell.BooleanCellValue.ToString()
                                        fghasData = True
                                    Case CellType.Error
                                        newRow(col) = cell.ErrorCellValue.ToString()
                                        fghasData = True
                                    Case CellType.Formula
                                        Try
                                            Dim evaluator As IFormulaEvaluator = WorkbookFactory.CreateFormulaEvaluator(workbook)
                                            Dim formulaResult As CellValue = evaluator.Evaluate(cell)
                                            newRow(col) = formulaResult.StringValue
                                            fghasData = True
                                        Catch ex As Exception
                                            LOG.Warn(ex.Message, ex)
                                            'Console.WriteLine("公式計算錯誤: " & ex.Message)
                                            newRow(col) = cell.CellFormula
                                            fghasData = True
                                        End Try
                                    Case Else
                                        newRow(col) = DBNull.Value
                                End Select
                            End If
                        Next
                        If fghasData Then dtT1.Rows.Add(newRow)
                    End If
                Next
            End Using
        Catch ex As Exception
            Dim V_GUID As String = Guid.NewGuid().ToString()
            LOG.Warn(ex.Message, ex)
            'LOG.Error(ex.Message, ex) 'Dim attach As Attachment=getAttach1(Fullfilename) '找出log檔案
            'Dim s_RATct As String = Get_ReadAllText(FullfileNM)
            'Dim s_Ext As String = Path.GetExtension(FullfileNM'If(s_RATct <> "", Path.GetExtension(FullfileNM), "")
            Dim strErrmsg As String = "#ReadExceldtT1" & vbCrLf
            strErrmsg &= GetErrorMsgSys() '取得錯誤資訊寫入
            strErrmsg &= String.Concat("FullfileNM:", FullfileNM, vbCrLf, "[", V_GUID, "]", vbCrLf, "ex.Message:", ex.Message, vbCrLf)
            WriteTraceLog(strErrmsg, ex)

            Errmag &= ex.Message & vbCrLf
            LOG.Error(Errmag, ex)
            'Console.WriteLine("發生錯誤: " & ex.Message)
            '可以在此處返回 Nothing 或包含錯誤資訊的 DataTable
            'Dim s_ERRMSG1 As String = String.Concat("ReadExcelToDataTable:", vbCrLf, ex.Message, vbCrLf)
            'WriteTraceLog(s_ERRMSG1, ex) 'Throw ex
            Return Nothing
        End Try

        Return dtT1
    End Function

