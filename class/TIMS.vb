    ''' <summary>將序號與資料表最大值同步(LEN(ESERNUM),8)</summary>
    ''' <param name="oConn"></param>
    ''' <returns></returns>
    Public Shared Function UPDATE_MAX_ESERNUM_SEQ2(oConn As SqlConnection) As Boolean
        Dim TableSeq As String = "STUD_ENTERTYPE2_ESERNUM_SEQ2"

        Using oTrans As SqlTransaction = oConn.BeginTransaction()
            Try
                ' 步驟 1: 在交易中取得目標資料表的最大序號(LEN(ESERNUM)<8)，並處理 NULL 值
                Dim sqlMaxId As String = "SELECT ISNULL(MAX(ESERNUM), 0) FROM dbo.STUD_ENTERTYPE2 WITH(NOLOCK) WHERE LEN(ESERNUM)<8"
                Dim iRst_eSerNum_MaxID As Integer = CInt(New SqlCommand(sqlMaxId, oConn, oTrans).ExecuteScalar())
                If iRst_eSerNum_MaxID <= 0 Then Return False

                ' 步驟 2: 鎖定並取得 SYS_AUTONUM 的當前值 ' 使用 OUTPUT 子句可以一次完成 UPDATE 和 SELECT
                Dim sqlUpdate As String = "UPDATE SYS_AUTONUM SET CURVAL=@MAXID, MTIME=GETDATE() OUTPUT inserted.CURVAL WHERE TABLENAME=@TABLENAME"
                Using UsCmd As New SqlCommand(sqlUpdate, oConn, oTrans)
                    UsCmd.Parameters.AddWithValue("@MAXID", iRst_eSerNum_MaxID)
                    UsCmd.Parameters.AddWithValue("@TABLENAME", TableSeq)
                    Dim updatedCurVal As Object = UsCmd.ExecuteScalar()

                    If IsNothing(updatedCurVal) Then
                        ' 步驟 3: 如果沒有記錄，則插入一筆新記錄
                        Dim sqlInsert As String = "INSERT INTO SYS_AUTONUM (TABLENAME, CURVAL, MTIME) VALUES (@TABLENAME, @CURVAL, GETDATE())"
                        Using iCmd As New SqlCommand(sqlInsert, oConn, oTrans)
                            iCmd.Parameters.AddWithValue("@TABLENAME", TableSeq)
                            iCmd.Parameters.AddWithValue("@CURVAL", iRst_eSerNum_MaxID)
                            iCmd.ExecuteNonQuery()
                        End Using
                    End If
                End Using

                ' 步驟 4: 提交交易
                oTrans.Commit()
                Return True

            Catch ex As Exception
                LOG.Warn(ex.Message, ex)
                oTrans.Rollback() ' 將例外重新拋出，讓呼叫者知道操作失敗
                Throw
            End Try
        End Using
    End Function

