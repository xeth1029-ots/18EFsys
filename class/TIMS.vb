    ''' <summary>SAVE ORG_BIDCASEFL_PI</summary>
    ''' <param name="oConn"></param>
    ''' <param name="rPMS"></param>
    Public Shared Sub SAVE_ORG_BIDCASEFL_PI(ByRef MyPage As Page, ByRef oConn As SqlConnection, rPMS As Hashtable)
        Dim iBCFID As Integer = GetMyValue2(rPMS, "BCFID", cst_oType_obj)
        Dim iBCID As Integer = GetMyValue2(rPMS, "BCID", cst_oType_obj)
        Dim iKBSID As Integer = GetMyValue2(rPMS, "KBSID", cst_oType_obj)
        Dim iBCPID As Integer = GetMyValue2(rPMS, "BCPID", cst_oType_obj)
        Dim vUploadPath As String = GetMyValue2(rPMS, "UploadPath")
        Dim vFILENAME1 As String = GetMyValue2(rPMS, "FILENAME1")
        Dim vSRCFILENAME1 As String = GetMyValue2(rPMS, "SRCFILENAME1")
        Dim vMODIFYACCT As String = GetMyValue2(rPMS, "MODIFYACCT")
        If vMODIFYACCT = "" Then Return

        Dim iBCFPID As Integer = 0
        Dim sParms1 As New Hashtable From {{"BCFID", iBCFID}, {"BCID", iBCID}, {"KBSID", iKBSID}, {"BCPID", iBCPID}}
        Dim sSql1 As String = "SELECT * FROM ORG_BIDCASEFL_PI WHERE BCFID=@BCFID AND BCID=@BCID AND KBSID=@KBSID AND BCPID=@BCPID"
        Dim dtFLPI As DataTable = DbAccess.GetDataTable(sSql1, oConn, sParms1)
        If dtFLPI.Rows.Count = 0 Then
            'If iBCFID <= 0 Then Return
            iBCFPID = DbAccess.GetNewId(oConn, "ORG_BIDCASEFL_PI_BCFPID_SEQ,ORG_BIDCASEFL_PI,BCFPID")
            Dim iParms As New Hashtable From {
                {"BCFPID", iBCFPID},
                {"BCFID", iBCFID},
                {"BCID", iBCID},
                {"KBSID", iKBSID},
                {"BCPID", iBCPID},
                {"FILENAME1", vFILENAME1},
                {"SRCFILENAME1", vSRCFILENAME1},
                {"MODIFYACCT", vMODIFYACCT}
            }
            Dim isSql As String = ""
            isSql &= " INSERT INTO ORG_BIDCASEFL_PI(BCFPID, BCFID, BCID, KBSID, BCPID, FILENAME1, SRCFILENAME1, MODIFYACCT, MODIFYDATE)" & vbCrLf
            isSql &= " VALUES(@BCFPID,@BCFID,@BCID,@KBSID,@BCPID,@FILENAME1,@SRCFILENAME1,@MODIFYACCT,GETDATE())" & vbCrLf
            DbAccess.ExecuteNonQuery(isSql, oConn, iParms)
        Else
            Dim drFLPI As DataRow = dtFLPI.Rows(0)
            iBCFPID = CINT1(drFLPI("BCFPID"))
            Dim OldvFILENAME1 As String = Convert.ToString(drFLPI("FILENAME1"))
            'Dim OldvSRCFILENAME1 As String=Convert.ToString(drFLPI("SRCFILENAME1"))
            '刪除舊檔案(放在UPDATA 的後面表示已經處理完成DB了) OldvFILENAME1 <> ""
            Dim fg_CAN_DELETE_OLDFILE As Boolean = (vUploadPath <> "" AndAlso vFILENAME1 <> "" AndAlso OldvFILENAME1 <> "" AndAlso vFILENAME1 <> OldvFILENAME1)
            If fg_CAN_DELETE_OLDFILE Then
                Try
                    '刪除舊檔案
                    MyFileDelete(MyPage.Server.MapPath($"{vUploadPath}{OldvFILENAME1}"))
                Catch ex As Exception
                    LOG.Warn(ex.Message, ex)
                    'Common.MessageBox(Me, cst_errMsg_2) 'Common.MessageBox(Me, ex.ToString)
                    Dim strErrmsg As String = String.Concat(ex.Message, vbCrLf, "ex.ToString:", ex.ToString, vbCrLf)
                    strErrmsg &= String.Concat("vUploadPath: ", vUploadPath, vbCrLf)
                    strErrmsg &= String.Concat("vFILENAME1: ", vFILENAME1, vbCrLf)
                    strErrmsg &= String.Concat("OldvFILENAME1: ", OldvFILENAME1, vbCrLf)
                    strErrmsg &= String.Concat("Server.MapPath(String.Concat(vUploadPath, OldvFILENAME1)): ", MyPage.Server.MapPath($"{vUploadPath}{OldvFILENAME1}"), vbCrLf)
                    WriteTraceLog(MyPage, ex, strErrmsg)
                End Try
            End If

            Dim uParms As New Hashtable From {{"FILENAME1", vFILENAME1}, {"SRCFILENAME1", vSRCFILENAME1}, {"MODIFYACCT", vMODIFYACCT}, {"BCFPID", iBCFPID}}
            Dim usSql As String = ""
            usSql &= " UPDATE ORG_BIDCASEFL_PI" & vbCrLf
            usSql &= " SET FILENAME1=@FILENAME1,SRCFILENAME1=@SRCFILENAME1,MODIFYACCT=@MODIFYACCT,MODIFYDATE=GETDATE()" & vbCrLf
            usSql &= " WHERE BCFPID=@BCFPID" & vbCrLf
            DbAccess.ExecuteNonQuery(usSql, oConn, uParms)
        End If
    End Sub

    ''' <summary>取得班級申請資料</summary>
    ''' <param name="oConn"></param>
    ''' <param name="vBCID"></param>
    ''' <returns></returns>
    Public Shared Function GET_ORG_BIDCASEFL_PI(oConn As SqlConnection, vBCID As String) As DataTable
        If (vBCID = "") Then Return Nothing
        Dim sPMS As New Hashtable From {{"BCID", CINT1(vBCID)}}
        Dim sSql As String = ""
        sSql &= " SELECT a.BCID,a.BCPID, a.PLANID,a.COMIDNO,a.SEQNO" & vbCrLf
        sSql &= " ,b.SRCFILENAME1,b.FILENAME1,b.KBSID" & vbCrLf
        sSql &= " ,b.BCFPID,pp.PSNO28" & vbCrLf
        sSql &= " ,b.MODIFYDATE,DATEDIFF(DAY,b.MODIFYDATE,GETDATE()) MODIFY_DAY,DATEDIFF(MI,b.MODIFYDATE,GETDATE()) MODIFY_MI" & vbCrLf
        sSql &= " FROM ORG_BIDCASEPI a" & vbCrLf
        sSql &= " JOIN ORG_BIDCASEFL_PI b on b.BCPID=a.BCPID" & vbCrLf
        sSql &= " JOIN ORG_BIDCASEFL f on f.BCFID=b.BCFID" & vbCrLf
        sSql &= " JOIN PLAN_PLANINFO pp on pp.PLANID=a.PLANID and pp.COMIDNO=a.COMIDNO and pp.SEQNO=a.SEQNO" & vbCrLf
        sSql &= " WHERE a.BCID=@BCID" & vbCrLf
        Dim dt As DataTable = DbAccess.GetDataTable(sSql, oConn, sPMS)
        Return dt
    End Function

    Public Shared Function GET_ORG_BIDCASEFL_PI3(oConn As SqlConnection, vBCID As String) As DataTable
        If (vBCID = "") Then Return Nothing
        Dim sPMS As New Hashtable From {{"BCID", CINT1(vBCID)}}
        Dim sSql As String = ""
        sSql &= " SELECT a.BCID,a.BCPID, a.PLANID,a.COMIDNO,a.SEQNO" & vbCrLf
        sSql &= " ,b.SRCFILENAME1,b.FILENAME1,b.KBSID,b.BCFP3ID,pp.PSNO28" & vbCrLf
        sSql &= " ,b.MODIFYDATE,DATEDIFF(DAY,b.MODIFYDATE,GETDATE()) MODIFY_DAY" & vbCrLf
