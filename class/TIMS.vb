    '取得登入帳號的登入資料。
    Public Shared Sub Get_LoginYear(ByRef obj As ListControl, ByVal sAccount As String, ByRef objconn As SqlConnection)
        Dim sql As String = ""
        sql &= " SELECT DISTINCT m.YEARS FROM VIEW_LOGINPLAN m" & vbCrLf
        sql &= " WHERE EXISTS (SELECT 'X' FROM AUTH_ACCRWPLAN a WHERE a.PLANID=m.PLANID AND a.ACCOUNT=@Account)" & vbCrLf
        sql &= " ORDER BY m.YEARS" & vbCrLf
        Call OpenDbConn(objconn)
        Dim dt As New DataTable
        Dim oCmd As New SqlCommand(sql, objconn)
        With oCmd
            .Parameters.Clear()
            .Parameters.Add("Account", SqlDbType.VarChar).Value = sAccount
            dt.Load(.ExecuteReader())
        End With
        With obj
            If dt.Rows.Count > 0 Then
                .DataSource = dt
                .DataTextField = "YEARS"
                .DataValueField = "YEARS"
                .DataBind()
            Else
                With obj
                    .Items.Clear()
                    If TypeOf obj Is DropDownList Then
                        .Items.Insert(0, New ListItem("此帳號無有效資料", ""))
                    End If
                End With
            End If
        End With
