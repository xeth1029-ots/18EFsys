    ''' <param name="ExamNo1"></param>
    ''' <param name="ExamOcid1"></param>
    ''' <param name="Trans"></param>
    ''' <returns></returns>
    Public Shared Function Get_NewExamNOt(ByVal PlanID As String,
                                          ByVal ExamNo1 As String,
                                          ByVal ExamOcid1 As String,
                                          ByRef Trans As SqlTransaction) As String
        '取出准考證號   Start
        Dim NewExamNO As String = String.Concat(ExamNo1, "001") '從001開始
        Dim sql As String = " SELECT MAX(CONVERT(INT,right(EXAMNO,3)))+1 MAXEXAMNO"
        sql &= String.Concat(" FROM STUD_ENTERTYPE WHERE LEN(ExamNo)=9 AND OCID1=", ExamOcid1, " AND PLANID=", PlanID)
        Dim dr As DataRow = DbAccess.GetOneRow(sql, Trans)

        Dim sql2 As String = " SELECT MAX(CONVERT(INT,right(EXAMNO,3))) + 1 MAXEXAMNO"
        sql2 &= String.Concat(" FROM STUD_ENTERTYPE WHERE LEN(ExamNo)!=9 AND OCID1=", ExamOcid1, " AND PLANID=", PlanID)
        Dim dr2 As DataRow = DbAccess.GetOneRow(sql2, Trans)
        '(異常有不為9碼的)准考證號
        If dr2 IsNot Nothing Then If Convert.ToString(dr2("MAXEXAMNO")) <> "" Then Return ""

        If dr Is Nothing Then Return NewExamNO

        Select Case Convert.ToString(dr("maxExamNo")).Length' Len(dr("maxExamNo").ToString)
            Case 1
                NewExamNO = String.Concat(ExamNo1, "00", dr("maxExamNo"))'.ToString
            Case 2
                NewExamNO = String.Concat(ExamNo1, "0", dr("maxExamNo"))'.ToString
            Case 3
                NewExamNO = String.Concat(ExamNo1, dr("maxExamNo")) '.ToString
        End Select
        Return NewExamNO
