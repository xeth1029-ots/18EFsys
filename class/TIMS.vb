    'Imports System.IO,'Imports System.Threading,'Imports System.Threading.Tasks,'Imports System.Web ' 引入 System.Web 命名空間，因為使用了 HttpServerUtility,
    ''' <summary>
    ''' 檢核檔案存在與否 (新增超時機制)
    ''' </summary>
    ''' <param name="myServer">HttpServerUtility 物件，用於 MapPath</param>
    ''' <param name="Upload_Path">檔案在應用程式內的相對路徑</param>
    ''' <param name="filename">檔案名稱</param>
    ''' <returns>Boolean: True 表示檔案存在，False 表示檔案不存在</returns>
    ''' <exception cref="TimeoutException">如果檔案檢查超過 1 分鐘，則拋出此例外</exception>
    Public Shared Function CHK_PIC_EXISTS_WITH_TIMEOUT(ByRef myServer As HttpServerUtility, ByVal Upload_Path As String, ByVal filename As String) As Boolean
        ' 檢查檔案路徑是否為空
        If String.IsNullOrWhiteSpace(filename) Then Return False
        ' 完整的物理路徑，例如：\\NAS_SERVER\share\path\filename
        Dim fullPath As String = myServer.MapPath($"{Upload_Path}{filename}")
        ' 設定超時時間為n毫秒
        Const TIMEOUT_MILLISECONDS As Integer = 1000 * 11
        ' 儲存檔案是否存在檢查的結果
        Dim rst As Boolean = False
        ' 創建一個 Task 來執行 File.Exists
        Using checkTask As Task(Of Boolean) = Task.Run(Function()
                                                           Return File.Exists(fullPath) ' 這段程式碼在另一個執行緒中執行
                                                       End Function)
            Try
                ' 等待 Task 完成，並限制等待時間
                Dim isCompletedSuccessfully As Boolean = checkTask.Wait(TIMEOUT_MILLISECONDS)
                If isCompletedSuccessfully Then
                    ' Task 在 時間內完成，取得結果
                    rst = checkTask.Result
                Else
                    ' Task 超時，但仍處於運行狀態 (通常發生在 File.Exists 阻塞時) ' **根據您的要求：1分鐘如果沒反應，跳出 Exception**
                    Dim ex As New TimeoutException($"檔案檢查超時 (超過 {TIMEOUT_MILLISECONDS / 1000} 秒)。檢查路徑: {EncryptAes(fullPath)}")
                    Call WriteTraceLog(ex.Message, ex)
                    Throw ex
                End If
            Catch ex As AggregateException
                Call WriteTraceLog(ex.Message, ex)
                ' 處理 Task 內部拋出的例外
                Throw ex.InnerException
            Catch ex As Exception
                ' 處理其他可能的例外，例如上面拋出的 TimeoutException
                Call WriteTraceLog(ex.Message, ex)
                Throw ex
            End Try
        End Using
        Return rst
    End Function

