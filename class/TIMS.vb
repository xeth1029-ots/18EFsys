    ''' <returns></returns>
    Public Shared Function Get_EXAM3DATA(ByRef oConn As SqlConnection, ByVal v_EXAMID As String, ByRef txtGP As TextBox, ByRef txtXM As TextBox) As DataRow
        Dim dr As DataRow = Nothing
        'TIMS.GetEXAM3data(objconn, Convert.ToString(dr("EXAMIDS1")))
        Dim sql As String = ""
        sql &= " SELECT a.EXAMID,a.EXNAME" & vbCrLf
        sql &= " ,CONCAT('(',a.EXAMID,')',a.EXNAME) EXNAME_N" & vbCrLf
        sql &= " ,a.EXLEVEL ,a.EGID ,b.JGNAME" & vbCrLf
        sql &= " FROM KEY_EXAM3 a" & vbCrLf
        sql &= " JOIN KEY_EXAMGROUP b on b.EGID=a.EGID" & vbCrLf
        sql &= " WHERE a.EXAMID=@EXAMID" & vbCrLf
        Dim sCmd As New SqlCommand(sql, oConn)
        Dim dt As New DataTable
        Call OpenDbConn(oConn)
        With sCmd
            .Parameters.Clear()
            .Parameters.Add("EXAMID", SqlDbType.VarChar).Value = v_EXAMID
