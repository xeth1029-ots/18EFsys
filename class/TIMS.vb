    ''' <summary>
    ''' 驗証Email OK為true
    ''' </summary>
    ''' <param name="strEmail"></param>
    ''' <returns></returns>
    Public Shared Function CheckEmail(ByVal strEmail As String) As Boolean
        'flag TRUE: EMAIL正確 // FALSE: EMAIL錯誤
        Const CharEng As String = "ABCDEFGHIJKLMNOPQRSTUVWXYZ"
        Const CharNumber As String = "0123456789"
        Const CharTest As String = ".@-_"
        Const CharTest2 As String = ".@"

        Dim flag As Boolean = True
        flag = System.Text.RegularExpressions.Regex.IsMatch(strEmail, "^([\w-\.]+)@((\[[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.)|(([\w-]+\.)+))([a-zA-Z]{2,4}|[0-9]{1,3})(\]?)$")
        If strEmail.IndexOf("@") = -1 Then
            flag = False
            Return flag
        End If
        If Not flag OrElse strEmail.IndexOf(".") = -1 Then flag = False
        If Not flag OrElse strEmail.Split("@").Length <> 2 Then flag = False
        If Not flag OrElse strEmail.IndexOf("@@") > -1 Then flag = False
        If Not flag OrElse strEmail.IndexOf("..") > -1 Then flag = False
        If Not flag OrElse strEmail.IndexOf("@.") > -1 Then flag = False
        If Not flag OrElse strEmail.IndexOf(".@") > -1 Then flag = False
        If Not flag OrElse strEmail.EndsWith("@") = True Then flag = False
        If Not flag OrElse strEmail.StartsWith("@") = True Then flag = False
        If Not flag OrElse strEmail.EndsWith(".") = True Then flag = False
        If Not flag OrElse strEmail.StartsWith(".") = True Then flag = False

        If flag Then '沒有上面的錯誤，再試著做下列的Email驗證
            strEmail = strEmail.ToUpper
            For i As Integer = 0 To strEmail.Length - 1
                If CharEng.IndexOf(strEmail.Chars(i)) > -1 _
                    OrElse CharNumber.IndexOf(strEmail.Chars(i)) > -1 _
                    OrElse CharTest.IndexOf(strEmail.Chars(i)) > -1 Then
                    flag = True
                Else
                    flag = False
                    Exit For
                End If
                '第一位資料
                If i = 0 Then
                    If CharTest2.IndexOf(strEmail.Chars(i)) > -1 Then
                        flag = False
                        Exit For
                    End If
                End If
                '最後一位資料
                If i = (strEmail.Length - 1) Then
                    If CharTest2.IndexOf(strEmail.Chars(i)) > -1 Then
                        flag = False
                        Exit For
                    End If
                End If
            Next
        End If
        Return flag
    End Function

