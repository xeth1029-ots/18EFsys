,P2.TrainDemain ,P1.PlanCause ,P1.PurScience ,P1.PurTech ,P1.PurMoral,p1.TMIDCORRECT
,P2.TGOVEXAM,P2.GOVAGENAME,P2.TGOVEXAMNAME,P1.ENTERSUPPLYSTYLE,P2.FUNCLEVEL
,CASE WHEN P2.TMethod LIKE '%01%' THEN 'V' END TMethodC01
,CASE WHEN P2.TMethod LIKE '%02%' THEN 'V' END TMethodC02
,CASE WHEN P2.TMethod LIKE '%03%' THEN 'V' END TMethodC03
,CASE WHEN P2.TMethod LIKE '%99%' THEN 'V' END TMethodC99
,P2.TMethodOth ,P2.POWERNEED1 ,P2.POWERNEED2 ,P2.POWERNEED3,P2.POLICYREL,P2.POWERNEED4 ,P2.POWERNEED4CHK
,dbo.FN_GET_APPSTAGE(P1.APPSTAGE) MyAppStage
,p1.CapAge1, p1.DISTANCE, dbo.FN_DISTANCE_P(p1.DISTANCE) DISTANCE_NP
FROM CLASS_CLASSINFO a WITH(NOLOCK)
JOIN PLAN_PLANINFO P1 WITH(NOLOCK) ON a.PlanID=P1.PlanID AND a.ComIDNO=P1.ComIDNO AND a.SeqNo=P1.SeqNo
