    '刪除學員資料 (CLASS_STUDENTSOFCLASSDELDATA)
    Public Shared Function sUtl_DelSTUDENTSOFCLASS(ByRef MyPage As Page, ByVal rqSOCID As String, ByRef oConn As SqlConnection, ByRef oTrans As SqlTransaction) As Integer
        Dim rst As Integer = 0
        Dim sm As SessionModel = SessionModel.Instance()

        rqSOCID = ClearSQM(rqSOCID)
        If rqSOCID = "" Then Return 0 '異常不處理
        If Convert.ToString(sm.UserInfo.UserID) = "" Then Return 0 '異常不處理

        '確認
        Dim parms As New Hashtable From {{"SOCID", rqSOCID}}
        Dim sql As String = " SELECT * FROM CLASS_STUDENTSOFCLASS WHERE SOCID=@SOCID"
        'parms.Add("MODIFYACCT", sm.UserInfo.UserID)
        Dim dt As DataTable = DbAccess.GetDataTable(sql, oTrans, parms)
        If dt.Rows.Count <> 1 Then Return 0 '異常不處理

        '變更Modify人時
        Dim sqlu As String = " UPDATE CLASS_STUDENTSOFCLASS SET MODIFYACCT=@MODIFYACCT,MODIFYDATE=GETDATE() WHERE SOCID=@SOCID"
        Dim parmsU As New Hashtable From {{"MODIFYACCT", sm.UserInfo.UserID}, {"SOCID", rqSOCID}}
        DbAccess.ExecuteNonQuery(sqlu, oTrans, parmsU)

        '使用欄位 '計算欄位
        Dim sColName As String = ""
        For i As Integer = 0 To dt.Columns.Count - 1 '所有欄位
            If sColName <> "" Then sColName &= ","
            sColName &= dt.Columns(i).ColumnName
        Next
        'For Each cColumn As Data.DataColumn In dtN.Columns
        '    cColumn.AllowDBNull=True
        'Next

        '搬移資料
        sql = ""
        sql &= " INSERT INTO CLASS_STUDENTSOFCLASSDELDATA (" & sColName & ")"
        sql &= " SELECT " & sColName & " FROM CLASS_STUDENTSOFCLASS WHERE SOCID=@SOCID"
        sql &= " AND MODIFYACCT=@MODIFYACCT"
        parms.Clear()
        parms.Add("SOCID", rqSOCID)
        parms.Add("MODIFYACCT", sm.UserInfo.UserID)
        DbAccess.ExecuteNonQuery(sql, oTrans, parms)

        '刪除Class_StudentsOfClass
        sql = ""
        sql &= " DELETE CLASS_STUDENTSOFCLASS WHERE SOCID=@SOCID"
        sql &= " AND MODIFYACCT=@MODIFYACCT"
        parms.Clear()
        parms.Add("SOCID", rqSOCID)
        parms.Add("MODIFYACCT", sm.UserInfo.UserID)
        DbAccess.ExecuteNonQuery(sql, oTrans, parms)
    End Function

    '刪除學員資料 (CLASS_STUDENTSOFCLASSDELDATA)
    Public Shared Function sUtl_DelSTUDENTSOFCLASS(ByRef MyPage As Page, ByVal rqSOCID As String, ByRef oConn As SqlConnection) As Integer
        Dim rst As Integer = 0
        Dim sm As SessionModel = SessionModel.Instance()

        rqSOCID = ClearSQM(rqSOCID)
        If rqSOCID = "" Then Return 0 '異常不處理
        If Convert.ToString(sm.UserInfo.UserID) = "" Then
            Return 0 '異常不處理
        End If

        '使用欄位
        Call OpenDbConn(oConn)
        Dim oTrans As SqlTransaction = DbAccess.BeginTrans(oConn)
        Try
            rst = sUtl_DelSTUDENTSOFCLASS(MyPage, rqSOCID, oConn, oTrans)
            DbAccess.CommitTrans(oTrans)
        Catch ex As Exception
            LOG.Warn(ex.Message, ex)
            DbAccess.RollbackTrans(oTrans)
            CloseDbConn(oConn) '異常中止連線
            oConn = Nothing

            Dim strErrmsg As String = ""
            strErrmsg &= "/*  Public Shared Function sUtl_DelSTUDENTSOFCLASS */" & vbCrLf
            strErrmsg &= "/*  ex.ToString: */" & vbCrLf
            strErrmsg &= ex.ToString & vbCrLf
            strErrmsg &= GetErrorMsg(MyPage) '取得錯誤資訊寫入
            Call WriteTraceLog(strErrmsg)
        End Try
        Return rst
    End Function

    ''' <summary>檢核特殊狀況 out@sErrmsg </summary>
    ''' <param name="MyPage"></param>
    ''' <param name="sErrmsg"></param>
    ''' <param name="ss3"></param>
    ''' <param name="oConn"></param>
    Public Shared Sub Chk_TIMSB1251(ByRef MyPage As Page, ByRef sErrmsg As String,
                                    ByVal ss3 As String, ByRef oConn As SqlConnection)
        'Classification1_List.SelectedValue
        'https://jira.turbotech.com.tw/browse/TIMSB-1251
        'CLASSIFICATION1 1:學科/2術科
        Dim sm As SessionModel = SessionModel.Instance()
        Dim sClassification1 As String = GetMyValue(ss3, "Classification1")
        Dim sMaxTNum As String = GetMyValue(ss3, "MaxTNum")
        Dim OLessonTeah1_Value As String = GetMyValue(ss3, "OLessonTeah1_Value")
        Dim OLessonTeah2_Value As String = GetMyValue(ss3, "OLessonTeah2_Value")
        Dim OLessonTeah3_Value As String = GetMyValue(ss3, "OLessonTeah3_Value")
        If Cst_TPlanID68.IndexOf(sm.UserInfo.TPlanID) = -1 Then '3.1若計畫代碼為68 (不檢核)
            Exit Sub
        End If

        '3.1若計畫代碼為68
        '3.2又是選術科
        '3.3隸屬班級則必填，以取得其班級人數。
        '3.4 依班級人數，來判斷老師人數每10人可申請一名，最多2名,則可儲存()
        Dim iCanUseTeacherNum As Integer = 0

        Dim iTeacherNum As Integer = 0
        If OLessonTeah1_Value <> "" Then iTeacherNum += 1
        If OLessonTeah2_Value <> "" Then iTeacherNum += 1
        If OLessonTeah3_Value <> "" Then iTeacherNum += 1

        Select Case sClassification1
            Case "1"
                If iTeacherNum > 1 Then
                    sErrmsg &= "該計畫學科, 最多只可申請1名教師!!" & vbCrLf
                End If

            Case "2"
                'Dim sMaxTNum As String=Convert.ToString(drCC("TNum")) 'Get_MAXCCTNum(Me, Classid_Hid.Value, objconn)
                '3.2又是選術科
                If sMaxTNum <> "" Then
                    iCanUseTeacherNum = 1
                    If CINT1(sMaxTNum) > 10 AndAlso CINT1(sMaxTNum) <= 20 Then iCanUseTeacherNum = 2
                    If CINT1(sMaxTNum) > 20 Then iCanUseTeacherNum = 3
                    Select Case iCanUseTeacherNum
                        Case 1
                            If iTeacherNum > 1 Then
                                sErrmsg &= "班級人數10人以下(含), 最多只可申請1名教師!!" & vbCrLf
                            End If
                        Case 2
                            If iTeacherNum > 2 Then
                                sErrmsg &= "班級人數10人以上, 最多只可申請2名教師!!" & vbCrLf
                            End If
                        Case 3
                            sErrmsg &= "班級人數大於20人不適用於此計畫!!" & vbCrLf
                    End Select
                End If
        End Select

    End Sub

