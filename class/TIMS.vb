    Public Shared Function IsValidJson(jsonString As String) As Boolean
        Try
            JsonConvert.DeserializeObject(jsonString)
            Return True
        Catch ex As Exception
            Dim s_ERRMSG1 As String = String.Concat("IsValidJson:", ex.Message, vbCrLf, ",jsonString:", vbCrLf, jsonString, vbCrLf)
            WriteTraceLog(s_ERRMSG1, ex) 'Throw ex
        End Try
        Return False
    End Function

    Public Shared Function GetFileSize(ByVal fileLength As Long) As String
        Dim tNum As Decimal = fileLength
        If tNum <= 1024 Then Return String.Concat(tNum, "Byte").Replace(".0", " ")
        tNum = tNum / 1024
        If tNum <= 1024 Then Return String.Concat(Math.Round(tNum, 1), "KB").Replace(".0", " ")
        tNum = tNum / 1024
        If tNum <= 1024 Then Return String.Concat(Math.Round(tNum, 1), "MB").Replace(".0", " ")
        tNum = tNum / 1024
        If tNum <= 1024 Then Return String.Concat(Math.Round(tNum, 1), "GB").Replace(".0", " ")
        tNum = tNum / 1024
        Return String.Concat(Math.Round(tNum, 1), "TB").Replace(".0", " ") '(暫時設定此系統最大容量為TB)
        'rst=rst.Replace(".0", "")   '若檔案容量含有[.0]時,則將小數點拿掉
        ' 20180718 Note:因Integer型別最大值對應到的大小為2GB，所以[檔案大小]最大值為2GB Return rst
    End Function

    ''' <summary>
    ''' 刪除無用暫存檔
    ''' </summary>
    ''' <param name="oConn"></param>
    ''' <returns></returns>
    Public Shared Function DEL_ADP_ZIPFILE(oConn As SqlConnection) As Integer
        Dim sSql As String = ""
        sSql &= " SELECT TOP 1 A.FZSEQ,A.FNAME,A.FDIRNAME,A.FULLNAME1,A.FSIZE1,A.FSTATUS1,A.MODIFYACCT,A.MODIFYDATE" & vbCrLf
        sSql &= " FROM dbo.ADP_ZIPFILE A WITH(NOLOCK)" & vbCrLf
        sSql &= " WHERE A.FSTATUS1 IS NULL AND A.MODIFYDATE<=GETDATE()-1" & vbCrLf
        sSql &= " ORDER BY A.MODIFYDATE" & vbCrLf
        Dim dtZF As DataTable = DbAccess.GetDataTable(sSql, oConn)
        If dtNODATA(dtZF) Then Return 0

        Dim iCnt As Integer = 0
        For Each drF As DataRow In dtZF.Rows
            Dim FULLNAME1 As String = $"{drF("FULLNAME1")}"
            Dim FDIRNAME As String = $"{drF("FDIRNAME")}"
            Try
                Dim pms_UU As New Hashtable From {{"FZSEQ", drF("FZSEQ")}}
                Dim sql_UU As String = "UPDATE ADP_ZIPFILE SET FSTATUS1='S' WHERE FZSEQ=@FZSEQ"
                ExecuteNonQuery(sql_UU, oConn, pms_UU)
                Call MyFileDelete($"{drF("FULLNAME1")}")
                Call MyDirDelete($"{drF("FDIRNAME")}")
                Dim pms_UU2 As New Hashtable From {{"FZSEQ", drF("FZSEQ")}}
                Dim sql_UU2 As String = "UPDATE ADP_ZIPFILE SET FSTATUS1='D' WHERE FZSEQ=@FZSEQ"
                ExecuteNonQuery(sql_UU2, oConn, pms_UU2)
                iCnt += 1
            Catch ex As Exception
                Dim s_ERRMSG1 As String = String.Concat("DEL_ADP_ZIPFILE: ", ex.Message, vbCrLf)
                s_ERRMSG1 &= String.Concat("FDIRNAME: ", FDIRNAME, vbCrLf)
                s_ERRMSG1 &= String.Concat("FULLNAME1: ", FULLNAME1, vbCrLf)
                WriteTraceLog(s_ERRMSG1, ex) 'Throw ex
                Return -1
            End Try
        Next
        Return iCnt
    End Function

