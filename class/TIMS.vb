        Dim sql As String = ""
        Select Case SearchQueryDisplay
            Case 0
                sql = " SELECT * FROM KEY_PLAN WHERE ISNULL(CLSYEAR,CONVERT(varchar(4),YEAR(GETDATE())))>=CONVERT(varchar(4),YEAR(GETDATE()))" & vbCrLf
                sql &= " AND CLSYEAR IS NULL OR ISNULL(CLSYEAR,SUBSTRING(CONVERT(VARCHAR,GETDATE(),111),1,4))>=SUBSTRING(CONVERT(VARCHAR,GETDATE(),111),1,4)" & vbCrLf
                sql &= " ORDER BY TPLANID"

