    Public Shared Function GetDISASTER2dt(ByVal byADID As String, ByRef oConn As SqlConnection) As DataTable
        Dim ZIPCODEstr As String = ""
        byADID = ClearSQM(byADID)
        If byADID = "" Then Return Nothing

        Dim pms1 As New Hashtable From {{"ADID", byADID}}
        Dim sql As String = ""
        sql &= " WITH WC1 AS ( SELECT ZIPCODE FROM ADP_DISASTER2 WHERE ADID=@ADID)" & vbCrLf
        sql &= " SELECT a.ZIPCODE,a.CTNAME+'-'+a.ZNAME ZIPNAME2" & vbCrLf
        sql &= " FROM VIEW_ZIPNAME a" & vbCrLf
        sql &= " JOIN WC1 b on b.ZIPCODE=a.ZIPCODE" & vbCrLf 'sql &= " WHERE 1=1" & vbCrLf
        sql &= " ORDER BY a.ZIPCODE" & vbCrLf
        Dim dt2 As DataTable = DbAccess.GetDataTable(sql, oConn, pms1)
        Return dt2
    End Function

    '取得該序號目前的災害地區
    Public Shared Function GetDISASTER2(ByVal byADID As String, ByRef oConn As SqlConnection) As String
        Dim ZIPCODEstr As String = ""
        byADID = ClearSQM(byADID)
        If byADID = "" Then Return ""

        Dim dt2 As DataTable = GetDISASTER2dt(byADID, oConn)
        If dtNODATA(dt2) Then Return ""
        'If dt2.Rows.Count=0 Then Return ZIPCODEstr
        If dt2.Rows.Count > 0 Then
            For Each dr2 As DataRow In dt2.Rows
                If Convert.ToString(dr2("ZIPCODE")) <> "" Then
                    Dim tmpValue1 As String = String.Concat("'", dr2("ZIPCODE"), "'")
                    If tmpValue1 <> "" AndAlso ZIPCODEstr.IndexOf(tmpValue1) = -1 Then '重複字過濾
                        ZIPCODEstr &= String.Concat(If(ZIPCODEstr <> "", ",", ""), tmpValue1)
                    End If
                End If
            Next
        End If

        Return ZIPCODEstr
    End Function

    ''' <summary>
    ''' 取得該序號目前的災害地區-ZIPNAME2
    ''' </summary>
    ''' <param name="byADID"></param>
    ''' <param name="oConn"></param>
    ''' <param name="iSHOW">'iSHOW: 1:完整顯示 2:只顯示10筆</param>
    ''' <returns></returns>
    Public Shared Function GetDISASTER2_N(ByVal byADID As String, ByRef oConn As SqlConnection, ByRef iSHOW As Integer) As String
        Dim ZIPCODEstr As String = ""
        byADID = ClearSQM(byADID)
        If byADID = "" Then Return ""
        'iSHOW: 1:完整顯示 2:只顯示10筆
        Dim dt2 As DataTable = GetDISASTER2dt(byADID, oConn)
        If dtNODATA(dt2) Then Return ""
        'If dt2.Rows.Count=0 Then Return ZIPCODEstr 'If dt2.Rows.Count > 0 Then 'End If

        Dim i2 As Integer = 0
        For Each dr2 As DataRow In dt2.Rows
            If Convert.ToString(dr2("ZIPNAME2")) <> "" Then
                i2 += 1
                Dim tmpValue1 As String = String.Concat("'", dr2("ZIPNAME2"), "'")
                If tmpValue1 <> "" AndAlso ZIPCODEstr.IndexOf(tmpValue1) = -1 Then '重複字過濾
                    ZIPCODEstr &= String.Concat(If(ZIPCODEstr <> "", ",", ""), tmpValue1)
                End If
                If iSHOW = 2 AndAlso i2 > 10 Then
                    ZIPCODEstr &= String.Concat(", ...", "(共有", dt2.Rows.Count, "項次)!")
                    Exit For
                End If
            End If
        Next

        ZIPCODEstr = ClearSQM(ZIPCODEstr)
        Return ZIPCODEstr
    End Function

