    Public Shared Function Get_ParentRID(ByVal Relship As String, ByRef tConn As SqlConnection) As String
        Call OpenDbConn(tConn)
        Dim ParentName As String = ""
        Dim sql As String = " Select ORGNAME2 FROM VIEW_RELSHIP23 WHERE RELSHIP=@Relship"
        Dim sCmd As New SqlCommand(sql, tConn)
        Dim dt As New DataTable
        With sCmd
            .Parameters.Clear()
            .Parameters.Add("Relship", SqlDbType.VarChar).Value = Relship
            dt.Load(.ExecuteReader())
        End With
        If dtNODATA(dt) Then Return ""
        ParentName = dt.Rows(0)("ORGNAME2")
        Return ParentName
    End Function

