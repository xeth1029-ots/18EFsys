    '顯示郵遞區號訊息。
    Public Shared Function SHOW_ZIP2MSG(ByRef MyPage As Page,
                                        ByVal sZIPCODE As String,
                                        ByVal sEnterDate As String,
                                        ByRef oConn As SqlConnection) As String
        Dim rst As String = ""
        If sZIPCODE = "" Then Return rst '無值離開
        If sEnterDate = "" Then Return rst '無值離開
        Dim sm As SessionModel = SessionModel.Instance()

        '計畫不在範圍當中。
        If TIMS.Cst_TV1_TPlanID.IndexOf(sm.UserInfo.TPlanID) = -1 Then Return rst
        If TIMS.Cst_TV1_TPlanID.IndexOf(sm.UserInfo.TPlanID) > -1 _
            AndAlso DateDiff(DateInterval.Day, CDate(Cst_TV1_SDATE), CDate(sEnterDate)) >= 0 _
            AndAlso DateDiff(DateInterval.Day, CDate(sEnterDate), CDate(Cst_TV1_FDATE)) >= 0 Then
            '第1.2種颱風適用報名日期
            Dim sql As String = ""
            sql &= " SELECT MSG1" & vbCrLf
            sql &= " FROM ID_ZIP2MSG" & vbCrLf
            sql &= " WHERE USE1='Y'" & vbCrLf
            sql &= " AND MSGTYPEN IN (1,2)" & vbCrLf
            sql &= " AND LEFT(ZIPCODE,2)=LEFT(@ZIPCODE,2)" & vbCrLf '比對前2碼
            Dim sCmd As New SqlCommand(sql, oConn)
            Call OpenDbConn(oConn)
            Dim dt As New DataTable
            With sCmd
                .Parameters.Clear()
                .Parameters.Add("ZIPCODE", SqlDbType.VarChar).Value = sZIPCODE
                dt.Load(.ExecuteReader())
            End With
            If dt.Rows.Count > 0 Then rst = Convert.ToString(dt.Rows(0)("MSG1")) '取第1筆資料顯示
        End If

        If rst = "" Then
            If TIMS.Cst_TV2_TPlanID.IndexOf(sm.UserInfo.TPlanID) > -1 _
                AndAlso DateDiff(DateInterval.Day, CDate(Cst_TV2_SDATE), CDate(sEnterDate)) >= 0 _
                AndAlso DateDiff(DateInterval.Day, CDate(sEnterDate), CDate(Cst_TV2_FDATE)) >= 0 Then
                '第1.2種颱風適用報名日期
                Dim sql As String = ""
                sql &= " SELECT MSG1" & vbCrLf
                sql &= " FROM ID_ZIP2MSG" & vbCrLf
                sql &= " WHERE USE1='Y'" & vbCrLf
                sql &= " AND MSGTYPEN IN (3)" & vbCrLf
                sql &= " AND LEFT(ZIPCODE,2)=LEFT(@ZIPCODE,2)" & vbCrLf '比對前2碼
                Dim sCmd As New SqlCommand(sql, oConn)
                Call OpenDbConn(oConn)
                Dim dt As New DataTable
                With sCmd
                    .Parameters.Clear()
                    .Parameters.Add("ZIPCODE", SqlDbType.VarChar).Value = sZIPCODE
                    dt.Load(.ExecuteReader())
                End With
                If dt.Rows.Count > 0 Then rst = Convert.ToString(dt.Rows(0)("MSG1")) '取第1筆資料顯示
            End If
        End If
        Return rst
    End Function

    '檢核是否有郵遞區號訊息。
    Public Shared Function CHK_ZIP2MSG(ByRef MyPage As Page, ByVal sZIPCODE As String, ByVal sEnterDate As String,
                                       ByRef oConn As SqlConnection, ByRef iTYPEN As Integer) As Boolean
        Dim rst As Boolean = False '無資訊
        'iTYPEN:返回颱風類型。
        If sZIPCODE = "" Then Return rst '無值離開
        If sEnterDate = "" Then Return rst '無值離開
        Dim sm As SessionModel = SessionModel.Instance()

        If TIMS.Cst_TV1_TPlanID.IndexOf(sm.UserInfo.TPlanID) > -1 _
            AndAlso DateDiff(DateInterval.Day, CDate(Cst_TV1_SDATE), CDate(sEnterDate)) >= 0 _
            AndAlso DateDiff(DateInterval.Day, CDate(sEnterDate), CDate(Cst_TV1_FDATE)) >= 0 Then
            '第1.2種颱風適用報名日期
            Dim sql As String = ""
            sql &= " SELECT MSG1,MSGTYPEN" & vbCrLf
            sql &= " FROM ID_ZIP2MSG" & vbCrLf
            sql &= " WHERE USE1='Y' AND MSGTYPEN IN (1,2)" & vbCrLf
            sql &= " AND LEFT(ZIPCODE,2)=LEFT(@ZIPCODE,2)" & vbCrLf '比對前2碼
            Dim sCmd As New SqlCommand(sql, oConn)
            Call OpenDbConn(oConn)
            Dim dt As New DataTable
            With sCmd
                .Parameters.Clear()
                .Parameters.Add("ZIPCODE", SqlDbType.VarChar).Value = sZIPCODE
                dt.Load(.ExecuteReader())
                '.ExecuteReader.Close()
            End With
            If dt.Rows.Count > 0 Then
                Dim drJ As DataRow = dt.Rows(0)
                iTYPEN = Val(drJ("MSGTYPEN"))
                rst = True '查有資料(有顯示資訊)
            End If
        End If

        If Not rst Then
            If TIMS.Cst_TV2_TPlanID.IndexOf(sm.UserInfo.TPlanID) > -1 _
              AndAlso DateDiff(DateInterval.Day, CDate(Cst_TV2_SDATE), CDate(sEnterDate)) >= 0 _
              AndAlso DateDiff(DateInterval.Day, CDate(sEnterDate), CDate(Cst_TV2_FDATE)) >= 0 Then
                '第3種颱風適用報名日期
                Dim sql As String = ""
                sql &= " SELECT MSG1,MSGTYPEN" & vbCrLf
                sql &= " FROM ID_ZIP2MSG" & vbCrLf
                sql &= " WHERE USE1='Y' AND MSGTYPEN IN (3)" & vbCrLf
                sql &= " AND LEFT(ZIPCODE,2)=LEFT(@ZIPCODE,2)" & vbCrLf '比對前2碼
                Dim sCmd As New SqlCommand(sql, oConn)
                Call OpenDbConn(oConn)
                Dim dt As New DataTable
                With sCmd
                    .Parameters.Clear()
                    .Parameters.Add("ZIPCODE", SqlDbType.VarChar).Value = sZIPCODE
                    dt.Load(.ExecuteReader())
                    '.ExecuteReader.Close()
                End With
                If dt.Rows.Count > 0 Then
                    Dim drJ As DataRow = dt.Rows(0)
                    iTYPEN = CINT1(drJ("MSGTYPEN"))
                    rst = True '查有資料(有顯示資訊)
                End If
            End If
        End If
        Return rst
    End Function

    ''' <summary>
    ''' '檢核是否有郵遞區號訊息-重大災害受災地區範圍。('限定計畫)
    ''' </summary>
    ''' <param name="MyPage"></param>
    ''' <param name="sZIPCODE"></param>
    ''' <param name="sENTERDATE"></param>
    ''' <param name="oConn"></param>
    ''' <param name="iADID">out</param>
    ''' <returns></returns>
    Public Shared Function CHK_DIS2MSG(ByRef MyPage As Page, ByVal sZIPCODE As String, ByVal sENTERDATE As String,
                                       ByRef oConn As SqlConnection, ByRef iADID As Integer) As Boolean
        Dim rst As Boolean = False '無資訊 true:有資訊
        Dim sm As SessionModel = SessionModel.Instance()
        '限定計畫
        If Cst_DIS_TPlanID.IndexOf(sm.UserInfo.TPlanID) = -1 Then Return rst
        'iADID:返回 重大災害受災地區範圍 序號。
        If sZIPCODE = "" OrElse sENTERDATE = "" Then Return rst '無值離開
        '計畫不在範圍當中。'起始日期未達 '超過結束日期
        'https://jira.turbotech.com.tw/browse/TIMSC-150

        Dim sql As String = ""
        sql &= " WITH WC1 AS ( SELECT ADID,ALARMMSG1" & vbCrLf
        sql &= " FROM ADP_DISASTER" & vbCrLf
        sql &= " WHERE FUNC2='Y' AND BEGDATE<=convert(datetime, @ENTERDATE, 111) AND ENDDATE>=convert(datetime, @ENTERDATE, 111) )" & vbCrLf
        sql &= " SELECT a.ADID ,a.ALARMMSG1" & vbCrLf
        sql &= " FROM WC1 a" & vbCrLf
        sql &= " JOIN ADP_DISASTER2 b ON a.ADID=b.ADID" & vbCrLf
        sql &= " WHERE b.USE1='Y' AND b.ZIPCODE=@ZIPCODE" & vbCrLf
        Dim sCmd As New SqlCommand(sql, oConn)
        Call OpenDbConn(oConn)
        Dim dt As New DataTable
        With sCmd
            .Parameters.Clear()
            .Parameters.Add("ENTERDATE", SqlDbType.VarChar).Value = Cdate3(sENTERDATE)
            .Parameters.Add("ZIPCODE", SqlDbType.VarChar).Value = sZIPCODE
            dt.Load(.ExecuteReader())
        End With
        If dt.Rows.Count > 0 Then
            Dim dr1 As DataRow = dt.Rows(0)
            iADID = CINT1(dr1("ADID"))
            Return True '查有資料(有顯示資訊) 'rst=True '查有資料(有顯示資訊)
        End If

        Return rst
    End Function

