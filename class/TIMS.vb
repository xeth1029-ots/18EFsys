    ''' <param name="trans"></param>
    ''' <returns></returns>
    Public Shared Function GETMAX_ESERNUM_SEQ(ByRef trans As SqlTransaction) As Integer
        'iRst = DbAccess.GetNewId(trans, "STUD_ENTERTYPE2_ESERNUM_SEQ,STUD_ENTERTYPE2,ESERNUM")
        Dim iRst As Integer = DbAccess.GetAutoNum(trans.Connection, trans, "STUD_ENTERTYPE2_ESERNUM_SEQ")
