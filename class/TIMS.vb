    '取得勞保勾稽資料
    Public Shared Function Get_BLIGATEDATA4(ByVal iSB4ID As Integer, ByVal IDNO As String, ByRef oConn As SqlConnection) As DataRow
        Dim rst As DataRow = Nothing
        Dim sSql As String = ""
        sSql &= " SELECT a.SB4ID,a.IDNO,a.FTYPE,a.NAME,a.BIRTHDAY,a.ACTNO,a.COMNAME,a.CHANGEMODE,a.MDATE" & vbCrLf
        sSql &= " ,a.SALARY,a.DEPARTMENT,a.MODIFYDATE,a.DEPTMENT,a.BIEF,a.BIEFDESC,ISNULL(b.UNAME,a.COMNAME) UNAME" & vbCrLf
        sSql &= " ,format(MDATE, 'yyyy/MM/dd') MDATE_AD,b.Addr,b.Tel,left(b.zip,3) bZip3" & vbCrLf
        sSql &= " FROM STUD_BLIGATEDATA4 a" & vbCrLf
        sSql &= " LEFT JOIN BUS_BASICDATA b ON a.ActNo=b.Ubno" & vbCrLf
        sSql &= " WHERE a.SB4ID=@SB4ID AND a.IDNO=@IDNO" & vbCrLf
        Dim sCmd As New SqlCommand(sSql, oConn)
        Call OpenDbConn(oConn)
        Dim dt As New DataTable
        With sCmd
            .Parameters.Clear()
            .Parameters.Add("SB4ID", SqlDbType.VarChar).Value = iSB4ID
            .Parameters.Add("IDNO", SqlDbType.VarChar).Value = IDNO
            dt.Load(.ExecuteReader())
        End With
        If dt.Rows.Count = 1 Then rst = dt.Rows(0)
        Return rst
    End Function

