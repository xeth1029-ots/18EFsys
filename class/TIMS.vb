    ''' <summary>組合表格欄位值，(排除)單引號, 排除重複</summary>
    ''' <param name="dt"></param>
    ''' <param name="RTNCOLUMN"></param>
    ''' <returns></returns>
    Public Shared Function ECHOVAL(dt As DataTable, RTNCOLUMN As String) As String
        Dim RST As String = ""
        If dtNODATA(dt) Then Return RST
        For Each dr1 As DataRow In dt.Rows
            RST &= $"{If(RST <> "", ",", "")}{dr1(RTNCOLUMN)}"
        Next
        Return CombiSQM5IN(RST)
    End Function
