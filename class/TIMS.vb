    '組合條碼39 匯出table 供郵局間接。
    Public Shared Function LoadDatab39(ByVal iType As Integer, ByVal ss As String, ByVal tConn As SqlConnection) As DataTable
        Dim dtR As New DataTable
        Dim sm As SessionModel = SessionModel.Instance()

        'iType: 1: SD_02_004_R, 2: SD_02_006_R
        Select Case iType
            Case 1
                'ss 傳入參數請確認
                Dim planid As String = GetMyValue(ss, "planid")
                Dim vOCID As String = GetMyValue(ss, "OCID") '一定要有OCID
                Dim STDate1 As String = GetMyValue(ss, "start_date")
                Dim STDate2 As String = GetMyValue(ss, "end_date")
                Dim EnterPathY As String = GetMyValue(ss, "EnterPathY")
                Dim EnterPathN As String = GetMyValue(ss, "EnterPathN")

                '分署、班級名稱、條碼值、收件人、郵遞區號、地址
                Dim sql As String = ""
                sql &= " select f.OCID ,c.distname ,f.classcname" & vbCrLf
                sql &= " ,concat(b.setid,'-',convert(varchar,b.enterdate, 112),'-',b.sernum) barcode39" & vbCrLf
                sql &= " ,a.Name" & vbCrLf
                sql &= " ,dbo.FN_GET_ZIPCODE(a.ZipCODE,a.ZipCODE6W) StudZipCode" & vbCrLf
                sql &= " ,concat(g.ZIPNAME,a.Address) StudAddress" & vbCrLf
                sql &= " ,b.ExamNO" & vbCrLf
                sql &= " from Stud_EnterTemp a" & vbCrLf
                sql &= " join Stud_EnterType b on a.SETID=b.SETID" & vbCrLf
                sql &= " join CLASS_CLASSINFO f on b.OCID1=f.OCID" & vbCrLf
                sql &= " join VIEW_PLAN c on c.PlanID=f.PlanID" & vbCrLf
                sql &= " join Key_TrainType k on k.TMID=f.TMID" & vbCrLf
                sql &= " join Auth_Relship d on d.RID=f.RID" & vbCrLf
                sql &= " join Org_orginfo e on e.orgid=d.orgid" & vbCrLf
                sql &= " join Org_OrgPlanInfo O on d.RSID=O.RSID" & vbCrLf
                sql &= " join dbo.VIEW_ZIPNAME g on g.ZipCode=a.ZipCode" & vbCrLf
                sql &= " left join Sys_OrgVar so ON d.RID=so.RID and c.Tplanid=so.Tplanid" & vbCrLf
                sql &= " join dbo.VIEW_ZIPNAME i on i.ZipCode=o.ZipCode" & vbCrLf
                sql &= " left join Org_notice m on c.planid=m.planid and e.orgid=m.orgid and m.ocid is null" & vbCrLf
                sql &= " left join Org_notice n on c.planid=n.planid and e.orgid=n.orgid and b.OCID1= n.ocid" & vbCrLf
                sql &= " where 1=1" & vbCrLf
                sql &= If(vOCID <> "", " AND b.OCID1=@vOCID ", " AND 1<>1") & vbCrLf '1<>1 沒有資料
                If planid <> "" Then sql &= " and f.planid=@planid" & vbCrLf
                If STDate1 <> "" Then sql &= " AND f.STDate >= convert(datetime, @STDate1, 111)" & vbCrLf
                If STDate2 <> "" Then sql &= " AND f.STDate <= convert(datetime, @STDate2, 111)" & vbCrLf
                If EnterPathY <> "" Then sql &= " AND b.EnterPath=@EnterPathY" & vbCrLf
                If EnterPathN <> "" Then sql &= " AND ISNULL(b.EnterPath,' ') !=@EnterPathN" & vbCrLf

                sql &= " order by b.ExamNO" & vbCrLf
                Dim sCmd As New SqlCommand(sql, tConn)
                Call OpenDbConn(tConn)
                With sCmd
                    .Parameters.Clear()
                    If vOCID <> "" Then .Parameters.Add("vOCID", SqlDbType.VarChar).Value = vOCID
                    If planid <> "" Then .Parameters.Add("planid", SqlDbType.VarChar).Value = planid
                    If STDate1 <> "" Then .Parameters.Add("STDate1", SqlDbType.VarChar).Value = STDate1
                    If STDate2 <> "" Then .Parameters.Add("STDate2", SqlDbType.VarChar).Value = STDate2
                    If EnterPathY <> "" Then .Parameters.Add("EnterPathY", SqlDbType.VarChar).Value = EnterPathY
                    If EnterPathN <> "" Then .Parameters.Add("EnterPathN", SqlDbType.VarChar).Value = EnterPathN
                    dtR.Load(.ExecuteReader())
                End With
            Case 2
                'OCID1,DistID,SelResultID,WOResult,EnterPathY,EnterPathN
                Dim vOCID As String = GetMyValue(ss, "OCID1") '一定要有OCID
                Dim DistID As String = GetMyValue(ss, "DistID")
                Dim SelResultID As String = GetMyValue(ss, "SelResultID")
                Dim WOResult As String = GetMyValue(ss, "WOResult")
                Dim EnterPathY As String = GetMyValue(ss, "EnterPathY")
                Dim EnterPathN As String = GetMyValue(ss, "EnterPathN")

                '分署、班級名稱、條碼值、收件人、郵遞區號、地址
                Dim sql As String = ""
                sql &= " select c.distname ,f.classcname" & vbCrLf
                sql &= " ,concat(b.setid,'-',convert(varchar,b.enterdate, 112),'-',b.sernum) barcode39" & vbCrLf
                sql &= " ,a.Name" & vbCrLf
                sql &= " ,dbo.FN_GET_ZIPCODE(a.ZipCODE,a.ZipCODE6W) StudZipCode" & vbCrLf
                sql &= " ,concat(g.ZIPNAME,a.Address) StudAddress" & vbCrLf
                sql &= " ,b.ExamNO" & vbCrLf
                sql &= " From Stud_EnterTemp a" & vbCrLf
                sql &= " join Stud_EnterType b on a.SETID=b.SETID" & vbCrLf
                sql &= " join CLASS_CLASSINFO f on b.OCID1=f.OCID" & vbCrLf
                sql &= " join VIEW_PLAN c on c.PlanID=f.PlanID" & vbCrLf
                sql &= " join Auth_Relship d on d.RID=f.RID" & vbCrLf
                sql &= " join Org_orginfo e on e.orgid=d.orgid" & vbCrLf
                sql &= " join Org_OrgPlanInfo O on O.RSID=d.RSID" & vbCrLf
                sql &= " join Key_TrainType l on l.TMID=f.TMID" & vbCrLf
                sql &= " join VIEW_ZIPNAME g on g.ZipCode=a.ZipCode" & vbCrLf
                sql &= " join VIEW_ZIPNAME i on i.ZipCode=O.ZipCode" & vbCrLf
                sql &= " join Sys_OrgVar ov on ov.RID=b.RID and ov.Tplanid=c.Tplanid" & vbCrLf
                sql &= " join STUD_SELRESULT k on b.SETID=k.SETID and b.EnterDate=k.EnterDate" & vbCrLf

                sql &= If(vOCID <> "", " AND k.OCID=@vOCID ", " AND 1<>1") & vbCrLf '1<>1 沒有資料

                sql &= " WHERE 1=1" & vbCrLf

                sql &= If(vOCID <> "", " AND b.OCID1=@vOCID ", " AND 1<>1") & vbCrLf '1<>1 沒有資料

                If DistID <> "" Then sql &= " and d.DistID=@DistID" & vbCrLf

                If SelResultID <> "" Then sql &= " and k.SelResultID=@SelResultID" & vbCrLf

                Select Case WOResult
                    Case "-1" '缺考(Stud_EnterType).FLOAT
                        sql &= " and b.WriteResult=-1 and b.OralResult=-1" & vbCrLf
                    Case "1" '非缺考(Stud_EnterType).FLOAT
                        sql &= " and (b.WriteResult >=0 or b.OralResult >=0)" & vbCrLf
                    Case Else
                        sql &= " AND 1<>1" & vbCrLf '沒有資料
                End Select
                If EnterPathY <> "" Then sql &= " AND b.EnterPath=@EnterPathY" & vbCrLf

                If EnterPathN <> "" Then sql &= " AND ISNULL(b.EnterPath,' ') !=@EnterPathN" & vbCrLf

                sql &= " order by b.ExamNO" & vbCrLf
                Dim sCmd As New SqlCommand(sql, tConn)
                Call OpenDbConn(tConn)
                With sCmd
                    .Parameters.Clear()
                    If vOCID <> "" Then .Parameters.Add("vOCID", SqlDbType.VarChar).Value = vOCID
                    If DistID <> "" Then .Parameters.Add("DistID", SqlDbType.VarChar).Value = DistID
                    If SelResultID <> "" Then .Parameters.Add("SelResultID", SqlDbType.VarChar).Value = SelResultID
                    If EnterPathY <> "" Then .Parameters.Add("EnterPathY", SqlDbType.VarChar).Value = EnterPathY
                    If EnterPathN <> "" Then .Parameters.Add("EnterPathN", SqlDbType.VarChar).Value = EnterPathN
                    dtR.Load(.ExecuteReader())
                End With
        End Select
        Return dtR
    End Function

    '匯出條碼39供郵局間接。
    Public Shared Sub ExpRptb39(ByVal MyPage As Page, ByRef oConn As SqlConnection, ByRef dt As DataTable)
        MyPage.Response.ContentEncoding = System.Text.Encoding.GetEncoding("big5")
        'Dim Y, M, D As String
        Dim sYyyyMMdd As String = DateTime.Today.ToString("yyyyMMdd")
        Dim sFName As String = sYyyyMMdd & ".csv"

        '提示使用者是否要儲存檔案
        MyPage.Response.AddHeader("content-disposition", "attachment; filename=" & sFName)

        '直接在ie內頁顯示內容
        'Response.AddHeader("content-disposition", "inline; filename=" & FName)

        '文件內容指定為excel
        MyPage.Response.ContentType = "application/vnd.ms-excel;charset=Big5"

        '分署、班級名稱、條碼值、收件人、郵遞區號、地址
        Dim str_OutPutStr As String = ""
        str_OutPutStr &= "分署" 'distname
        str_OutPutStr &= ",班級名稱" 'classcname
        str_OutPutStr &= ",條碼值" 'barcode39
        str_OutPutStr &= ",收件人" 'Name
        str_OutPutStr &= ",郵遞區號" 'StudZipCode
        str_OutPutStr &= ",地址" 'StudAddress
        str_OutPutStr &= vbCrLf

        '要輸出的ht內容
        MyPage.Response.BinaryWrite(System.Text.Encoding.Convert(System.Text.Encoding.Unicode, System.Text.Encoding.Default, System.Text.Encoding.Unicode.GetBytes(str_OutPutStr)))

        For Each dr As DataRow In dt.Rows

            Dim strLine As New System.Text.StringBuilder
            strLine.Append(dr("distname"))
            strLine.Append(",").Append(dr("classcname"))
            strLine.Append(",").Append(dr("barcode39"))
            strLine.Append(",").Append(dr("Name"))
            strLine.Append(",").Append(dr("StudZipCode"))
            strLine.Append(",").Append(dr("StudAddress"))
            strLine.Append(vbCrLf)

            MyPage.Response.BinaryWrite(System.Text.Encoding.Convert(System.Text.Encoding.Unicode, System.Text.Encoding.Default, System.Text.Encoding.Unicode.GetBytes(strLine.ToString())))
        Next
        '替代 .End()，避免 System.Threading.ThreadAbortException 
        Utl_RespWriteEnd(MyPage, oConn, "")
        'Call CloseDbConn(oConn) '結束程式執行 MyPage.Response.End()
    End Sub

