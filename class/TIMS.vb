    ''' <summary>  msg-寫入log檔案 yyyyMMdd </summary>
    ''' <param name="MyPage"></param>
    ''' <param name="sLogMessage"></param>
    Public Shared Sub WriteLog(ByRef MyPage As Page, ByVal sLogMessage As String)
        Dim sMyFilePath As String = MyPage.Server.MapPath("~/logs/")
        Dim MyFileName As String = String.Format("{0}.txt", Format(Now, "yyyyMMdd"))
        Dim Logfiles1 As String = sMyFilePath & MyFileName 'cst_Logfiles1
        '判斷Log紀錄檔是否存在
        If Not System.IO.Directory.Exists(sMyFilePath) Then
            System.IO.Directory.CreateDirectory(sMyFilePath)
            Threading.Thread.Sleep(1) '假設處理某段程序需花費1毫秒 (避免機器不同步)
        End If
        '判斷Log紀錄檔是否存在
        If Not IO.File.Exists(Logfiles1) Then
            '若檔案不存在製造預設值
            Dim sr2 As System.IO.Stream
            sr2 = System.IO.File.OpenWrite(Logfiles1)
            sr2.Close()
        End If
        '寫入新的錯誤訊息
        Dim srr2 As New System.IO.StreamWriter(Logfiles1, True, System.Text.Encoding.Default)
        srr2.WriteLine(String.Format("{0}  {1}", CStr(Now), sLogMessage))
        srr2.Flush()
        srr2.Close()
    End Sub

