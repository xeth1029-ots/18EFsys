    ''' <summary>db確認資料不存在</summary>
    ''' <param name="sm"></param>
    ''' <param name="oConn"></param>
    ''' <param name="ItemName"></param>
    ''' <returns></returns>
    Public Shared Function InsertCookieTableCheck1(ByRef sm As SessionModel, ByRef oConn As SqlConnection, ByRef ItemName As String) As Boolean
        Call OpenDbConn(oConn)
        Dim Account As String = ClearSQM(sm.UserInfo.UserID)
        Dim PlanID As String = ClearSQM(sm.UserInfo.PlanID)
        If Account = "" OrElse PlanID = "" Then Return False
        Dim dt1 As New DataTable
        Dim SQL1 As String = " SELECT 1 FROM COOKIE_DATA WITH(NOLOCK) WHERE ACCOUNT=@ACCOUNT AND PLANID=@PlanID AND ITEMNAME=@ItemName"
        Using SCMD1 As New SqlCommand(SQL1, oConn)
            With SCMD1
                .Parameters.Add("ACCOUNT", Account)
                .Parameters.Add("PlanID", PlanID)
                .Parameters.Add("ItemName", ItemName)
                dt1.Load(.ExecuteReader())
            End With
        End Using
        Return dtNODATA(dt1)
    End Function

    '新增快取資料
    Public Shared Sub InsertCookieTable(ByRef MyPage As Page, ByRef dt As DataTable, ByRef da As SqlDataAdapter,
                                        ByVal ItemName As String, ByVal ItemValue As String,
                                        ByVal flag_save As Boolean, ByRef oConn As SqlConnection) 'Optional ByVal save As Boolean=False
        Dim dr As DataRow = Nothing
        Dim sm As SessionModel = SessionModel.Instance()

        Dim Account As String = ClearSQM(sm.UserInfo.UserID)
        Dim PlanID As String = ClearSQM(sm.UserInfo.PlanID)
        If Account = "" OrElse PlanID = "" Then Exit Sub
        ItemName = ClearSQM(ItemName)
        ItemValue = ClearSQM(ItemValue)
        If ItemName = "" Then Exit Sub
        If dt Is Nothing Then
            Call OpenDbConn(oConn)
            Dim sql As String = " SELECT * FROM COOKIE_DATA WHERE Account='" & Account & "' AND PLANID='" & PlanID & "'"
            dt = DbAccess.GetDataTable(sql, da, oConn)
        End If

        Dim FF3 As String = "ItemName='" & ItemName & "'"
        If dt.Select(FF3).Length = 0 Then
            If InsertCookieTableCheck1(sm, oConn, ItemName) Then
                dr = dt.NewRow
                dt.Rows.Add(dr)
                dr("Account") = Account
                dr("PlanID") = PlanID
                dr("ItemName") = ItemName
                dr("ItemValue") = If(ItemValue = "", " ", ItemValue)
            End If
        Else
            dr = dt.Select(FF3)(0)
            dr("ItemValue") = If(ItemValue = "", " ", ItemValue)
        End If

        If flag_save Then DbAccess.UpdateDataTable(dt, da)

    End Sub

    '取得使用者輸入性別 依身份証判斷
    Public Shared Function GetMemberSex(ByVal IDNO As String) As String
        'Dim flag As Boolean=False
        Dim rst As String = "M" '預設為 男@M
        If IDNO.Length > 1 Then
            Select Case IDNO.Substring(1, 1)
                Case "1", "A", "C", "8" '男:M
                    rst = "M"
                Case "2", "B", "D", "9" '女:F
                    rst = "F"
            End Select
        End If
