    ''' <summary> 取得zipNmae '傳入 郵遞區號，回傳地區名稱 </summary>
    ''' <param name="zipCode"></param>
    ''' <param name="zipcodeNW"></param>
    ''' <param name="dtZip"></param>
    ''' <returns></returns>
    Public Shared Function getZipName2(ByVal zipCode As String, ByVal zipcodeNW As String, ByRef dtZip As DataTable) As String
        Dim rst As String = "" 'zipCode2

        Dim flag_use_5w As Boolean = If(zipcodeNW.Length = 5, True, False)
        Dim flag_use_6w As Boolean = If(zipcodeNW.Length = 6, True, False)
        Dim flag_use_B2 As Boolean = If(zipcodeNW.Length = 2, True, False)
        Dim flag_use_B3 As Boolean = If(zipcodeNW.Length = 3, True, False)
        Dim zipcodeA As String = zipCode
        Dim i_zipCode As Integer = 0
        Dim ff3 As String = ""
        If flag_use_5w OrElse flag_use_6w Then
            zipcodeA = zipcodeNW '6碼
            zipCode = ClearSQM(zipcodeNW.Substring(0, 3))
            If (Not Int32.TryParse(zipCode, i_zipCode)) Then Return rst
            If i_zipCode < 0 OrElse i_zipCode > 999 Then Return rst

            ff3 = String.Concat("ZipCode='", zipCode, "'")
            If dtZip.Select(ff3).Length = 0 Then Return rst
            zipcodeA = String.Concat(zipCode, zipcodeNW)
            Dim dr1 As DataRow = dtZip.Select(ff3)(0)
            rst = String.Format("({0}){1}{2}", zipcodeA, dr1("ZipName"), dr1("LName"))
        ElseIf flag_use_B2 OrElse flag_use_B3 Then
            zipCode = ClearSQM(zipCode) '3碼
            If zipCode = "" Then Return rst
            If (Not Int32.TryParse(zipCode, i_zipCode)) Then Return rst
            If i_zipCode < 0 OrElse i_zipCode > 999 Then Return rst

            ff3 = String.Concat("ZipCode='", zipCode, "'")
            If dtZip.Select(ff3).Length = 0 Then Return rst
            zipcodeA = String.Concat(zipCode, zipcodeNW) '組合3+3 // 3+2
            Dim dr1 As DataRow = dtZip.Select(ff3)(0)
            rst = String.Format("({0}){1}{2}", zipcodeA, dr1("ZipName"), dr1("LName"))
        ElseIf zipCode <> "" Then
            If (Not Int32.TryParse(zipCode, i_zipCode)) Then Return rst
            If i_zipCode < 0 OrElse i_zipCode > 999 Then Return rst

            ff3 = String.Concat("ZipCode='", zipCode, "'")
            If dtZip.Select(ff3).Length = 0 Then Return rst
            zipcodeA = String.Concat(zipCode, zipcodeNW) '組合3+3 // 3+2
            Dim dr1 As DataRow = dtZip.Select(ff3)(0)
            rst = String.Format("({0}){1}{2}", zipcodeA, dr1("ZipName"), dr1("LName"))
        End If
        Return rst
    End Function

