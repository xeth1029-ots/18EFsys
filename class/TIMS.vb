        Dim sql As String = "SELECT 'x' from class_studentsofclass WHERE ocid=@ocid and socid=@socid"
        Dim sCmd As New SqlCommand(sql, objconn)
        Call OpenDbConn(objconn)
        Dim dt As New DataTable
        With sCmd
            .Parameters.Clear()
            .Parameters.Add("ocid", SqlDbType.VarChar).Value = ocid
            .Parameters.Add("socid", SqlDbType.VarChar).Value = socid
            dt.Load(.ExecuteReader())
        End With
        If dt.Rows.Count = 1 Then rst = True '有一筆資料時是對的
        Return rst
    End Function

