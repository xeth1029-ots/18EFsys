    ''' <summary> 傳入郵遞區號，回傳組合地址 </summary>
    ''' <param name="zipcodeNW"></param>
    ''' <param name="sAddress"></param>
    ''' <param name="sPLACENAME"></param>
    ''' <param name="dtZip"></param>
    ''' <returns></returns>
    Public Shared Function getZipName6(ByVal zipcodeNW As String, ByVal sAddress As String,
                                       ByVal sPLACENAME As String, ByRef dtZip As DataTable) As String
        Dim rst As String = ""
        sAddress = If(sAddress <> "", Trim(sAddress), "")
        zipcodeNW = ClearSQM(zipcodeNW) 'zipcodeNW=If(zipcodeNW <> "", Trim(zipcodeNW), "")
        sPLACENAME = If(sPLACENAME <> "", Trim(sPLACENAME), "")
        Dim s_zipCode As String = ""
        Dim s_zipCode3 As String = ""
        Dim s_ZipName As String = ""

        Dim flag_use_5w As Boolean = If(zipcodeNW.Length = 5, True, False) '3+2
        Dim flag_use_6w As Boolean = If(zipcodeNW.Length = 6, True, False) '3+3
        Dim flag_use_F3 As Boolean = If(zipcodeNW.Length = 3, True, False) '前3碼
        rst = ""
        If flag_use_F3 OrElse flag_use_5w OrElse flag_use_6w Then s_zipCode = zipcodeNW.Substring(0, 3) '前3碼
        If flag_use_5w Then s_zipCode3 = zipcodeNW.Substring(3, 2) '後2碼
        If flag_use_6w Then s_zipCode3 = zipcodeNW.Substring(3, 3) '後3碼
        If s_zipCode = "" Then Return rst
        If Not IsNumeric2(s_zipCode) Then Return rst

        If s_zipCode <> "" AndAlso IsNumeric2(s_zipCode) Then
            Dim ff3 As String = "ZipCode='" & s_zipCode & "'"
            If dtZip.Select(ff3).Length > 0 Then
                Dim dr1 As DataRow = dtZip.Select(ff3)(0)
                s_ZipName = Convert.ToString(dr1("ZipName"))
            End If
        End If

        rst = ""
        If s_zipCode <> "" Then rst &= s_zipCode
        If s_zipCode3 <> "" Then rst &= String.Concat("-", s_zipCode3)
        If s_ZipName <> "" Then rst &= s_ZipName
        If sAddress <> "" Then rst &= sAddress
        If sPLACENAME <> "" Then rst &= String.Concat(" (", sPLACENAME, ")")
        Return rst
    End Function

