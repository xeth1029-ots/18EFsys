    '檢核該計畫班別代碼是否有設定 依大計畫、轄區、年度
    Public Shared Function CheckCLSID(ByRef MyPage As Page, ByRef oConn As SqlConnection) As Boolean
        Dim Rst As Boolean = False
        Dim sm As SessionModel = SessionModel.Instance()

        Dim iPYNum As Integer = 1 'iPYNum=sUtl_GetPYNum(Me) '1:2017前 2:2017 3:2018
        iPYNum = sUtl_GetPYNum(MyPage)

        'penny 加入職類判斷
        Dim sqlstr As String = ""
        sqlstr &= " SELECT a.CLSID,a.CLASSID,a.CLASSNAME,a.CONTENT,c.TMID" & vbCrLf
        Select Case iPYNum
            Case Is >= 3
                sqlstr &= " ,c.TRAINID,c.TRAINNAME,c.JOBID,c.JOBNAME" & vbCrLf
            Case Else
                sqlstr &= " ,ISNULL(c.JOBID, c.TRAINID) TRAINID" & vbCrLf
                sqlstr &= " ,ISNULL(c.JOBNAME, c.TRAINNAME) TRAINNAME" & vbCrLf
                sqlstr &= " ,ISNULL(c.JOBID, c.TRAINID) JOBID" & vbCrLf
                sqlstr &= " ,ISNULL(c.JOBNAME, c.TRAINNAME) JOBNAME" & vbCrLf
        End Select

        sqlstr &= " FROM dbo.ID_CLASS a" & vbCrLf
        sqlstr &= " JOIN dbo.KEY_PLAN b ON a.TPLANID=b.TPLANID" & vbCrLf
        If Cst_TPlanID28AppPlan.IndexOf(sm.UserInfo.TPlanID) > -1 Then
            '產投類
            Select Case iPYNum
                Case Is >= 3
                    sqlstr &= " JOIN (SELECT * FROM dbo.VIEW_TRAINTYPE WHERE BUSID='H') c ON a.TMID=c.TMID" & vbCrLf
                Case Else
                    sqlstr &= " JOIN (SELECT * FROM dbo.KEY_TRAINTYPE WHERE PARENT=197) c ON a.TMID=c.TMID" & vbCrLf
            End Select
        Else
            sqlstr &= " JOIN dbo.KEY_TRAINTYPE c ON a.TMID=c.TMID" & vbCrLf
        End If
        sqlstr &= " WHERE a.TPLANID='" & sm.UserInfo.TPlanID & "'" & vbCrLf
        sqlstr &= " AND a.DISTID='" & sm.UserInfo.DistID & "'" & vbCrLf
        sqlstr &= " AND a.YEARS='" & sm.UserInfo.Years & "'" & vbCrLf

        Dim oCmd As New SqlCommand(sqlstr, oConn)
        Call OpenDbConn(oConn)
        Dim dt As New DataTable
        With oCmd
            .Parameters.Clear()
            dt.Load(.ExecuteReader())
        End With
        If dt.Rows.Count > 0 Then Rst = True '有資料為True
        Return Rst
    End Function

