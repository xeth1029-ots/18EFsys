    'SOP檢驗日期輸入 yyyy/MM/dd。
    Public Shared Sub CheckDateErr(ByRef sChkDate As String, ByVal txtName As String, ByVal beUse As Boolean, ByRef sErrMessage As String)
        If sChkDate <> "" Then sChkDate = Trim(sChkDate)
        If beUse AndAlso sChkDate = "" Then sErrMessage &= $"{txtName} 為必填資料!" & vbCrLf
        Try
            If sChkDate <> "" Then
                If IsDate(sChkDate) Then
                    sChkDate = CDate(sChkDate).ToString("yyyy/MM/dd")
                Else
                    sErrMessage &= $"{txtName} 日期格式有誤(yyyy/MM/dd)!" & vbCrLf
                End If
            End If
        Catch ex As Exception
            LOG.Warn(ex.Message, ex)
            sErrMessage &= $"{txtName} 日期格式有誤(yyyy/MM/dd)!" & vbCrLf
        End Try
    End Sub

    'SOP檢驗代碼輸入資料。(錯誤輸出為網頁式加BR)
    Public Shared Function CheckIDValeuErr(ByRef MyValue As String, ByVal txtName As String, ByVal beUse As Boolean,
                                           ByVal colName As String, ByRef dtKey As DataTable, ByRef sErrMessage As String) As Boolean
        Dim rst As Boolean = True '檢查ok為True
        If MyValue <> "" Then MyValue = Trim(MyValue)
        If MyValue <> "" Then MyValue = ClearSQM(MyValue)
        If beUse AndAlso MyValue = "" Then
            rst = False
            sErrMessage &= $"必須填寫 {txtName}<BR>"
        End If
        If MyValue <> "" Then
            Dim sff As String = $"{colName}='{ChangeSQM(MyValue)}'"
            Try
                If dtKey.Select(sff).Length = 0 Then
                    rst = False
                    sErrMessage &= $"{txtName}不符合鍵詞<BR>"
                End If
            Catch ex As Exception
                LOG.Warn(ex.Message, ex)
                rst = False
                sErrMessage &= $"{txtName}不符合鍵詞<BR>"
            End Try
        End If
        Return rst
    End Function

