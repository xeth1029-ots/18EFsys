    '取出計價模式(PLAN_COSTCATE)
    Public Shared Function GetCostMode(ByRef MyPage As Page, ByRef oConn As SqlConnection) As Integer
        Dim iRst As Integer = 0 '(0:異常)
        '1.成本加工費法(限定自辦使用)'2.每人每時單價計價法'3.每人輔助單價計價法'4.個人單價計價法
        ' (直接在 AuthBasePage 處理, 不用個別檢查 Session) If TIMS.ChkSession(MyPage) Then Return iRst

        Dim sm As SessionModel = SessionModel.Instance()
        Dim sql As String = "SELECT * FROM PLAN_COSTCATE WHERE TPlanID=@TPlanID"
        Dim sCmd As New SqlCommand(sql, oConn)
        Call OpenDbConn(oConn)
        Dim dt As New DataTable
        With sCmd
            .Parameters.Clear()
            .Parameters.Add("TPlanID", SqlDbType.VarChar).Value = CStr(sm.UserInfo.TPlanID)
            dt.Load(.ExecuteReader())
        End With
        If dt.Rows.Count = 0 Then Return 0
        Dim dr As DataRow = dt.Rows(0)

        iRst = dr("CateNo")
        Select Case iRst
            Case 2 '2.每人每時
                Return iRst
            Case 3 '3.每人輔助
                Return iRst
            Case 4 '4.個人單價
                Return iRst
            Case 1
                '此訓練計畫採成本加工費法(計價種類限定使用:自辦 非委外)!!
                iRst = 0
            Case Else
                iRst = 0
        End Select
        Return iRst
    End Function

    '取得REVISE_COSTITEM 的序號 iO1N2 : 1@Old /2@New
    Public Shared Function Get_REVC_RCID(ByVal sCmdArg As String, ByVal iO1N2 As Integer, ByVal tConn As SqlConnection) As Integer
        Dim iRCIDrst As Integer = 0
        Dim rPlanID As String = GetMyValue(sCmdArg, "rPlanID")
        Dim rComIDNO As String = GetMyValue(sCmdArg, "rComIDNO")
        Dim rSeqNo As String = GetMyValue(sCmdArg, "rSeqNo")
        Dim rSCDate As String = GetMyValue(sCmdArg, "rSCDate")
        Dim rSubSeqNO As String = GetMyValue(sCmdArg, "rSubSeqNO")

        Dim sql As String = ""
        sql &= " SELECT RCID FROM REVISE_COSTITEM"
        sql &= " WHERE PlanID=@PlanID and ComIDNO=@ComIDNO and SeqNO=@SeqNO"
        sql &= " and CDATE=@CDATE and SUBSEQNO=@SUBSEQNO and O1N2=@O1N2"
        Dim sCmdC1 As New SqlCommand(sql, tConn)

        Dim dt1 As New DataTable
        With sCmdC1
            .Parameters.Clear()
            .Parameters.Add("PLANID", SqlDbType.Int).Value = rPlanID
            .Parameters.Add("COMIDNO", SqlDbType.VarChar).Value = rComIDNO
            .Parameters.Add("SEQNO", SqlDbType.Int).Value = rSeqNo
            .Parameters.Add("CDATE", SqlDbType.DateTime).Value = Cdate2(rSCDate)
            .Parameters.Add("SUBSEQNO", SqlDbType.Int).Value = CINT1(rSubSeqNO)
            .Parameters.Add("O1N2", SqlDbType.Int).Value = iO1N2
            dt1.Load(.ExecuteReader())
        End With
        If dt1.Rows.Count > 0 Then iRCIDrst = dt1.Rows(0)("RCID")
        Return iRCIDrst
    End Function

    '取得申請變更的資訊
    Public Shared Function GET_REVISE_COSTITEMdt(ByVal sCmdArg As String, ByVal iRCID As Integer, ByVal iO1N2 As Integer, ByVal tConn As SqlConnection) As DataTable
        Dim rPlanID As String = GetMyValue(sCmdArg, "rPlanID")
        Dim rComIDNO As String = GetMyValue(sCmdArg, "rComIDNO")
        Dim rSeqNo As String = GetMyValue(sCmdArg, "rSeqNo")
        Dim rSCDate As String = GetMyValue(sCmdArg, "rSCDate")
        Dim rSubSeqNO As String = GetMyValue(sCmdArg, "rSubSeqNO")
        Dim sql As String = "SELECT * FROM PLAN_COSTITEM WHERE 1<>1"
        Dim dt3 As DataTable = DbAccess.GetDataTable(sql, tConn)

        sql = "SELECT * FROM REVISE_COSTITEM WHERE RCID=" & iRCID & " and O1N2=" & iO1N2
        Dim dr1 As DataRow = DbAccess.GetOneRow(sql, tConn)
        If dr1 Is Nothing Then Return dt3

        sql = ""
        sql &= " SELECT * FROM REVISE_COSTITEM_L1 WHERE RCID=" & iRCID & " and O1N2=" & iO1N2
        sql &= " ORDER BY COSTID"
        Dim dt2 As DataTable = DbAccess.GetDataTable(sql, tConn)
        If dt2.Rows.Count = 0 Then Return dt3

        For Each drV As DataRow In dt2.Rows '(REVISE_COSTITEM_L1)
            Dim objrow As DataRow = dt3.NewRow() '(PLAN_COSTITEM)
            dt3.Rows.Add(objrow)
            objrow("PCID") = drV("RCNID")
            objrow("PLANID") = rPlanID
            objrow("COMIDNO") = rComIDNO
            objrow("SEQNO") = rSeqNo
            objrow("COSTMODE") = dr1("COSTMODE")
            objrow("COSTID") = drV("COSTID")
            objrow("ITEMOTHER") = drV("ITEMOTHER")
            objrow("OPRICE") = drV("OPRICE")
            objrow("ITEMAGE") = drV("ITEMAGE")
            objrow("ITEMCOST") = drV("ITEMCOST")
            objrow("ADMFLAG") = drV("ADMFLAG")
            objrow("TAXFLAG") = drV("TAXFLAG")
            objrow("ModifyAcct") = drV("ModifyAcct")
            objrow("ModifyDate") = drV("ModifyDate")
        Next
        Return dt3
    End Function

    '請先完成訓期已滿1/2學員離退訓作業
    Public Shared Function Chk_SELRESULTBLIDET(ByVal OCID1 As String, ByRef oConn As SqlConnection) As Boolean
        Dim rst As Boolean = False '查無資料ok ，查有資料異常
        If OCID1 = "" Then Return rst
        'https://jira.turbotech.com.tw/browse/TIMSC-246
        Dim sql As String = ""
        sql &= " with wc1 as (select ocid,idno,studstatus from v_studentinfo where ocid=@OCID1)" & vbCrLf
        sql &= " select cc.OCID,a.IDNO" & vbCrLf
        sql &= " ,x.ocid x_OCID ,x.idno x_IDNO" & vbCrLf
        sql &= " FROM STUD_SELRESULTBLI bi" & vbCrLf
        sql &= " JOIN STUD_SELRESULTBLIDET bd on bi.SB3ID=bd.SB3ID" & vbCrLf
        sql &= " JOIN VIEW2 cc on cc.ocid=bd.ocid" & vbCrLf
        sql &= " JOIN VIEW_PLAN ip on ip.planid=cc.planid" & vbCrLf
        sql &= " JOIN STUD_ENTERTEMP a on a.SETID=bi.SETID" & vbCrLf
        sql &= " JOIN STUD_ENTERTYPE b on b.setid=bi.setid and b.enterdate=bi.enterdate and b.sernum=bi.sernum" & vbCrLf
        '是學員
        sql &= " join wc1 xc on xc.ocid=cc.ocid and xc.idno=a.idno" & vbCrLf
        '有做離退訓
        sql &= " left join wc1 x on x.ocid=cc.ocid and x.idno=a.idno AND x.studstatus in (2,3)" & vbCrLf
        sql &= " WHERE ip.tplanid in (" & Cst_TPlanID_BliDet201605 & ")" & vbCrLf
        sql &= " and ip.tplanid not in (" & Cst_TPlanID_BliDet201605_NG & ")" & vbCrLf
        sql &= " AND cc.IsSuccess='Y' AND cc.NotOpen='N'" & vbCrLf
        sql &= " and bd.STATUSNC2='2'" & vbCrLf
        sql &= " AND bd.STATUSPT IN ('ST2')" & vbCrLf
        sql &= " and cc.ocid=@OCID1 and x.idno is null" & vbCrLf
        Dim sCmd As New SqlCommand(sql, oConn)
        Call OpenDbConn(oConn)
        Dim dt As New DataTable
        With sCmd
            .Parameters.Clear()
            .Parameters.Add("OCID1", SqlDbType.VarChar).Value = OCID1
            dt.Load(.ExecuteReader())
        End With
        If dt.Rows.Count > 0 Then rst = True
        Return rst
    End Function

    ''' <summary> 遞補學員 使用SCMD's_type 'SF:取得確認狀態 SS:取得學員狀態 </summary>
    ''' <param name="s_type">SF/SS</param>
    ''' <param name="oConn"></param>
    ''' <param name="Trans"></param>
    ''' <returns></returns>
    ''' <remarks></remarks>
    Public Shared Function Get_StudCMDX(ByVal s_type As String,
                                        ByRef oConn As SqlConnection,
                                        ByRef Trans As SqlTransaction) As SqlCommand
        Dim sql As String = ""
        Select Case s_type 'SF:取得確認狀態 SS:取得學員狀態
            Case "SF" '取得確認狀態 STUDMODE: NULL/A/2/3 'A:遞補學員 2/3:離退訓 NULL:正常清單 STUD_CONFIRM
                sql &= " SELECT STUDMODE FROM STUD_CONFIRM"
                sql &= " WHERE OCID=@vOCID AND CFSEQNO=@CFSEQNO AND SOCID=@SOCID"
                Dim sCmd_SF1 As New SqlCommand(sql, oConn)
                If Not Trans Is Nothing Then sCmd_SF1 = New SqlCommand(sql, oConn, Trans)
                Return sCmd_SF1

            Case "SS" '取得學員狀態 CLASS_STUDENTSOFCLASS
                sql &= " SELECT OCID,SOCID,STUDSTATUS FROM CLASS_STUDENTSOFCLASS" & vbCrLf
                sql &= " WHERE OCID=@vOCID AND SOCID=@SOCID" & vbCrLf
                Dim sCmd_SS1 As New SqlCommand(sql, oConn)
                If Not Trans Is Nothing Then sCmd_SS1 = New SqlCommand(sql, oConn, Trans)
                Return sCmd_SS1
        End Select
        Return Nothing
    End Function

    ''' <summary> 查無資料，則為遞補人員 '非第1次, 可能有-遞補學員 </summary>
    ''' <param name="vOCID"></param>
    ''' <param name="iCFSEQNO_N"></param>
    ''' <param name="SOCID"></param>
    ''' <param name="sCmd_SF1"></param>
    ''' <param name="sCmd_SS1"></param>
    ''' <returns></returns>
    Public Shared Function Get_STUDMODE1(ByVal vOCID As String, ByVal iCFSEQNO_N As Integer,
                                         ByVal SOCID As String,
                                         ByVal sCmd_SF1 As SqlCommand, ByVal sCmd_SS1 As SqlCommand) As String
        If (vOCID = "" OrElse SOCID = "") Then Return ""
        If (iCFSEQNO_N < 0) Then Return ""
        Dim rst As String = "A" 'A:遞補學員 2/3:離退訓 NULL:正常清單
        'SELECT STUDMODE,COUNT(1) CNT ,MIN(MODIFYDATE),MAX(MODIFYDATE) FROM STUD_CONFIRM GROUP BY STUDMODE
        Dim dt As New DataTable
        With sCmd_SF1
            .Parameters.Clear()
            .Parameters.Add("vOCID", SqlDbType.Int).Value = CINT1(vOCID)
            .Parameters.Add("CFSEQNO", SqlDbType.Int).Value = iCFSEQNO_N '上次
            .Parameters.Add("SOCID", SqlDbType.Int).Value = CINT1(SOCID)
            dt.Load(.ExecuteReader())
        End With
        If dt.Rows.Count = 0 Then Return rst '(上次)查無資料，則為遞補人員

        Dim vSTUDMODE_1 As String = Convert.ToString(dt.Rows(0)("STUDMODE"))
        Select Case vSTUDMODE_1
            Case "2", "3", "A"
                Dim dt1 As New DataTable
                With sCmd_SS1
                    .Parameters.Clear()
                    .Parameters.Add("vOCID", SqlDbType.Int).Value = CINT1(vOCID)
                    .Parameters.Add("SOCID", SqlDbType.Int).Value = CINT1(SOCID)
                    dt1.Load(.ExecuteReader())
                End With
                If dt1.Rows.Count = 0 Then
                    Return "2" '查無學員資料該學員被離訓
                End If
                Select Case Convert.ToString(dt1.Rows(0)("STUDSTATUS"))
                    Case "2", "3"
                        Return Convert.ToString(dt1.Rows(0)("STUDSTATUS")) '查學員資料該學員被離/退訓
                End Select
                rst = vSTUDMODE_1 '上次的狀況 (A/2/3) 'A:遞補學員 2/3:離退訓 NULL:正常清單
            Case Else
                rst = "" '0/NULL:正常清單
        End Select
        Return rst
    End Function

    ''' <summary>
    ''' 取得該班，最大可用序號(+1) 從1開始
    ''' </summary>
    ''' <param name="vOCID"></param>
    ''' <param name="oConn"></param>
    ''' <returns></returns>
    Public Shared Function Get_CFSEQNO1(ByVal vOCID As String, ByRef oConn As SqlConnection) As Integer
        Dim rst As Integer = 1 '應該是從1開始  SELECT MIN(CFSEQNO),MAX(CFSEQNO) FROM CLASS_CONFIRM
        If vOCID = "" Then Return rst

        Dim sql As String = ""
        sql &= " SELECT CFSEQNO ,CFSEQNO+1 CFSEQNO1"
        sql &= " FROM CLASS_CONFIRM"
        sql &= " WHERE OCID=@vOCID"
        sql &= " ORDER BY CFSEQNO DESC" & vbCrLf
        Dim sCmd As New SqlCommand(sql, oConn)
        Dim dt As New DataTable
        With sCmd
            .Parameters.Clear()
            .Parameters.Add("vOCID", SqlDbType.Int).Value = CINT1(vOCID)
            dt.Load(.ExecuteReader())
        End With
        If dt.Rows.Count = 0 Then Return rst '無資料從1開始
        rst = CINT1(dt.Rows(0)("CFSEQNO1")) '有資料加1(+1)
        Return rst
    End Function

