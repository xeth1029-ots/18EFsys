    '(近3年) 取得該學員所有報名日期。(產投限定)
    Public Shared Function GetRelEnterDateDtY3(ByVal UserIDNO As String, ByVal UserBirth As String,
                                               ByVal sDate As String, ByVal eDate As String,
                                               ByVal tConn As SqlConnection) As DataTable
        '1.sDate eDate 為必填值 2.因為有可能沒有參訓資料，所以資料往前推3年
        Dim dt As DataTable = Nothing
        Dim sql As String = ""
        sql &= " WITH WS1 AS ( SELECT ss.IDNO,ss.OCID,ss.STUDSTATUS" & vbCrLf
        sql &= " FROM V_STUDENTINFO ss" & vbCrLf
        sql &= " WHERE ss.IDNO='" & UserIDNO & "'" & vbCrLf
        sql &= " AND CONVERT(date,ss.FTDATE) >= CONVERT(date,GETDATE())" & " )" & vbCrLf

        sql &= " SELECT se2.eSerNum" & vbCrLf
        sql &= " ,se2.eSETID" & vbCrLf
        sql &= " ,se2.RelEnterDate" & vbCrLf
        sql &= " ,se2.signUpMemo" & vbCrLf
        sql &= " ,se1.IDNO" & vbCrLf
        sql &= " ,CONVERT(varchar, se1.Birthday, 111) Birthday" & vbCrLf
        sql &= " ,cc.OCID" & vbCrLf
        sql &= " ,CONVERT(varchar, cc.STDate, 111) STDate" & vbCrLf
        sql &= " ,CONVERT(varchar, cc.FTDate, 111) FTDate" & vbCrLf
        'TRound
        sql &= " ,dbo.FN_CDATE1B(cc.STDate)+'<br>~<br>'+DBO.FN_CDATE1B(cc.FTDate) TRound" & vbCrLf
        sql &= " ,ip.Years" & vbCrLf
        sql &= " ,ip.PlanName" & vbCrLf
        sql &= " ,ip.DistName" & vbCrLf
        sql &= " ,oo.Orgname" & vbCrLf
        sql &= " ,cc.CLASSCNAME" & vbCrLf
        sql &= " ,cc.THours" & vbCrLf
        sql &= " ,cc.TNum" & vbCrLf
        sql &= " ,case when ISNULL(se2.signno,-1)=-1 then '線上收件成功' else '線上收件成功<br>序號：'+convert(varchar,se2.signno) end signno" & vbCrLf
        'signUpStatus-0:收件完成 1:報名成功 2:報名失敗 3:正取(Key_SelResult) 4:備取 5:未錄取
        sql &= " ,se2.signUpStatus" & vbCrLf
        'sql &= " ,dbo.FN_GET_PLAN_ONCLASS(cc.PlanID,cc.ComIDNO,cc.SeqNo,'WEEKTIME') WEEKS2" & vbCrLf
        sql &= " ,CASE WHEN pp.tnum>0 THEN ROUND(convert(float,pp.totalcost)/pp.tnum,2) ELSE 0 END totalcost" & vbCrLf
        sql &= " ,CASE WHEN pp.tnum>0 THEN ROUND(convert(float,pp.defgovcost)/pp.tnum,2) ELSE 0 END defgovcost" & vbCrLf
        sql &= " ,CONVERT(varchar, GETDATE(), 111) ANOW" & vbCrLf
        '若超過開訓日 且超過報名結束日 則為1 否為0 (1:啟動'未錄取 顯示功能。)
        sql &= " ,CASE WHEN CONVERT(date,cc.STDate)<=CONVERT(date,GETDATE()) AND CONVERT(date,cc.FENTERDATE)<=CONVERT(date,GETDATE()) THEN 1 ELSE 0 END XDAY1" & vbCrLf
        '6個月內的報名資料，供計算使用金額比較使用。
        sql &= " ,CASE WHEN CONVERT(date,se2.EnterDate)>=CONVERT(date,DATEADD(day,-(30*6),GETDATE())) AND CONVERT(date,GETDATE())<Convert(date,cc.STDATE+15) THEN 1 ELSE 0 END XDAY2" & vbCrLf
        '3年內範圍資料
        sql &= " ,CASE WHEN convert(date,cc.STDate)>=" & To_date(sDate) & " AND convert(date,cc.STDate)<=" & To_date(eDate) & " then 1 else 0 END XDAY3" & vbCrLf
        sql &= " ,ISNULL(ss.STUDSTATUS,0) STUDSTATUS" & vbCrLf

        sql &= " FROM STUD_ENTERTEMP2 se1" & vbCrLf
        sql &= " JOIN STUD_ENTERTYPE2 se2 ON se1.eSETID=se2.eSETID" & vbCrLf
        sql &= " JOIN CLASS_CLASSINFO cc ON cc.OCID=se2.OCID1" & vbCrLf
        sql &= " JOIN PLAN_PLANINFO pp on pp.planid=cc.planid and pp.comidno=cc.comidno and pp.seqno=cc.seqno" & vbCrLf
        sql &= " JOIN ORG_ORGINFO oo on oo.comidno=cc.comidno" & vbCrLf
        sql &= " JOIN VIEW_PLAN ip ON ip.PlanID=cc.PlanID" & vbCrLf
        sql &= " LEFT JOIN WS1 ss on ss.IDNO=se1.IDNO AND ss.OCID=se2.OCID1" & vbCrLf
        sql &= " WHERE cc.STDATE >= CONVERT(date, DATEADD(YEAR,-1,GETDATE()))" & vbCrLf
        sql &= " AND cc.IsSuccess='Y'" & vbCrLf
        sql &= " AND cc.NotOpen='N'" & vbCrLf
        'sql &= " AND cc.STDate >= " & to_date(sDate) & vbCrLf
        sql &= " AND convert(date,cc.STDATE-180) <=@STDATE" & vbCrLf '往前推n日的開訓日(避免報名日後有重複班級)
        sql &= " AND ip.TPlanID IN (" & Cst_TPlanID28_1d & ")" & vbCrLf
        'sql &= " AND ip.TPlanID='28'" & vbCrLf
        sql &= " AND se1.IDNO=@IDNO" & vbCrLf
        'sql &= " AND se1.Birthday=@Birthday" & vbCrLf
        sql &= " ORDER BY 1,2" & vbCrLf
        'objstr &= " and cc.OCID='" & drv("OCIDID") & "'" & vbCrLf

        'parms.Add("STDATE", to_date(eDate)) '從字元字串轉換成日期及/或時間時，轉換失敗
        'parms.Add("Birthday", to_date(UserBirth))
        'parms.Add("Birthday", UserBirth)
        Dim parms As New Hashtable From {{"STDATE", eDate}, {"IDNO", UserIDNO}}
        dt = DbAccess.GetDataTable(sql, tConn, parms)
        Return dt
    End Function

