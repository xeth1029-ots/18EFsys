    '字串yyyyMMdd取得日期yyyy/MM/dd。
    Public Shared Function sUtl_YMDValue(ByVal s_yyyyMMdd As String) As String
        Dim rst As String = ""
        Try
            If s_yyyyMMdd.Length >= 8 Then
                rst = $"{Mid(s_yyyyMMdd, 1, 4)}/{Mid(s_yyyyMMdd, 5, 2)}/{Mid(s_yyyyMMdd, 7, 2)}"
                If IsDate(rst) Then rst = CDate(rst).ToString("yyyy/MM/dd")
            End If
        Catch ex As Exception
            rst = ""
        End Try
        Return rst
    End Function

    '檢查字串 是否為00:00~23:59 HH:MM。取得回傳值
    Public Shared Function sUtl_chkTIMEFormat(ByVal YMDvalue As String, ByRef sTIMEVal As String) As Boolean
        Dim rst As Boolean = True ' False
        Dim dtTime As DateTime
        Dim HH As Integer = 0
        Dim MM As Integer = 0
        Dim sHH As String = ""
        Dim sMM As String = ""
        Try
            If sTIMEVal.Length = 5 Then
                HH = CINT1(Mid(sTIMEVal, 1, 2))
                MM = CINT1(Mid(sTIMEVal, 4, 2))
                If HH < 0 OrElse HH > 23 Then rst = False
                If MM < 0 OrElse MM > 59 Then rst = False
                'rst=True
            End If
        Catch ex As Exception
            LOG.Warn(ex.Message, ex)
            rst = False
        End Try
        If rst Then
            sHH = Right($"0{HH}", 2)
            sMM = Right($"0{MM}", 2)
            sTIMEVal = $"{sHH}:{sMM}"
            Try
                dtTime = Convert.ToDateTime($"{YMDvalue} {sTIMEVal}")
            Catch ex As Exception
                LOG.Warn(ex.Message, ex)
                rst = False
            End Try
        End If
        Return rst
    End Function

    ''' <summary> 時分 顯示與值都是-2位數 HH MM[設定下拉DropDownList 初始值] </summary>
    ''' <param name="objHR"></param>
    ''' <param name="objMI"></param>
    Public Shared Sub SUB_SET_HR_MI(ByRef objHR As DropDownList, ByRef objMI As DropDownList)
        objHR.Items.Clear()
        objMI.Items.Clear()
        For iHRMI As Integer = 0 To 59
            If iHRMI <= 23 Then
                Dim vHR As String = Right($"0{iHRMI}", 2)
                objHR.Items.Add(New ListItem(vHR, vHR))
            End If
            Dim vMI As String = Right($"0{iHRMI}", 2)
            objMI.Items.Add(New ListItem(vMI, vMI))
        Next
        objHR.AppendDataBoundItems = True
        objMI.AppendDataBoundItems = True
        Common.SetListItem(objHR, "00")
        Common.SetListItem(objMI, "00")
    End Sub

