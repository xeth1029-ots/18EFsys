    Public Shared Function GetMinusPoint(ByRef oConn As SqlConnection, ByVal OCID As String, ByVal RID As String, ByVal PlanID As String) As EMinusPoint
        Dim strRtn As EMinusPoint = EMinusPoint.mpKey
        Call OpenDbConn(oConn)
        Dim sql As String = " select leaveid,minuspoint from org_leave where planid=@planid and orgid in (select orgid from auth_relship where rid=@rid)"
        Dim sCmd As New SqlCommand(sql, oConn)
        Dim dtOO As New DataTable
        With sCmd
            .Parameters.Clear()
            .Parameters.Add("planid", SqlDbType.VarChar).Value = PlanID 'sm.UserInfo.PlanID
            .Parameters.Add("rid", SqlDbType.VarChar).Value = RID
            dtOO.Load(.ExecuteReader())
        End With

        Dim sql2 As String = " select leaveid,minuspoint from class_leave where ocid=@ocid"
        Dim sCmd2 As New SqlCommand(sql2, oConn)
        Dim dtCC As New DataTable
        With sCmd2
            .Parameters.Clear()
            .Parameters.Add("ocid", SqlDbType.VarChar).Value = OCID
            dtCC.Load(.ExecuteReader())
        End With

        'strRtn=eMinusPoint.mpOrg
        If dtCC.Rows.Count > 0 Then
            strRtn = EMinusPoint.mpClass
        ElseIf dtOO.Rows.Count > 0 Then
            strRtn = EMinusPoint.mpOrg
        End If

        Return strRtn
    End Function

    Public Shared Function ChkUpper(ByVal str1 As String) As Boolean
        For i As Integer = 0 To str1.Length - 1
            If CheckABC(str1.Chars(i)) AndAlso str1.Chars(i) = UCase(str1.Chars(i)) Then
                Return True
            End If
        Next
        Return False
    End Function

    Public Shared Function ChkLower(ByVal str1 As String) As Boolean
        For i As Integer = 0 To str1.Length - 1
            If CheckABC(str1.Chars(i)) AndAlso str1.Chars(i) = LCase(str1.Chars(i)) Then
                Return True
            End If
        Next
        Return False
    End Function

    Public Shared Function ChkNumber(ByVal str1 As String) As Boolean
        Const cst_Number As String = "0123456789"
        For i As Integer = 0 To str1.Length - 1
            If cst_Number.IndexOf(str1.Chars(i)) > -1 Then Return True
        Next
        Return False
    End Function

    Public Shared Function ChkSymbol(ByVal str1 As String) As Boolean
        Const cst_Number As String = "~!@#$%^&*()_+=-`[]{};':<>?,./"
        'Const cst_Number As String="#!*()<>"
        For i As Integer = 0 To str1.Length - 1
            If cst_Number.IndexOf(str1.Chars(i)) > -1 Then Return True
        Next
        Return False
    End Function

    '未填列學員主要身分別及預算別之班級提示功能
    Public Shared Function Get_TIMSC227(ByRef MyPage As Page, ByRef oConn As SqlConnection) As String
        Dim rst As String = ""
        ' (直接在 AuthBasePage 處理, 不用個別檢查 Session) If TIMS.ChkSession(MyPage) Then Return rst 'SESSION不完整
        'https://jira.turbotech.com.tw/browse/TIMSC-227
        '截至今日尚有以下班級尚未於開訓後21日內完成學員資料維護作業：（班級名稱1）、（班級名稱2）、（…依此類推），請儘速至「首頁>>學員動態管理>>學員資料管理>> 學員資料維護」功能完成作業，倘已經完成之班級，請忽略此訊息，謝謝。
        Dim sql As String = ""
        sql &= " SELECT DISTINCT cs.RID,cs.TPLANID,cs.YEARS,cs.STDATE,cs.FTDATE,cs.OCID" & vbCrLf
        '班級
        sql &= " ,dbo.FN_GET_CLASSCNAME(cs.CLASSCNAME,cs.CYCLTYPE) CLASSCNAME2" & vbCrLf
        sql &= " FROM dbo.V_STUDENTINFO cs" & vbCrLf
        '未填列學員主要身分別 '未填列學員預算別
        sql &= " WHERE (cs.MIDENTITYID IS NULL OR cs.BUDGETID IS NULL)" & vbCrLf
        '自第22天(依開訓日)起每次登入即跳出視窗'未結訓22天
        sql &= " AND cs.STDATE+22 <=convert(date,GETDATE()) AND cs.FTDATE+22 >=convert(date,GETDATE())" & vbCrLf
        '系統登入業務範圍'年度'計畫 '限定計畫
        sql &= " AND cs.RID=@RID AND cs.Years=@Years AND cs.TPlanID=@TPlanID AND cs.TPlanID IN ('02','14','59')" & vbCrLf
        '排序依開訓日
        sql &= " ORDER BY cs.STDATE" & vbCrLf
        'sql &= " and years='2017'" & vbCrLf

        LOG.Debug("Get_TIMSC227: " & sql)

        Dim sm As SessionModel = SessionModel.Instance()
        Dim sCmd As New SqlCommand(sql, oConn)
        Call OpenDbConn(oConn)
        Dim dt As New DataTable
        With sCmd
            .Parameters.Clear()
            .Parameters.Add("Years", SqlDbType.VarChar).Value = Convert.ToString(sm.UserInfo.Years)
            .Parameters.Add("TPlanID", SqlDbType.VarChar).Value = Convert.ToString(sm.UserInfo.TPlanID)
            .Parameters.Add("RID", SqlDbType.VarChar).Value = Convert.ToString(sm.UserInfo.RID)
            dt.Load(.ExecuteReader())
        End With
        If dt.Rows.Count = 0 Then Return rst

        Const cst_CLASSNAME1 As String = "@CLASSNAME1"
        Const cst_msg227 As String = "截至今日尚有以下班級尚未於開訓後21日內完成學員資料維護作業：@CLASSNAME1，請儘速至「首頁>>學員動態管理>>學員資料管理>> 學員資料維護」功能完成作業，倘已經完成之班級，請忽略此訊息，謝謝。"
        Dim sCLASSNAME1 As String = ""
        For Each dr1 As DataRow In dt.Rows
            sCLASSNAME1 &= $"{If(sCLASSNAME1 <> "", "、", "")}{dr1("CLASSCNAME2")}"
        Next
        If sCLASSNAME1 <> "" Then rst = Replace(cst_msg227, cst_CLASSNAME1, sCLASSNAME1)
        Return rst
    End Function

