    '將【最後登入時間】< 3個月前 (2020/8/5)的帳號，設為不啟用。
    '將【帳號停用日】設為：【最後登入時間】+3個月
    ''' <summary> 所有超過3個月未登入的帳號，設為不啟用 </summary>
    Public Shared Sub UPDATE_STOP_ACCOUNT(ByRef oConn As SqlConnection)
        Call OpenDbConn(oConn)
        Dim sql As String = " SELECT 1 FROM AUTH_ACCOUNT WHERE LAST_LOGINDATE<=(GETDATE()-90) AND ISUSED='Y'" & vbCrLf
        Dim sCmd As New SqlCommand(sql, oConn)
        Dim dt As New DataTable
        With sCmd
            .Parameters.Clear()
            dt.Load(.ExecuteReader())
        End With
        If dt.Rows.Count = 0 Then Return '(查無資料離開)

        Dim pms_u As New Hashtable
        Dim u_sql As String = ""
        u_sql &= " UPDATE AUTH_ACCOUNT" & vbCrLf
        u_sql &= " SET ISUSED='N' ,STOPDATE=GETDATE()" & vbCrLf
        u_sql &= " FROM AUTH_ACCOUNT" & vbCrLf
        u_sql &= " WHERE LAST_LOGINDATE<=(GETDATE()-90) AND ISUSED='Y'" & vbCrLf
        ExecuteNonQuery(u_sql, oConn, pms_u)
    End Sub

    ''' <summary> 啟動後台登入-測試使用- </summary>
    ''' <param name="UserID"></param>
    ''' <param name="oConn"></param>
    Public Shared Sub UPDATE_BACKUSE_Y(ByVal UserID As String, ByRef oConn As SqlConnection)
        Dim Rst As DataRow = Nothing
        If UserID = "" Then Exit Sub 'Return Rst
        Dim flag_test As Boolean = sUtl_ChkTest() '測試
        Dim flag_test2 As Boolean = sUtl_ChkTest("testWebForm1") '測試登入頁
        If Not flag_test AndAlso Not flag_test2 Then Exit Sub 'Return Rst
        'If Not flag_test2 Then Exit Sub
        'LOG.Debug(String.Format("##UPDATE_BACKUSE_Y UserID:{0} -", UserID))

        'parms.Clear() 'NO BACKUSE
        Dim sql As String = "UPDATE AUTH_ACCOUNT SET BACKUSE='Y' WHERE Account=@Account AND BACKUSE IS NULL"
        Dim parms As New Hashtable From {{"Account", UserID}}
        ExecuteNonQuery(sql, oConn, parms)

        '直接啟用-強制測試登入
        Dim sql2 As String = "UPDATE AUTH_ACCOUNT SET ISUSED='Y',LAST_LOGINDATE=GETDATE(),STOPDATE=GETDATE()+30 WHERE Account=@Account AND ISUSED='N'"
        Dim parms2 As New Hashtable From {{"Account", UserID}}
        ExecuteNonQuery(sql2, oConn, parms2)

        'STOPDATE<=GETDATE()
        Dim sql3 As String = "UPDATE AUTH_ACCOUNT SET STOPDATE=GETDATE()+30 WHERE Account=@Account AND STOPDATE<=GETDATE()"
        Dim parms3 As New Hashtable From {{"Account", UserID}}
        ExecuteNonQuery(sql3, oConn, parms3)
    End Sub

