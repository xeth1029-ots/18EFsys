            dt.DefaultView.RowFilter = "PROPERTYID=1"
            With obj1
                .DataSource = dv2dt(dt.DefaultView)
                .DataTextField = "PLANNAME"
                .DataValueField = "TPLANID"
                .DataBind()
                .Items.Insert(0, New ListItem("全部", ""))
            End With
            dt.DefaultView.RowFilter = "PROPERTYID IS NULL"
            With objX
                .DataSource = dv2dt(dt.DefaultView)
                .DataTextField = "PLANNAME"
                .DataValueField = "TPLANID"
                .DataBind()
                .Items.Insert(0, New ListItem("全部", ""))
            End With
            'dt.Dispose()
        End Using
    End Sub

    '取出鍵詞2-訓練計畫代碼 '0職前 1在職(進修) 2委託訓練 
    Public Shared Function Get_TPlan2Val(ByRef obj0 As System.Web.UI.WebControls.CheckBoxList,
        ByRef obj1 As System.Web.UI.WebControls.CheckBoxList,
        ByRef objX As System.Web.UI.WebControls.CheckBoxList, Optional ByVal sType As Integer = 0) As String
        'Type: 
        '0:勾選計畫用於 [SQL][有單引號] '
        '1:勾選數量  [數]
        '2:勾選報表用 [無單引號]
        '3:勾選報表用 [斜線] [單引號] \'
        '4:勾選計畫用於 [SQL][有單引號] [全部為空]
        '5:文字面的顯示 [文字][無單引號] [全部為空] (報表用)
        '6:轉數字 [數值][無單引號] [全部為空] (報表用)

        Dim Rst As String = ""
        Dim Rst1 As Integer = 0
        Dim Rst4 As String = ""
        Dim Rst5 As String = ""
        Dim Rst6 As String = ""
        Dim cntValue As Integer = 0
        Dim cntChecked As Integer = 0

        Rst = ""
        Rst1 = 0
        Select Case sType
            Case 4, 5, 6
                For Each objitem As ListItem In obj0.Items '大計畫
                    If objitem.Value <> "" Then cntValue += 1
                    If objitem.Selected AndAlso objitem.Value <> "" Then
                        If Rst4 <> "" Then Rst4 += ","
                        Rst4 += "'" & objitem.Value & "'"
                        If Rst5 <> "" Then Rst5 += ","
                        Rst5 += objitem.Text
                        If IsNumeric(objitem.Value) Then
                            If Rst6 <> "" Then Rst6 += ","
                            Rst6 += CStr(CInt(objitem.Value))
                        End If
                        cntChecked += 1
                    End If
                Next
                For Each objitem As ListItem In obj1.Items '大計畫
                    If objitem.Value <> "" Then cntValue += 1
                    If objitem.Selected AndAlso objitem.Value <> "" Then
                        If Rst4 <> "" Then Rst4 += ","
                        Rst4 += "'" & objitem.Value & "'"
                        If Rst5 <> "" Then Rst5 += ","
                        Rst5 += objitem.Text
                        If IsNumeric(objitem.Value) Then
                            If Rst6 <> "" Then Rst6 += ","
                            Rst6 += CStr(CInt(objitem.Value))
                        End If
                        cntChecked += 1
                    End If
                Next
                For Each objitem As ListItem In objX.Items '大計畫
                    If objitem.Value <> "" Then cntValue += 1
                    If objitem.Selected AndAlso objitem.Value <> "" Then
                        If Rst4 <> "" Then Rst4 += ","
                        Rst4 += "'" & objitem.Value & "'"
                        If Rst5 <> "" Then Rst5 += ","
                        Rst5 += objitem.Text
                        If IsNumeric(objitem.Value) Then
                            If Rst6 <> "" Then Rst6 += ","
                            Rst6 += CStr(CInt(objitem.Value))
                        End If
                        cntChecked += 1
                    End If
                Next
                If cntChecked = cntValue Then
                    Rst4 = ""
                    Rst5 = ""
                    Rst6 = ""
                End If
            Case Else
                For Each objitem As ListItem In obj0.Items '大計畫
                    If objitem.Selected AndAlso objitem.Value <> "" Then
                        Rst &= String.Concat(If(Rst <> "", ",", ""), "'", objitem.Value, "'")
                        Rst1 += 1
                    End If
                Next
                For Each objitem As ListItem In obj1.Items '大計畫
                    If objitem.Selected AndAlso objitem.Value <> "" Then
                        Rst &= String.Concat(If(Rst <> "", ",", ""), "'", objitem.Value, "'")
                        Rst1 += 1
                    End If
                Next
                For Each objitem As ListItem In objX.Items '大計畫
                    If objitem.Selected AndAlso objitem.Value <> "" Then
                        Rst &= String.Concat(If(Rst <> "", ",", ""), "'", objitem.Value, "'")
                        Rst1 += 1
                    End If
                Next
        End Select

        Select Case sType
            Case 1 '1:勾選數量
                Rst = Rst1
            Case 2 '2:勾選報表用(不含單引號)
                Rst = Rst.Replace("'", "")
            Case 3 '3:勾選報表用(含 斜線 單引號)
                Rst = Rst.Replace("'", "\'")
            Case 4
                Rst = Rst4
            Case 5
                Rst = Rst5
            Case 6
                Rst = Rst6
        End Select

        Return Rst
    End Function

