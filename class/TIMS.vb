    ''' <summary> 異常為-1 ，正常有數字(改由程式直接處理 Class_EnterSignNo 的累加) </summary>
    ''' <param name="oTrans"></param>
    ''' <param name="oConn"></param>
    ''' <param name="OCID_val"></param>
    ''' <returns></returns>
    Public Shared Function GetSignNoxEnterType3(ByRef oTrans As SqlTransaction, ByRef oConn As SqlConnection, ByRef OCID_val As String) As Long
        'Threading.Thread.Sleep(1) '假設處理某段程序需花費1毫秒 (避免機器不同步)
        'eric,不呼叫預存程序 Do_InsertT2SignNo '改由程式直接處理 Class_EnterSignNo 的累加 '也不再考慮指定 IDNO 的報名資料(Stud_EnterType2)是否存在的邏輯
        Dim rst_i As Integer = 0
        Dim rst_u As Integer = 0
        Dim i_SIGNNO As Long = -1
        '班級代碼 OCID 參數要大於0
        Dim i_OCID As Integer = -1

        If OCID_val = "" OrElse CINT1(OCID_val) <= 0 OrElse Not Long.TryParse(OCID_val, i_OCID) Then Return i_SIGNNO '-1

        Dim s_sql As String = "SELECT SIGNNO FROM CLASS_ENTERSIGNNO WHERE OCID=@OCID"
        Dim sCmd As New SqlCommand(s_sql, oConn, oTrans)
        Dim u_sql As String = "UPDATE CLASS_ENTERSIGNNO SET SIGNNO=@SIGNNO WHERE OCID=@OCID" & vbCrLf
        Dim uCmd As New SqlCommand(u_sql, oConn, oTrans)
        Dim i_sql As String = "INSERT INTO CLASS_ENTERSIGNNO(OCID,SIGNNO) VALUES (@OCID ,1)" & vbCrLf
        Dim iCmd As New SqlCommand(i_sql, oConn, oTrans)

        Dim dt As New DataTable
        With sCmd
            .Parameters.Clear()
            .Parameters.Add("OCID", SqlDbType.BigInt).Value = i_OCID 'Val(OCID)
            dt.Load(.ExecuteReader())
        End With
        If dt IsNot Nothing AndAlso dt.Rows.Count > 0 Then
            i_SIGNNO = CINT1(dt.Rows(0)("SIGNNO")) + 1
            With uCmd
                .Parameters.Clear()
                .Parameters.Add("SIGNNO", SqlDbType.BigInt).Value = i_SIGNNO
                .Parameters.Add("OCID", SqlDbType.BigInt).Value = i_OCID 'Val(OCID)
                rst_u = .ExecuteNonQuery()
            End With
            Return i_SIGNNO
        Else
            With iCmd
                .Parameters.Clear()
                .Parameters.Add("OCID", SqlDbType.BigInt).Value = i_OCID 'Val(OCID)
                rst_i = .ExecuteNonQuery()
            End With
            i_SIGNNO = 1
            Return i_SIGNNO
        End If
        Return i_SIGNNO
    End Function

