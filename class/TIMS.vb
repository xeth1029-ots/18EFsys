    '20090601 by Jimmy 依需求「e網報名審核成功說明事項」先檢查「班級」是否有設定，若有則以班級為準，若無則再檢查「訓練機構(單位)」是否有設定，若有則以「單位」為準，否則顯示空白
    Public Shared Function Get_FinalEComment(ByVal chkType As String, ByVal OrgID As String,
                                             ByVal OCID As String, ByVal RID As String,
                                             ByVal DistID As String, ByVal PlanID As String,
                                             ByVal retDt As DataTable, ByVal tConn As SqlConnection) As DataTable

        Dim dr As DataRow = Nothing
        Dim chkflag As Boolean = False

        Try
            Select Case chkType
                Case "Class" 'by 班級
                    retDt = Get_ClassEComment(OrgID, OCID, RID, DistID, tConn)
                Case "Org" 'by 機構(分區)
                    retDt = Get_OrgEComment(OrgID, RID, PlanID, tConn) '20090618 by Jimmy for 不同年度、計畫、轄區
            End Select

            If Not retDt Is Nothing Then
                If retDt.Rows.Count > 0 Then
                    dr = retDt.Rows(0)
                    If Convert.ToString(dr("eComment")) <> "" Then
                        chkflag = True
                    End If
                End If
            End If

            If chkType = "Class" AndAlso Not chkflag Then '班級沒有說明事項時，繼續向上找單位
                retDt = Get_FinalEComment("Org", OrgID, OCID, RID, DistID, PlanID, Nothing, tConn)
            ElseIf chkType = "Org" AndAlso Not chkflag Then
                retDt = Nothing
            End If
        Catch ex As Exception
            Dim V_GUID As String = Guid.NewGuid().ToString()
            LOG.Warn(ex.Message, ex) '取得錯誤資訊寫入
            Dim strErrmsg As String = String.Concat("ex.Message:", ex.Message, "[", V_GUID, "]", vbCrLf)
            WriteTraceLog(strErrmsg, ex)
            Throw ex
        End Try

        Return retDt
    End Function

    ''' <summary>
