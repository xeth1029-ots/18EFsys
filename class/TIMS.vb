    ''' <summary> 加密 Aes (Try-Catch)-Turbo.Crypto4 </summary>
    ''' <param name="oPlainTxt"></param>
    ''' <returns></returns>
    ''' <remarks></remarks>
    Public Shared Function EncryptAes(ByVal oPlainTxt As Object) As String
        Dim rst As String = ""
        If oPlainTxt Is Nothing OrElse Convert.ToString(oPlainTxt).Length = 0 Then Return rst
        Try
            Dim Aes As New AesTk 'Turbo.Crypto4
            rst = Aes.Encrypt(oPlainTxt)
        Catch ex As Exception
            LOG.Warn("EncryptAes: " & ex.Message, ex)
        End Try
        Return rst
    End Function

    ''' <summary> 解密 Aes-Turbo.Crypto4 </summary>
    ''' <param name="oCipherTxt"></param>
    ''' <returns></returns>
    ''' <remarks></remarks>
    Public Shared Function DecryptAes(ByVal oCipherTxt As Object) As String
        Dim rst As String = ""
        If oCipherTxt Is Nothing OrElse Convert.ToString(oCipherTxt).Length = 0 Then Return rst
        Try
            Dim Aes As New AesTk 'Turbo.Crypto4
            rst = Aes.Decrypt(oCipherTxt)
        Catch ex As Exception
            LOG.Warn("DecryptAes: " & ex.Message, ex)
        End Try
        Return rst
    End Function

