    ''' <summary> 傳入郵遞區號，回傳地區位置別(前3碼) </summary>
    ''' <param name="ZIP"></param>
    ''' <param name="tConn"></param>
    ''' <returns></returns>
    Public Shared Function Get_ZipLName(ByVal ZIP As String, ByVal tConn As SqlConnection) As String
        Dim rst As String = ""
        ZIP = ClearSQM(ZIP)
        '判斷數字可能性，若不是數字就返回空白算了。
        If ZIP <> "" Then ZIP = If(ZIP.Length > 3, ZIP.Substring(0, 3), ZIP)
        If ZIP <> "" Then ZIP = If(IsNumeric2(ZIP), $"{CINT1(ZIP)}", "")
