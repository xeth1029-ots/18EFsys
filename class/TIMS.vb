        Return dt
    End Function

    ''' <summary>筆數/每頁筆數/計算頁總筆數</summary>
    ''' <param name="iCNUM"></param>
    ''' <param name="iPAGENUM"></param>
    ''' <returns></returns>
    Public Shared Function GET_PAGEROWNUM(ByVal iCNUM As Integer, ByVal iPAGENUM As Integer) As Integer
        If iCNUM <= iPAGENUM Then Return iPAGENUM
        '((@CIDX-1)/10),(((@CIDX-1)/10)+1)*10 
        '\（整數除法）：兩數相除取商數整數，若兩數含小數，則先行４捨６入為整數後再相除。
        Return (((iCNUM - 1) \ iPAGENUM) + 1) * iPAGENUM
    End Function

    ''' <summary>"申請申複階段受理期間未開放，請確認後再操作! False／true:開放</summary>
    ''' <param name="oConn"></param>
    ''' <param name="rPMS"></param>
    ''' <returns></returns>
    Public Shared Function CAN_APPLISTAGE_PTYPE02(ByRef oConn As SqlConnection, ByRef rPMS As Hashtable) As Boolean
        'view-source:https://localhost:44383/TC/01/TC_01_021?ID=928
        '開放受理之申請階段／PLAN_APPSTAGE
        Dim vYEARS As String = GetMyValue2(rPMS, "YEARS")
        Dim vAPPSTAGE As String = GetMyValue2(rPMS, "APPSTAGE")
        If vYEARS = "" OrElse vAPPSTAGE = "" Then Return False
        'PTYPE1 : 01:申請階段 ／02:申複階段
        OpenDbConn(oConn)
        Dim dt As New DataTable
        Dim sSql As String = ""
        sSql &= " SELECT a.YEARS,a.APPSTAGE,a.SACCEPTDATE,a.FACCEPTDATE" & vbCrLf
        sSql &= " FROM PLAN_APPSTAGE a" & vbCrLf
        sSql &= " WHERE DATEDIFF(MI,a.SACCEPTDATE,GETDATE())>=0 AND DATEDIFF(MI,GETDATE(),a.FACCEPTDATE)>0" & vbCrLf
        sSql &= " AND a.PTYPE1='02' AND a.YEARS=@YEARS AND a.APPSTAGE=@APPSTAGE" & vbCrLf
        Dim sCmd As New SqlCommand(sSql, oConn)
        With sCmd
            .Parameters.Clear()
            .Parameters.Add("YEARS", SqlDbType.VarChar).Value = vYEARS
            .Parameters.Add("APPSTAGE", SqlDbType.VarChar).Value = vAPPSTAGE
            dt.Load(.ExecuteReader())
        End With
        If dt Is Nothing OrElse dt.Rows.Count = 0 Then Return False
        Return True
    End Function
