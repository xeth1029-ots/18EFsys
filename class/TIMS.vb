    ''' <param name="oConn"></param>
    ''' <returns></returns>
    ''' <remarks></remarks>
    Public Shared Function Check_OrgBlackList(ByRef MyPage As Page,
                                              ByVal ComIDNO As String,
                                              ByRef oConn As SqlConnection) As Boolean
        Dim rst As Boolean = False '預設  訓練單位處分功能 停用 isBlack 
        'true:啟用黑名單 false:停用黑名單 (BLACK)
        Dim sBlackList As String = ""
        Dim iBlackListCnt As Integer = 0
        Dim sm As SessionModel = SessionModel.Instance()

        ' (直接在 AuthBasePage 處理, 不用個別檢查 Session) If TIMS.ChkSession(MyPage) Then Return rst 'SESSION不完整
        Dim sTPlanID As String = sm.UserInfo.TPlanID '判斷該計畫是否啟用黑名單功能。
        'Dim sDistID As String=sm.UserInfo.DistID
        Dim iBlackType As Integer = Chk_OrgBlackType(MyPage, oConn)

        Dim sql As String = ""
        sql = "SELECT ISNULL(BlackList,' ') BLACKLIST FROM KEY_PLAN WHERE TPlanID=@TPlanID"
        Dim sCmd As New SqlCommand(sql, oConn)
        Call OpenDbConn(oConn)
        Dim dt As New DataTable
        With sCmd
            .Parameters.Clear()
            .Parameters.Add("TPlanID", SqlDbType.VarChar).Value = sTPlanID
            dt.Load(.ExecuteReader())
        End With
        If dt.Rows.Count > 0 Then sBlackList = Convert.ToString(dt.Rows(0)("BlackList"))

        'sBlackList=DbAccess.ExecuteScalar(sql, objConn)
        If sBlackList <> "Y" Then Return rst '未啟用黑名單功能
        If ComIDNO = "" Then '(未輸入統編) '未輸入統編依計畫判斷是否有啟動黑名單功能
            Select Case sBlackList
                Case "Y"
                    rst = True '啟用
                Case Else
                    rst = False '不啟用
            End Select
            Return rst '回傳(啟用/不啟用)
        End If
        '輸入統編
        rst = Check_OrgBlackList2(MyPage, ComIDNO, iBlackType, oConn)
        Return rst '回傳('在黑名單中/不在黑名單中)
    End Function

