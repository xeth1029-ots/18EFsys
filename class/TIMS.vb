    ''' <summary>
    ''' 新增帳號時，系統寄發「密碼通知函」AUTH_PXSSWARD_HIS
    ''' </summary>
    ''' <param name="oConn"></param>
    ''' <param name="s_parms"></param>
    ''' <returns></returns>
    Public Shared Function INSERT_PXSSWARDHIS(ByRef oConn As SqlConnection, ByVal s_parms As Hashtable) As Hashtable
        Dim iu_prams As New Hashtable
        'If sm Is Nothing Then Return Nothing
        '/*SDMATYPE 密碼寄信種類-1:新設密碼-2:忘記密碼(修改密碼)-3:修改密碼 */ SENDMAILTYPE /SDMATYPE
        Dim vSDMATYPE As String = GetMyValue2(s_parms, "SDMATYPE")
        If vSDMATYPE = "" Then Return Nothing
        Dim vMODIFYACCT As String = GetMyValue2(s_parms, "MODIFYACCT")
        If vMODIFYACCT = "" Then Return Nothing
        Dim vACCOUNT As String = GetMyValue2(s_parms, "ACCOUNT")
        Dim vSENDMAIL As String = GetMyValue2(s_parms, "SENDMAIL")
        Dim vHSEQ As String = GetMyValue2(s_parms, "HSEQ") 'TIMS.GetGUID(oConn)
        Dim vHASHPWD1 As String = GetMyValue2(s_parms, "HASHPWD1")
        Dim vPXSSENC1 As String = GetMyValue2(s_parms, "PXSSENC1")
        Dim aNow As Date = GetSysDateNow(oConn) 'yyyy-MM-dd HH:mm:ss
        'Dim vSENDMAILDATE As String=aNow.ToString("yyyy-MM-dd HH:mm:ss")

        '/*密碼寄信種類-1:新設密碼-2:忘記密碼(修改密碼)-3:修改密碼 */
        Select Case vSDMATYPE
            Case "2"
                '刪除3小時內的密碼-如果還未設定密碼
                Call Del_PXSSWARDHIS_3h(oConn, s_parms)
        End Select

        '/*密碼寄信種類-1:新設密碼-2:忘記密碼(修改密碼)-3:修改密碼 */
        Select Case vSDMATYPE
            Case "1", "2" '1:新設密碼-2:忘記密碼(修改密碼)
                vACCOUNT = ClearSQM(vACCOUNT)
                If vACCOUNT = "" Then Return Nothing
                vSENDMAIL = ClearSQM(vSENDMAIL)
                'If vSENDMAIL="" Then Return Nothing
                iu_prams.Clear()
                iu_prams.Add("MODIFYACCT", vMODIFYACCT)
                Dim drH As DataRow = Get_drHSEQ(oConn, iu_prams)
                If drH Is Nothing Then Return Nothing

                Dim sqlstr As String = ""
                sqlstr &= " INSERT INTO AUTH_PXSSWARD_HIS( PXSEQ,ACCOUNT,HSEQ ,SENDMAIL,SENDMAILTYPE ,SENDMAILDATE,CREATEACCT,CREATEDATE,MODIFYACCT,MODIFYDATE)" & vbCrLf
                sqlstr &= " VALUES ( @PXSEQ,@ACCOUNT,@HSEQ ,@SENDMAIL,@SENDMAILTYPE ,@SENDMAILDATE,@CREATEACCT,GETDATE(),@MODIFYACCT,GETDATE())" & vbCrLf
                Dim iPXSEQ As Integer = DbAccess.GetNewId(oConn, "AUTH_PXSSWARD_HIS_PXSEQ_SEQ,AUTH_PXSSWARD_HIS,PXSEQ")
                iu_prams.Clear()
                iu_prams.Add("PXSEQ", iPXSEQ)
                iu_prams.Add("ACCOUNT", vACCOUNT)
                iu_prams.Add("HSEQ", drH("HSEQ")) '儲存/寄信使用
                iu_prams.Add("HASH1", drH("HASH1")) '寄信使用
                iu_prams.Add("SENDMAIL", vSENDMAIL)
                iu_prams.Add("SENDMAILTYPE", vSDMATYPE)
                iu_prams.Add("SENDMAILDATE", aNow)
                iu_prams.Add("CREATEACCT", vMODIFYACCT)
                iu_prams.Add("MODIFYACCT", vMODIFYACCT)
                DbAccess.ExecuteNonQuery(sqlstr, objConn:=oConn, parms:=iu_prams)

                '直接寄信EMAIL
                If vSENDMAIL <> "" Then Utl_SENDMAIL(iu_prams)

            Case "3" '修改-依密碼函修改
                Dim sql As String = ""
                sql &= " UPDATE AUTH_PXSSWARD_HIS" & vbCrLf
                sql &= " SET HASHPWD1=@HASHPWD1 ,PXSSENC1=@PXSSENC1 ,SENDMAILTYPE=@SENDMAILTYPE" & vbCrLf
                sql &= " ,CONFIRMACCT=@CONFIRMACCT ,CONFIRMDATE=GETDATE() ,MODIFYACCT=@MODIFYACCT ,MODIFYDATE=GETDATE()" & vbCrLf
                sql &= " WHERE UPPER(ACCOUNT)=@ACCOUNT AND HSEQ=@HSEQ" & vbCrLf
                iu_prams.Clear()
                iu_prams.Add("HASHPWD1", vHASHPWD1)
                iu_prams.Add("PXSSENC1", vPXSSENC1)
                iu_prams.Add("SENDMAILTYPE", vSDMATYPE)
                iu_prams.Add("CONFIRMACCT", vMODIFYACCT)
                iu_prams.Add("MODIFYACCT", vMODIFYACCT)
                iu_prams.Add("ACCOUNT", UCase(vACCOUNT))
                iu_prams.Add("HSEQ", vHSEQ)
                Dim iRst As Integer = DbAccess.ExecuteNonQuery(sql, objConn:=oConn, parms:=iu_prams)
                If iRst <> 1 Then Return iu_prams

                Dim sqlstr As String = ""
                sqlstr &= " UPDATE AUTH_ACCOUNT" & vbCrLf
                sqlstr &= " SET HASHPWD1=@HASHPWD1" & vbCrLf
                sqlstr &= String.Concat(" ,", Get_strPORDASSW, "=@PXSSENC1") & vbCrLf
                sqlstr &= " ,LAST_LOGINDATE=GETDATE() ,MODIFYACCT=@MODIFYACCT ,MODIFYDATE=GETDATE()" & vbCrLf
                sqlstr &= " WHERE UPPER(ACCOUNT)=@ACCOUNT" & vbCrLf
                iu_prams.Clear()
                iu_prams.Add("HASHPWD1", vHASHPWD1)
                iu_prams.Add("PXSSENC1", vPXSSENC1)
                iu_prams.Add("MODIFYACCT", vMODIFYACCT)
                iu_prams.Add("ACCOUNT", UCase(vACCOUNT))
                DbAccess.ExecuteNonQuery(sqlstr, objConn:=oConn, parms:=iu_prams)
                If iRst <> 1 Then Return iu_prams

            Case "4" '修改沒有密碼函
                Dim sqlstr As String = ""
                sqlstr &= " UPDATE AUTH_ACCOUNT" & vbCrLf
                sqlstr &= " SET HASHPWD1=@HASHPWD1" & vbCrLf
                sqlstr &= String.Concat(" ,", Get_strPORDASSW, "=@PXSSENC1") & vbCrLf
                sqlstr &= " ,LAST_LOGINDATE=GETDATE() ,MODIFYACCT=@MODIFYACCT ,MODIFYDATE=GETDATE()" & vbCrLf
                sqlstr &= " WHERE UPPER(ACCOUNT)=@ACCOUNT" & vbCrLf
                iu_prams.Clear()
                iu_prams.Add("HASHPWD1", vHASHPWD1)
                iu_prams.Add("PXSSENC1", vPXSSENC1)
                iu_prams.Add("MODIFYACCT", vMODIFYACCT)
                iu_prams.Add("ACCOUNT", UCase(vACCOUNT))
                DbAccess.ExecuteNonQuery(sqlstr, objConn:=oConn, parms:=iu_prams)
        End Select

        Return iu_prams
    End Function

