    Public Shared Function GetCookieTable(ByRef sm As SessionModel, ByRef oConn As SqlConnection) As DataTable
        Dim Rstdt As New DataTable '=Nothing
        'Dim sm As SessionModel=SessionModel.Instance()
        Dim Account As String = ClearSQM(sm.UserInfo.UserID) ': If Account="" Then Return Rstdt
        Dim PlanID As String = ClearSQM(sm.UserInfo.PlanID) ': If PlanID="" Then Return Rstdt
        If Account = "" OrElse PlanID = "" Then Return Rstdt

        Call OpenDbConn(oConn)
        Dim sql As String = ""
        sql = " SELECT * FROM COOKIE_DATA WHERE ACCOUNT=@ACCOUNT AND PLANID=@PLANID"
        Dim sCmd As New SqlCommand(sql, oConn)
        With sCmd
            .Parameters.Clear()
            .Parameters.Add("ACCOUNT", SqlDbType.VarChar).Value = Account
