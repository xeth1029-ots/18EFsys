    ''' <summary> 判斷是否為超級使用者-iType, sm </summary>
    ''' <param name="iType"></param>
    ''' <param name="sm"></param>
    ''' <returns></returns>
    Public Shared Function IsSuperUser(ByRef sm As SessionModel, ByVal iType As Integer) As Boolean
        Dim bRst As Boolean = False '不是
        'Dim sm As SessionModel=SessionModel.Instance() 'iType:1 判斷是否為 超級管理者snoopy 3:帳號設定使用-跨轄區與計畫(署)
        'SELECT * FROM AUTH_ACCOUNT WHERE ROLEID='0' AND LID='0' 'SELECT LID ,COUNT(1) CNT FROM  AUTH_ACCOUNT GROUP BY LID 0:署 1:分署 2:委訓
        If sm Is Nothing Then Return bRst
        Select Case iType
            Case 1 '超級管理者使用者 第1級  'ROLEID=0 LID=0 '使用者為snoopy 跨權限啟用!!!
                If sm.UserInfo.RoleID = "0" AndAlso sm.UserInfo.LID = 0 Then bRst = True
                Return bRst
            Case 3
                '帳號設定使用-跨轄區與計畫(署)
                Select Case sm.UserInfo.RoleID
                    Case "0", "1" '0:超級使用者 1:系統管理者 (SELECT * FROM ID_ROLE) 
                        If sm.UserInfo.LID = 0 AndAlso sm.UserInfo.AUTHUSE = "1" Then bRst = True
                        Return bRst
                End Select
        End Select
        Return bRst
    End Function

