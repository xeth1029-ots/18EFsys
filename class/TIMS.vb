    '執行緒Log寫入資料庫
    Public Shared Sub InsertLog(ByVal sPROCESSID As String, ByVal iPROPERCENT As Integer, ByVal sPROCONTECT As String)
        Dim sLONGStr As String = sPROCONTECT
        Const cst_maxCount As Integer = 2000 '最大可存字數

        'Const cst_LONGfd As String="PROCONTECT"
        Dim iSql As String = ""
        iSql &= " INSERT INTO LOG_THREAD(PRCID ,PROCESSID ,PROPERCENT ,PROCONTECT ,PRODATE)" & vbCrLf
        iSql &= " VALUES (@PRCID ,@PROCESSID ,@PROPERCENT ,@PROCONTECT ,GETDATE())" & vbCrLf
        Dim uSql As String = " UPDATE LOG_THREAD SET PROCONTECT=PROCONTECT+@PROCONTECT WHERE PRCID=@PRCID" '/*PK*/ 

        Using oConn As SqlConnection = DbAccess.GetConnection()
            Call OpenDbConn(oConn)
            Dim iPRCID As Integer = DbAccess.GetNewId(oConn, "LOG_THREAD_PRCID_SEQ,LOG_THREAD,PRCID")
            If sLONGStr.Length > cst_maxCount Then
                Dim i As Integer = 0
                Dim sLONGStr2000 As String = ""
                Do
                    sLONGStr2000 = Mid(sLONGStr, 1, cst_maxCount)
                    sLONGStr = Mid(sLONGStr, cst_maxCount + 1)
                    If sLONGStr2000 <> "" Then
                        If i = 0 Then
                            '第1組字
                            Using iCmd As New SqlCommand(iSql, oConn)
                                With iCmd
                                    Dim parms As New Hashtable From {{"PRCID", iPRCID}, {"PROCESSID", sPROCESSID}, {"PROPERCENT", iPROPERCENT}, {"cst_LONGfd", sLONGStr2000}}
                                    ExecuteNonQuery(iSql, oConn, parms)
                                End With
                            End Using
                        Else
                            '補充後面的字
                            Using uCmd As New SqlCommand(uSql, oConn)
                                With uCmd
                                    Dim parms As New Hashtable From {{"cst_LONGfd", sLONGStr2000}, {"PRCID", iPRCID}}
                                    ExecuteNonQuery(uSql, oConn, parms)
                                End With
                            End Using
                        End If
                    End If
                    i += 1
                Loop Until sLONGStr2000.Length <= 0
            Else
                Using iCmd As New SqlCommand(iSql, oConn)
                    With iCmd
                        Dim parms As New Hashtable From {{"PRCID", iPRCID}, {"PROCESSID", sPROCESSID}, {"PROPERCENT", iPROPERCENT}, {"cst_LONGfd", sLONGStr}}
                        ExecuteNonQuery(iSql, oConn, parms)
                    End With
                End Using
            End If
            Call CloseDbConn(oConn)
        End Using
    End Sub

    Public Shared Function Get_httpsProtocol() As Boolean
        '<add key="httpsProtocol" value="OFF"/>
        Dim rst As Boolean = True
        Try
            'Dim httpsProtocol As String=ConfigurationSettings.AppSettings("httpsProtocol")  '測試用
            Dim httpsProtocol As String = Utl_GetConfigSet("httpsProtocol")
            If Not httpsProtocol Is Nothing Then
                If Convert.ToString(httpsProtocol) <> "" Then
