    '檢核 就業關聯性 是否全部填寫 false:有部份未填寫 true:全部已填寫
    Public Shared Function CHK_JOBRELATE_OCID(ByVal vOCID1 As String,
                                              ByVal iCPOINT As Integer,
                                              ByRef oConn As SqlConnection) As Boolean
        Dim rst As Boolean = True 'true:全部已填寫
        Select Case iCPOINT
            Case 1, 9 '只有就業3個月和提前就業須檢核
            Case Else
                Return rst
        End Select
        Const cst_FTDATE2 As String = "2017/01/01" '適用2017年1月1日之後結訓的班

        Dim sql As String = ""
        sql &= " SELECT COUNT(j3.SOCID) CNT1" & vbCrLf '就業資訊
        sql &= " ,COUNT(j3.JOBRELATE) CNT2" & vbCrLf '就業關聯性
        sql &= " FROM STUD_GETJOBSTATE3 j3" & vbCrLf
        sql &= " JOIN CLASS_STUDENTSOFCLASS cs on cs.socid=j3.socid" & vbCrLf
        sql &= " JOIN CLASS_CLASSINFO cc on cc.ocid=cs.ocid" & vbCrLf
        sql &= " WHERE (cs.STUDSTATUS NOT IN (2,3) OR (cs.STUDSTATUS=2 AND cs.RTREASONID='02'))"
        sql &= " AND j3.ISGETJOB=1" & vbCrLf
        sql &= " AND cc.FTDATE>=" & To_date(cst_FTDATE2) & vbCrLf
        sql &= " AND cs.OCID=@OCID" & vbCrLf
        sql &= " AND j3.CPOINT=@CPOINT" & vbCrLf
        '排除在職者: 
        sql &= " AND ISNULL(cs.WorkSuppIdent,'N')='N'" & vbCrLf
        'sql &= " and rownum <=10" & vbCrLf
        Dim sCmd As New SqlCommand(sql, oConn)
        Call OpenDbConn(oConn)
        Dim dt As New DataTable
        With sCmd
            .Parameters.Clear()
            .Parameters.Add("OCID", SqlDbType.VarChar).Value = vOCID1
            .Parameters.Add("CPOINT", SqlDbType.Int).Value = iCPOINT
            dt.Load(.ExecuteReader())
            '.ExecuteReader.Close()
        End With
        If dt.Rows.Count > 0 Then
            Dim dr As DataRow = dt.Rows(0)
            If CINT1(dr("CNT1")) > CINT1(dr("CNT2")) Then
                rst = False 'CNT2 小於 CNT1 表示有就業 但未填寫 就業關聯性
            End If
        End If
        Return rst
    End Function

