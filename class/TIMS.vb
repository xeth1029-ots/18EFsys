    'System_Msg
    Public Shared Function Get_SHAREDCODE_MSG(ByVal itemName As String, ByVal CODEKIND As String, ByVal CODEID As String, ByRef oConn As SqlConnection) As String
        Dim rst As String = ""
        Dim sql As String = ""
        sql &= " SELECT REMARK_DES ALTMSG,FLAG1 SDATE,FLAG2 EDATE"
        sql &= " FROM SYS_SHAREDCODE"
        sql &= " WHERE CODE_KIND=@CODEKIND AND CODE_ID=@CODEID"
        Using sCmd As New SqlCommand(sql, oConn)
            Try
                Call OpenDbConn(oConn)
                Dim dt As New DataTable
                With sCmd
                    .Parameters.Clear()
                    .Parameters.Add("CODEKIND", SqlDbType.VarChar).Value = CODEKIND
                    .Parameters.Add("CODEID", SqlDbType.VarChar).Value = CODEID
                    dt.Load(.ExecuteReader())
                End With
                If dt.Rows.Count <> 1 Then Return rst '只能等於1
                rst = $"{dt.Rows(0)(itemName)}"
            Catch ex As Exception
                LOG.Warn("Get_SHAREDCODE_MSG: " & ex.ToString(), ex)
            End Try
        End Using
        Return rst
    End Function

