    Public Shared Function GETMAILDATA_ECSEQ6_DT(oConn As SqlConnection, s_DISTID As String) As DataTable
        Dim flag_test As Boolean = sUtl_ChkTest() '測試
        If flag_test Then s_DISTID = "000" '測試

        Dim parms As New Hashtable From {{"DISTID", s_DISTID}}
        Dim sSql As String = "
