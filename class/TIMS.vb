    Public Shared Function Get_DataTableCOLUMN(ByRef dt1 As DataTable) As String
        Dim sColName As String = ""
        If dt1 Is Nothing Then Return sColName
        For i As Integer = 0 To dt1.Columns.Count - 1 '所有欄位
