    ''' <summary> 取得產投流水號(前6碼)年度別(3)+上下年(1)+計畫別(1)+分署別(1) 課程申請流水號 </summary>
    ''' <param name="PLANYEAR"></param>
    ''' <param name="STDATE"></param>
    ''' <param name="PLAN1"></param>
    ''' <param name="DistID"></param>
    ''' <returns></returns>
    Public Shared Function Get_PSNO28_6(ByVal PLANYEAR As String, ByVal STDATE As String, ByVal PLAN1 As String, ByVal DistID As String) As String
        Dim rst As String = ""
        '訓練單位於班級課程正式儲存時，於TIMS系統內新增該課程流水號，以利查詢，詳細說明如下。
        '訓練單位於班級申請功能處點選課程正式儲存後, 會將確定提班課程於班級查詢處點選送出, 針對
        '送出之班級系統自動給予流水號以利分署進行班級審查。
        '流水號呈現方式:
        '年度別 + 上下半年 + 計畫別 + 分署別 + 4碼流水號
        '呈現方式()
        '年度別：106年度申請課程呈現「106」。
        '上下半年：上半年申請課程呈現「1」、下半年申請課程呈現「2」。
        '計畫別：產業人才投資計畫呈現「A」、提升自主勞工計畫呈現「B」。
        '分署別：北分署呈現「1」、桃分署呈現「2」、中分署呈現「3」、南分署呈現「4」、高分署呈現「5」。
        '4碼流水號：依送出時間點順序給予「0001、0002」等流水號。
        '例：106年度上半年度，產業人才投資計畫北分署訓練單位申請的課程 
        '產生流水號為「1061A10001」

        If PLANYEAR = "" OrElse STDATE = "" OrElse PLAN1 = "" OrElse DistID = "" Then Return rst
        Dim YY1 As String = CINT1(PLANYEAR) - 1911 '年度別：106年度申請課程呈現「106」
        '上下半年：上半年申請課程呈現「1」、下半年申請課程呈現「2」
        Dim UD1 As String = If(CDate(STDATE).ToString("MMdd") >= "0701", "2", "1")

        Dim DIST1 As String = "" '分署別：北分署呈現「1」、桃分署呈現「2」、中分署呈現「3」、南分署呈現「4」、高分署呈現「5」。
        Select Case DistID
            Case "001"
                DIST1 = "1"
            Case "003"
                DIST1 = "2"
            Case "004"
                DIST1 = "3"
            Case "005"
                DIST1 = "4"
            Case "006"
                DIST1 = "5"
            Case Else
                DIST1 = "X" '異常"
                Return "" '異常為空
        End Select
        '取得產投流水號(前6碼)年度別(3)+上下年(1)+計畫別(1)+分署別(1)
        rst = String.Concat(YY1, UD1, PLAN1, DIST1)
        If rst.Length <> 6 Then Return "" '異常為空
        Return rst
    End Function

    ''' <summary>(更新PSNO28) 目前最大值(+1) 課程申請流水號</summary>
    ''' <param name="vPlanID"></param>
    ''' <param name="vComIDNO"></param>
    ''' <param name="vSEQNO"></param>
    ''' <param name="vPSNO28_6"></param>
    ''' <returns></returns>
    Public Shared Function UPDATE_PSNO28xPLANINFO(ByVal vPlanID As String, ByVal vComIDNO As String, ByVal vSEQNO As String, ByVal vPSNO28_6 As String) As String
        'Threading.Thread.Sleep(1) '假設處理某段程序需花費1毫秒 (避免機器不同步)
        Dim sPSNO28 As String = ""

        Dim tConn As SqlConnection = DbAccess.GetConnection()
        Dim oTrans As SqlTransaction = DbAccess.BeginTrans(tConn)
        Try
            Dim sCmd As New SqlCommand("Do_InsertP2PSNO28", tConn, oTrans) With {
                .CommandType = CommandType.StoredProcedure
            }
            With sCmd.Parameters
                .Clear()
                .Add("v_PlanID", SqlDbType.VarChar).Value = vPlanID
                .Add("v_ComIDNO", SqlDbType.VarChar).Value = vComIDNO
                .Add("v_SEQNO", SqlDbType.VarChar).Value = vSEQNO
                .Add("v_PSNO28_6", SqlDbType.VarChar).Value = vPSNO28_6
                .Add("returValue", SqlDbType.VarChar, 20)
            End With
            sCmd.Parameters("returValue").Direction = ParameterDirection.Output
            sCmd.ExecuteNonQuery()
            sPSNO28 = sCmd.Parameters("returValue").Value
            DbAccess.CommitTrans(oTrans)
        Catch ex As Exception
            LOG.Warn("UPDATE_PSNO28xPLANINFO: " & ex.ToString(), ex)
            DbAccess.RollbackTrans(oTrans)
            Call CloseDbConn(tConn)
            'Throw ex
        End Try
        Call CloseDbConn(tConn)
        Return sPSNO28
    End Function

