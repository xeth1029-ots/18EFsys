    ''' </summary>
    ''' <param name="strday"></param>
    ''' <returns></returns>
    Public Shared Function IsDate7(ByVal strday As String) As Boolean
        Dim FLAG As Boolean = False
        Dim tmpday As String = Cdate18(strday)
        Try
            If IsDate(tmpday) Then
                If CDate(tmpday).Year > 1753 Then
                    FLAG = True
                End If
            End If
        Catch ex As Exception
            LOG.Warn(ex.Message, ex)
            Dim strErrmsg As String = ""
            strErrmsg &= "/*  Public Shared Function IsDate7 */" & vbCrLf
            strErrmsg &= String.Concat("/* ex.Message: ", ex.Message, "*/", vbCrLf)
            strErrmsg &= String.Concat("/* strday: ", strday, "*/", vbCrLf)
            'strErrmsg &= GetErrorMsg(MyPage) '取得錯誤資訊寫入
            Call WriteTraceLog(strErrmsg, ex)
            'Throw ex
        End Try
        Return FLAG
