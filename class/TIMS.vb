    ''' <summary> 應限制訓練起日及訓練迄日間隔不得超過4個月 (若超過為(異常)false,正常true) </summary>
    ''' <param name="dSTDate">訓練起日</param>
    ''' <param name="dFTDate">訓練迄日</param>
    ''' <param name="iMonth">4個月</param>
    ''' <returns>若超過為(異常)false,正常true</returns>
    ''' <remarks></remarks>
    Public Shared Function Chk_STFDateMn4(ByVal dSTDate As Date, ByVal dFTDate As Date, ByVal iMonth As Integer) As Boolean
        Dim rst As Boolean = True '正常true
        Dim dNxFTDate As Date = DateAdd(DateInterval.Month, iMonth, dSTDate)
        If DateDiff(DateInterval.Day, dNxFTDate, dFTDate) > 0 Then rst = False '超過為(異常)false
        Return rst
    End Function

    ''' <summary>
    ''' 訓練迄日不得設定超過8月份(上半年)及2月份(下半年) (若超過為(異常)false,正常true)
    ''' </summary>
    ''' <param name="dSTDate">訓練起日</param>
    ''' <param name="dFTDate">訓練迄日</param>
    ''' <returns>若超過為(異常)false,正常true</returns>
    ''' <remarks></remarks>
    Public Shared Function Chk_STFDateMn82(ByVal dSTDate As Date, ByVal dFTDate As Date) As Boolean
        Dim rst As Boolean = True '正常true

        Dim dNxFTDate As Date
        Dim sMMdd As String = Cdate3(dSTDate, "MMdd") '依起日來判斷上半年/下半年
        Dim sYYYY1 As String = Cdate3(dSTDate, "yyyy") '上半年
        Dim sYYYY2 As String = $"{CINT1(sYYYY1) + 1}" '下半年
        If sMMdd < "0701" Then
            '上半年
            dNxFTDate = CDate($"{sYYYY1}/09/01")
            If DateDiff(DateInterval.Day, dNxFTDate, dFTDate) >= 0 Then
                rst = False '超過為(異常)false
            End If
        Else
            '下半年
            dNxFTDate = CDate($"{sYYYY2}/03/01")
            If DateDiff(DateInterval.Day, dNxFTDate, dFTDate) >= 0 Then
                rst = False '超過為(異常)false
            End If
        End If
        Return rst
    End Function

