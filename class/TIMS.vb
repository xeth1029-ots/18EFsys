    ''' <summary>System.Web.UI.WebControls.Table 轉為HtmlTable </summary>
    ''' <param name="table1"></param>
    ''' <returns></returns>
    Public Shared Function ConvertHtmlTable(table1 As System.Web.UI.WebControls.Table) As HtmlTable
        '假設 table1 是一个 System.Web.UI.WebControls.Table 实例
        Dim HtmlTable1 As New HtmlTable()
        For Each row1 As TableRow In table1.Rows
            Dim HtmlTableRow1 As New HtmlTableRow()
            For Each cell1 As TableCell In row1.Cells
                '或其他處理方式
                Dim htmlTableCell1 As New HtmlTableCell With {.InnerHtml = cell1.Text}
                HtmlTableRow1.Cells.Add(htmlTableCell1)
            Next
            HtmlTable1.Rows.Add(HtmlTableRow1)
        Next
        Return HtmlTable1
    End Function

