    Public Shared Sub HISTORY1_SENDMAIL(oConn As SqlConnection, dtHIS1 As DataTable, v_IpAddress As String)
        If dtNODATA(dtHIS1) Then Return

        '(資料庫異常，放棄-防止駭客攻擊)
        If oConn Is Nothing OrElse Not OpenDbConn(oConn) Then Return 'rst 'Call OpenDbConn(oConn)
        Dim sql As String = ""
        sql &= " SELECT L_IP,L_HOSTNAME,L_CREATETIME,L_MODIFYTIME,L_COUNT,L_EMAIL"
        sql &= " FROM SYS_HISTORY1 WITH(NOLOCK)"
        sql &= " WHERE L_IP=@L_IP AND L_MODIFYTIME>=GETDATE()-(1./24./4.)" '15分鐘內(有異動)
        sql &= " AND L_EMAIL IS NULL AND L_COUNT>=9" '達到9次的(登入)錯誤‘L_EMAIL IS NULL 尚未寄信'寄信:1
        sql &= " AND CONVERT(date,L_MODIFYTIME)=CONVERT(date,GETDATE())" '當日
        Dim sCmd As New SqlCommand(sql, oConn)
        Dim dt As New DataTable
        With sCmd
            .Parameters.Clear()
            .Parameters.Add("L_IP", SqlDbType.VarChar).Value = v_IpAddress 'Common.GetIpAddress() 'MyPage.Request.UserHostAddress
            dt.Load(.ExecuteReader())
        End With
        If dtNODATA(dtHIS1) Then Return '查無資料離開

        'send-eamil
        Dim iRow As Integer = 0
        For Each dr1 As DataRow In dt.Rows
            If Convert.ToString(dr1("L_EMAIL")) = "" Then
                Dim u_sql As String = ""
                u_sql &= " UPDATE SYS_HISTORY1 SET L_EMAIL=1" 'L_EMAIL Is NULL 尚未寄信'寄信:1
                u_sql &= " FROM SYS_HISTORY1"
                u_sql &= " WHERE L_IP=@L_IP AND L_MODIFYTIME>=GETDATE()-(1./24./4.)" '15分鐘內(有異動)
                u_sql &= " AND L_EMAIL IS NULL AND L_COUNT>=9" '達到9次的(登入)錯誤‘L_EMAIL IS NULL 尚未寄信'寄信:1
                u_sql &= " AND CONVERT(date,L_MODIFYTIME)=CONVERT(date,GETDATE())" '當日
                Dim uCmd As New SqlCommand(u_sql, oConn)
                With uCmd
                    .Parameters.Add("L_IP", SqlDbType.VarChar).Value = v_IpAddress 'Common.GetIpAddress() 'MyPage.Request.UserHostAddress
                    .ExecuteNonQuery()
                End With
                Dim sMailBody As String = ""
                sMailBody &= String.Concat("IP:[", dr1("L_IP"), "]-HOST:", dr1("L_HOSTNAME"), "-C:", dr1("L_CREATETIME"), "-M:", dr1("L_MODIFYTIME"), "-[", dr1("L_COUNT"), "]", vbCrLf)
                sMailBody &= String.Concat("-- SYS,HISTORY1_SENDMAIL,HISTORY1,L_MODIFYTIME,(1.0/12),(1./24./4.),CNT,9 --", vbCrLf, vbCrLf)
                Call SendMailTest(sMailBody)
                iRow += 1
                If iRow > 3 Then Exit For '太多離開
            End If
        Next
    End Sub

