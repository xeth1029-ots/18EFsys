    ''' </summary>
    ''' <param name="MyPage"></param>
    ''' <param name="objconn"></param>
    ''' <returns></returns>
    <Obsolete("產投/在職 應該用不到這個判斷邏輯,程式應檢查是否存在不必要的邏輯")>
    Public Shared Function Get_TPlanID_P0(ByRef MyPage As Page, ByVal objconn As SqlConnection) As Boolean
        Dim rst As Boolean = False '該計畫為職前 (否)
        Dim sm As SessionModel = SessionModel.Instance()

        If sm.UserInfo.TPlanID Is Nothing Then Return rst
        If sm.UserInfo.DistID Is Nothing Then Return rst
        If sm.UserInfo.Years <= 0 Then Return rst
        If Convert.ToString(sm.UserInfo.TPlanID) = "" Then Return rst
        If Convert.ToString(sm.UserInfo.DistID) = "" Then Return rst
        If Convert.ToString(sm.UserInfo.Years) = "" Then Return rst
        Dim dt As New DataTable

        'null:其他(停用) 0:職前 1:在職
        Dim sql As String = $" SELECT 'x' FROM VIEW_PLAN WHERE PROPERTYID=0 AND TPLANID='{sm.UserInfo.TPlanID}' AND YEARS='{sm.UserInfo.Years}'"
