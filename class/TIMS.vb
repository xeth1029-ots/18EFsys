    ''' <summary>
    ''' 驗証密碼正確性一組密碼，至少要有2個英文字及2個數字組成
    ''' </summary>
    ''' <param name="MemberPwd"></param>
    ''' <returns></returns>
    Public Shared Function CheckPxssword(ByVal MemberPwd As String) As Boolean
        Dim FLAG As Boolean = False '不符合
        Dim ErrString As String = ""
        MemberPwd = MemberPwd.ToUpper '將字串換成大寫
        Dim CharEng As String = "ABCDEFGHIJKLMNOPQRSTUVWXYZ"
        Dim CharNumber As String = "0123456789"
        Dim intEng, intNumber As Integer
        intEng = 0
        intNumber = 0
        For i As Integer = 0 To MemberPwd.Length - 1
            If CharEng.IndexOf(MemberPwd.Chars(i)) > -1 Then
                intEng += 1
            End If
            If CharNumber.IndexOf(MemberPwd.Chars(i)) > -1 Then
                intNumber += 1
            End If
        Next
        If intEng >= 2 AndAlso intNumber >= 2 Then
            FLAG = True '符合範圍
        End If
        If intEng >= 4 Then '4組英文
            FLAG = True '符合範圍
        End If
        If intNumber >= 4 Then '4組數字
            FLAG = True '符合範圍
        End If
        Return FLAG
    End Function

