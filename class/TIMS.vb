    ''' <param name="obj"></param>
    ''' <param name="PARENTS"></param>
    ''' <param name="conn"></param>
    ''' <returns></returns>
    Public Shared Function GetGCode2B(ByVal obj As DropDownList, ByVal PARENTS As String, ByRef conn As SqlConnection) As DropDownList
        Dim sql As String = ""
        sql &= " SELECT c.GCID2,c.GCODE" & vbCrLf 'sql &= " ,'(' + LPAD(c.GCODE,2,'0') + ')' + c.CNAME CNAME" & vbCrLf
        sql &= " ,concat('(',RIGHT(concat('00',c.GCODE), 2),')',c.CNAME) CNAME" & vbCrLf
        sql &= " ,c.PARENTS" & vbCrLf
        sql &= " FROM ID_GOVCLASSCAST2 c" & vbCrLf
        '第2層/'第1層
        sql &= $" WHERE {If(PARENTS <> "", $" c.PARENTS={PARENTS}", " c.PARENTS IS NULL")}"
        sql &= " ORDER BY c.GCODE" & vbCrLf
        Dim dt As DataTable = DbAccess.GetDataTable(sql, conn)
        With obj
            .DataSource = dt
            .DataTextField = "CNAME"
            If PARENTS <> "" Then .DataValueField = "GCID2" Else .DataValueField = "GCODE"
            .DataBind()
        End With
        Return obj
    End Function

    ''' <summary>'職類課程人時成本分類檔(無介面人工維護)</summary>
    ''' <param name="GCID"></param>
    ''' <param name="strYears"></param>
    ''' <param name="conn"></param>
    ''' <returns></returns>
    Public Shared Function Get_GCIDName(ByVal GCID As String, ByVal strYears As String, ByRef conn As SqlConnection) As String
        Dim Rst As String = ""
        Dim sql As String = ""
        If GCID = "" Then Return Rst
        'strYears 2014/2015/2018
        Const cst_strYears_2014 As String = "2014"
        Const cst_strYears_2015 As String = "2015"
        Const cst_strYears_2018 As String = "2018"
        Select Case strYears
            Case cst_strYears_2014 '"2014"
                sql &= " SELECT concat('(',CASE WHEN GCODE2 IS NULL THEN CONVERT(varchar, GCODE1) ELSE CONVERT(varchar, GCODE2) END,')',CNAME) NAME" & vbCrLf
                sql &= " FROM ID_GOVCLASSCAST" & vbCrLf
                sql &= String.Concat(" WHERE GCID=", GCID)
            Case cst_strYears_2015 '"2015"
                'sql &= " SELECT '(' + LPAD(c.GCODE,2,'0') +')' + c.CNAME CNAME" & vbCrLf
                sql &= " SELECT concat('(',RIGHT('00'+CONVERT(VARCHAR, c.GCODE), 2),')',c.CNAME) CNAME" & vbCrLf
                sql &= " FROM ID_GOVCLASSCAST2 c" & vbCrLf
                sql &= String.Concat(" WHERE c.GCID2=", GCID)'GCID2
            Case cst_strYears_2018 '"2018"
                sql &= " SELECT concat('[',c.GCODE2,']',c.CNAME) CNAME" & vbCrLf
                sql &= " FROM V_GOVCLASSCAST3 c" & vbCrLf
                sql &= String.Concat(" WHERE c.GCID3=", GCID) 'GCID3
        End Select
        Rst = DbAccess.ExecuteScalar(sql, conn)
        Return Rst
    End Function

    ''' <summary> 取得 主要職類table y2018 </summary>
    ''' <param name="dt"></param>
    ''' <param name="oConn"></param>
    ''' <returns></returns>
    Public Shared Function Get_GOVCLASSCAST3dt(ByRef dt As DataTable, ByRef oConn As SqlConnection) As DataTable
        Dim sql As String = ""
        sql &= " SELECT tt.TMID, tt.BUSID, tt.BUSNAME, tt.JOBID, tt.JOBNAME, tt.TRAINID, tt.TRAINNAME" & vbCrLf
        sql &= " ,g.GCODE2, g.CNAME, g.GCID3" & vbCrLf
        sql &= " FROM V_GOVCLASSCAST3 g" & vbCrLf
        sql &= " JOIN VIEW_TRAINTYPE tt ON tt.TMID=g.TMID AND tt.TRAINID IS NOT NULL" & vbCrLf
        sql &= " ORDER BY tt.BUSID, tt.JOBID, tt.TMID" & vbCrLf
        dt = DbAccess.GetDataTable(sql, oConn)
        Return dt
    End Function

