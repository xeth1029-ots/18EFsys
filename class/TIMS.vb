        Dim rst As DataRow = Nothing

        Dim flag_oTestEnv As Boolean = sUtl_ChkTest() '(確認是否為測試環境)

        Dim parms As New Hashtable From {{"RID", rqRID}, {"PlanID", Re_Planid}, {"ComIDNO", Re_ComIDNO}, {"SeqNO", Re_SeqNO}}

        Dim sql As String = ""
        sql &= " WITH WAR1 AS (SELECT c.RID ,c.OrgID FROM Auth_Relship c WHERE c.RID=@RID)" & vbCrLf
        sql &= " SELECT a.*" & vbCrLf
        sql &= " ,CASE WHEN e.JobID IS NULL THEN e.TrainID ELSE e.JobID END TrainID" & vbCrLf
        sql &= " ,CASE WHEN e.JobID IS NULL THEN e.trainName ELSE e.JobName END TrainName" & vbCrLf
        sql &= " ,CASE WHEN e.JobID IS NULL THEN e.TrainID ELSE e.JobID END JobID" & vbCrLf
        sql &= " ,CASE WHEN e.JobID IS NULL THEN e.trainName ELSE e.JobName END JobName" & vbCrLf
        sql &= " ,b.OrgName ,d.PlanName ,s.CJOB_NAME ,s.CJOB_NO" & vbCrLf
        sql &= " FROM dbo.PLAN_PLANINFO a" & vbCrLf
        sql &= " JOIN dbo.ORG_ORGINFO b ON a.ComIDNO=b.ComIDNO" & vbCrLf
        sql &= " JOIN WAR1 ON WAR1.OrgID=b.OrgID AND WAR1.RID=a.RID" & vbCrLf
        sql &= " JOIN dbo.KEY_PLAN d ON a.TPlanID=d.TPlanID" & vbCrLf
        sql &= " JOIN dbo.KEY_TRAINTYPE e ON a.TMID=e.TMID" & vbCrLf
        sql &= " LEFT JOIN dbo.SHARE_CJOB s ON s.CJOB_UNKEY=a.CJOB_UNKEY" & vbCrLf
        If v_AppliedResult <> "" Then
            parms.Add("AppliedResult", v_AppliedResult)
            sql &= " WHERE a.AppliedResult=@AppliedResult" & vbCrLf
        Else
            '正式
            sql &= " WHERE a.ISAPPRPAPER='Y'" & vbCrLf
        End If
        ''sql &= " AND a.TransFlag='N'" & vbCrLf
        If Not flag_oTestEnv Then sql &= " AND a.TransFlag='N'" & vbCrLf '(正式)
        sql &= " AND a.PlanID=@PlanID AND a.ComIDNO=@ComIDNO AND a.SeqNO=@SeqNO" & vbCrLf

        Dim dt As DataTable = DbAccess.GetDataTable(sql, oConn, parms)

        iCnt = dt.Rows.Count

        '只有1筆資料才是正確的。 'Dim drPlaninfo As DataRow
        If dt.Rows.Count = 1 Then rst = dt.Rows(0) '.Count 'DbAccess.GetOneRow(strsql, objconn) 

        Return rst
    End Function

    ''' <summary>行政管理疏失/重大異常狀況，勾選鍵詞表</summary>
