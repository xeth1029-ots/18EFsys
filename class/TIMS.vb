    ''' <summary>
    ''' 根據檔案副檔名獲取對應的 Content-Type
    ''' </summary>
    Private Function GetContentType(fileExtension As String) As String
        Select Case fileExtension
            Case ".txt"
                Return "text/plain"
            Case ".pdf"
                Return "application/pdf"
            Case ".doc", ".docx"
                Return "application/msword"
            Case ".xls", ".xlsx"
                Return "application/vnd.ms-excel"
            Case ".ppt", ".pptx"
                Return "application/vnd.ms-powerpoint"
            Case ".zip"
                Return "application/zip"
            Case ".rar"
                Return "application/x-rar-compressed"
            Case ".jpg", ".jpeg"
                Return "image/jpeg"
            Case ".png"
                Return "image/png"
            Case ".gif"
                Return "image/gif"
            Case ".bmp"
                Return "image/bmp"
            Case ".svg"
                Return "image/svg+xml"
            Case ".mp3"
                Return "audio/mpeg"
            Case ".mp4"
                Return "video/mp4"
            Case Else
                ' 如果是未知類型，使用 application/octet-stream，這會提示瀏覽器下載檔案
                Return "application/octet-stream"
        End Select
    End Function

    Function DownloadImagePath(ByRef MyPage As Page, oConn As SqlConnection, imgSavePath As String, imgFileName As String) As String
        'Dim StrErrMsg1 As String= "" 'Dim fileName1 As String= TIMS.GetMyValue2(htPP, "fileName1") 'Dim filePath As String= Server.MapPath("~/new_note.txt")
        Dim filePath As String = MyPage.Server.MapPath(String.Concat(imgSavePath, TIMS.GetValidFileName(imgFileName)))

        ' 檢查檔案是否存在
        If Not File.Exists(filePath) Then
            ' 如果檔案不存在，返回 HTTP 404 'StrErrMsg1= "檔案不存在。"
            Return "檔案不存在。"
        End If

        Dim fileExtension1 As String = Path.GetExtension(imgFileName)
        ' 設定檔案的 Content-Type 'JPEG/ JPG 圖片： Image/ jpeg 'PNG 圖片： Image/ png
        Dim contentType As String = GetContentType(fileExtension1) ' "text/plain"
        ' 設定下載檔案的名稱
        Dim DownloadFileName1 As String = String.Concat(GetRnd6Eng(), "-", Now.ToString("yyyyMMddHHmmss"), fileExtension1) '"new_note.txt"
        ' 清除 Response 緩衝區
        With MyPage
            .Response.Clear()
            .Response.BufferOutput = False ' 避免緩衝所有內容，直接串流
            ' 設定 Response Headers
            .Response.ContentType = contentType
            .Response.AddHeader("Content-Disposition", "attachment; filename=" & DownloadFileName1)
            '將檔案內容寫入 Response 串流
            .Response.WriteFile(filePath)
            ' 結束 Response 處理
            Utl_RespWriteEnd(MyPage, oConn, "") '.Response.End()
        End With
        Return ""
    End Function

    ''' <summary>
    ''' 系統開機時間
    ''' </summary>
    ''' <returns></returns>
    Public Shared Function SystemBootTime() As String
        '獲取自系統啟動以來經過的毫秒數
        Dim tickCount As Long = Environment.TickCount '.TickCount64

        ' 將毫秒轉換為 TimeSpan
        Dim uptime As TimeSpan = TimeSpan.FromMilliseconds(tickCount)

        ' 計算開機時間
        Dim bootTime As DateTime = DateTime.Now - uptime

        ' 獲取開機時間
        Dim str1 As String = ""
        str1 &= String.Concat($"系統已運行時間: {uptime.Days} 天 {uptime.Hours} 小時 {uptime.Minutes} 分鐘 {uptime.Seconds} 秒", vbCrLf)
        str1 &= String.Concat($"系統開機時間: {bootTime}", vbCrLf)
        'str1 &= String.Concat($"系統開機日期: {bootTime.ToShortDateString()}", vbCrLf)
        Return str1
    End Function

