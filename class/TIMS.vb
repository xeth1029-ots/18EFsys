    '取得目前table的所有ocid以逗點分隔
    Public Shared Function Get_ssOCID(ByRef dt As DataTable) As String
        Dim rst As String = ""
        For Each dr As DataRow In dt.Rows
            If rst <> "" Then
                Dim ff3 As String = $",{dr("ocid")},"
                If $",{rst},".IndexOf(ff3) = -1 Then
                    rst &= $"{If(rst <> "", ",", "")}{dr("ocid")}"
                End If
            Else
                rst &= $"{dr("ocid")}"
            End If
        Next
        Return rst
    End Function

    '取得要比對的課程資料
    Public Shared Function Get_TRAINDESC(ByVal ssOCID As String, ByRef dtEnter As DataTable, ByVal tConn As SqlConnection) As DataTable
        Dim dt As DataTable
        Dim sql As String = ""
        sql &= " SELECT pt.PTDID" & vbCrLf
        sql &= " ,CONVERT(varchar, pt.straindate, 111) STRAINDATE" & vbCrLf
        sql &= " ,CONVERT(varchar, pt.straindate, 111)+' '+ LEFT(pt.pname,5) straindate1" & vbCrLf
        sql &= " ,CONVERT(varchar, pt.straindate, 111)+' '+ RIGHT(pt.pname,5) straindate2" & vbCrLf
        sql &= " ,pt.PNAME" & vbCrLf '時間區間
        sql &= " ,pt.phour" & vbCrLf
        sql &= " ,cc.ocid" & vbCrLf
        sql &= " ,CONVERT(varchar, cc.stdate, 111) stdate" & vbCrLf
        sql &= " ,CONVERT(varchar, cc.ftdate, 111) ftdate" & vbCrLf
        sql &= " FROM PLAN_PLANINFO pp" & vbCrLf
        sql &= " join PLAN_TRAINDESC pt on  pt.planid=pp.planid and pt.comidno=pp.comidno and pt.seqno=pp.seqno" & vbCrLf
        sql &= " join CLASS_CLASSINFO cc on cc.planid=pp.planid and cc.comidno=pp.comidno and cc.seqno=pp.seqno" & vbCrLf
        sql &= " join ID_PLAN ip on ip.planid=cc.planid" & vbCrLf
        sql &= " WHERE pp.IsApprPaper='Y' AND cc.IsSuccess='Y' AND cc.NotOpen='N' AND ip.TPLANID='28'" & vbCrLf
        sql &= " AND cc.STDATE >= convert(date,DATEADD(YEAR,-1,GETDATE()))" & vbCrLf
        If ssOCID = "" Then
            sql &= " and 1<>1" & vbCrLf
        Else
            sql &= " and cc.OCID IN (" & ssOCID & ")" & vbCrLf
        End If
        dt = DbAccess.GetDataTable(sql, tConn)

        '保留可能錄訓的班級，排除無效班級
        Dim ff As String = ""
        For Each drv As DataRow In dtEnter.Rows 'signUpStatus
            Dim canDelete As Boolean = False
            'signUpStatus-0:收件完成 1:報名成功 2:報名失敗 3:正取(Key_SelResult) 4:備取 5:未錄取
            Select Case Convert.ToString(drv("signUpStatus"))
                Case "0", "1", "3"
                    Select Case Convert.ToString(drv("STUDSTATUS"))
                        Case "2", "3"
                            canDelete = True
                    End Select
                Case Else
                    canDelete = True
            End Select

            If canDelete Then
                ff = "OCID=" & CStr(drv("OCID"))
                If dt.Select(ff).Length > 0 Then
                    For Each drv2 As DataRow In dt.Select(ff)
                        drv2.Delete()
                    Next
                End If
            End If
        Next
        '確定搜尋班級。
        dt.AcceptChanges()

        Return dt
    End Function

