    ''' <summary>判斷是否為數字，正數(浮點數可為.0或.5) '格式有誤，僅提供填寫小數點後為5('須大於0不可為0)</summary>
    ''' <param name="obj"></param>
    ''' <returns></returns>
    Public Shared Function IsNumeric5(ByVal obj As Object) As Boolean
        Dim Rst As Boolean = False
        If (obj Is Nothing) Then Return Rst
        Const cst_x05 As Double = 0.5
        Try
            If IsNumeric(obj) AndAlso (Val(obj) > 0) AndAlso (Val(obj) Mod cst_x05) = 0 Then '須大於0'須小數點後為5，或是整數的數字
                Rst = True
            End If
        Catch ex As Exception
            LOG.Warn(ex.Message, ex)
        End Try
        Return Rst
    End Function

