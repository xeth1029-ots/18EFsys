    ''' <param name="PCSValue">concat(a.PlanID,'_',a.ComIDNO,'_',a.SeqNo)</param>
    ''' <param name="STRAINDATE">STRAINDATE</param>
    ''' <param name="tConn"></param>
    ''' <returns></returns>
    Public Shared Function CHK_TRAINDESC_STRAINDATE(ByVal PCSValue As String, ByVal STRAINDATE As String, ByVal tConn As SqlConnection) As Boolean
        Dim rst As Boolean = False
        Dim sql As String = ""
        sql &= " SELECT 1 FROM dbo.PLAN_TRAINDESC a" & vbCrLf
        sql &= " WHERE concat(a.PlanID,'_',a.ComIDNO,'_',a.SeqNo)=@PCSValue" & vbCrLf
        sql &= " AND a.STRAINDATE=@STRAINDATE" & vbCrLf
        Dim sCmd As New SqlCommand(sql, tConn)
        Call OpenDbConn(tConn)
        Dim dt As New DataTable
        With sCmd
            .Parameters.Clear()
            .Parameters.Add("PCSValue", SqlDbType.VarChar).Value = PCSValue
            .Parameters.Add("STRAINDATE", SqlDbType.DateTime).Value = Cdate2(STRAINDATE)
            dt.Load(.ExecuteReader())
        End With
        If dt.Rows.Count = 0 Then Return rst
        rst = True
        Return rst
    End Function

