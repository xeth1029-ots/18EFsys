    '取出鍵詞-群組代碼
    Public Shared Function Get_AuthGroup(ByRef obj As ListControl, ByVal tConn As SqlConnection) As ListControl
        Dim sSql As String = ""
        sSql &= " SELECT G.GDISTID ,G.GID" & vbCrLf
        sSql &= " ,concat(D.CONTACTNAME,'-',dbo.DECODE8(G.GTYPE,'0','署','1','分','2','委',''),'-',REPLACE(G.GNAME,'-','')) GNAME" & vbCrLf
        sSql &= " ,G.GTYPE" & vbCrLf
        sSql &= " FROM AUTH_GROUP G" & vbCrLf
        sSql &= " JOIN V_DISTRICT D ON D.DISTID=G.GDISTID" & vbCrLf
        sSql &= " WHERE G.GSTATE!='D'" & vbCrLf
        sSql &= " ORDER BY G.GDISTID, G.GTYPE, G.GID" & vbCrLf
        Dim sCmd As New SqlCommand(sSql, tConn)
        Call OpenDbConn(tConn)
        Dim dt As New DataTable
        With sCmd
            .Parameters.Clear()
            dt.Load(.ExecuteReader())
        End With
        With obj
            .DataSource = dt
            .DataTextField = "GNAME"
            .DataValueField = "GID"
            .DataBind()
        End With
        Return obj
    End Function

    ''' <summary> 取出鍵詞-訓練計畫代碼 </summary>
    ''' <param name="obj"></param>
    ''' <param name="dt"></param>
    ''' <param name="SearchQueryDisplay"></param>
    ''' <param name="IsAll"></param>
    ''' <param name="strWHERE"></param>
    ''' <param name="conn"></param>
    ''' <returns></returns>
    Public Shared Function Get_TPlan(ByRef obj As ListControl,
        Optional ByVal dt As DataTable = Nothing,
        Optional ByVal SearchQueryDisplay As Integer = 0,
        Optional ByVal IsAll As String = "N",
        Optional ByVal strWHERE As String = "",
        Optional ByVal conn As SqlConnection = Nothing) As ListControl
        'dt若為nothing則採用排除規則 'SearchQueryDisplay:0 不啟動 1:要啟動 2:'查詢時含序號 'IsAll:Y:ALL N(其他):不理會 'strWHERE 加入WHERE 條件
        Dim sql As String = ""
        If dt Is Nothing Then
            'sql="SELECT * FROM Key_Plan WHERE (Clsyear is null or Clsyear > '" & Year(Now) & "') "" ORDER BY TPLANID"
            '當系統管理中的參數設定,將計畫停用年度設定為2009年時,'計畫在下列的統計功能中, 就會不出現, 不管是選2008年或其他年度, 
            '都不出現, 也就無法統計了, 煩請將此限制功能拿掉, 也就是不管計畫是否被停用,'統計功能中, 一樣要顯示出這個計畫 penny 2009-01-08
            Select Case SearchQueryDisplay
                Case 2 '查詢時含序號
                    sql &= " SELECT a.TPLANID,a.PLANNAME,a.QUERYDISPLAY,a.CLSYEAR ,concat('(',a.TPLANID,') ',a.PLANNAME) PLANNAME2" & vbCrLf
                    sql &= " FROM dbo.KEY_PLAN a" & vbCrLf
                    sql &= " WHERE 1=1" & vbCrLf
                Case 1 '查詢時 (查詢時是否顯示)
                    sql &= " SELECT a.TPLANID,a.PLANNAME,a.QUERYDISPLAY,a.CLSYEAR FROM dbo.KEY_PLAN a" & vbCrLf
                    sql &= " WHERE a.QUERYDISPLAY='Y'" & vbCrLf
                Case Else '0 不啟動 其他狀況
                    sql &= " SELECT a.TPLANID,a.PLANNAME,a.QUERYDISPLAY,a.CLSYEAR FROM dbo.KEY_PLAN a" & vbCrLf
                    sql &= " WHERE 1=1" & vbCrLf
            End Select
            If strWHERE <> "" Then sql &= $" AND {strWHERE}{vbCrLf}"
            sql &= " AND (a.CLSYEAR IS NULL OR ISNULL(a.CLSYEAR,SUBSTRING(CONVERT(VARCHAR,GETDATE(),111),1,4))>=SUBSTRING(CONVERT(VARCHAR,GETDATE(),111),1,4))" & vbCrLf
            sql &= " ORDER BY a.TPLANID" & vbCrLf

            Dim FlagConnNG As Boolean = If(conn Is Nothing, True, False)
            If FlagConnNG Then conn = DbAccess.GetConnection()
            dt = DbAccess.GetDataTable(sql, conn)
            If FlagConnNG Then Call CloseDbConn(conn)
        End If

        With obj
            .DataSource = dt
            Select Case SearchQueryDisplay
                Case 2
                    '查詢時含序號
                    .DataTextField = "PLANNAME2"
                Case Else
                    .DataTextField = "PLANNAME"
            End Select
            .DataValueField = "TPLANID"
            .DataBind()
            If TypeOf obj Is DropDownList Then
                .Items.Insert(0, New ListItem(cst_ddl_PleaseChoose3, ""))
            ElseIf UCase(IsAll) = cst_YES Then
                .Items.Insert(0, New ListItem("全部", ""))
            End If
        End With

        Return obj
    End Function

    '取出鍵詞2-訓練計畫代碼 '0職前 1在職(進修) 2委託訓練 
    Public Shared Sub Get_TPlan2(ByRef obj0 As System.Web.UI.WebControls.CheckBoxList,
        ByRef obj1 As System.Web.UI.WebControls.CheckBoxList,
        ByRef objX As System.Web.UI.WebControls.CheckBoxList,
