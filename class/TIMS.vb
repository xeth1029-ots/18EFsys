                sql &= " + CASE WHEN ISNULL(tt.ExpMonths1,0)!=0  THEN ' ' + CAST(tt.ExpMonths1 AS VARCHAR) + '月' ELSE '' END ExpUnit1" & vbCrLf
                sql &= " ,dbo.fn_GET_PLAN_TEACHER3(p1.planid,p1.comidno,p1.seqno,'B',tt.TechID) TeacherDesc " 'TechTYPE: A:師資/B:助教
                sql &= " FROM CLASS_CLASSINFO a" & vbCrLf
                sql &= " JOIN PLAN_PLANINFO P1 ON a.PlanID=P1.PlanID AND a.ComIDNO=P1.ComIDNO AND a.SeqNo=P1.SeqNo" & vbCrLf
                sql &= " JOIN PLAN_VERREPORT Pv ON P1.PlanID=Pv.PlanID AND P1.ComIDNO=Pv.ComIDNO AND P1.SeqNo=Pv.SeqNo "
                sql &= " JOIN PLAN_TRAINDESC pt ON P1.comidno=pt.comidno AND P1.planid=pt.planid AND P1.seqno=pt.seqno" & vbCrLf
                sql &= " JOIN TEACH_TEACHERINFO tt ON pt.TechID2=TT.TechID" & vbCrLf
                sql &= " LEFT JOIN KEY_DEGREE KD ON TT.DegreeID=KD.DegreeID "
                sql &= " WHERE a.OCID=@OCID"
                Dim sCmd As New SqlCommand(sql, oConn)
                Call OpenDbConn(oConn)
                With sCmd
                    .Parameters.Clear()
                    .Parameters.Add("OCID", SqlDbType.VarChar).Value = OCID
                    dt1.Load(.ExecuteReader())
                End With
            Case cst_sType_B_未轉班
                Dim sql As String = ""
                '姓名
                sql &= " SELECT DISTINCT tt.TeachCName" & vbCrLf
                '專業領域
                '"(20181113 依照問題單號129的需求,調整『專業領域』欄位內容資料)"
                'sql &= " ,tt.Specialty1" & vbCrLf
                'sql &= " +(CASE WHEN tt.Specialty2 IS NOT NULL THEN ';' + tt.Specialty2 ELSE '' END)" & vbCrLf
                'sql &= " +(CASE WHEN tt.Specialty3 IS NOT NULL THEN ';' + tt.Specialty3 ELSE '' END)" & vbCrLf
                'sql &= " +(CASE WHEN tt.Specialty4 IS NOT NULL THEN ';' + tt.Specialty4 ELSE '' END)" & vbCrLf
                'sql &= " +(CASE WHEN tt.Specialty5 IS NOT NULL THEN ';' + tt.Specialty5 ELSE '' END) Specialty1" & vbCrLf
                sql &= " ,(CASE WHEN tt.Specialty1 IS NOT NULL THEN tt.Specialty1 ELSE '' END) Specialty1" & vbCrLf  'edit，by:20181113
                '專業證照-相關證照
                sql &= " ,CASE WHEN tt.ProLicense1 IS NOT NULL AND tt.ProLicense2 IS NOT NULL THEN concat(tt.ProLicense1,'、',tt.ProLicense2)" & vbCrLf
                sql &= "  WHEN tt.ProLicense1 IS NOT NULL AND tt.ProLicense2 IS NULL THEN tt.ProLicense1" & vbCrLf
                sql &= "  WHEN tt.ProLicense1 IS NULL AND tt.ProLicense2 IS NOT NULL THEN tt.ProLicense2" & vbCrLf
                sql &= "  ELSE tt.ProLicense END ProLicense" & vbCrLf
                '學歷                     
                sql &= " ,kD.Name DegreeName" & vbCrLf
                '工作經驗與年資             
                sql &= " ,tt.ExpUnit1" & vbCrLf
                sql &= " + CASE WHEN ISNULL(tt.ExpYears1,0)!=0 THEN ',' + CAST(tt.ExpYears1 AS VARCHAR) + '年' ELSE '' END" & vbCrLf
                sql &= " + CASE WHEN ISNULL(tt.ExpMonths1,0)!=0  THEN ' ' + CAST(tt.ExpMonths1 AS VARCHAR) + '月' ELSE '' END ExpUnit1" & vbCrLf
                sql &= " ,dbo.fn_GET_PLAN_TEACHER3(p1.planid,p1.comidno,p1.seqno,'B',tt.TechID) TeacherDesc " 'TechTYPE: A:師資/B:助教
                sql &= " FROM PLAN_PLANINFO p1" & vbCrLf
                sql &= " JOIN PLAN_VERREPORT pv ON p1.PlanId=pv.PlanId AND p1.ComIDNO=pv.ComIDNO AND p1.seqNo=pv.seqNo" & vbCrLf
                sql &= " JOIN PLAN_TRAINDESC pt ON p1.PlanId=pt.PlanId AND p1.ComIDNO=pt.ComIDNO AND p1.seqNo=pt.seqNo" & vbCrLf
                sql &= " JOIN TEACH_TEACHERINFO tt ON pt.TECHID2=tt.TECHID" & vbCrLf
                sql &= " LEFT JOIN Key_Degree kd ON tt.DEGREEID=kd.DEGREEID" & vbCrLf
                sql &= " WHERE p1.PlanID=@PlanID AND p1.ComIDNO=@ComIDNO AND p1.SeqNo=@SeqNo"
                Dim sCmd As New SqlCommand(sql, oConn)
                Call OpenDbConn(oConn)
                With sCmd
                    .Parameters.Clear()
                    .Parameters.Add("PlanID", SqlDbType.Int).Value = CINT1(PlanID)
                    .Parameters.Add("ComIDNO", SqlDbType.VarChar).Value = ComIDNO
                    .Parameters.Add("SeqNo", SqlDbType.Int).Value = CINT1(SeqNo)
                    dt1.Load(.ExecuteReader())
                End With
        End Select
        Return dt1
    End Function

    ''' <summary>
    ''' 取得訓練地點資料
    ''' </summary>
    ''' <param name="ss3"></param>
    ''' <returns></returns>
    ''' <remarks></remarks>
    Public Shared Function Get_TrainPlaceDt3(ByRef oConn As SqlConnection, ByVal ss3 As String) As DataTable
        Dim dt1 As New DataTable
        Dim sType As String = GetMyValue(ss3, "sType")
        Dim OCID As String = GetMyValue(ss3, "OCID")
        Dim PlanID As String = GetMyValue(ss3, "PlanID")
        Dim ComIDNO As String = GetMyValue(ss3, "ComIDNO")
        Dim SeqNo As String = GetMyValue(ss3, "SeqNo")
        Select Case sType
            Case cst_sType_A_已轉班
                Dim sql As String = ""
                sql &= " SELECT a.planid, a.comidno, a.seqno, a.ocid ,p1.CapDegree" & vbCrLf
                '訓練費用編列說明
                sql &= " ,p1.NOTE,P1.TMScience ,P1.TMTech" & vbCrLf
                sql &= " ,P1.SciPlaceID ,P1.SciPlaceID2 ,P1.TechPlaceID ,P1.TechPlaceID2 ,p2.capall ,P2.TeacherDesc ,P2.TeacherDesc2 ,K3.Name SName" & vbCrLf
                sql &= " ,concat(dbo.FN_GZIP33(P3.ZipCode,P3.ZIP6W),V2.ZipName,P3.Address) Address1, P3.Connum Connum1, P3.HWDESC HWDESC1" & vbCrLf
                sql &= " ,concat(dbo.FN_GZIP33(P4.ZipCode,P4.ZIP6W),V3.ZipName,P4.Address) Address2, P4.Connum Connum2, P4.HWDESC HWDESC2" & vbCrLf
                sql &= " ,concat(dbo.FN_GZIP33(P5.ZipCode,P5.ZIP6W),V4.ZipName,P5.Address) Address3, P5.Connum Connum3, P5.HWDESC HWDESC3" & vbCrLf
                sql &= " ,concat(dbo.FN_GZIP33(P6.ZipCode,P6.ZIP6W),V5.ZipName,P6.Address) Address4, P6.Connum Connum4, P6.HWDESC HWDESC4" & vbCrLf
                sql &= " ,CASE WHEN P3.OtherDesc IS NOT NULL THEN ISNULL(P3.OtherDesc,'')+'; '+ISNULL(P4.OtherDesc,'') ELSE ISNULL(P4.OtherDesc,'') END OTHERDESC3" & vbCrLf
                sql &= " FROM CLASS_CLASSINFO a" & vbCrLf
                sql &= " JOIN PLAN_PLANINFO P1 ON a.PlanID=P1.PlanID AND a.ComIDNO=P1.ComIDNO AND a.SeqNo=P1.SeqNo" & vbCrLf
                sql &= " JOIN VIEW_RIDNAME V1 ON P1.RID=V1.RID" & vbCrLf
                sql &= " LEFT JOIN PLAN_VERREPORT P2 ON P1.PlanID=P2.PlanID AND P1.ComIDNO=P2.ComIDNO AND P1.SeqNo=P2.SeqNo" & vbCrLf
                sql &= " LEFT JOIN (SELECT * FROM Plan_TrainPlace WHERE (classification=1 OR classification=3) ) P3 ON p3.comidno=p1.comidno AND p1.SciPlaceID=P3.PLACEID" & vbCrLf
                sql &= " LEFT JOIN (SELECT * FROM Plan_TrainPlace WHERE (classification=2 OR classification=3) ) P4 ON p4.comidno=p1.comidno AND p1.TechPlaceID=P4.PLACEID" & vbCrLf
                sql &= " LEFT JOIN (SELECT * FROM Plan_TrainPlace WHERE (classification=1 OR classification=3) ) P5 ON p5.comidno=p1.comidno AND p1.SciPlaceID2=P5.PLACEID" & vbCrLf
                sql &= " LEFT JOIN (SELECT * FROM Plan_TrainPlace WHERE (classification=2 OR classification=3) ) P6 ON p6.comidno=p1.comidno AND p1.TechPlaceID2=P6.PLACEID" & vbCrLf
                sql &= " LEFT JOIN Key_Degree K3 ON p1.CapDegree=K3.DegreeID" & vbCrLf
                sql &= " LEFT JOIN view_ZipName V2 ON P3.ZipCode=V2.ZipCode" & vbCrLf
                sql &= " LEFT JOIN view_ZipName V3 ON P4.ZipCode=V3.ZipCode" & vbCrLf
                sql &= " LEFT JOIN view_ZipName V4 ON P5.ZipCode=V4.ZipCode" & vbCrLf
                sql &= " LEFT JOIN view_ZipName V5 ON P6.ZipCode=V5.ZipCode" & vbCrLf
                sql &= " WHERE a.OCID=@OCID"
                'sql &= " /*AND V1.TPLANID='28' AND V1.YEARS='2021'*/" & vbCrLf
                Dim sCmd As New SqlCommand(sql, oConn)
                Call OpenDbConn(oConn)
                With sCmd
                    .Parameters.Clear()
                    .Parameters.Add("OCID", SqlDbType.VarChar).Value = OCID
                    dt1.Load(.ExecuteReader())
                End With

            Case cst_sType_B_未轉班
                Dim sql As String = ""
                sql &= " SELECT ppi.PlanID ,pvp.TeacherDesc ,pvp.TeacherDesc2 ,kd.Name SName ,pvp.CapAll" & vbCrLf
                '訓練費用編列說明
                sql &= " ,ppi.NOTE,ppi.TMScience,ppi.TMTech" & vbCrLf
                sql &= " ,concat(dbo.FN_GZIP33( ptp.ZipCode, ptp.ZIP6W), vzn.ZipName, ptp.Address) Address1, ptp.Connum Connum1, ptp.HWDesc HWDesc1" & vbCrLf
                sql &= " ,concat(dbo.FN_GZIP33(ptp2.ZipCode,ptp2.ZIP6W),vzn2.ZipName,ptp2.Address) Address2,ptp2.Connum Connum2,ptp2.HWDesc HWDesc2" & vbCrLf
                sql &= " ,concat(dbo.FN_GZIP33(ptp3.ZipCode,ptp3.ZIP6W),vzn3.ZipName,ptp3.Address) Address3,ptp3.Connum Connum3,ptp3.HWDesc HWDesc3" & vbCrLf
                sql &= " ,concat(dbo.FN_GZIP33(ptp4.ZipCode,ptp4.ZIP6W),vzn4.ZipName,ptp4.Address) Address4,ptp4.Connum Connum4,ptp4.HWDesc HWDesc4" & vbCrLf
                sql &= " ,ptp.OtherDesc ,ptp2.OtherDesc OtherDesc2" & vbCrLf
                sql &= " ,CASE WHEN ptp.OtherDesc IS NOT NULL THEN ISNULL(ptp.OtherDesc,'')+'; '+ISNULL(ptp2.OtherDesc,'') ELSE ISNULL(ptp2.OtherDesc,'') END OTHERDESC3" & vbCrLf
                sql &= " FROM PLAN_PLANINFO ppi" & vbCrLf
                sql &= " LEFT JOIN Plan_VerReport pvp ON pvp.PlanID=ppi.PlanID AND pvp.ComIDNO=ppi.ComIDNO AND pvp.SeqNO=ppi.SeqNO" & vbCrLf
                sql &= " LEFT JOIN Plan_TrainPlace ptp ON ppi.ComIDNO=ptp.ComIDNO AND ppi.SciPlaceID=ptp.PlaceID AND (ptp.classification=1 OR ptp.classification=3) AND ptp.ModifyType IS NULL" & vbCrLf
                sql &= " LEFT JOIN Plan_TrainPlace ptp2 ON ppi.ComIDNO=ptp2.ComIDNO AND ppi.TechPlaceID=ptp2.PlaceID AND (ptp2.classification=2 OR ptp2.classification=3) AND ptp2.ModifyType IS NULL" & vbCrLf
                sql &= " LEFT JOIN Plan_TrainPlace ptp3 ON ppi.ComIDNO=ptp3.ComIDNO AND ppi.SciPlaceID2=ptp3.PlaceID AND (ptp3.classification=1 OR ptp3.classification=3) AND ptp3.ModifyType IS NULL" & vbCrLf
                sql &= " LEFT JOIN Plan_TrainPlace ptp4 ON ppi.ComIDNO=ptp4.ComIDNO AND ppi.TechPlaceID2=ptp4.PlaceID AND (ptp4.classification=2 OR ptp4.classification=3) AND ptp4.ModifyType IS NULL" & vbCrLf
                sql &= " LEFT JOIN Key_Degree kd ON kd.DegreeID=ppi.CapDegree" & vbCrLf
                sql &= " LEFT JOIN view_ZipName vzn ON vzn.ZipCode=ptp.ZipCode" & vbCrLf
                sql &= " LEFT JOIN view_ZipName vzn2 ON vzn2.ZipCode=ptp2.ZipCode" & vbCrLf
                sql &= " LEFT JOIN view_ZipName vzn3 ON vzn3.ZipCode=ptp3.ZipCode" & vbCrLf
                sql &= " LEFT JOIN view_ZipName vzn4 ON vzn4.ZipCode=ptp4.ZipCode" & vbCrLf
                sql &= " WHERE ppi.PlanID=@PlanID AND ppi.ComIDNO=@ComIDNO AND ppi.SeqNo=@SeqNo"
                Dim sCmd As New SqlCommand(sql, oConn)
                Call OpenDbConn(oConn)
                With sCmd
                    .Parameters.Clear()
                    .Parameters.Add("PlanID", SqlDbType.Int).Value = CINT1(PlanID)
                    .Parameters.Add("ComIDNO", SqlDbType.VarChar).Value = ComIDNO
                    .Parameters.Add("SeqNo", SqlDbType.Int).Value = CINT1(SeqNo)
                    dt1.Load(.ExecuteReader())
                End With

        End Select
        Return dt1
    End Function

