    Public Shared Function Get_FunIDReUse(ByRef obj As ListControl, ByVal conn As SqlConnection, ByVal sFunID As String) As ListControl
        'fix 將資料類型從 nvarchar 轉換到 numeric 時發生錯誤 問題
        Dim sql As String = ""
        sql &= " SELECT a.Name+': '+cast(a.FunID as varchar(11)) Name1 ,a.FunID "
        sql &= " FROM ID_FUNCTION a"
        sql &= " WHERE a.ReUse='Y' AND a.Valid='Y'" & vbCrLf
        sql &= If(sFunID <> "", $" And a.FunID In ({sFunID})", "") & vbCrLf
        sql &= " ORDER BY 1" & vbCrLf
        Dim dt As DataTable = Nothing
        dt = DbAccess.GetDataTable(sql, conn)
        With obj
            .DataSource = dt
            .DataTextField = "Name1"
            .DataValueField = "FunID"
            .DataBind()
        End With
        Return obj
    End Function

