    'Change inverted commas 單引號 single quotation marks
    Public Shared Function ChangeSQM(ByRef obj1 As Object) As String
        Dim str As String = ""
        If obj1 Is Nothing Then Return str
        str = Convert.ToString(obj1)
        If str = "" Then Return str
        If str.IndexOf("'") > -1 Then str = Replace(str, "'", "''")
        If str Is Nothing Then str = ""
        Return str
    End Function

