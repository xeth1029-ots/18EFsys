    Public Shared Function GET_ORG_SFCASEFL_iSFCFID(sm As SessionModel, oConn As SqlConnection, vSFCID As String, vKSFID As String, vWAIVED As String, drOB As DataRow) As Integer
        Dim iSFCFID As Integer = -1
        If vSFCID = "" OrElse vKSFID = "" OrElse vWAIVED = "" Then Return -1
        Dim sParms As New Hashtable From {{"SFCID", CINT1(vSFCID)}, {"KSFID", CINT1(vKSFID)}, {"WAIVED", vWAIVED}}
        Dim sSql As String = ""
        sSql &= " SELECT SFCFID FROM ORG_SFCASEFL" & vbCrLf
        sSql &= " WHERE SFCID=@SFCID AND KSFID=@KSFID AND WAIVED=@WAIVED ORDER BY SFCFID DESC" & vbCrLf
        Dim dt1 As DataTable = DbAccess.GetDataTable(sSql, oConn, sParms)
        If dt1 Is Nothing OrElse dt1.Rows.Count = 0 Then
            iSFCFID = DbAccess.GetNewId(oConn, "ORG_SFCASEFL_SFCFID_SEQ,ORG_SFCASEFL,SFCFID")
            Dim iParms As New Hashtable From {{"SFCFID", iSFCFID}, {"SFCID", CINT1(vSFCID)}, {"KSFID", CINT1(vKSFID)}, {"MODIFYACCT", sm.UserInfo.UserID}, {"WAIVED", vWAIVED}}
            Dim isSql As String = ""
            isSql &= " INSERT INTO ORG_SFCASEFL(SFCFID,SFCID,KSFID,MODIFYACCT,MODIFYDATE,WAIVED)" & vbCrLf
            isSql &= " VALUES(@SFCFID,@SFCID,@KSFID,@MODIFYACCT,GETDATE(),@WAIVED)" & vbCrLf
            DbAccess.ExecuteNonQuery(isSql, oConn, iParms)
            Return iSFCFID
        Else
