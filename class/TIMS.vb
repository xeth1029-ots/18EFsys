    'budid BudgetID 不能有單引號
    Public Shared Function GET_BudgetName(ByVal sBudgetID As String, ByRef oConn As SqlConnection) As String
        Dim rst As String = ""
        sBudgetID = ClearSQM(sBudgetID)
        If sBudgetID = "" Then Return rst

        Const Cst_partition As String = ","
        Dim sql As String = " SELECT BUDID, BUDNAME FROM VIEW_BUDGET2 ORDER BY BUDID "
        Dim sCmd As New SqlCommand(sql, oConn)
        Call OpenDbConn(oConn)
        Dim dt As New DataTable
        With sCmd
            .Parameters.Clear()
            dt.Load(.ExecuteReader())
        End With

        If sBudgetID.IndexOf(Cst_partition) = -1 Then
            '表示只有1筆資料
            Dim ff3 As String = $"BUDID='{sBudgetID}'" 'String.Concat(
            If dt.Select(ff3).Length <> 0 Then
                rst = dt.Select(ff3)(0)("budname")
                Return rst
            End If
        Else
            '有多筆資料，以逗號分隔
            Dim ArrayValue As Array = Split(sBudgetID, Cst_partition)
            For i As Integer = 0 To ArrayValue.Length - 1
                Dim ff3 As String = $"BUDID='{ArrayValue(i)}'" 'String.Concat("BUDID='", , "'")
                If dt.Select(ff3).Length <> 0 Then
                    rst &= String.Concat(If(rst <> "", ",", ""), dt.Select(ff3)(0)("budname"))
                End If
            Next
        End If
        Return rst
    End Function

