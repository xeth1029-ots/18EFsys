        Try
            If sess_obj IsNot Nothing AndAlso TypeOf sess_obj Is DataTable Then
                'Session 中存在 DataTable，並且類型正確
                Dim dt As DataTable = DirectCast(sess_obj, DataTable)
                sess_obj = sess_obj ' 可以繼續使用 DataTable 對象
