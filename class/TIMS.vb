    Public Shared Function Get_STUDENTINFO(ByVal strSS As String, ByRef oConn As SqlConnection) As DataTable
        Dim rDt As DataTable = Nothing
        'Dim rst As String=""
        Dim vPlanID As String = GetMyValue(strSS, "PlanID")
        Dim vRID As String = GetMyValue(strSS, "RID")
        If vPlanID = "" OrElse vRID = "" Then Return rDt
        Dim vOCID As String = GetMyValue(strSS, "OCID") '可為空值

