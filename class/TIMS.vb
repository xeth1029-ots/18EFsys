    ''' <summary> 職前參訓歷史查詢-WEB-SERVICE-1- ADP_TRAININGLIST </summary>
    ''' <param name="vIDNO"></param>
    ''' <param name="flag_ALL"></param>
    ''' <returns></returns>
    Public Shared Function GetTrainingList(ByVal vIDNO As String, ByVal flag_ALL As Boolean) As DataTable
        'flag_ALL : false: 略過-非在職者 (若為全部時不略過)(Continue For)

        'Const cst_all_column As String="IDNO,NAME,BIRTHDAY,DISTNAME,YEARS,TPLANID,PLANNAME,ORGNAME,TRAINNAME,CJOB_NAME,CLASSCNAME,THours,TRound,WEEKS,TFLAG,WorkSuppIdent,SumOfMoney,BudIDName,AppliedStatus,AppliedStatusM,MEMO1"
        Dim dt As DataTable = Utl_CreateITSWebcCDT()

        'Const cst_SYSNAME_1 As String="PSHTL001"
        Const cst_s_AUTH As String = "ce130f098d90e52491a8097fcd119b4d"

        Dim sw As New System.Diagnostics.Stopwatch() '引用stopwatch物件
        sw.Reset() '碼表歸零
        sw.Start() '碼表開始計時

        'WebRequest物件如何忽略憑證問題
        System.Net.ServicePointManager.ServerCertificateValidationCallback = New System.Net.Security.RemoteCertificateValidationCallback(AddressOf ValidateServerCertificate)
        'TLS 1.2-基礎連接已關閉: 傳送時發生未預期的錯誤 'HttpClient
        System.Net.ServicePointManager.SecurityProtocol = System.Net.SecurityProtocolType.Tls12 '3072
        'https://itsapi.etraining.gov.tw/ITSWebExport
        'https://itsapi.etraining.gov.tw/ITSWebExport/swagger/index.html?url=/ITSWebExport/swagger/v1/swagger.json
        'http://wltims.wda.gov.tw/ITSWebc/twsITSWebc.asmx
        'https://wltims.wda.gov.tw/ITSWebc/twsITSWebc.asmx
        'https://wltims.wda.gov.tw/ITSWebc/testDef2.aspx
        'Dim GTL_1 As New GetTraining.GetTrainingList
        Dim GTL_2 As New ITSWebc.twsITSWebc

        Dim ITSrc1 As ITSWebc.ResultOfSTUDENT_TRAINING_HISTORY_VIEW
        ITSrc1 = GTL_2.GetStudHis1(cst_s_AUTH, vIDNO, "")
        If ITSrc1.Count = 0 Then Return dt

        Dim iROW As Integer = 0
        For Each mlist As ITSWebc.STUDENT_TRAINING_HISTORY_VIEW In ITSrc1.Records
            'If Cst_TPlanID28ApPlan5.IndexOf(mlist.TPLANID) > -1 Then Continue For '略過-計畫為在職
            If Not flag_ALL AndAlso CHG_YESNO(mlist.WORKSUPPIDENT, "N") = "N" Then Continue For 'false: 略過-非在職者 (若為全部時不略過)(Continue For)

            iROW += 1
            Dim dr As DataRow = dt.NewRow()
            dt.Rows.Add(dr)
            dr("ROWNUM") = iROW
            UPD_ITSWebcDr(dr, mlist, Nothing)
        Next
        sw.Stop() '碼錶停止

        '印出所花費的總豪秒數
        Dim s_log1 As String = String.Format("##GetTrainingList vIDNO:{0} ,flag_ALL:{1} ,COUNT:{2} ,ms:{3}", vIDNO, flag_ALL, iROW, sw.Elapsed.TotalMilliseconds.ToString())
        LOG.Debug(s_log1)
        Return dt
    End Function

    ''' <summary> 快速建立ITS 職前使用欄位 </summary>
    ''' <returns></returns>
    Public Shared Function Utl_CreateITSWebcCDT() As DataTable
        'Const cst_all_column As String="IDNO,NAME,BIRTHDAY,DISTNAME,YEARS,TPLANID,PLANNAME,ORGNAME,TRAINNAME,CJOB_NAME,CLASSCNAME,THours,TRound,WEEKS,TFLAG,WorkSuppIdent,SumOfMoney,BudIDName,AppliedStatus,AppliedStatusM,MEMO1"
        '--webservic 欄位
        Const cst_all_column As String = "IDNO,NAME,BIRTHDAY,DISTNAME,COMIDNO,DISTID,YEARS,TPLANID,PLANNAME,ORGNAME,TRAINNAME,CJOB_NAME,CLASSCNAME,THOURS,TROUND,WEEKS,TFLAG,WORKSUPPIDENT,SUMOFMONEY,PayMoney,AppliedNote,SupplyId,MEMO1,BudID,BudIDName,AllotDate,AppliedStatusM,AppliedStatusMName,AppliedStatus,AppliedStatusName,StudStatus,StudStatusName"
        '--自行增加欄位
        Const cst_my_column As String = "ROWNUM,STDATE,FTDATE"
        '--自行增加-數字欄位
        Const cst_int_column As String = "YEARS,THours,SumOfMoney,ROWNUM"
        'tSYSNAME.Text=ClearSQM(tSYSNAME.Text)
        'Dim vtSYSNAME As String=cst_SYSNAME_1
        Dim s_all_column As String() = cst_all_column.Split(",")
        Dim s_my_column As String() = cst_my_column.Split(",")
        Dim s_i_column As String() = cst_int_column.Split(",")
        'v_IDNOs=CombiSQM2IN(v_IDNOs)

        Dim dt As New DataTable
        '--自行增加欄位-s_my_column
        For Each str1 As String In s_my_column
            If CHK_VAL_INDEXOF(s_i_column, str1) Then
                dt.Columns.Add(str1, Type.GetType("System.Int32"))
            Else
                dt.Columns.Add(str1)
            End If
        Next
        '--webservic 欄位-s_all_column
        For Each str1 As String In s_all_column
            If CHK_VAL_INDEXOF(s_i_column, str1) Then
                dt.Columns.Add(str1, Type.GetType("System.Int32"))
            Else
                dt.Columns.Add(str1)
            End If
        Next
        'For Each cColumn As Data.DataColumn In dtN.Columns
        '    cColumn.AllowDBNull=True
        'Next
        Return dt
    End Function

    Public Shared Sub UPD_ITSWebcDr(ByRef dr As DataRow, ByRef mlist As ITSWebc.STUDENT_TRAINING_HISTORY_VIEW, ByRef oParms As Hashtable)
        'https://wltims.wda.gov.tw/ITSWebc/testDef2.aspx
        'Dim mlist As ITSWebc.STUDENT_TRAINING_HISTORY_VIEW
        'Dim dr As DataRow=dt.NewRow()
        Dim vSTDATE As String = Cdate3(mlist.CDI_BEGIN_DATE) '訓練日期（起）STDate 
        Dim vFTDATE As String = Cdate3(If(mlist.EXIT_DATE, mlist.CDI_END_DATE)) '離退訓日期／訓練日期（迄）FTDate
        dr("STDATE") = vSTDATE  '訓練日期（起）STDate 
        dr("FTDATE") = vFTDATE  '離退訓日期／訓練日期（迄）FTDate
        dr("IDNO") = mlist.IDNO ' 身分證字號
        dr("NAME") = mlist.CNAME '姓名 CNAME/NAME
        dr("BIRTHDAY") = Cdate3(mlist.BIRTHDAY) '出生日期 DateTime
        dr("DISTNAME") = mlist.DISTNAME '分署名稱
        dr("COMIDNO") = mlist.BNA '訓練單位統一編號 COMIDNO
        dr("DISTID") = mlist.DISTID '分署代號
        dr("YEARS") = (mlist.TWYEAR + 1911) 'int 年度 民國
        dr("TPLANID") = mlist.TPLANID '舊系統計畫KEY
        dr("PLANNAME") = mlist.NTPNAME 'PLANNAME 計畫名稱
        dr("ORGNAME") = mlist.BTINAME 'ORGNAME 訓練單位名稱
        dr("TRAINNAME") = mlist.TRAINNAME '訓練職類
        dr("CJOB_NAME") = mlist.CGJT_NAME 'CJOB_NAME'通俗職類
        dr("CLASSCNAME") = mlist.CLASSNAME 'CLASSCNAME 班級名稱
        dr("TROUND") = String.Format("{0}-{1}", vSTDATE, vFTDATE) 'cdate3(mlist.CDI_BEGIN_DATE) & "-" & cdate3(mlist.CDI_END_DATE) '開結訓日期組合
        'dr("WEEKS")=mlist.WEEKS '上課時間
        Dim iTHOURS As Integer = If(mlist.TRAINHOURS < mlist.THOURS, mlist.TRAINHOURS, mlist.THOURS) 'int 班級訓練時數
        dr("THOURS") = iTHOURS 'int 班級訓練時數
        dr("TFLAG") = mlist.CSS_STATUS 'TFLAG 訓練狀態(中文)
        dr("WORKSUPPIDENT") = CHG_YESNO(mlist.WORKSUPPIDENT, "N") 'mlist.WorkSuppIdent 'CHG_YESNO(mlist.WorkSuppIdent) 是否為在職者補助身份
        dr("SUMOFMONEY") = mlist.SUMOFMONEY 'int 補助金額
        'dr("PayMoney")=mlist.PayMoney 'int 個人支付	
        dr("AppliedNote") = mlist.APPLIEDNOTE  '審核備註
        'dr("SupplyId")=mlist.SupplyId '補助比例 代碼 (中文)
        'dr("MEMO1")=mlist.MEMO1 '備註欄位 可顯示「在職者」或「待業者」
        dr("BudID") = mlist.CBTID 'BudID 預算別
        dr("BudIDName") = mlist.CBTNAME 'BudIDName 預算別(中文)
        dr("AllotDate") = Cdate3(If(mlist.ALLOTDATE, Convert.DBNull)) 'mlist.ALLOTDATE '撥款日期
        dr("AppliedStatusM") = mlist.APPLIEDSTATUSM '學員經費審核狀態-申請
        dr("AppliedStatusMName") = mlist.APPLIEDSTATUSM_NAME 'mlist..AppliedStatusMName '學員經費審核狀態(中文)
        dr("AppliedStatus") = mlist.APPLIEDSTATUS '學員經費撥款狀態
        dr("AppliedStatusName") = mlist.APPLIEDSTATUS_NAME 'mlist.AppliedStatusName '學員經費撥款狀態(中文)
        dr("StudStatus") = mlist.CSSNO 'StudStatus 訓練狀態代號
        dr("StudStatusName") = mlist.CSS_STATUS 'StudStatusName '訓練狀態(中文)

        If oParms Is Nothing Then Return
        oParms.Add("STDATE", vSTDATE) '= vSTDATE  '訓練日期（起）STDate 
        oParms.Add("FTDATE", vFTDATE) '= vFTDATE  '離退訓日期／訓練日期（迄）FTDate
        oParms.Add("IDNO", mlist.IDNO) '= mlist.IDNO ' 身分證字號
        oParms.Add("NAME", mlist.CNAME) '= mlist.CNAME '姓名 CNAME/NAME
        oParms.Add("BIRTHDAY", Cdate3(mlist.BIRTHDAY)) '= cdate3(mlist.BIRTHDAY) '出生日期 DateTime
        oParms.Add("DISTNAME", mlist.DISTNAME) '= mlist.DISTNAME '分署名稱
        oParms.Add("COMIDNO", mlist.BNA) '= mlist.BNA '訓練單位統一編號 COMIDNO
        oParms.Add("DISTID", mlist.DISTID) '= mlist.DISTID '分署代號
        oParms.Add("YEARS", (mlist.TWYEAR + 1911)) '= (mlist.TWYEAR + 1911) 'int 年度 民國
        oParms.Add("TPLANID", mlist.TPLANID) '= mlist.TPLANID '舊系統計畫KEY
        oParms.Add("PLANNAME", mlist.NTPNAME) '= mlist.NTPNAME 'PLANNAME 計畫名稱
        oParms.Add("ORGNAME", mlist.BTINAME) '= mlist.BTINAME 'ORGNAME 訓練單位名稱
        oParms.Add("TRAINNAME", mlist.TRAINNAME) '= mlist.TRAINNAME '訓練職類
        oParms.Add("CJOB_NAME", mlist.CGJT_NAME) '= mlist.CGJT_NAME 'CJOB_NAME'通俗職類
        oParms.Add("CLASSCNAME", mlist.CLASSNAME) '= mlist.CLASSNAME 'CLASSCNAME 班級名稱
        oParms.Add("TROUND", String.Format("{0}-{1}", vSTDATE, vFTDATE)) '= String.Format("{0}-{1}", vSTDATE, vFTDATE) 'cdate3(mlist.CDI_BEGIN_DATE) & "-" & cdate3(mlist.CDI_END_DATE) '開結訓日期組合
