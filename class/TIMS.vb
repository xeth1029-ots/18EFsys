    '提前就業認定邏輯原則: 確認 True
    Public Shared Function Chk_WkAheadOfSch(ByVal TrainHours As Single, ByVal THours As Single, ByVal NeedPay As String, ByVal RTReasonID As String) As Boolean
        'Single:單精確 https://msdn.microsoft.com/zh-tw/library/ae55hdtk.aspx
        'TrainHours:實際參訓時數,'THours:班級應訓練總時數,'NeedPay:退訓賠償費用 Y:要賠償 N:免賠償,'RTReasonID:退訓原因 02:提前就業, '使用程式：SD_05_004_add
        Dim WkAheadOfSchFlag As Boolean = False 'WkAheadOfSchFlag = False
        '提前就業計算原則：1.學員實際參訓時數達總時數 1/2 以上(含) '提前就業計算原則：2.經職訓中心專案核定免負擔退訓賠償費用者 '3.(選提前就業者)
        If (TrainHours / THours) >= 0.5 AndAlso NeedPay = "N" AndAlso RTReasonID = "02" Then
            WkAheadOfSchFlag = True '認定為提前就業(真正的)
        End If
        Return WkAheadOfSchFlag
    End Function

