    ''' <summary>
    ''' 以自然人憑證序號, 取得帳號資料, 若找不到回傳 nothing(基本帳號table)
    ''' </summary>
    ''' <param name="sSerialNo">憑證序號</param>
    ''' <returns></returns>
    Public Shared Function sUtl_GetAccount1(ByVal sSerialNo As String, ByVal sConn As SqlConnection) As DataRow
        Dim rst As DataRow = Nothing
        Dim odt As New DataTable

        Dim sql As String = ""
        sql &= " SELECT a.ACCOUNT, a.IDNO, a.ROLEID, a.LID,a.NAME, a.ISUSED" & vbCrLf
        sql &= " ,d.ORGID, d.ORGNAME" & vbCrLf
        sql &= " ,a.DEFAULT_PLANID, a.DEFAULT_YEAR" & vbCrLf
        sql &= " ,CASE WHEN GETDATE()>=STOPDATE THEN 'Y' ELSE 'N' END STOPMSG" & vbCrLf
        sql &= " FROM AUTH_ACCOUNT A" & vbCrLf
        sql &= " JOIN ORG_ORGINFO d on d.ORGID=a.ORGID" & vbCrLf
        sql &= " WHERE a.SERIALNO=@serialno" & vbCrLf
        Dim s_parms As New Hashtable From {{"serialno", sSerialNo}}
        odt = DbAccess.GetDataTable(sql, sConn, s_parms)

        '取得1筆資料。
        If IsNothing(odt) Then Return rst
        If odt.Rows.Count = 0 Then Return rst

        'If odt.Rows.Count > 1 Then
        '    logger.Warn("sUtl_GetAccount1: sSerialNo=" & sSerialNo & " 有多筆帳號資料")
        'End If
        Dim dr1 As DataRow = odt.Rows(0)
        rst = sUtl_GetAccount2(sSerialNo, dr1("LID"), sConn)
        Return rst
    End Function

    ''' <summary>
    ''' 以自然人憑證序號, 取得帳號資料 DEFAULT (依業務 計畫)
    ''' </summary>
    ''' <param name="sSerialNo"></param>
    ''' <param name="LID"></param>
    ''' <param name="sConn"></param>
    ''' <returns></returns>
    Public Shared Function sUtl_GetAccount2(ByVal sSerialNo As String, ByVal LID As String, ByVal sConn As SqlConnection) As DataRow
        Dim rst As DataRow = Nothing
        Dim sql As String = ""
        Dim odt As New DataTable

        Select Case LID
            Case 0, 1
                sql = ""
                sql &= " SELECT a.ACCOUNT,a.IDNO,a.ROLEID,a.LID,a.NAME,a.ISUSED" & vbCrLf
                sql &= " ,d.ORGID,d.ORGNAME" & vbCrLf
                sql &= " ,a.AUTHUSE" & vbCrLf
                sql &= " ,a.DEFAULT_PLANID, a.DEFAULT_YEAR" & vbCrLf
                sql &= " ,CASE WHEN GETDATE()>=STOPDATE THEN 'Y' ELSE 'N' END STOPMSG" & vbCrLf
                sql &= " ,c.RID,c.RELSHIP, c.ORGLEVEL, c.DISTID,c.PLANID" & vbCrLf 'c.PLANID:0
                sql &= " FROM AUTH_ACCOUNT a" & vbCrLf
                sql &= " JOIN ORG_ORGINFO d ON d.ORGID=a.ORGID" & vbCrLf
                sql &= " JOIN AUTH_RELSHIP c ON c.ORGID=a.ORGID" & vbCrLf
                sql &= " WHERE a.SERIALNO=@serialno" & vbCrLf

            Case Else
                sql = ""
                sql &= " SELECT a.ACCOUNT,a.IDNO,a.ROLEID,a.LID,a.NAME,a.ISUSED" & vbCrLf
                sql &= " ,d.ORGID,d.ORGNAME" & vbCrLf
                sql &= " ,a.AUTHUSE,a.SERIALNO" & vbCrLf
                sql &= " ,a.DEFAULT_PLANID, a.DEFAULT_YEAR" & vbCrLf
                sql &= " ,CASE WHEN GETDATE()>=STOPDATE THEN 'Y' ELSE 'N' END STOPMSG" & vbCrLf
                sql &= " ,c.RID,c.RELSHIP,c.ORGLEVEL,c.DISTID,p.PLANID" & vbCrLf 'p.PLANID:PLANID
                sql &= " FROM AUTH_ACCOUNT a" & vbCrLf
                sql &= " JOIN ORG_ORGINFO d ON d.ORGID=a.ORGID" & vbCrLf
                sql &= " JOIN AUTH_ACCRWPLAN p on p.ACCOUNT=a.ACCOUNT" & vbCrLf
                sql &= " JOIN AUTH_RELSHIP c ON c.RID=p.RID" & vbCrLf
                sql &= " WHERE a.SERIALNO=@serialno" & vbCrLf

        End Select

        Dim s_parms As New Hashtable From {{"serialno", sSerialNo}}
        odt = DbAccess.GetDataTable(sql, sConn, s_parms)

        '取得1筆資料。
        If IsNothing(odt) Then Return rst
        If odt.Rows.Count = 0 Then Return rst

        'If odt.Rows.Count > 1 Then LOG.Warn("sUtl_GetAccount2: sSerialNo=" & sSerialNo & " 有多筆帳號資料")
        rst = odt.Rows(0)
        Return rst
    End Function

    ''' <summary>
    ''' 取得帳號資料, 若找不到回傳 nothing (依業務)
    ''' </summary>
    ''' <param name="sTxtUserID">帳號</param>
    ''' <param name="sConn"></param>
    ''' <param name="flagOnlyBX">true:(只可使用後台登入) false:(不限定／全部)</param>
    ''' <returns></returns>
    Public Shared Function sUtl_GetAccount(ByVal sTxtUserID As String, ByRef sConn As SqlConnection, ByVal flagOnlyBX As Boolean) As DataRow
        Dim rst As DataRow = Nothing
        Dim odt As New DataTable

        Dim parms As New Hashtable From {{"account", UCase(sTxtUserID)}}
        Dim sql As String = ""
        sql &= " SELECT a.ACCOUNT,a.ROLEID,a.LID,a.HASHPWD1,a.EMAIL,a.IDNO,a.PHONE" & vbCrLf
        sql &= " ,a.NAME, a.ISUSED, a.DEFAULT_PLANID, a.DEFAULT_YEAR" & vbCrLf
        sql &= " ,c.RID,c.RELSHIP, c.ORGLEVEL, c.DISTID" & vbCrLf
        sql &= " ,d.ORGID, d.ORGNAME" & vbCrLf
        sql &= " ,a.AUTHUSE,b.NAME ROLENAME" & vbCrLf
        sql &= " ,CASE WHEN GETDATE()>=STOPDATE THEN 'Y' ELSE 'N' END STOPMSG" & vbCrLf
        sql &= " FROM dbo.AUTH_ACCOUNT a" & vbCrLf
        sql &= " JOIN dbo.ID_ROLE b ON a.RoleID=b.RoleID" & vbCrLf
        sql &= " JOIN dbo.AUTH_RELSHIP c ON a.ORGID=c.ORGID" & vbCrLf
        sql &= " JOIN dbo.ORG_ORGINFO d ON c.ORGID=d.ORGID" & vbCrLf
        sql &= " WHERE UPPER(a.ACCOUNT)=@account" & vbCrLf
        If (flagOnlyBX) Then sql &= " AND a.BACKUSE='Y'" & vbCrLf

        odt = DbAccess.GetDataTable(sql, sConn, parms)

        '取得1筆資料。
        If IsNothing(odt) Then Return rst
        If odt.Rows.Count = 0 Then Return rst
        rst = odt.Rows(0)
        Return rst
    End Function

    ''' <summary> 檢查是否為使用中。 未使用為false 已使用為true </summary>
    ''' <param name="PTID"></param>
    ''' <returns></returns>
    Public Shared Function ChkPTIDUse(ByVal PTID As String, ByRef oConn As SqlConnection) As Boolean
        Dim rst As Boolean = False
        'true: Common.MessageBox(Me, "該場地目前被使用，不可刪除!!")
        If PTID = "" Then Return rst

        Call OpenDbConn(oConn)
        Dim sql As String = ""
        sql &= " SELECT 'X' FROM dbo.VIEW_TRAINPLACE" & vbCrLf
        sql &= " WHERE (s1ptid=@PTID or s2ptid=@PTID or t1ptid=@PTID or t2ptid=@PTID)" & vbCrLf
        Dim dt As New DataTable
        Dim oCmd As New SqlCommand(sql, oConn)
        With oCmd
            .Parameters.Clear()
            .Parameters.Add("PTID", SqlDbType.Int).Value = CINT1(PTID)
            dt.Load(.ExecuteReader())
        End With
        If dtHaveDATA(dt) Then rst = True
        If (rst) Then Return rst

        Dim sql2 As String = ""
        sql2 &= " SELECT 'X' FROM dbo.VIEW_TRAINPLACE" & vbCrLf
        sql2 &= " WHERE (spptid=@PTID or tpptid=@PTID)" & vbCrLf
        Dim dt2 As New DataTable
        Dim oCmd2 As New SqlCommand(sql2, oConn)
        With oCmd2
            .Parameters.Clear()
            .Parameters.Add("PTID", SqlDbType.Int).Value = CINT1(PTID)
            dt2.Load(.ExecuteReader())
        End With
        If dtHaveDATA(dt2) Then rst = True
        If (rst) Then Return rst

        Return rst 'false(未查詢到使用該場地)
    End Function

    ''' <summary>取得民國年(轉換西元年) </summary>
    ''' <param name="o_YEARS"></param>
    ''' <returns></returns>
    Public Shared Function GET_YEARS_ROC(ByVal o_YEARS As Object) As String
        Dim rst As String = ""
        If o_YEARS Is Nothing OrElse $"{o_YEARS}" = "" OrElse Not IsNumeric(o_YEARS) Then Return rst
        'Dim s_YEARS As String=Convert.ToString(o_YEARS)  'If s_YEARS="" Then Return rst
        rst = String.Concat("", If(CINT1(o_YEARS) < 1911, CINT1(o_YEARS), CINT1(o_YEARS) - 1911))
        Return rst
    End Function

