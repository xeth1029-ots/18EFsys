    ''' <summary> 確認正確-報名登錄最晚可作業日期-自辦在職計畫/企業委託 </summary>
    ''' <param name="sFENTERDATE"></param>
    ''' <param name="sFENTERDATE2"></param>
    ''' <returns></returns>
    Public Shared Function Chk_FENTERDATE2(ByVal sFENTERDATE As String, ByVal sFENTERDATE2 As String) As Boolean
        Dim rst As Boolean = True
        If sFENTERDATE = "" Then Return False '若為空返回異常
        If sFENTERDATE2 = "" Then Return False '若為空返回異常

        Dim dFENTERDATE As Date = Cdate2(Cdate3(sFENTERDATE))
        Dim dFEnterdate3 As Date = dFENTERDATE.AddDays(3) '+3

        Dim dFENTERDATE2 As Date = Cdate2(Cdate3(sFENTERDATE2))
        '/* 計畫：自辦 / 企業委託
        '1.報名登錄最晚可作業時間：報名結束日期 + 3 日曆天
        '於開班資料查詢功能， 開放報名登錄最晚可作業時間 "可修改"，
        '但此欄位仍需檢核有符合在 報名結束日期 ~ 報名結束日期 + 3 日曆天 這個區間內。 */
        If Not DateDiff(DateInterval.Day, dFENTERDATE, dFENTERDATE2) >= 0 Then Return False
        If Not DateDiff(DateInterval.Day, dFENTERDATE2, dFEnterdate3) >= 0 Then Return False
        Return rst
    End Function

