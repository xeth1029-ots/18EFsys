        '2.功能：訓練機構管理>>基本資料設定>>訓練機構設定
        '於產投計畫，當分署新增訓練機構時，系統自動將此新的訓練單位歸屬到有該年度、計畫之該分署所有帳號。
        'sql=" select * from AUTH_RELSHIP where PLANID=4988 and RSID=43523" & vbCrLf
        '查詢該序號的業務資訊-委訓單位
        DbAccess.Open(oConn)

        Dim s_sql2 As String = " SELECT * FROM AUTH_RELSHIP WITH(NOLOCK) WHERE ORGLEVEL=2 AND PLANID=@PLANID AND RSID=@RSID" & vbCrLf
        Dim s_parms2 As New Hashtable From {{"PLANID", iPlanID}, {"RSID", iRSID}}
        Dim dtRP As DataTable = DbAccess.GetDataTable(s_sql2, oConn, s_parms2)
        If dtRP.Rows.Count = 0 Then Return '查無有效資料離開
        Dim drRP As DataRow = dtRP.Rows(0)

        '查詢該計畫可登入的帳號 分署 (二級／承辦人)
        Dim s_sql3 As String = " SELECT * FROM VIEW_LOGINACCOUNT WHERE ISUSED='Y' AND PLANID=@PLANID AND ROLEID=@ROLEID" & vbCrLf
        Dim s_parms3 As New Hashtable From {{"PLANID", iPlanID}, {"ROLEID", iRoleID}}
        Dim dtLA As DataTable = DbAccess.GetDataTable(s_sql3, oConn, s_parms3)
        If dtLA.Rows.Count = 0 Then Return '查無有效資料離開(多筆)

        'Dim i_parms As New Hashtable
        Dim i_sql As String = ""
        i_sql &= " INSERT INTO AUTH_ACCTORG( CID,PLANID,RID,ACCT1,ACCT2,MODIFYACCT,MODIFYDATE )" & vbCrLf
        i_sql &= " VALUES ( @CID,@PLANID,@RID,@ACCT1,@ACCT2, @MODIFYACCT,GETDATE() )" & vbCrLf
        Dim iCmd As New SqlCommand(i_sql, oConn)

        'Dim rst As Boolean=True 'ByRef dtOrgList As DataTable
        Const Cst_二級 As Integer = 4
        Const Cst_承辦人 As Integer = 5
        Dim s_Acct As String = ""
        Dim s_AcctOther As String = ""
        'SELECT Case Request("RoleID") '配合上頁所傳來的使用者權限
        Select Case iRoleID  '配合上頁所傳來的使用者權限
            Case Cst_二級
                s_Acct = "ACCT2" '二級使用者帳號
                s_AcctOther = "ACCT1" '承辦人帳號
            Case Cst_承辦人
                s_Acct = "ACCT1" '承辦人帳號
                s_AcctOther = "ACCT2" '二級使用者帳號
            Case Else
                '限定權限 二級 與 承辦人 可做委訓單位歸屬!
                Return '退出
        End Select

        Dim sm As SessionModel = SessionModel.Instance()
        Dim sRIDValue As String = drRP("RID").ToString()
        For Each drLA As DataRow In dtLA.Rows
            Dim sAccount As String = drLA("ACCOUNT").ToString()

            Dim sql As String = $"SELECT * FROM AUTH_ACCTORG WHERE PLANID=@PLANID AND {s_Acct}=@ACCT"
            Dim sCmd As New SqlCommand(sql, oConn)
