    '統一編號檢查實作(統編 規則) 'isValidTWBID isTWBID TWBID COMIDNO true:OK false:NG
    Public Shared Function isValidTWBID(ByVal twbid As String) As Boolean
        Dim rst As Boolean = False
        Dim weight As String = "12121241"
        Dim type2 As Boolean = False '第七個數是否為7
        Dim iTmp As Integer = 0
        Dim iSum As Integer = 0
        If Not twbid.Length = 8 OrElse Not Check123(twbid) Then Return rst '非8位數。／'含非數字。
        For i As Integer = 0 To 7
            iTmp = Val(twbid.Chars(i)) * Val(weight.Chars(i))
            iSum += (iTmp \ 10) + (iTmp Mod 10) '取出十位數和個位數相加
            If i = 6 AndAlso twbid.Chars(i) = "7" Then type2 = True '第七個數是否為7
        Next
        If type2 Then
            'If (iSum Mod 10)=0 OrElse ((iSum + 1) Mod 10)=0 Then rst=True
            '營利事業統一編號檢查碼邏輯修正說明（附件）
            '為"7"：'其中之一『和』能被「5」整除，則符合邏輯。
            If (iSum Mod 5) = 0 OrElse ((iSum + 1) Mod 5) = 0 Then rst = True
        Else
            '非"7"：'最後結果，能被「5」整除，故符合邏輯。
            If (iSum Mod 5) = 0 Then rst = True
        End If
        Return rst
    End Function

