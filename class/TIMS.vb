    Public Shared Function Get_PayEDate(ByVal TSDate As DateTime, ByVal TEDate As DateTime,
                                        ByVal PayMonth As Single, Optional ByVal LDate As DateTime = #1/1/1911#) As DateTime
        'Single:單精確
        Dim PMonth As Decimal
        Dim rst As DateTime
        Dim EDate As DateTime

        If LDate = #1/1/1911# Then
            PMonth = CmpDayMonth(TSDate, TEDate)
            EDate = TEDate
        Else
            If LDate > TEDate Then
                PMonth = CmpDayMonth(TSDate, TEDate)
                EDate = TEDate
            Else
                PMonth = CmpDayMonth(TSDate, LDate)
                EDate = LDate
            End If
        End If
        If PMonth = PayMonth Then
            rst = EDate
        Else
            rst = DateAdd(DateInterval.Day, (PayMonth * 30) - 1, TSDate)
            '生活津貼，計算發放迄日 BY 201110
        End If
        If rst > EDate Then rst = EDate
        Return rst
    End Function
    '**by Milor 20080613----end

    '**by Milor 20080626----start
    '用來取得問題單後送階層，若沒有則使用LID
    Public Shared Function Get_FAQID(ByVal tmpLid As String, ByVal userID As String, ByRef objconn As SqlConnection) As String
        Dim rstFAQID As String = "0"
        Dim sRoleID As String = ""
        'If userID="" Then Return rstFAQID
        Dim dt As DataTable = Nothing
        Dim oCmd As SqlCommand = Nothing
        Dim sql As String = ""
        If userID <> "" Then
            Call OpenDbConn(objconn)
            sql = "SELECT ROLEID FROM AUTH_ACCOUNT WHERE ACCOUNT=@ACCOUNT"
            oCmd = New SqlCommand(sql, objconn)
            With oCmd
                .Parameters.Clear()
                .Parameters.Add("ACCOUNT", SqlDbType.VarChar).Value = userID
                dt = New DataTable
                dt.Load(.ExecuteReader())
            End With
            If dt.Rows.Count > 0 Then sRoleID = Convert.ToString(dt.Rows(0)("ROLEID"))
        End If

        If userID <> "" Then
            Call OpenDbConn(objconn)
            sql = "SELECT ISNULL(FAQID,'0') FAQID FROM AUTH_ACCOUNT WHERE ACCOUNT=@ACCOUNT"
            oCmd = New SqlCommand(sql, objconn)
            With oCmd
                .Parameters.Clear()
                .Parameters.Add("ACCOUNT", SqlDbType.VarChar).Value = userID
                dt = New DataTable
                dt.Load(.ExecuteReader())
            End With
            If dt.Rows.Count > 0 Then rstFAQID = Convert.ToString(dt.Rows(0)("FAQID"))
        End If

        If rstFAQID <> "0" Then
            '取得 後送階層的下一階
            rstFAQID = Get_ParentFAQID(rstFAQID, objconn)
        End If
        '0 [查不到],'1中心承辦人,'2中心窗口,'3系統開發商,'4會議確認,'未設定
        If rstFAQID = "0" Then '若FAQID未設定，則下列為預設動作
            Select Case tmpLid
                Case "0" '局後送階層為 2.中心窗口
                    rstFAQID = "2"
                Case "1" '中心窗口後送階層為 3.系統開發商
                    'rstFAQID="3"
                    Select Case sRoleID
                        Case "5", "99"  '該類後送 2.中心窗口	
                            rstFAQID = "2"
                        Case Else  '該類後送 3.系統開發商
                            rstFAQID = "3"
                    End Select
                Case "2" '委訓單位後送階層為 1.中心承辦人
                    rstFAQID = "1"
                Case Else   '0表示查不到任何後送0.
                    rstFAQID = "0"
            End Select
        End If
        Return rstFAQID
    End Function
    '**by Milor 20080626----end

