    ''' <summary> 取得錯誤訊息 </summary>
    ''' <param name="MyPage"></param>
    ''' <returns></returns>
    Public Shared Function GetErrorMsg(ByRef MyPage As Page) As String
        'Threading.Thread.Sleep(1) '假設處理某段程序需花費1毫秒 (避免機器不同步)
        Dim sMailBody As String = ""
        Dim flag_use_httpcontext As Boolean = If(IsNothing(MyPage), True, False)
        'Dim LastError As Exception=MyPage.Server.GetLastError
        Dim s_LASTERROR_INFO As String = ""
        Try
            If flag_use_httpcontext Then
                If HttpContext.Current IsNot Nothing AndAlso HttpContext.Current.Server IsNot Nothing AndAlso HttpContext.Current.Server.GetLastError IsNot Nothing Then
                    s_LASTERROR_INFO &= "LastError： " & HttpContext.Current.Server.GetLastError.ToString() & vbCrLf '存入錯誤訊息
                    s_LASTERROR_INFO &= "StackTrace：" & HttpContext.Current.Server.GetLastError.StackTrace.ToString() & vbCrLf '存入錯誤訊息2
                End If
            Else
                If MyPage IsNot Nothing AndAlso MyPage.Server IsNot Nothing AndAlso MyPage.Server.GetLastError IsNot Nothing Then
                    s_LASTERROR_INFO &= "LastError： " & MyPage.Server.GetLastError.ToString() & vbCrLf '存入錯誤訊息
                    s_LASTERROR_INFO &= "StackTrace：" & MyPage.Server.GetLastError.StackTrace.ToString() & vbCrLf '存入錯誤訊息2
                End If
            End If
        Catch ex As Exception
            LOG.Warn(ex.Message, ex)
