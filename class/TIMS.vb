        sql &= $" WHERE cs.StudStatus IN (1,4) AND SS.IDNO='{sIDNO}' AND CS.OCID NOT IN ({OCID})" & vbCrLf
        'a.StudStatus IN (1,4)
        sql &= $" AND ( (STDate<={To_date(STDate)} AND FTDate>={To_date(STDate)}) OR (STDate<={To_date(FTDate)} AND FTDate>={To_date(FTDate)} ) )" & vbCrLf
