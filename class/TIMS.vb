    ''' <summary> '取得 審查課程職類 TABLE </summary>
    ''' <param name="oConn"></param>
    ''' <param name="HtPP"></param>
    ''' <returns></returns>
    Public Shared Function GET_GCODEREVIEdt(ByRef oConn As SqlConnection, ByRef HtPP As Hashtable) As DataTable
        'Dim v_cblGOVCODE3 As String=TIMS.GetCblValue(cblGOVCODE3)
        'Dim v_YEARS As String=GetMyValue2(HtPP, "YEARS")
        Dim v_APPSTAGE As String = GetMyValue2(HtPP, "APPSTAGE")
        'Dim v_DISTID As String=GetMyValue2(HtPP, "DISTID")
        Dim v_cblGOVCODE3 As String = GetMyValue2(HtPP, "cblGOVCODE3")
        Dim v_cblGOVCODE3_in As String = CombiSQLIN(v_cblGOVCODE3)

        's_parms.Clear()
        Dim s_parms As New Hashtable From {{"YEARS", GetMyValue2(HtPP, "YEARS")}, {"APPSTAGE", v_APPSTAGE}, {"DISTID", GetMyValue2(HtPP, "DISTID")}}
        Dim sql As String = ""
        sql &= " SELECT a.SGRID,a.YEARS,a.APPSTAGE,a.GCODE,a.DISTID" & vbCrLf 'sql &= " ,MODIFYACCT ,MODIFYDATE" & vbCrLf
        sql &= " FROM SYS_GCODEREVIE a" & vbCrLf
        sql &= " WHERE a.YEARS=@YEARS AND a.APPSTAGE=@APPSTAGE AND a.DISTID=@DISTID" & vbCrLf
        If v_cblGOVCODE3 <> "" AndAlso v_cblGOVCODE3_in <> "" Then
            sql &= String.Concat(" AND a.GCODE IN (", v_cblGOVCODE3_in, ")") & vbCrLf
        End If
        Dim dt As DataTable = DbAccess.GetDataTable(sql, oConn, s_parms)
        Return dt
    End Function

    ''' <summary> 若為申復 取得初次申請 </summary>
    ''' <param name="v_ddlACCEPTSTAGE"></param>
    ''' <returns></returns>
    Public Shared Function GET_ACCEPTSTAGE_LASTTIME(ByRef v_ddlACCEPTSTAGE As String) As String
        'Dim v_ddlACCEPTSTAGE As String=GetMyValue2(HtPP, "ddlACCEPTSTAGE")
        '(5)申復：就看有沒有需要，也可能不辦。上半年由哪個分署主辦，申覆就一樣由該分署辦理。
        Dim v_ACCEPTSTAGE_LASTTIME As String = ""
        Select Case v_ddlACCEPTSTAGE
            Case "A2"
                v_ACCEPTSTAGE_LASTTIME = "A1" 'WHEN 'A1' THEN '上半年' WHEN 'A2' THEN '上半年申復'
            Case "B2"
                v_ACCEPTSTAGE_LASTTIME = "B1" 'WHEN 'B1' THEN '政策性' WHEN 'B2' THEN '政策性申復'
            Case "C2"
                v_ACCEPTSTAGE_LASTTIME = "C1" 'WHEN 'C1' THEN '下半年' WHEN 'C2' THEN '下半年申復'
            Case "D2"
                v_ACCEPTSTAGE_LASTTIME = "D1" 'WHEN 'D1' THEN '進階政策性' WHEN 'D2' THEN '進階政策性申復'
        End Select
