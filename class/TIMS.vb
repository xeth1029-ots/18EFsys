    '由參訓身分別代號轉換成中文名稱 不能有單引號
    Public Shared Function Get_IdentityName(ByVal IdentityID As String, ByVal partition As String, ByRef oConn As SqlConnection) As String
        Dim rst As String = ""
        If IdentityID = "" Then Return rst
        'Dim sql As String="SELECT * FROM KEY_IDENTITY"
        Dim sql As String = ""
        sql &= " SELECT IDENTITYID, CONVERT(NVARCHAR(30), NAME) NAME FROM dbo.KEY_IDENTITY WITH(NOLOCK)" & vbCrLf
        sql &= " UNION SELECT '-1','無'" & vbCrLf
        Dim sCmd As New SqlCommand(sql, oConn)
        Call OpenDbConn(oConn)
        Dim dt As New DataTable
        With sCmd
            .Parameters.Clear()
            dt.Load(.ExecuteReader())
            '.ExecuteReader.Close()
        End With
        '去除單引號資料。
        If IdentityID <> "" AndAlso IdentityID.IndexOf("'") > -1 Then
            IdentityID = Replace(IdentityID, "'", "")
        End If
        rst = Get_IdentityName(IdentityID, dt, partition)
        Return rst
    End Function

    ''' <summary>
    ''' 由參訓身分別代號轉換成中文名稱(含dt)
    ''' </summary>
    ''' <param name="IdentityID"></param>
    ''' <param name="dt"></param>
    ''' <param name="Cst_partition"></param>
    ''' <param name="Cst_partChange"></param>
    ''' <returns></returns>
    Public Shared Function Get_IdentityName(ByRef IdentityID As String, ByRef dt As DataTable, ByRef Cst_partition As String, ByRef Cst_partChange As String) As String
        Dim rst As String = ""
        'Cst_partition 偵測分隔符號(傳出、轉入使用)
        Dim dr As DataRow
        If IdentityID = "" Then Return rst
        If IdentityID.IndexOf(Cst_partition) = -1 Then
            '表示只有一種身分
            If dt.Select("IDENTITYID='" & IdentityID & "'").Length > 0 Then
                dr = dt.Select("IDENTITYID='" & IdentityID & "'")(0)
                rst = dr("NAME")
            End If
        Else
            '有多種身份，以逗號分隔
            Dim AllIdentity As Array = Split(IdentityID, Cst_partition)
            For i As Integer = 0 To AllIdentity.Length - 1
                If dt.Select("IDENTITYID='" & AllIdentity(i) & "'").Length > 0 Then
                    dr = dt.Select("IDENTITYID='" & AllIdentity(i) & "'")(0)
                    If rst <> "" Then rst &= Cst_partChange
                    rst &= dr("Name")
                End If
            Next
        End If
        Return rst
    End Function

