    '=線上報名預算的政府補助 
    '所有線上報名的歷史，排除已補助的班級經費，所剩下的餘額(=線上報名預算的政府補助)
    '加入要開班與尚未達到開訓日的條件( notopen='N' AND STDate>=GETDATE() )
    '已為加入要開班 的條件( notopen='N'  ) 20100722 BY AMU
    '加入過濾條件，只限定產業人才投資方案的經費
    'signUpStatus-0:收件完成 1:報名成功 2:報名失敗 3:正取(Key_SelResult) 4:備取 5:未錄取
    '排除報名失敗與未錄取 (a.signUpStatus not in (2,5)) by AMU 20090915
    '(限定產業人才投資方案) 20090325 BY AMU
    '排除離退訓班級 20100826 BY AMU
    '加入補助費用 46 補助辦理保母職業訓練 '47 補助辦理照顧服務員職業訓練 20110223 by AMU
    '排除當學員為備取或正取時，開訓時間超過15天，未成為學員者 20110223 BY AMU
    '限定 '領取產投補助費用 3年5萬的計畫 201107 BY AMU
    '報名中課程預估補助費用:只要是報名(排除是學生的，排除審核異常的)，就計算 201506 BY AMU
    Public Shared Function Get_DefGeoCost28(ByVal IDNO As String,
        ByVal sDate As String, ByVal eDate As String,
        ByVal tmpConn As SqlConnection) As Double
        Dim VoidCost As Double = 0
        Dim dt2 As DataTable
        Dim dtStudStatus23 As DataTable
        Dim dtSTDateAdd15 As DataTable
        Dim dtSTDateAdd15b As DataTable
        'Dim VoidCost As Double=0

        '參訓學員
        '排除 離退訓班級(不要計算)
        Dim str As String = ""
        str &= " SELECT cc.OCID,cs.StudStatus" & vbCrLf
        str &= " from CLASS_CLASSINFO cc" & vbCrLf
        str &= " join CLASS_STUDENTSOFCLASS cs on cs.OCID=cc.OCID" & vbCrLf
        str &= " join STUD_STUDENTINFO ss on ss.SID=cs.SID" & vbCrLf
        str &= " WHERE ss.IDNO='" & IDNO & "'" & vbCrLf
        If sDate <> "" AndAlso eDate <> "" Then
            str &= " AND cc.STDate >= " & To_date(sDate) & vbCrLf
            str &= " AND cc.STDate <= " & To_date(eDate) & vbCrLf
        End If
        dtStudStatus23 = DbAccess.GetDataTable(str, tmpConn)

        '未成為學員者
        '排除 當學員為備取或正取或未錄取時，開訓時間超過15天，未成為學員者 20110223 BY AMU(不要計算)
        'Stud_EnterTemp2: 排除 報名後，開訓時間超過15天，未成為學員者 20110225 BY AMU(不要計算)
        'signUpStatus-0:收件完成 1:報名成功 2:報名失敗 3:正取(Key_SelResult) 4:備取 5:未錄取
        str = ""
        str &= " SELECT a.OCID1 OCID,a.signUpStatus" & vbCrLf
        str &= " FROM Stud_EnterType2 a" & vbCrLf
        str &= " JOIN Stud_EnterTemp2 b ON a.esetid=b.esetid" & vbCrLf
        str &= " JOIN CLASS_CLASSINFO cc ON cc.OCID=a.OCID1" & vbCrLf
        str &= " JOIN ID_PLAN ip on cc.planid=ip.planid and ip.TPlanID IN (" & Cst_TPlanID28_1a & ")" & vbCrLf
        str &= " LEFT JOIN Stud_StudentInfo ss ON ss.idno=b.idno" & vbCrLf
        str &= " LEFT JOIN CLASS_STUDENTSOFCLASS cs ON cs.ocid=cc.ocid and cs.SID=ss.SID" & vbCrLf
        'signUpStatus-0:收件完成 1:報名成功 2:報名失敗 3:正取(Key_SelResult) 4:備取 5:未錄取
        '2:報名失敗 4:備取 5:未錄取 (1:報名成功 ,3:正取)
        str &= " WHERE a.signUpStatus IN (2,4,5)" & vbCrLf
        str &= " AND CONVERT(date,GETDATE())>CONVERT(date,cc.STDATE+15)" & vbCrLf
        str &= " AND cs.SOCID IS NULL" & vbCrLf '排除未完成報到
        str &= " AND b.IDNO='" & IDNO & "'" & vbCrLf
        If sDate <> "" AndAlso eDate <> "" Then
            str &= " AND cc.STDate >= " & To_date(sDate) & vbCrLf
            str &= " AND cc.STDate <= " & To_date(eDate) & vbCrLf
        End If
        dtSTDateAdd15 = DbAccess.GetDataTable(str, tmpConn)

        '(錄取作業) 審核成功
        'Stud_EnterTemp: 排除 報名後，開訓時間超過15天，未成為學員者 20110225 BY AMU(不要計算)
        str = ""
        str &= " SELECT cc.OCID,SS.SelResultID" & vbCrLf
        str &= " FROM Stud_EnterTemp a" & vbCrLf
        str &= " JOIN Stud_EnterType b on a.SETID=b.SETID" & vbCrLf
        str &= " JOIN STUD_SELRESULT ss ON ss.SETID=b.SETID and CONVERT(date, ss.EnterDate)=CONVERT(date, b.EnterDate) and ss.SerNum=b.SerNum" & vbCrLf
        str &= " JOIN CLASS_CLASSINFO cc on cc.ocid=b.ocid1" & vbCrLf
        str &= " JOIN ID_PLAN ip on cc.planid=ip.planid and ip.TPlanID IN (" & Cst_TPlanID28_1a & ")" & vbCrLf
        str &= " LEFT JOIN Stud_StudentInfo ss1  ON ss1.idno=a.idno" & vbCrLf
        str &= " LEFT JOIN Class_StudentsOfClass cs on cs.ocid=cc.ocid and cs.SID=ss1.SID" & vbCrLf
        '排除未錄取與備取'01:正取 02:備取 03:未錄取
        str &= " WHERE ISNULL(ss.Admission,'Y')='N'" & vbCrLf
        str &= " AND CONVERT(date,GETDATE())<CONVERT(date,cc.STDATE+15)" & vbCrLf
        str &= " and cs.SOCID IS NULL" & vbCrLf
        str &= " and a.IDNO='" & IDNO & "'" & vbCrLf
        If sDate <> "" AndAlso eDate <> "" Then
            str &= " AND cc.STDate >= " & To_date(sDate) & vbCrLf
            str &= " AND cc.STDate <= " & To_date(eDate) & vbCrLf
        End If
        dtSTDateAdd15b = DbAccess.GetDataTable(str, tmpConn)

        '(計算範圍)排除 其他(2:報名失敗 5:未錄取) 資訊
        str = ""
        str &= " SELECT cc.OCID" & vbCrLf
        str &= " ,format(round(pp.DefGovCost*1.00/ISNULL(cc.TNum,1),2), '#######0.##') DefGovCost" & vbCrLf
        str &= " From CLASS_CLASSINFO cc" & vbCrLf
        str &= " JOIN Plan_PlanInfo pp ON pp.ComIDNO=cc.ComIDNO and pp.PlanID=cc.PlanID and pp.SeqNO=cc.SeqNO" & vbCrLf
        str &= " AND cc.NOTOPEN='N'" & vbCrLf ' 20100722 by AMU
        str &= " JOIN ID_PLAN ip on cc.planid=ip.planid and ip.TPlanID IN (" & Cst_TPlanID28_1a & ")" & vbCrLf
        '所有報名資訊
        'signUpStatus-0:收件完成 1:報名成功 2:報名失敗 3:正取(Key_SelResult) 4:備取 5:未錄取
        str &= " WHERE cc.OCID IN (" & vbCrLf
        str &= " 	SELECT a.OCID1" & vbCrLf
        str &= " 	FROM Stud_EnterType2 a" & vbCrLf
        str &= " 	JOIN Stud_EnterTemp2 b on a.esetid=b.esetid" & vbCrLf
        str &= " 	JOIN CLASS_CLASSINFO cc on cc.OCID=a.OCID1" & vbCrLf
        str &= " 	WHERE CONVERT(DATE,a.EnterDate)>=CONVERT(DATE,dateadd(day,-(30*6),GETDATE()))" & vbCrLf '6個月內的報名資料
        str &= "    AND CONVERT(date,GETDATE())<CONVERT(date,cc.STDATE+15)" & vbCrLf '排除開訓15天後資料。
        str &= " 	AND a.signUpStatus NOT IN (2,5)" & vbCrLf '除 2:報名失敗 5:未錄取  
        str &= " 	AND b.IDNO='" & IDNO & "')" & vbCrLf
        '排除已申請補助金的資訊
        str &= " AND cc.OCID NOT IN (" & vbCrLf
        'str &= " 	SELECT B.OCID-- SUM(A.SUMOFMONEY ),B.OCID ,C.IDNO" & vbCrLf
        str &= " 	SELECT B.OCID" & vbCrLf
        str &= " 	FROM Stud_SubsidyCost A" & vbCrLf
        str &= " 	JOIN Class_StudentsOfClass B ON A.SOCID=B.SOCID" & vbCrLf
        str &= " 	JOIN Stud_StudentInfo C ON B.SID=C.SID" & vbCrLf
        str &= " 	WHERE c.IDNO ='" & IDNO & "'" & vbCrLf
        str &= " 	AND a.SUMOFMONEY > 0)" & vbCrLf

        '在這段報名時間中(3年5萬)
        If sDate <> "" AndAlso eDate <> "" Then
            str &= " AND cc.STDate >= " & To_date(sDate) & vbCrLf
            str &= " AND cc.STDate <= " & To_date(eDate) & vbCrLf
        End If
        dt2 = DbAccess.GetDataTable(str, tmpConn)

        Dim AddFlag1 As Boolean = True  '計算該筆補助金(有離退訓班級資料者)
        Dim AddFlag2 As Boolean = True  '計算該筆補助金(備取或正取時，開訓時間超過15天，未成為學員者)
        Dim AddFlag3 As Boolean = True  '開訓時間超過15天，未成為學員者2

        If dt2.Rows.Count > 0 Then
            For i As Integer = 0 To dt2.Rows.Count - 1
                AddFlag1 = True '預設計算
                AddFlag2 = True '預設計算
                AddFlag3 = True '預設計算
                'AddFlag4=True '預設計算

                Dim dr As DataRow = dt2.Rows(i)
                '有離退訓班級資料者
                If dtStudStatus23.Rows.Count > 0 Then
                    '排除 離退訓班級
                    If dtStudStatus23.Select("OCID=" & dr("OCID")).Length > 0 Then
                        'VoidCost += dr("DefGovCost")
                        AddFlag1 = False  '不計算此筆報名資料
                    End If
                End If

                ' 開訓時間超過15天，未成為學員者
                If dtSTDateAdd15.Rows.Count > 0 Then
                    ' 開訓時間超過15天，未成為學員者
                    If dtSTDateAdd15.Select("OCID=" & dr("OCID")).Length > 0 Then
                        'VoidCost += dr("DefGovCost")
                        AddFlag2 = False  '不計算此筆報名資料
                    End If
                End If

                ' 開訓時間超過15天，未成為學員者2
                If dtSTDateAdd15b.Rows.Count > 0 Then
                    ' 開訓時間超過15天，未成為學員者
                    If dtSTDateAdd15b.Select("OCID=" & dr("OCID")).Length > 0 Then
                        'VoidCost += dr("DefGovCost")
                        AddFlag3 = False  '不計算此筆報名資料
                    End If
                End If

                '3者為True 計算該筆報名費用(減項)
                If AddFlag1 AndAlso AddFlag2 AndAlso AddFlag3 Then
                    VoidCost += dr("DefGovCost")
                End If
            Next
        End If
        dt2.Dispose()
        dtStudStatus23.Dispose()
        dtSTDateAdd15.Dispose()
        dtSTDateAdd15b.Dispose()
        Return VoidCost
    End Function

    ''' <summary>
    ''' 產投 先試著取審核通過的三年區間
    ''' 先試著取參訓過的三年區間
    ''' 取得第1~N次的 補助申請區間(起迄)日期
    ''' </summary>
    ''' <param name="aIDNO"></param>
    ''' <param name="sdate"></param>
    ''' <param name="edate"></param>
    ''' <param name="tConn"></param>
    ''' <remarks></remarks>
    Public Shared Sub Get_YearsPeriod(ByVal aIDNO As String,
                                      ByRef sdate As String,
                                      ByRef edate As String,
                                      ByRef tConn As SqlConnection)

        'Const cst_stdatev1 As String="2011/01/01"
        'public Const cst_stdatev1 As String="2010/04/01"
        'If aIDNO <> "" Then aIDNO=Trim(aIDNO)
        'If aIDNO <> "" Then aIDNO=UCase(Trim(aIDNO))

        Dim dt As DataTable
        Dim sqlStr As String = ""
        sqlStr &= " SELECT g.SDate, g.EDate" & vbCrLf
        sqlStr &= " FROM (" & vbCrLf
        sqlStr &= "   SELECT CONVERT(varchar, c.STDate, 111) SDate" & vbCrLf
        sqlStr &= "   ,CONVERT(varchar, dateadd(day,-1,dateadd(YEAR,3,c.STDate)), 111) EDate" & vbCrLf
        sqlStr &= "   ,d.PlanYear,c.STDate" & vbCrLf
        sqlStr &= "   FROM dbo.STUD_STUDENTINFO a WITH(NOLOCK)" & vbCrLf
        sqlStr &= "   JOIN dbo.CLASS_STUDENTSOFCLASS b WITH(NOLOCK) ON a.SID=b.SID" & vbCrLf
        sqlStr &= "   JOIN dbo.CLASS_CLASSINFO c WITH(NOLOCK) ON b.OCID=c.OCID and c.NotOpen='N'" & vbCrLf
        sqlStr &= "   JOIN dbo.PLAN_PLANINFO d WITH(NOLOCK) ON c.PlanID=d.PlanID AND c.ComIDNO=d.ComIDNO AND c.SeqNO=d.SeqNO" & vbCrLf
        sqlStr &= "   and d.TPlanID IN (" & Cst_TPlanID28_1a & ")" & vbCrLf
        sqlStr &= "   WHERE a.IDNO= '" & aIDNO & "'" & vbCrLf

        sqlStr &= "   UNION" & vbCrLf
        sqlStr &= "   SELECT CONVERT(varchar, a.STDate, 111) SDate" & vbCrLf
        sqlStr &= "   ,CONVERT(varchar, dateadd(day,-1,dateadd(YEAR,3,a.STDate)), 111) EDate" & vbCrLf
        sqlStr &= "   ,CONVERT(varchar,a.YEARS) COLLATE Chinese_Taiwan_Stroke_CS_AS PLANYEAR" & vbCrLf
        sqlStr &= "   ,a.STDate" & vbCrLf
        sqlStr &= "   FROM dbo.ADP_TRAININGLIST a WITH(NOLOCK)" & vbCrLf
        sqlStr &= "   WHERE a.WorkSuppIdent='Y'"
        sqlStr &= "   and a.TPlanID IN (" & Cst_TPlanID28_1b1b & ")"
        sqlStr &= "   and a.STDate>= " & To_date(cst_STDateV1) & vbCrLf ''" & cst_stdatev1 & "'" & vbCrLf
        sqlStr &= "   AND a.IDNO= '" & aIDNO & "'" & vbCrLf

        '例外資訊增加
        sqlStr &= "   UNION" & vbCrLf
        sqlStr &= "   SELECT CONVERT(varchar, a.STDate, 111) SDate" & vbCrLf
        sqlStr &= "   ,CONVERT(varchar, dateadd(day,-1,dateadd(YEAR,3,a.STDate)), 111) EDate" & vbCrLf
        sqlStr &= "   ,CONVERT(varchar,a.YEARS) COLLATE Chinese_Taiwan_Stroke_CS_AS PLANYEAR" & vbCrLf
        sqlStr &= "   ,a.STDate" & vbCrLf
        sqlStr &= "   FROM dbo.ADP_TRAININGLIST_OTH a WITH(NOLOCK)" & vbCrLf
        sqlStr &= "   WHERE a.WorkSuppIdent='Y'"
        sqlStr &= "   and a.TPlanID IN (" & Cst_TPlanID28_1b1b & ")"
        sqlStr &= "   and a.STDate>= " & To_date(cst_STDateV1) & vbCrLf ''" & cst_stdatev1 & "'" & vbCrLf
        sqlStr &= "   AND a.IDNO= '" & aIDNO & "'" & vbCrLf

        sqlStr &= " ) g" & vbCrLf
        sqlStr &= " WHERE 1=1" & vbCrLf
        If edate <> "" AndAlso IsDate(edate) Then
            sqlStr &= " and g.STDate > " & To_date(edate) & vbCrLf
        End If
        sqlStr &= " ORDER BY g.PlanYear,g.STDate ASC" & vbCrLf
        Call OpenDbConn(tConn)
        Dim cmd As New SqlCommand(sqlStr, tConn)
        With cmd
            .Parameters.Clear()
            dt = New DataTable
            dt.Load(.ExecuteReader())
        End With
        If dt.Rows.Count > 0 Then
            '有資料
            sdate = CDate(dt.Rows(0)("SDate")).ToString("yyyy/MM/dd")  '取得第1~N次的 補助申請區間(起迄)日期
            edate = CDate(dt.Rows(0)("EDate")).ToString("yyyy/MM/dd")
        Else
            '有結束日，表示超過範圍尚未申請，設定新的 補助申請區間(起迄)日期
            If edate <> "" Then
                If IsDate(edate) Then
                    sdate = DateAdd(DateInterval.Day, 1, CDate(edate))
                    edate = DateAdd(DateInterval.Day, -1, DateAdd(DateInterval.Year, 3, CDate(sdate))).ToString("yyyy/MM/dd")
                End If
            End If
        End If
    End Sub

    '(產投) 取得審核區間日期3年為一期 INPUT@IDNO,STDate  OUTPUT@sDate,eDate Stud_SubsidyCost
    Public Shared Sub Get_SubSidyCostDay(ByVal IDNO As String,
                                         ByVal STDate As String,
                                         ByRef sDate As String,
                                         ByRef eDate As String,
                                         ByRef tConn As SqlConnection)
        If STDate = "" Then STDate = CDate(Now).ToString("yyyy/MM/dd")
        IDNO = ChangeIDNO(IDNO)
        Dim chk As Boolean = False
        Dim errchk As Boolean = False '異常情況(1)
        Do While chk = False
            Try
                '先試著取審核過的三年區間 '先試著取參訓過的三年區間
                Call Get_YearsPeriod(IDNO, sDate, eDate, tConn)
                '沒取到 就直接用目前的開訓日期的三年區間
                If sDate = String.Empty OrElse eDate = String.Empty Then
                    sDate = STDate
                    eDate = DateAdd(DateInterval.Day, -1, DateAdd(DateInterval.Year, 3, CDate(sDate))).ToString("yyyy/MM/dd")
                End If
                '判斷開訓日期是否落入取得區間，不是的話就重新取得
                If sDate <> String.Empty AndAlso eDate <> String.Empty Then
                    If CDate(STDate) >= CDate(sDate) AndAlso CDate(STDate) <= CDate(eDate) Then chk = True '開訓日期在區間內OK
                    If chk = False Then sDate = String.Empty '清除開始日期繼續下一輪
                End If
                '異常情況(1)
                If sDate <> String.Empty Then
                    If DateDiff(DateInterval.Year, CDate(STDate), CDate(sDate)) >= 4 Then errchk = True
                End If
                '異常情況(2)
                If eDate <> String.Empty Then
                    If DateDiff(DateInterval.Year, CDate(STDate), CDate(eDate)) >= 4 Then errchk = True
                End If
                If errchk Then
                    sDate = STDate
                    eDate = DateAdd(DateInterval.Day, -1, DateAdd(DateInterval.Year, 3, CDate(sDate))).ToString("yyyy/MM/dd")
                    Exit Do
                End If
            Catch ex As Exception
                LOG.Error(ex.Message, ex)
                sDate = STDate
                eDate = DateAdd(DateInterval.Day, -1, DateAdd(DateInterval.Year, 3, CDate(sDate))).ToString("yyyy/MM/dd")
                chk = True
                Exit Do
            End Try
        Loop
    End Sub

    '傳進OCID1值，傳回該班的報名人數
    Public Shared Function Get_EnterCount(ByVal OCID1 As String, ByRef tConn As SqlConnection) As Integer
        Dim iRst As Integer = 0
        If OCID1 = "" Then Return iRst

        '取得報名人數(網路) '扣除e網審核失敗
        'signUpStatus-0:收件完成 1:報名成功 2:報名失敗 3:正取(Key_SelResult) 4:備取 5:未錄取
        Dim rPMS As New Hashtable From {{"OCID1", OCID1}}
        Dim sql As String = ""
        sql &= " SELECT ISNULL(COUNT(1),0) TOTAL" & vbCrLf
        sql &= " FROM dbo.STUD_ENTERTEMP2 se2 WITH(NOLOCK)" & vbCrLf
        sql &= " JOIN dbo.STUD_ENTERTYPE2 sy2 WITH(NOLOCK) ON se2.ESETID=sy2.ESETID" & vbCrLf
        sql &= " WHERE sy2.OCID1=@OCID1" & vbCrLf
        sql &= " AND ISNULL(sy2.signUpStatus,0) != 2" & vbCrLf '扣除e網審核失敗
        iRst = DbAccess.ExecuteScalar(sql, tConn, rPMS)
        Return iRst
    End Function

    Public Shared Function IsAllDateCheck(ByVal objPage As System.Web.UI.Page,
                                          ByVal OCID As String, ByVal Type As String, ByRef oConn As SqlConnection) As String '是否為全日制檢查
        Dim msg As String = ""
        If OCID = "" Then Return msg


        Dim dt As DataTable
        Dim dr As DataRow
        Dim IsNull_Class9_12 As Integer = 0
        Dim Total_Class1_8 As Integer = 0
        Const daybase As Integer = 30 '基本條件30天
        Dim DayQuotient As Integer = 0 '商數
        Dim DayMod As Integer = 0      '餘數
        Dim Totalhours As Integer = 0  '總上課小時數基準
        Dim Over30day_hours As Integer = 0 '超過30天的上課時數基準
        Dim base30hours As Integer = 0  '30天的上課時數
        Dim Over30hours As Integer = 0  '超過30天的上課時數實際
        Dim Ischeck As String = "Y"     '判斷是否還要檢查總上課時數是否達到標準,若有錯誤訊息產生就不檢查
        Dim sql2 As String = ""
        Dim dt2 As DataTable
        Dim dr2 As DataRow
        Dim dr3 As DataRow
        '查CLASS_CLASSINFO 資料表
        Dim pPMS As New Hashtable From {{"OCID", OCID}}

        Dim sql As String = ""
        sql &= " SELECT ocid,STDate,FTdate" & vbCrLf
        'sql &= " ,IsFullDate,trunc(FTdate-STDate) trains_periods" & vbCrLf
        sql &= " ,IsFullDate, DATEDIFF(DAY,STDate,FTdate) trains_periods" & vbCrLf
        sql &= " ,STDate+30 date30" & vbCrLf
        sql &= " FROM dbo.CLASS_CLASSINFO" & vbCrLf
        sql &= " WHERE OCID=@OCID" & vbCrLf
        dr3 = DbAccess.GetOneRow(sql, oConn, pPMS)
        If dr3 Is Nothing Then Return msg

        If Not dr3 Is Nothing Then
            If Convert.ToString(dr3("IsFullDate")) = "Y" Then '如果是法定全日制 才做檢查
                If CInt(dr3("trains_periods")) < 30 Then
                    msg &= "【訓練期間】未滿30天!\n"
                Else              '計算出總時數需達幾小時以上
                    DayQuotient = CInt(dr3("trains_periods")) \ daybase ' daybase=30 天
                    DayMod = CInt(dr3("trains_periods")) Mod daybase    ' daybase=30 天
                    If DayMod >= 10 And DayMod <= 19 Then       '例如:訓練天數是40-49天的總時數需為130天以上,70-79天總時數230以此類推
                        Totalhours = (DayQuotient * 100) + 30
                    ElseIf DayMod >= 20 And DayMod <= 29 Then   '例如:訓練天數是50-59天的總時數需為160天以上,80-89天總時數260以此類推
                        Totalhours = (DayQuotient * 100) + 60
                    Else
                        Totalhours = DayQuotient * 100          '例如 :訓練天數是30-39天的總時數需為100天以上,60-69為200天基準
                    End If
                    Over30day_hours = Totalhours - 100 '例如 : 總訓練天數是45天,45天-30天=5天,計算這5天需要達到的上課時數標準(計算超過30天的上課時數基準)
                End If
                '---------------------------------------檢查一星期上幾天課 start-----------------------
                sql2 = ""
                sql2 &= " SELECT count(a.SchoolDate) as weekcount" & vbCrLf
                sql2 &= " from (SELECT SchoolDate,DATEPART(week, SchoolDate) as weeks," & vbCrLf  '傳回星期是第幾週
                sql2 &= "  case when class1 is not null then 1 else 0 end" & vbCrLf
                sql2 &= " +case when class2 is not null then 1 else 0 end" & vbCrLf
                sql2 &= " +case when class3 is not null then 1 else 0 end" & vbCrLf
                sql2 &= " +case when class4 is not null then 1 else 0 end" & vbCrLf
                sql2 &= " +case when class5 is not null then 1 else 0 end" & vbCrLf
                sql2 &= " +case when class6 is not null then 1 else 0 end" & vbCrLf
                sql2 &= " +case when class7 is not null then 1 else 0 end" & vbCrLf
                sql2 &= " +case when class8 is not null then 1 else 0 end class1_8" & vbCrLf
                sql2 &= " FROM dbo.CLASS_SCHEDULE WHERE ocid='" & OCID & "') a" & vbCrLf
                sql2 &= " WHERE a.class1_8 <> 0" & vbCrLf   '排除沒有上課天數
                sql2 &= " GROUP BY a.weeks" & vbCrLf
                dt2 = DbAccess.GetDataTable(sql2, oConn)
                If dt2.Rows.Count > 0 Then
                    For Each dr2 In dt2.Rows
                        If CInt(dr2("weekcount")) < 4 Then    '每週上課至少4次
                            msg &= "每週上課未達4次(天)\n"
                            Exit For
                        End If
                    Next
                End If
                '---------------------------------------檢查一星期上幾天課 end---------------------------------------
                sql = " SELECT" & vbCrLf
                sql &= " SchoolDate," & vbCrLf
                sql &= "  case when class1 is not null then 1 else 0 end" & vbCrLf
                sql &= " +case when class2 is not null then 1 else 0 end" & vbCrLf
                sql &= " +case when class3 is not null then 1 else 0 end" & vbCrLf
                sql &= " +case when class4 is not null then 1 else 0 end" & vbCrLf
                sql &= " +case when class5 is not null then 1 else 0 end" & vbCrLf
                sql &= " +case when class6 is not null then 1 else 0 end" & vbCrLf
                sql &= " +case when class7 is not null then 1 else 0 end" & vbCrLf
                sql &= " +case when class8 is not null then 1 else 0 end class1_8," & vbCrLf
                sql &= "  case when class9 is not null then 1 else 0 end" & vbCrLf
                sql &= " +case when class10 is not null then 1 else 0 end" & vbCrLf
                sql &= " +case when class11 is not null then 1 else 0 end" & vbCrLf
                sql &= " +case when class12 is not null then 1 else 0 end class9_12" & vbCrLf
                sql &= " FROM dbo.CLASS_SCHEDULE" & vbCrLf
                sql &= " WHERE ocid='" & OCID & "'" & vbCrLf
                sql &= " ORDER BY SchoolDate"
                dt = DbAccess.GetDataTable(sql, oConn)
                If dt.Rows.Count > 0 Then
                    For Each dr In dt.Rows
                        IsNull_Class9_12 += dr("class9_12")  '計算9_12節是否有排課,0是沒排課>1表示有排課,節次需為日間1-8節
                        If IsNull_Class9_12 > 0 Then
                            msg &= "節次需為【日間1-8節】，【9-12節】不能有排課\n"
                            Ischeck = "N"    '判斷是否還要檢查總上課時數,若有錯誤訊息產生就不檢查
                            Exit For
                        End If
                        If CInt(dr("class1_8")) < 4 And CInt(dr("class1_8")) <> 0 Then '是否每次上課至少4小時,排除沒有排課
                            msg &= "每次(天)上課未達4小時\n "
                            Ischeck = "N"    '判斷是否還要檢查總上課時數,若有錯誤訊息產生就不檢查
                            Exit For
                        End If
                        If dr("SchoolDate") <= dr3("date30") Then  '
                            base30hours += dr("class1_8")    '計算實際前30天的時數
                        Else
                            Over30hours += dr("class1_8")    '計算超過30天的時數
                        End If
                        Total_Class1_8 += dr("class1_8") '計算實際總時數
                    Next
                    If Ischeck = "Y" Then      '若是每次上課至少都有4小時,及節次也都在1-8節,才檢查
                        If Total_Class1_8 < Totalhours Then
                            msg &= "【上課總時數】未達" & Totalhours & "小時以上\n"
                        End If
                        If base30hours < 100 Then
                            msg &= "第一個月【上課時數】未達100小時以上\n"
                        End If
                        If Over30hours < Over30day_hours Then
                            msg &= "一個月後的【上課時數】未達" & Over30day_hours & "小時以上\n"
                        End If
                    End If
                    Select Case Type
                        Case "ReturnMsg" '傳回msg
                            If msg <> "" Then
                                msg = "是否符合【全日制】檢查：\n" & msg
                            End If
                            Return msg
                        Case "ShowMsg" '不回傳直接代出錯誤訊息
                            If msg <> "" Then
                                Dim strScript As String
                                Dim strBlockName As String = xBlockName() ' "MESSAGE_" + New Random().GetHashCode().ToString("x")
                                msg = "是否符合【全日制】檢查：\n" & msg

                                strScript = String.Concat("<script language=""javascript"">alert('", msg, "');</script>")
                                objPage.RegisterStartupScript(strBlockName, strScript)
                            End If
                    End Select
                End If
            End If
        End If
        Return msg
    End Function

    '將 DataView 轉為 DataTable
    Public Shared Function dv2dt(ByVal v As DataView) As DataTable
        Dim dt As DataTable = v.Table.Clone
        For i As Integer = 0 To v.Count - 1
            dt.ImportRow(v(i).Row())
        Next
        Return dt
    End Function

    '取得 通俗職類 DataRow
    Public Shared Function Get_SHARECJOB(ByVal CJOB_UNKEY As String, ByRef objconn As SqlConnection) As DataRow
        Dim rst As DataRow = Nothing
        If CJOB_UNKEY <> "" Then
            Dim sql As String = "SELECT * FROM dbo.SHARE_CJOB WHERE CJOB_UNKEY=@CJOB_UNKEY "
            Call OpenDbConn(objconn)
            Dim oDt As New DataTable
            Dim oCmd As New SqlCommand(sql, objconn)
            With oCmd
                .Parameters.Clear()
                .Parameters.Add("CJOB_UNKEY", SqlDbType.Int).Value = CINT1(CJOB_UNKEY)
                oDt.Load(.ExecuteReader())
            End With
            If oDt.Rows.Count > 0 Then rst = oDt.Rows(0)
        End If
