                Dim dr As DataRow = dt.NewRow
                dt.Rows.Add(dr)
                dr("SDLID") = iSDLID
                dr("FunID") = FunID
                dr("DistID") = DistID
                dr("DelNote") = DelNote
                dr("OrgID") = If(OrgID = 0, Convert.DBNull, OrgID)
                dr("RID") = If(RID = "", Convert.DBNull, RID)
                dr("PlanID") = If(PlanID = 0, Convert.DBNull, PlanID)
                dr("ComIDNO") = If(ComIDNO = "", Convert.DBNull, ComIDNO)
                dr("SeqNO") = If(SeqNO = 0, Convert.DBNull, SeqNO)
                dr("OCID") = If(OCID = 0, Convert.DBNull, OCID)
                dr("SOCID") = If(SOCID = 0, Convert.DBNull, SOCID)
                dr("DelReason") = If(DelResaon = 0, Convert.DBNull, DelResaon)
                dr("DelReasonOther") = If(DelReasonOther = "", Convert.DBNull, DelReasonOther)
                dr("ModifyAcct") = UserID
                dr("ModifyDate") = Now
                DbAccess.UpdateDataTable(dt, da)
            Catch ex As Exception
                LOG.Warn(ex.Message, ex)
                Call CloseDbConn(conn)
                Dim sMailBody As String = ""
                Call Set_STR2STR(sMailBody, FunID, "FunID")
                Call Set_STR2STR(sMailBody, DistID, "DistID")
                Call Set_STR2STR(sMailBody, DelNote, "DelNote")
                Call Set_STR2STR(sMailBody, OrgID, "OrgID")
                Call Set_STR2STR(sMailBody, RID, "RID")
                Call Set_STR2STR(sMailBody, PlanID, "PlanID")
                Call Set_STR2STR(sMailBody, ComIDNO, "ComIDNO")
                Call Set_STR2STR(sMailBody, SeqNO, "SeqNO")
                Call Set_STR2STR(sMailBody, OCID, "OCID")
                Call Set_STR2STR(sMailBody, SOCID, "SOCID")
                Call Set_STR2STR(sMailBody, DelResaon, "DelResaon")
                Call Set_STR2STR(sMailBody, DelReasonOther, "DelReasonOther")
                Call Set_STR2STR(sMailBody, UserID, "ModifyAcct")
                Call Set_STR2STR(sMailBody, Now, "ModifyDate")
                'sMailBody=Replace(sMailBody, vbCrLf, "<br>" & vbCrLf)
                Call WriteTraceLog(Nothing, ex, sMailBody)
            End Try
            Call CloseDbConn(conn)
        End Using
    End Sub

    'INSERT DELETE LOG 刪除LOG記錄(SYS_DELLOG)
    Public Shared Sub InsertDelLog(ByRef MyPage As Page, ByRef htSS As Hashtable, ByRef oConn As SqlConnection)
        Dim UserID As String = GetMyValue2(htSS, "UserID")
        Dim iFunID As Integer = GetMyValue2(htSS, "iFunID")
        Dim DistID As String = GetMyValue2(htSS, "DistID")
        Dim DelNote As String = GetMyValue2(htSS, "DelNote")
        Dim iOrgID As Integer = GetMyValue2(htSS, "iOrgID")
        Dim RID As String = GetMyValue2(htSS, "RID")
        Dim iPlanID As Integer = GetMyValue2(htSS, "iPlanID")
        Dim ComIDNO As String = GetMyValue2(htSS, "ComIDNO")
        Dim iSeqNO As Integer = GetMyValue2(htSS, "iSeqNO")
        Dim iOCID As Integer = GetMyValue2(htSS, "iOCID")
        Dim iSOCID As Integer = GetMyValue2(htSS, "iSOCID")
        Dim DelResaon As String = GetMyValue2(htSS, "DelResaon")
        Dim DelReasonOther As String = GetMyValue2(htSS, "DelReasonOther")
        Dim SID As String = GetMyValue2(htSS, "SID")
        Dim IDNO As String = GetMyValue2(htSS, "IDNO")
        Dim NAME As String = GetMyValue2(htSS, "NAME")

        Dim sql As String = ""
        sql &= " INSERT INTO SYS_DELLOG ( SDLID,FUNID,DELNOTE,ORGID,RID,PLANID,COMIDNO,SEQNO,OCID,SOCID,MODIFYACCT,MODIFYDATE,DISTID,DELREASON,DELREASONOTHER,SID,IDNO,NAME)" & vbCrLf
        sql &= " VALUES ( @SDLID,@FUNID,@DELNOTE,@ORGID,@RID,@PLANID,@COMIDNO,@SEQNO,@OCID,@SOCID,@MODIFYACCT,GETDATE(),@DISTID,@DELREASON,@DELREASONOTHER,@SID,@IDNO,@NAME)" & vbCrLf
        Dim iCmd As New SqlCommand(sql, oConn)

        Try
            Call OpenDbConn(oConn)
            Dim iSDLID As Integer = DbAccess.GetNewId(oConn, "SYS_DELLOG_SDLID_SEQ,SYS_DELLOG,SDLID")
            With iCmd
                .Parameters.Clear()
                .Parameters.Add("SDLID", SqlDbType.Int).Value = iSDLID
                .Parameters.Add("FUNID", SqlDbType.Int).Value = iFunID
                .Parameters.Add("DELNOTE", SqlDbType.VarChar).Value = DelNote
                .Parameters.Add("ORGID", SqlDbType.Int).Value = iOrgID
                .Parameters.Add("RID", SqlDbType.VarChar).Value = RID
                .Parameters.Add("PLANID", SqlDbType.Int).Value = iPlanID
                .Parameters.Add("COMIDNO", SqlDbType.VarChar).Value = ComIDNO
                .Parameters.Add("SEQNO", SqlDbType.Int).Value = iSeqNO
                .Parameters.Add("OCID", SqlDbType.Int).Value = iOCID
                .Parameters.Add("SOCID", SqlDbType.Int).Value = iSOCID
                .Parameters.Add("MODIFYACCT", SqlDbType.VarChar).Value = UserID 'MODIFYACCT
                .Parameters.Add("DISTID", SqlDbType.VarChar).Value = DistID
                .Parameters.Add("DELREASON", SqlDbType.Int).Value = DelResaon 'DELREASON
                .Parameters.Add("DELREASONOTHER", SqlDbType.VarChar).Value = DelReasonOther
                .Parameters.Add("SID", SqlDbType.VarChar).Value = SID
                .Parameters.Add("IDNO", SqlDbType.VarChar).Value = IDNO
                .Parameters.Add("NAME", SqlDbType.VarChar).Value = NAME
                .ExecuteNonQuery()
            End With
        Catch ex As Exception
            LOG.Warn(ex.Message, ex)
            Dim sMailBody As String = ""
            Call Set_STR2STR(sMailBody, iFunID, "iFunID")
            Call Set_STR2STR(sMailBody, DistID, "DistID")
            Call Set_STR2STR(sMailBody, DelNote, "DelNote")
            Call Set_STR2STR(sMailBody, iOrgID, "iOrgID")
            Call Set_STR2STR(sMailBody, RID, "RID")
            Call Set_STR2STR(sMailBody, iPlanID, "iPlanID")
            Call Set_STR2STR(sMailBody, ComIDNO, "ComIDNO")
            Call Set_STR2STR(sMailBody, iSeqNO, "iSeqNO")
            Call Set_STR2STR(sMailBody, iOCID, "iOCID")
            Call Set_STR2STR(sMailBody, iSOCID, "iSOCID")
            Call Set_STR2STR(sMailBody, DelResaon, "DelResaon")
            Call Set_STR2STR(sMailBody, DelReasonOther, "DelReasonOther")
            Call Set_STR2STR(sMailBody, UserID, "ModifyAcct")
            Call Set_STR2STR(sMailBody, Now, "ModifyDate")

            '取得錯誤資訊寫入
            Dim V_GUID As String = Guid.NewGuid().ToString()
            Dim strErrmsg As String = String.Concat("/* ex.Message: */", ex.Message, "[", V_GUID, "]", GetErrorMsg(MyPage), sMailBody)
            Call WriteTraceLog(strErrmsg, ex)
        End Try
    End Sub

    '是否下放轄區中心決定 TRUE:顯示設定 FALSE:不顯示設定
    Public Shared Function CheckReusable(ByVal sTPlanID As String, ByRef oConn As SqlConnection) As Boolean
        Dim rst As Boolean = False '預設為不顯示  '不等於YES的都不顯示
        'Dim key_Plan_Reusable As String=Nothing
        If sTPlanID = "" Then Return rst

        '若 EmailSend='N' 也表示不可以下放轄區中心決定
        Dim sql As String = " SELECT ISNULL(Reusable,' ') REUSABLE FROM KEY_PLAN WHERE TPLANID=@TPLANID AND EMAILSEND='Y'"
        Dim s_parms As New Hashtable From {{"TPLANID", sTPlanID}}
        Dim dr1 As DataRow = DbAccess.GetOneRow(sql, oConn, s_parms)
        If dr1 Is Nothing Then Return rst
        Dim key_Plan_Reusable As String = Convert.ToString(dr1("REUSABLE"))
        'Dim conn As SqlConnection=DbAccess.GetConnection()
        'key_Plan_Reusable=DbAccess.ExecuteScalar(sql, conn) '因為sql 會轉出有一格空白的字元，所以要再加以整理
        'Call CloseDbConn(conn)
        'key_Plan_Reusable=Trim(key_Plan_Reusable)
        'If key_Plan_Reusable Is Nothing Then key_Plan_Reusable="" '未設定
        If key_Plan_Reusable = cst_YES Then rst = True '顯示('不等於YES的都不顯示)        
        Return rst
    End Function

    ''' <summary>'e網報名審核是否發送Email TRUE:發送 FALSE:不發送</summary>
    ''' <param name="MyPage"></param>
    ''' <param name="sTPlanID"></param>
    ''' <param name="sPlanID"></param>
    ''' <param name="oConn"></param>
    ''' <returns></returns>
    Public Shared Function CheckEmailSend(ByRef MyPage As Page, ByVal sTPlanID As String, ByVal sPlanID As String, ByRef oConn As SqlConnection) As Boolean
        Dim rst As Boolean = True '預設為發送
        Dim sm As SessionModel = SessionModel.Instance()

        'CheckEmailSend=True '預設為發送
        If sPlanID = "" Then sPlanID = sm.UserInfo.PlanID
        If sTPlanID = "" Then sTPlanID = sm.UserInfo.TPlanID
        '是否下放轄區中心決定 TRUE:顯示設定 FALSE:不顯示設定
        Dim ReusableFlag As Boolean = CheckReusable(sTPlanID, oConn)

        Dim sql As String = $" SELECT ISNULL(EMAILSEND,' ') EMAILSEND FROM KEY_PLAN WHERE TPLANID='{sTPlanID}'"
        Dim dr1 As DataRow = DbAccess.GetOneRow(sql, oConn)
        Dim TPlan_EmailSend As String = If(dr1 IsNot Nothing, Trim(Convert.ToString(dr1("EMAILSEND"))), "")

        '因為sql 會轉出有一格空白的字元，所以要再加以整理
        Dim sql2 As String = $" SELECT ISNULL(EMAILSEND,' ') EMAILSEND FROM ID_PLAN WHERE PlanID='{sPlanID}'"
        Dim dr2 As DataRow = DbAccess.GetOneRow(sql2, oConn)
        Dim id_Plan_EmailSend As String = If(dr2 IsNot Nothing, Trim(Convert.ToString(dr2("EMAILSEND"))), "")

        If ReusableFlag Then
            If id_Plan_EmailSend <> "" Then
                'YES:'發送/'不等於YES的都不發送
                rst = If(id_Plan_EmailSend = cst_YES, True, False)
            Else
                rst = If(TPlan_EmailSend = cst_NO, False, True) '不發送/發送
            End If
        Else
            rst = If(TPlan_EmailSend = cst_NO, False, True) '不發送/發送
        End If
        Return rst 'CheckEmailSend
    End Function

