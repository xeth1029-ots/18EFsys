        sql &= " JOIN STUD_STUDENTINFO ss on ss.SID=cs.SID" & vbCrLf
        sql &= " JOIN STUD_SUBDATA ss2 on ss2.SID=cs.SID" & vbCrLf
        sql &= " JOIN CLASS_CLASSINFO cc on cc.OCID=cs.OCID" & vbCrLf
