    ''' <summary>檢核 班別資料之「優先排序」欄位 不可重複 true:重複 false:沒有重複</summary>
    ''' <param name="ss"></param>
    ''' <param name="oConn"></param>
    ''' <param name="o_OthClassName1"></param>
    ''' <returns></returns>
    Public Shared Function Chk_FirstSort1(ByVal ss As String, ByRef oConn As SqlConnection, ByRef o_OthClassName1 As String) As Boolean
        Dim rst As Boolean = False
        If ss = "" Then Return rst
        'https://jira.turbotech.com.tw/browse/TIMSC-138
        '修改說明：班別資料之「優先排序」欄位，如有重複植入之序號者，即無法儲存並跳出出提醒文字。
        '此外，107年度啟用，區隔上、下年度，以6/30做為區隔，開訓日為1/1~6/30為上半年度，7/1~12/31為下半年度，上、下半年的數字要區分，
        '同一個半年度內，不可重複填寫相同數字。

        '同一訓練單位，在同一年度的產業人才投資方案訓練計畫內不可有相同的序號。
        Dim PlanID As String = GetMyValue(ss, "PlanID")
        Dim ComIDNO As String = GetMyValue(ss, "ComIDNO")

        Dim FirstSort As String = GetMyValue(ss, "FirstSort")
        Dim AppStage As String = GetMyValue(ss, "AppStage")
        'Dim STDate As String=GetMyValue(ss, "STDate")
        Dim PCSVALUE As String = GetMyValue(ss, "PCSVALUE")

        If PlanID = "" OrElse FirstSort = "" OrElse AppStage = "" Then Return rst
        'If STDate="" Then Return rst

        Call OpenDbConn(oConn)
        Dim dt As New DataTable
        Dim sql As String = ""
        sql &= " SELECT pp.CLASSNAME" & vbCrLf
        sql &= " FROM PLAN_PLANINFO pp" & vbCrLf
        sql &= " JOIN ID_PLAN ip on ip.PlanID=pp.PlanID" & vbCrLf
        sql &= " JOIN AUTH_RELSHIP rr on rr.RID=pp.RID" & vbCrLf
        sql &= " WHERE pp.ISAPPRPAPER='Y'" & vbCrLf
        sql &= " and pp.PlanID=@PlanID and pp.COMIDNO=@ComIDNO and pp.FirstSort=@FirstSort and pp.AppStage=@AppStage" & vbCrLf
        If PCSVALUE <> "" Then sql &= " and concat(pp.PlanID,'x',pp.Comidno,'x',pp.Seqno) !=@PCSVALUE" & vbCrLf '排除自身
        Dim sCmd As New SqlCommand(sql, oConn)
        With sCmd
            .Parameters.Clear()
            .Parameters.Add("PlanID", SqlDbType.Int).Value = CINT1(PlanID)
            .Parameters.Add("ComIDNO", SqlDbType.VarChar).Value = ComIDNO
            .Parameters.Add("FirstSort", SqlDbType.Int).Value = CINT1(FirstSort)
            .Parameters.Add("AppStage", SqlDbType.Int).Value = CINT1(AppStage)
            If PCSVALUE <> "" Then .Parameters.Add("PCSVALUE", SqlDbType.VarChar).Value = PCSVALUE
            dt.Load(.ExecuteReader())
        End With
        If dt.Rows.Count = 0 Then Return rst
        rst = True '有資料(重複了)
        o_OthClassName1 = Convert.ToString(dt.Rows(0)("CLASSNAME"))
        Return rst
    End Function

    '確認zipcode
    Public Shared Function IsZipCode(ByVal zipCode As Object, ByVal tConn As SqlConnection) As Boolean
        Dim rst As Boolean = False '異常false
        If zipCode Is Nothing Then Return rst
        Dim str1 As String = ClearSQM($"{zipCode}")
        If str1 = "" Then Return rst
        If Not IsNumeric2(str1) Then Return rst
        Dim sql As String = "SELECT 'X' FROM ID_ZIP WHERE ZIPCODE=@ZIPCODE"
        Dim sCmd As New SqlCommand(sql, tConn)
        Call OpenDbConn(tConn)
        Dim dt As New DataTable
        With sCmd
            .Parameters.Clear()
            .Parameters.Add("ZIPCODE", SqlDbType.Int).Value = TIMS.CINT1(str1)
            dt.Load(.ExecuteReader())
        End With
        If dt.Rows.Count > 0 Then rst = True
        Return rst
