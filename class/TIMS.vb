                                               ByRef cbl_OrgList As CheckBoxList, ByRef errMsg As String, ByRef oConn As SqlConnection) As Boolean
        'ByRef MyPage As Page, ByVal iRoleID As Integer, ByVal iPlanID As Integer, ByVal sAccount As String, ByVal sRIDValue As String, ByRef cbl_OrgList As CheckBoxList, ByRef errMsg As String
        Dim rst As Boolean = False
        If sAccount = "" Then Return rst

        Dim sm As SessionModel = SessionModel.Instance()
        Call OpenDbConn(oConn)

        '0: 超級管理者()'1:系統管理者()'2: 一級以上()'3: 一級()'4: 二級()'5: 承辦人()'99: 一般使用者()' 參考Table:ID_Role
