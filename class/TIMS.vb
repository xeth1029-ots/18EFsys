    '取出系統現有黑名單('依iBlackType)
    Public Shared Function Get_OrgBlackList(ByRef MyPage As Page, ByVal objconn As SqlConnection) As DataTable
        Dim rst As DataTable = Nothing
        Dim sm As SessionModel = SessionModel.Instance()
        ' (直接在 AuthBasePage 處理, 不用個別檢查 Session) If TIMS.ChkSession(MyPage) Then Return rst 'SESSION不完整
        Dim sTPlanID As String = sm.UserInfo.TPlanID '判斷該計畫是否啟用黑名單功能。
        Dim sDistID As String = sm.UserInfo.DistID
        Dim iBlackType As Integer = Chk_OrgBlackType(MyPage, objconn)

        Dim sql As String = ""
        Dim sBLACK2TPLANID As String = ""
        Select Case iBlackType
            Case 2
                '2：跨計畫合併限制處分紀錄，因跨計畫合併限制處分紀錄可能會有不同組合，需要另外一個欄位紀錄組合喔
                sql = "SELECT DISTINCT BLACK2TPLANID FROM KEY_PLAN WHERE BLACKTYPE=2 AND ','+BLACK2TPLANID+',' like '%,'+@TPlanID+',%'"
                Dim sCmd2 As New SqlCommand(sql, objconn)
                Call OpenDbConn(objconn)
                Dim dt2 As New DataTable
                With sCmd2
                    .Parameters.Clear()
                    .Parameters.Add("TPlanID", SqlDbType.VarChar).Value = sTPlanID
                    dt2.Load(.ExecuteReader())
                End With
                sBLACK2TPLANID = ""
                For Each dr2 As DataRow In dt2.Rows
                    If sBLACK2TPLANID <> "" Then sBLACK2TPLANID &= ","
                    sBLACK2TPLANID &= Convert.ToString(dr2("BLACK2TPLANID"))
                Next
                sBLACK2TPLANID = CombiSQM2IN(sBLACK2TPLANID)
        End Select

        sql = ""
        sql &= " SELECT ob.OBSN,ob.COMIDNO,ob.OBSDATE,ob.OBYEARS,ob.OBCOMMENT,ob.AVAIL,ob.MODIFYACCT,ob.MODIFYDATE,ob.OBNUM,ob.DISTID" & vbCrLf
        sql &= " ,ISNULL(ob.OBTERMS,'99') OBTERMS" & vbCrLf
        '限期內的黑名單為Y
        sql &= " ,CASE WHEN ob.Avail='Y' and (DATEDIFF(day,GETDATE(),ob.obSdate)>=0 and DATEDIFF(day, DATEADD(month, 12*ob.obYears, ob.obSdate), GETDATE())>=0) THEN 'Y' ELSE 'N' END isBlack" & vbCrLf
        sql &= " FROM Org_BlackList ob" & vbCrLf
        sql &= " WHERE ob.Avail='Y'" & vbCrLf '有效的(含不在限期內的)
        Select Case iBlackType
            Case 0 '0:回傳(不啟用)
                sql &= " and 1<>1" & vbCrLf  'Return rstOrgBlackList '回傳(不啟用)
            Case 1 '1：各計畫自行限制處分紀錄
                sql &= " and ob.TPlanID='" & sTPlanID & "'" & vbCrLf '有效的(含不在限期內的)
            Case 2 '2：跨計畫合併限制處分紀錄，因跨計畫合併限制處分紀錄可能會有不同組合，需要另外一個欄位紀錄組合喔
                If sBLACK2TPLANID <> "" Then
                    sql &= " and ob.TPlanID IN (" & sBLACK2TPLANID & ")" & vbCrLf '有效的(含不在限期內的)
                Else
                    sql &= " and ob.TPlanID='" & sTPlanID & "'" & vbCrLf '有效的(含不在限期內的)
                End If
            Case 3 '3：所有計畫合併限制處分紀錄
            Case 4 '4:回傳(無處分限制)
                sql &= " and 1<>1" & vbCrLf  'Return rstOrgBlackList '回傳(無處分限制)
        End Select
        rst = DbAccess.GetDataTable(sql, objconn)
        Return rst
    End Function

    Public Shared Function Get_FunEnable(ByVal tmpAcct As String, ByVal tmpID As Integer,
                                         ByVal tmpFun As String, ByRef oConn As SqlConnection) As Boolean
        Dim sqlStr As String = ""
        Dim rst As Boolean = False
        If tmpFun Is Nothing OrElse String.IsNullOrEmpty(tmpFun) Then Return rst
        Dim p_tmpFun As String = ""
        Select Case tmpFun.ToUpper()
            Case "DEL"
                p_tmpFun = "DEL"
                sqlStr = "SELECT DEL FROM AUTH_ACCRWFUN WHERE Account=@Account and FunID=@FunID "
            Case Else
                Return rst
        End Select
        If String.IsNullOrEmpty(p_tmpFun) Then Return rst
        Call OpenDbConn(oConn)
        Dim sCmd As New SqlCommand(sqlStr, oConn)
        Dim dt As New DataTable
        With sCmd
            .Parameters.Clear()
            .Parameters.Add("Account", SqlDbType.VarChar).Value = tmpAcct
            .Parameters.Add("FunID", SqlDbType.Int).Value = tmpID
            dt.Load(.ExecuteReader())
        End With
        If dt Is Nothing OrElse dt.Rows.Count = 0 Then Return rst
        If Convert.ToString(dt.Rows(0)(p_tmpFun)) = "1" Then Return True
        Return rst
    End Function

