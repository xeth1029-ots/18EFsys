    'Dim url As String=GetFunIDUrl(Request("ID")) 'Response.Redirect(url & "?ID=" & Request("ID"))
    Public Shared Function GetFunIDUrl(ByVal FunID As String, ByVal num As Integer, ByRef oConn As SqlConnection) As String
        Dim rst As String = ""
        If FunID = "" Then Return rst

        Select Case num
            Case 0 '絕對位置
                Dim pms As New Hashtable From {{"FunID", CINT1(FunID)}}
                Dim sql As String = " SELECT SPAGE FROM ID_FUNCTION WHERE FunID=@FunID"
                Dim oSPAGE As Object = DbAccess.ExecuteScalar(sql, oConn, pms)
                If oSPAGE Is Nothing Then Return rst
                rst = String.Concat("~/", oSPAGE)
            Case 1 '相對位置
                Dim pms As New Hashtable From {{"FunID", CINT1(FunID)}}
                Dim sql As String = " SELECT SPAGE FROM ID_FUNCTION WHERE SPAGE LIKE '%/%' AND FunID=@FunID"
                Dim oSPAGE As Object = DbAccess.ExecuteScalar(sql, oConn, pms)
                If oSPAGE Is Nothing Then Return rst
                Dim ary As Array = Split(String.Concat("", oSPAGE), "/")
                If ary.Length > 0 Then rst = ary(UBound(ary))
        End Select
        Return rst
    End Function

    ''' <summary>
    ''' 有權使用的功能-建置功能列 AUTH_GROUPACCT
    ''' </summary>
    ''' <param name="objconn"></param>
    ''' <returns></returns>
    Public Shared Function sGet_CanUseSchDt(ByRef objconn As SqlConnection) As DataTable
        Dim rst As DataTable = Nothing
        Dim sm As SessionModel = SessionModel.Instance()

        Dim vsTPlanID As String = $"{sm.UserInfo.TPlanID}"
        Dim vsDistID As String = $"{sm.UserInfo.DistID}"
        Dim vsUserID As String = $"{sm.UserInfo.UserID}"
        Dim vsRoleID As String = $"{sm.UserInfo.RoleID}"
        If vsRoleID <> "" Then vsRoleID = CINT1(vsRoleID)
        Dim vsLID As String = $"{sm.UserInfo.LID}"
        If vsLID <> "" Then vsLID = CINT1(vsLID)
        If vsTPlanID = "" OrElse vsDistID = "" OrElse vsUserID = "" OrElse vsRoleID = "" OrElse vsLID = "" Then Return rst

        Dim flgROLEIDx0xLIDx0 As Boolean = IsSuperUser(sm, 1)

        If objconn Is Nothing Then objconn = DbAccess.GetConnection()

        'Dim vsGID As String="" '查詢是否有限定計畫群組
        'Dim dt_group As DataTable
        ''Dim oCmd As SqlCommand

        '取得限定計畫的權限。
        Dim parm As New Hashtable From {{"Account", vsUserID}}
        Dim sql As String = ""
        sql &= " SELECT GID, ACCOUNT, GTPLANID" & vbCrLf
        sql &= " FROM AUTH_GROUPACCT" & vbCrLf
        sql &= " WHERE GTPLANID IS NOT NULL AND ACCOUNT=@Account" & vbCrLf
        sql &= $" AND ','+GTPLANID+',' LIKE '%,{vsTPlanID},%'" & vbCrLf '文字組合比對。
        Dim dtG As DataTable = DbAccess.GetDataTable(sql, objconn, parm)

        Dim vsGID As String = "" '查詢是否有限定計畫群組
        If Not flgROLEIDx0xLIDx0 Then
            If dtG.Rows.Count > 0 Then
                For i As Integer = 0 To dtG.Rows.Count - 1
                    Dim vTmp1 As String = ClearSQM(dtG.Rows(i)("GID"))
                    If vTmp1 <> "" Then
                        vsGID &= $"{If(vsGID <> "", ",", "")}{vTmp1}"
                    End If
                Next
            End If
        End If

        '取得(群組版)權限 'SelIDFunctionS7    
        sql = ""
        sql &= " SELECT P.FUNID ,CASE ISNULL(x.Sort,0) WHEN 0 THEN p.SORT ELSE x.SORT END NEWSORT" & vbCrLf
        sql &= " ,p.NAME,p.SPage,p.KIND,p.LEVELS,p.PARENT,p.PARENT PARENT1,p.VALID,p.SORT" & vbCrLf
        sql &= " ,p.MODIFYACCT,p.MODIFYDATE,p.MEMO,p.REUSE,p.ADDS,p.MOD,p.DEL,p.SECH,p.PRNT,p.FSTATE,p.ISREPORT" & vbCrLf
        sql &= " FROM ID_FUNCTION p" & vbCrLf '所有的功能。
        '計畫排序用。
        sql &= " LEFT JOIN PLAN_FUNC x ON p.FUNID=x.FUNID AND x.TPLANID=@TPlanID AND x.DISTID=@DistID" & vbCrLf 'SORT
        '包含 群組功能
        sql &= " WHERE EXISTS ( SELECT 'X' FROM AUTH_GROUPFUN c WHERE c.FUNID=p.FUNID" & vbCrLf
        '包含 計畫功能。
        sql &= "     AND EXISTS ( SELECT 'X' FROM AUTH_PLANFUNCTION c2 WHERE c2.TPLANID=@TPlanID AND c2.FUNID=c.FUNID )" & vbCrLf
        '包含 群組帳號
        sql &= "     AND EXISTS ( SELECT 'X' FROM AUTH_GROUPACCT c3 WHERE c3.ACCOUNT=@Account and c3.GID=c.GID" & vbCrLf
        sql &= $"{If(vsGID <> "", $" AND c3.GID In ({vsGID})", "")}{")"}" & vbCrLf '限定計畫的權限。
        '排除 群組帳號(功能刪除)
        sql &= "     AND NOT EXISTS ( SELECT 'X' FROM AUTH_GROUPDFUN c4 WHERE c4.ACCOUNT=@Account AND c4.FUNID=c.FUNID )" & vbCrLf
        sql &= " )" & vbCrLf
        sql &= " AND ISNULL(p.FState,' ')!='D'" & vbCrLf
        sql &= " ORDER BY p.KIND, p.LEVELS, NEWSORT, p.PARENT" & vbCrLf

        Dim parm2 As New Hashtable From {{"TPlanID", vsTPlanID}, {"DistID", vsDistID}, {"Account", vsUserID}}

        Dim dt_group As DataTable = DbAccess.GetDataTable(sql, objconn, parm2)

        If dt_group.Rows.Count > 0 Then
            If vsRoleID = 0 Then
                '超級使用者 '取得(群組版)權限 'SelIDFunctionS8    
                Dim parm3 As New Hashtable From {{"TPlanID", vsTPlanID}, {"DistID", vsDistID}, {"Account", vsUserID}}
                sql = ""
                sql &= " SELECT p.FUNID ,CASE ISNULL(x.SORT,0) WHEN 0 THEN p.SORT ELSE x.SORT END NEWSORT" & vbCrLf
                sql &= " ,p.NAME,p.SPAGE,p.KIND,p.LEVELS,p.PARENT,p.PARENT PARENT1,p.VALID,p.SORT" & vbCrLf
                sql &= " ,p.MODIFYACCT,p.MODIFYDATE,p.MEMO,p.REUSE,p.ADDS,p.MOD,p.DEL,p.SECH,p.PRNT,p.FSTATE,p.ISREPORT" & vbCrLf
                sql &= " FROM ID_FUNCTION p" & vbCrLf
                sql &= " LEFT JOIN PLAN_FUNC x ON p.FUNID=x.FUNID AND x.TPLANID=@TPlanID AND x.DISTID=@DistID" & vbCrLf 'SORT
                sql &= " WHERE (p.KIND IN ('SYS') AND p.VALID='Y' AND ISNULL(p.FState,' ')!='D')" & vbCrLf ','FAQ','OO'
                sql &= " OR EXISTS ( SELECT 'x' FROM AUTH_GROUPFUN c WHERE c.FUNID=p.FUNID AND p.VALID='Y'" & vbCrLf
                sql &= " 	AND EXISTS ( SELECT 'x' FROM AUTH_PLANFUNCTION c2 WHERE c2.TPLANID=@TPlanID AND c2.FUNID=c.FUNID )" & vbCrLf
                sql &= " 	AND EXISTS ( SELECT 'x' FROM AUTH_GROUPACCT c3 WHERE c3.ACCOUNT=@Account AND c3.GID=c.GID" & vbCrLf
                sql &= $"{If(vsGID <> "", $" AND c3.GID In ({vsGID})", "")}{")"}" & vbCrLf '限定計畫的權限。
                sql &= " 	AND NOT EXISTS ( SELECT 'x' FROM AUTH_GROUPDFUN c4 WHERE c4.ACCOUNT=@Account AND c4.FUNID=c.FUNID )" & vbCrLf
                sql &= " )" & vbCrLf
                sql &= " ORDER BY p.KIND, p.LEVELS, NEWSORT, p.PARENT" & vbCrLf
                dt_group = DbAccess.GetDataTable(sql, objconn, parm3)
            End If
            rst = dv2dt(dt_group.DefaultView)

        Else
            '取得(帳號版)權限 'SelIDFunctionS9    
            '正式機版本
            sql = ""
            sql &= " SELECT p.FunID ,case ISNULL(x.Sort,0) WHEN 0 THEN p.Sort else x.Sort end newSort" & vbCrLf
            sql &= " ,p.Name,p.SPage,p.Kind,p.Levels,p.Parent,p.PARENT PARENT1,p.Valid,p.Sort" & vbCrLf
            sql &= " ,p.ModifyAcct,p.ModifyDate,p.Memo,p.ReUse,p.Adds,p.Mod,p.Del,p.Sech,p.Prnt,p.FState,p.ISREPORT" & vbCrLf
            sql &= " FROM ID_FUNCTION p" & vbCrLf
            sql &= " LEFT JOIN PLAN_FUNC x on p.FunID=x.FunID and x.TPlanID=@TPlanID and x.DistID=@DistID" & vbCrLf 'SORT
            sql &= " WHERE 1=1" & vbCrLf
            'sql &= " AND (p.KIND IN ('SYS') AND p.VALID='Y' AND ISNULL(p.FSTATE,'')!='D')" & vbCrLf ','FAQ','OO'
            If Server_Path() = "TIMS" Then
                If vsRoleID = 0 Then '超級使用者
                    Select Case vsLID
                        Case 0 '局:0 'SelIDFunctionS9
                            '系統管理 '其他系統 '問答集
                            sql &= " AND ( (p.Kind IN ('SYS') AND p.Valid='Y' AND ISNULL(p.FSTATE,' ')!='D')" & vbCrLf ','FAQ','OO'
                            sql &= " OR exists (SELECT 'x' FROM AUTH_PLANFUNCTION c WHERE c.TPlanID=@TPlanID AND c.FunID=p.FunID AND p.Valid='Y') )" & vbCrLf

                            Dim parm3 As New Hashtable From {{"TPlanID", vsTPlanID}, {"DistID", vsDistID}}

                            If Not IsNothing(objconn) Then
                                dt_group = DbAccess.GetDataTable(sql, objconn, parm3)
                            Else
                                dt_group = DbAccess.GetDataTable(sql, parm3)
                            End If

                        Case 1 '中心:1
                            '啟用： '55:基本資料設定 '56:計畫代碼設定 '57:訓練機構設定
                            sql &= " AND ( (p.Kind='TC' AND p.FunID in (55,56,57) AND p.Valid='Y' AND ISNULL(p.FSTATE,' ')!='D')" & vbCrLf
                            '停用： '37:階層功能設定 '38:階層角色設定 '54:鍵詞維護
                            sql &= " OR (p.Kind='SYS' AND p.FunID NOT IN (37,38,54) AND p.Valid='Y') )" & vbCrLf

                            Dim parm3 As New Hashtable From {{"TPlanID", vsTPlanID}, {"DistID", vsDistID}}

                            dt_group = DbAccess.GetDataTable(sql, objconn, parm3)
                    End Select

                Else '非超級使用者
                    sql &= " AND ( EXISTS ( SELECT 'x' FROM AUTH_PLANFUNCTION c WHERE c.TPlanID=@TPlanID AND c.FunID=p.FunID AND p.Valid='Y' AND ISNULL(p.FSTATE,' ')!='D'" & vbCrLf
                    sql &= "     AND EXISTS (SELECT 'X' FROM AUTH_ACCRWFUN c2 WHERE c2.FunID=c.FunID AND c2.Account=@Account) ) )" & vbCrLf

                    Dim parm3 As New Hashtable From {{"TPlanID", vsTPlanID}, {"DistID", vsDistID}, {"Account", vsUserID}}

                    dt_group = DbAccess.GetDataTable(sql, objconn, parm3)
                End If
            End If
            rst = dv2dt(dt_group.DefaultView)
        End If
        Return rst
    End Function

