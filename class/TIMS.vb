        Dim pms_1 As New Hashtable From {{"KVSID", vKVSID}, {"TPLANID", vTPLANID}, {"ORGKINDGW", vORGKINDGW}}
        Dim sSql As String = ""
        sSql &= " SELECT k.KVSID,k.KVID ,k.KBNAME,k.KBDESC1 ,k.TPLANID,k.ORGKINDGW ,k.MUSTFILL,k.PARENT,k.KSORT" & vbCrLf
        sSql &= " ,k.USELATESTVER,k.DOWNLOADRPT,k.RPTNAME,k.UPLOADFL1,k.USEMEMO1,k.SENTBATVER,k.SENDCURRVER,k.NOTKBDESC1,k.NOTFLDESC1" & vbCrLf
        sSql &= " ,concat(k.KVID,'.',k.KBNAME) C_KBNAME" & vbCrLf
        sSql &= " ,concat(k.KVID,k.KBNAME) C_KBNAME2" & vbCrLf
        sSql &= " FROM KEY_VERIFY k" & vbCrLf
        sSql &= " WHERE k.KVSID=@KVSID AND k.TPLANID=@TPLANID AND k.ORGKINDGW=@ORGKINDGW" & vbCrLf
        drVV = DbAccess.GetOneRow(sSql, oConn, pms_1)
