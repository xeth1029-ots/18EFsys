    '檢核為地方政府或是分署單位 (依登入者帳號之機構ID) (限制時間的登入)
    Public Shared Function ChkFlagR23(ByVal sAccount As String,
                                      ByRef flagVLP As Boolean,
                                      ByVal tConn As SqlConnection) As String
        Dim rst As String = "" '空白沒有錯誤，有文字代表有錯誤。
        Const cst_errMsg1 As String = "只能有1筆帳號資料"
        '回傳: flagVLP true:限制時間的登入(是一般使用者) false:'無限制時間的登入 (是地方政府)
        Dim sql As String = ""
        Dim iLID As Integer = 0 '轉數字
        Dim sOrgID As Integer = 0
        sql = "SELECT LID,ORGID FROM AUTH_ACCOUNT WHERE ACCOUNT=@Account AND ISUSED='Y'"
        Dim sCmd As New SqlCommand(sql, tConn)
        'LID=CInt(DbAccess.ExecuteScalar(sql, objconn))
        Dim dtA As New DataTable
        Call OpenDbConn(tConn)
        With sCmd
            .Parameters.Clear()
            .Parameters.Add("Account", SqlDbType.VarChar).Value = sAccount
            dtA.Load(.ExecuteReader())
        End With
        If dtA.Rows.Count <> 1 Then Return cst_errMsg1 '只能有1筆帳號資料

        Dim dr1 As DataRow = dtA.Rows(0)
        iLID = CINT1(dr1("LID"))
        sOrgID = Convert.ToString(dr1("ORGID"))

        Dim flagR23 As Boolean = False
        If iLID = 2 Then
            '判斷是否為地方政府
            sql = ""
            sql &= " SELECT 'x'" & vbCrLf
            sql &= " FROM VIEW_RELSHIP23 R" & vbCrLf
            sql &= " JOIN ID_PLAN ip on ip.planid=r.planid and ip.distid=r.distid" & vbCrLf
            sql &= " WHERE ORGID2=@ORGID2" & vbCrLf
            Dim sCmd2 As New SqlCommand(sql, tConn)
            Dim dt2 As New DataTable
            Call OpenDbConn(tConn)
            With sCmd2
                .Parameters.Clear()
                .Parameters.Add("ORGID2", SqlDbType.VarChar).Value = sOrgID
                dt2.Load(.ExecuteReader())
            End With
            If dt2.Rows.Count > 0 Then flagR23 = True '是地方政府
        End If

        'Dim flagVLP As Boolean=False '無限制時間的登入
        flagVLP = False '無限制時間的登入
        If iLID = 2 Then
            '是委訓單位 若為地方政府
            flagVLP = True '有限制時間的登入
            If flagR23 Then '是地方政府
                flagVLP = False '無限制時間的登入
            End If
        End If
        Return rst
    End Function

    '顯示可用計畫年度。
    Public Shared Sub GetDropYearsDt(ByVal flagVLP As Boolean, ByVal sAccount As String,
                                     ByRef dtY As DataTable, ByVal tConn As SqlConnection)
        Dim sql As String = ""
        If flagVLP Then
            '有限制時間的登入
            sql = ""
            sql &= " SELECT DISTINCT YEARS FROM VIEW_LOGINPLAN" & vbCrLf
            sql &= " WHERE PLANID IN (SELECT PLANID FROM AUTH_ACCRWPLAN WHERE ACCOUNT='" & sAccount & "')" & vbCrLf
            sql &= " AND PLANID IN (SELECT PLANID FROM ID_PLAN WHERE 1=1 and DATEADD(month, 10, EDate) - GETDATE()>=0)" & vbCrLf
            sql &= " ORDER BY YEARS" & vbCrLf
            '計畫結束日加10個月帳號無法登入
        Else
            '無限制時間的登入
