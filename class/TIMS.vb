    '**by milor 20080613--職訓生活津貼申請用的Function----start
    '由起迄日計算月數
    Public Shared Function CmpDayMonth(ByVal SDate As DateTime, ByVal EDate As DateTime) As Decimal
        Dim Result As Decimal = 0

        '30 日為一個月，未滿 30 日者，10 日以上發給半個月，20 日以上發給一個月
        Dim dayCnt As Integer = Convert.ToInt32(DateDiff(DateInterval.Day, SDate, EDate)) + 1

        Dim dayMod As Integer = dayCnt Mod 30

        If dayMod = 0 Then
            Result = Int(dayCnt / 30)
        Else
            If dayMod >= 10 And dayMod < 20 Then
                Result = Int(dayCnt / 30) + 0.5
            ElseIf dayMod >= 20 Then
                Result = Int(dayCnt / 30) + 1
            Else
                Result = Int(dayCnt / 30)
            End If
        End If
        Return Result
    End Function

