    Public Shared Function Get_SALID(ByVal Salary As String) As String
        If Salary Is Nothing OrElse String.IsNullOrEmpty(Salary) Then Return ""

        Dim rst As String = "01" 'Val(Salary) <= 15000 
        If CINT1(Salary) > 50000 Then
            rst = "09"
        ElseIf CINT1(Salary) > 45000 Then
            rst = "08"
        ElseIf CINT1(Salary) > 40000 Then
            rst = "07"
        ElseIf CINT1(Salary) > 35000 Then
            rst = "06"
        ElseIf CINT1(Salary) > 30000 Then
            rst = "05"
        ElseIf CINT1(Salary) > 25000 Then
            rst = "04"
        ElseIf CINT1(Salary) > 20000 Then
            rst = "03"
        ElseIf CINT1(Salary) > 15000 Then
            rst = "02"
        End If
        Return rst
    End Function

