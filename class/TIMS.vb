        Dim saveFile As String = GetMyValue2(htSS, "saveFile")
        Dim s_ResponseNoEnd As String = GetMyValue2(htSS, "ResponseNoEnd")

        'ConvertDataTableToXLSX

        Dim buf As Byte() = GetMyValue2(htSS, "xlsx_buf", cst_oType_obj)
        If strPROG <> "" Then LOG.Debug(String.Format("#{0} Utl_ExportRp1 Ready Start 2 Export!", strPROG))
        'Dim v_ExpType As String=TIMS.GetListValue(RBListExpType)
        'Dim parmsExp As New Hashtable
        'parmsExp.Add("ExpType", v_ExpType) 'EXCEL/PDF/ODS
        'parmsExp.Add("FileName", sFileName1)
        'parmsExp.Add("strSTYLE", strSTYLE)
        'parmsExp.Add("strHTML", strHTML)
        'parmsExp.Add("ResponseNoEnd", "Y")
        'TIMS.Utl_ExportRp1(Me, parmsExp)

        If (strSTYLE <> "") Then strHTML = (strSTYLE & strHTML)

        Dim YMDSTR1x As String = DateTime.Now.ToString("ssHHddMMyyyymmss")
        If (s_FileName = "") Then s_FileName = YMDSTR1x
        Dim s_Extension As String = ""

        Dim s_log1 As String = ""
        Dim select_PrintType As String = s_ExpType.ToUpper()
        Select Case select_PrintType
            Case "EXCEL"
                If (strMETAXLS = "") Then strMETAXLS = "<meta http-equiv='Content-Type' content='application/vnd.ms-excel; charset=UTF-8'>" & vbCrLf
                strHTML = (strMETAXLS & strHTML)
                s_Extension = "xls"
            Case "PDF"
                s_Extension = "pdf"
            Case "ODS"
                s_Extension = "ods"
            Case "XLSX"
                s_Extension = "xlsx"
            Case Else
                s_log1 = String.Format("ExpType(參數有誤)!!{0}", select_PrintType)
                Common.MessageBox(MyPage, s_log1)
                Exit Sub
        End Select
        '組合檔名
        Dim strFileName As String = String.Format("{0}.{1}", s_FileName, s_Extension)
        '轉換UTF8
        Dim strFileNameUtf8 As String = HttpUtility.UrlEncode(strFileName, System.Text.Encoding.UTF8)

        'RespWrite
        '產生檔案(前置動作)
        If (select_PrintType = "EXCEL") Then '20191014_增修R13、R14需求：列印Excel檔案。
            MyPage.Response.Clear()
            'MyPage.Response.ClearHeaders()
            MyPage.Response.Charset = s_Charset
            MyPage.Response.ContentEncoding = System.Text.Encoding.GetEncoding(s_Charset)
            MyPage.Response.ContentType = "application/vnd.ms-excel" 'Excel
            MyPage.Response.AppendHeader("Content-Disposition", "attachment; filename=" & strFileNameUtf8)

        ElseIf (select_PrintType = "PDF") Then '20191014_增修R13、R14需求：列印PDF檔案。 
            MyPage.Response.Clear()
            'MyPage.Response.ClearHeaders()
            'MyPage.Response.Charset="UTF-8"
            'MyPage.Response.ContentEncoding=System.Text.Encoding.GetEncoding("UTF-8")
            MyPage.Response.Charset = s_Charset
            MyPage.Response.ContentEncoding = System.Text.Encoding.GetEncoding(s_Charset)
            MyPage.Response.ContentType = "application/pdf" 'PDF
            MyPage.Response.AppendHeader("Content-Disposition", "attachment; filename=" & strFileNameUtf8)

        ElseIf (select_PrintType = "ODS") Then '20191025_增修R14需求：列印ODS檔案。
            MyPage.Response.Clear()
            'MyPage.Response.ClearHeaders()
            'MyPage.Response.Charset="UTF-8"
            'MyPage.Response.ContentEncoding=System.Text.Encoding.GetEncoding("UTF-8")
            MyPage.Response.Charset = s_Charset
            MyPage.Response.ContentEncoding = System.Text.Encoding.GetEncoding(s_Charset)
            'MyPage.Response.ContentType="application/vnd.oasis.opendocument.spreadsheet" 'ODS
            MyPage.Response.ContentType = "application/octet-stream" 'unknown
            MyPage.Response.AppendHeader("Content-Disposition", "attachment; filename=" & strFileNameUtf8)

        ElseIf (select_PrintType = "XLSX") Then
            MyPage.Response.Clear()
            'MyPage.Response.ClearHeaders()
            'MyPage.Response.Charset="UTF-8"
            'MyPage.Response.ContentEncoding=System.Text.Encoding.GetEncoding("UTF-8")
            MyPage.Response.Charset = s_Charset
            MyPage.Response.ContentEncoding = System.Text.Encoding.GetEncoding(s_Charset)
            'MyPage.Response.ContentType="application/vnd.oasis.opendocument.spreadsheet" 'ODS
            MyPage.Response.ContentType = "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet" 'unknown
            MyPage.Response.AppendHeader("Content-Disposition", "attachment; filename=" & strFileNameUtf8)
        Else
            Common.MessageBox(MyPage, "請選擇[匯出檔案格式：](參數有誤)!!")
            Exit Sub
        End If

        ' 輸出至前端
        If (select_PrintType = "EXCEL") Then '20191014_增修R13、R14需求：列印Excel檔案。
            MyPage.Response.Write(strHTML) '輸出XLS檔案。

        ElseIf (select_PrintType = "PDF") Then '20191014_增修R13、R14需求：列印PDF檔案。
            Using stream As System.IO.MemoryStream = New System.IO.MemoryStream
                Dim pdf As HiQPdf.HtmlToPdf = New HiQPdf.HtmlToPdf With {
                    .SerialNumber = (New BasePage).HiQPdf_SerialNumber'"/7eWrq+b-mbOWnY2e-jYbOz9HP-387fy9/G-yM7fzM7R-zs3RxsbG-xg=="   '「HiQPdf」的SerialNumber
                }
                pdf.Document.PageOrientation = HiQPdf.PdfPageOrientation.Portrait   '紙張直向
                'pdf.Document.PageOrientation=HiQPdf.PdfPageOrientation.Landscape   '紙張橫向
                pdf.ConvertHtmlToStream(strHTML, Nothing, stream)
                MyPage.Response.BinaryWrite(stream.ToArray()) '輸出PDF檔案。
                'MyPage.Response.Flush()
            End Using

        ElseIf (select_PrintType = "ODS") Then '20191025_增修R14需求：列印ODS檔案。
            'Spire.License.LicenseProvider.SetLicenseFileName("license.elic.XLS.xml")
            'strHTML=strHTML.Replace(vbCrLf, "")
            'strHTML=strHTML.Replace(vbCr, "")
            Dim tk As New TurboOdfUtil.ExcelToODS() '讀取參考【TurboOdfUtil】。
            Dim content1 As Byte()
            If buf IsNot Nothing AndAlso buf.Length > 1 Then
                content1 = tk.ConvertXlsxToODS(buf)
            Else
                content1 = tk.ConvertHtmlTableToODS(strHTML, "sheet1") 'HTML格式轉成ODS格式輸出
            End If
            Dim flag_output As Boolean = True
            flag_output = If(content1 Is Nothing, False, If(content1.Length < 1, False, flag_output))
            If flag_output Then
                MyPage.Response.BinaryWrite(content1) '輸出ODS檔案。
            End If

        ElseIf (select_PrintType = "XLSX") Then
            'Spire.License.LicenseProvider.SetLicenseFileName("license.elic.XLS.xml")
            'strHTML=strHTML.Replace(vbCrLf, "")
            'strHTML=strHTML.Replace(vbCr, "")
            Dim s_sheet1 As String = String.Concat("sheet", TIMS.GetDateNo2(5))
            Dim tk As New TurboOdfUtil.ExcelToODS() '讀取參考【TurboOdfUtil】。
            Dim content1 As Byte() = tk.ConvertHtmlTableToExcel_NT(strHTML, s_sheet1) 'HTML格式轉成 XLSX 格式輸出
            'Dim flag_output As Boolean=True
            Dim flag_output As Boolean = If(content1 Is Nothing, False, If(content1.Length < 1, False, flag_output))
            If saveFile IsNot Nothing AndAlso strPROG <> "" Then
                If flag_output AndAlso saveFile.Equals("Y") Then
                    Call Utl_SaveFileXLSX(MyPage, htSS, s_FileName, s_Extension, content1)
                End If
            End If
            If flag_output Then MyPage.Response.BinaryWrite(content1) '輸出 XLSX 檔案。
        End If
        If strPROG <> "" Then LOG.Debug(String.Format("#{0} Utl_ExportRp1 Export End.", strPROG))

        Dim flag_ResponseEnd As Boolean = True '使用-ResponseEnd
        If (s_ResponseNoEnd Is Nothing) Then s_ResponseNoEnd = ""
        If (s_ResponseNoEnd <> "" AndAlso s_ResponseNoEnd.Equals("Y")) Then flag_ResponseEnd = False '(不使用-ResponseEnd)

        If (MyPage.Response Is Nothing) Then Return
        'If Not (MyPage.Response.IsClientConnected) Then Return
        'MyPage.Response.Flush()
        If Not (MyPage.Response.IsClientConnected) Then Return
        If flag_ResponseEnd Then MyPage.Response.End() '使用-ResponseEnd
    End Sub

    ''' <summary>
    ''' '匯出時存檔XLSX
    ''' </summary>
    ''' <param name="MyPage"></param>
    ''' <param name="htSS"></param>
    ''' <param name="s_FileName"></param>
    ''' <param name="s_Extension"></param>
    ''' <param name="content1"></param>
    Public Shared Sub Utl_SaveFileXLSX(ByRef MyPage As Page, ByRef htSS As Hashtable, ByRef s_FileName As String, ByRef s_Extension As String, ByRef content1 As Byte())
        Dim strPROG As String = GetMyValue2(htSS, "strPROG")
        Dim saveFile As String = GetMyValue2(htSS, "saveFile")
        'save file
        Dim sMyFilePath As String = MyPage.Server.MapPath("~/XLSX/")
        '判斷Log紀錄檔是否存在
        If Not System.IO.Directory.Exists(sMyFilePath) Then
            System.IO.Directory.CreateDirectory(sMyFilePath)
            Threading.Thread.Sleep(1) '假設處理某段程序需花費1毫秒 (避免機器不同步)
        End If
        'System.IO.
        Dim savefile1 As String = String.Format("{0}{1}.{2}", sMyFilePath, s_FileName, s_Extension)
        '檔案是否已存在
        Dim flag_Exists As Boolean = File.Exists(savefile1)
        Do While flag_Exists '檔案已存在
            Dim HMSSTR1x As String = DateTime.Now.ToString("yyyyMMddHHmmss")
            Dim s_FileName2 As String = String.Format("{0}{1}", s_FileName, HMSSTR1x)
            savefile1 = String.Format("{0}{1}.{2}", sMyFilePath, s_FileName2, s_Extension)
            flag_Exists = File.Exists(savefile1)
            Threading.Thread.Sleep(1) '假設處理某段程序需花費1毫秒 (避免機器不同步)
        Loop
        If strPROG <> "" Then LOG.Debug(String.Format("#{0} Utl_SaveFile Start!({1})", strPROG, savefile1))

        Dim wFile As System.IO.FileStream = New System.IO.FileStream(savefile1, System.IO.FileMode.Append)
        wFile.Write(content1, 0, content1.Length)
        wFile.Close()
        wFile = Nothing

        If strPROG <> "" Then LOG.Debug(String.Format("#{0} Utl_SaveFile OK End.({1})", strPROG, savefile1))
    End Sub

    ''' <summary>
    ''' 匯出下載檔XLSX
    ''' </summary>
    ''' <param name="MyPage"></param>
    ''' <param name="s_FileName"></param>
    ''' <param name="s_Extension"></param>
    ''' <returns></returns>
    Public Shared Function Utl_DownloadFileXLSX(ByRef MyPage As Page, ByRef s_FileName As String, ByRef s_Extension As String) As Boolean
        Dim sMyFilePath As String = MyPage.Server.MapPath("~/XLSX/")
        'System.IO.
        Dim file_path1 As String = String.Format("{0}{1}.{2}", sMyFilePath, s_FileName, s_Extension)
        '檔案是否已存在
        Dim flag_Exists As Boolean = File.Exists(file_path1)
        If Not flag_Exists Then Return False '(false:異常)
        '組合檔名
        Dim strFileName As String = String.Format("{0}.{1}", s_FileName, s_Extension)
        '轉換UTF8
        Dim strFileNameUtf8 As String = HttpUtility.UrlEncode(strFileName, System.Text.Encoding.UTF8)

        '這邊是要從server端下載檔案路徑
        'Dim file_path As String="C:/Program Files (x86)/IIS Express/AppServer/dotNET_40_Map.pdf"
        '宣告並建立WebClient物件
        Dim wc As Net.WebClient = New Net.WebClient()
        '載入要下載的檔案
        Dim bFile As Byte() = wc.DownloadData(file_path1)
        '清除Response內的HTML
        MyPage.Response.Clear()
        '設定標頭檔資訊 attachment 是本文章的關鍵字,filename是下載下來後取的名子
        MyPage.Response.AddHeader("Content-Disposition", "attachment;filename=" & strFileNameUtf8)
        '開始輸出讀取到的檔案
        MyPage.Response.BinaryWrite(bFile)
        '一定要加入這一行，否則會持續把Web內的HTML文字也輸出。
        'Response.End()
        'TIMS.Utl_RespWriteEnd(Me, objconn, "")
        Return True '(false:異常/true:正常)
    End Function

