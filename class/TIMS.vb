    '取得session字串  Public Shared Function SetMyValue( 取得1傳送參數
    Public Shared Function GetMyValue(ByVal strSession As String, ByVal FindMyItem As String) As String
        Dim rst As String = ""
        'Nothing　無法用字串判斷
        If strSession Is Nothing OrElse FindMyItem = "" OrElse strSession = "" Then Return rst
        Dim flag_test_ng_1 As Boolean = False
        Dim flag_test_ng_2 As Boolean = False
        Dim flag_test_ng_3 As Boolean = False
        If strSession.IndexOf(FindMyItem) = -1 Then flag_test_ng_1 = True '字串中無該字詞
        If strSession.ToUpper.IndexOf(FindMyItem.ToUpper) = -1 Then flag_test_ng_2 = True '字串中無該字詞(大寫)
        If strSession.ToLower.IndexOf(FindMyItem.ToLower) = -1 Then flag_test_ng_3 = True '字串中無該字詞(小寫)
        If flag_test_ng_1 AndAlso flag_test_ng_2 AndAlso flag_test_ng_3 Then Return rst '上述3種方式都無法找到

        Dim MyArray As Array = Split(strSession, "&")
        Dim MyItem As String = ""
        Dim MyValue As String = ""
        For i As Integer = 0 To MyArray.Length - 1
            If Split(MyArray(i), "=").Length > 1 Then
                MyItem = Split(MyArray(i), "=")(0)
                MyValue = Split(MyArray(i), "=")(1)
                If UCase(MyItem) = UCase(FindMyItem) Then
                    rst = MyValue
                    Exit For
                End If
            End If
        Next
        Return rst
    End Function

