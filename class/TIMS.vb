    ''' <summary>(本機)使用Mail.MailMessage寄信</summary>
    ''' <param name="V_SenderFrom"></param>
    ''' <param name="V_Emailto"></param>
    ''' <param name="V_Subject"></param>
    ''' <param name="V_MailBody"></param>
    ''' <param name="V_Encoding"></param>
    Public Shared Sub SendMail(ByVal V_SenderFrom As String, ByVal V_Emailto As String, ByVal V_Subject As String,
                               ByVal V_MailBody As String, ByVal V_Encoding As System.Text.Encoding)
        'Threading.Thread.Sleep(1) '假設處理某段程序需花費1毫秒 (避免機器不同步)
        Dim StopSendMail As String = Utl_GetConfigSet(cst_StopSendMail) 'StopSendMail
        '測試EMAIL 不受限制!
        If Not V_Emailto = Cst_EmailtoMe AndAlso StopSendMail = cst_YES Then Return '有停止寄信的訊息
        Dim CV_Emailto As String = ChangeEmail(V_Emailto)
        If Not CheckEmail(CV_Emailto) Then Return '(email有誤)
        'Dim smtpMail As New System.Web.net.SmtpClient
        'mymail.BodyEncoding=V_Encoding
#Disable Warning BC40000 ' 類型或成員已過時
        Dim mymail As New System.Web.Mail.MailMessage With {
            .Subject = V_Subject,
            .Body = V_MailBody,
            .To = CV_Emailto,
            .From = V_SenderFrom,
            .BodyFormat = System.Web.Mail.MailFormat.Html
        }
        Dim MailuserName As String = Utl_GetConfigSet("MailuserName")
        Dim MailuserPwd As String = Utl_GetConfigSet("MailuserPwd")
        MailuserName = If(MailuserName, "")
        MailuserPwd = If(MailuserPwd IsNot Nothing, DecryptAes(MailuserPwd), "")
        If (MailuserName <> "" AndAlso MailuserPwd <> "") Then
            mymail.Fields.Add("http://schemas.microsoft.com/cdo/configuration/smtpauthenticate", 1)
            mymail.Fields.Add("http://schemas.microsoft.com/cdo/configuration/sendusername", MailuserName)
            mymail.Fields.Add("http://schemas.microsoft.com/cdo/configuration/sendpassword", MailuserPwd)
        End If
        System.Web.Mail.SmtpMail.SmtpServer = Utl_GetConfigSet("MailServer")
        System.Web.Mail.SmtpMail.Send(mymail)
#Enable Warning BC40000 ' 類型或成員已過時
        Dim MLOGSTR1 As String = $"#SendMail,From:{V_SenderFrom}, Emailto:{V_Emailto}, vSubject:{V_Subject}, xEncoding:{V_Encoding}"
        LOG.Info(MLOGSTR1)
        'Throw ex
    End Sub

