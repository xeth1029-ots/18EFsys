    '判斷含中文字的半型長度 2006 XP
    Public Shared Function LENB(ByVal STR As String) As Integer
        'System.Text.Encoding.Default.GetBytes(STR).Length.ToString() 
        Dim I, LENINT As Integer
        LENINT = Len(STR)
        For I = 1 To Len(STR)
            If Len(Hex(Asc(Mid(STR, I, 1)))) = 8 _
                Or StrConv(Mid(STR, I, 1), VbStrConv.TraditionalChinese) <> Mid(STR, I, 1) Then
                LENINT += 1
            End If
        Next
        Return LENINT
    End Function

