    ''' <summary>線上申辦進度 計算完成度百分比 (0-100)</summary>
    ''' <param name="vBCID"></param>
    ''' <param name="vORGKINDGW"></param>
    ''' <returns></returns>
    Public Shared Function GET_iPROGRESS_BI(sm As SessionModel, oConn As SqlConnection, ByRef showMsg As String, vBCID As String, vORGKINDGW As String) As Integer
        Dim iProgress As Integer = 0
        showMsg = ""

        Dim PMS_OB As New Hashtable From {{"BCID", CINT1(vBCID)}}
        Dim SQL_OB As String = "SELECT * FROM ORG_BIDCASE WHERE BCID=@BCID"
        Dim drOB As DataRow = DbAccess.GetOneRow(SQL_OB, oConn, PMS_OB)
        If drOB Is Nothing Then Return iProgress '(無資料直接回傳)

        Dim pms_pi As New Hashtable From {{"BCID", CINT1(vBCID)}}
        Dim Sql_pi As String = " SELECT 1 FROM ORG_BIDCASEFL WHERE BCID=@BCID and WAIVED='PI'" & vbCrLf
        Dim dtWPI As DataTable = DbAccess.GetDataTable(Sql_pi, oConn, pms_pi)

        Dim pms_pi2 As New Hashtable From {{"BCID", CINT1(vBCID)}}
        Dim Sql_pi2 As String = ""
        Sql_pi2 &= " SELECT a.BCID,a.BCPID,CASE WHEN b.BCFPID IS NULL THEN 'Y' END BCFPIDNG" & vbCrLf
        Sql_pi2 &= " FROM ORG_BIDCASEPI a" & vbCrLf
        Sql_pi2 &= " LEFT JOIN ORG_BIDCASEFL_PI b on b.BCPID=a.BCPID and b.BCID=a.BCID" & vbCrLf
        Sql_pi2 &= " WHERE a.BCID=@BCID" & vbCrLf
        Dim dtPI2 As DataTable = DbAccess.GetDataTable(Sql_pi2, oConn, pms_pi2)

        Dim fg_WPI As Boolean = True '(預設為TRUE:無異常)
        If dtHaveDATA(dtWPI) AndAlso dtHaveDATA(dtPI2) Then
            For Each drPI2 As DataRow In dtPI2.Rows
                If ($"{drPI2("BCFPIDNG")}" = "Y") Then
                    fg_WPI = False '異常:FALSE '異常排除PI
                    Exit For
                End If
            Next
        End If

        'NOPROCESD  Y:排除計算完成度
        Dim rParmsA As New Hashtable From {{"ORGKINDGW", vORGKINDGW}, {"TPLANID", sm.UserInfo.TPlanID}}
        Dim sSqlA As String = "SELECT 1 FROM KEY_BIDCASE WHERE ORGKINDGW=@ORGKINDGW AND TPLANID=@TPLANID AND NOPROCESD IS NULL"
        Dim dtA As DataTable = DbAccess.GetDataTable(sSqlA, oConn, rParmsA)
        If dtNODATA(dtA) Then Return iProgress '0分

        Dim rParms As New Hashtable From {{"BCID", CINT1(vBCID)}, {"ORGKINDGW", vORGKINDGW}, {"TPLANID", sm.UserInfo.TPlanID}}
        Dim rsSql As String = ""
        rsSql &= " SELECT 1 FROM ORG_BIDCASEFL a" & vbCrLf
        rsSql &= " JOIN KEY_BIDCASE kb ON kb.KBSID=a.KBSID AND kb.NOPROCESD IS NULL" & vbCrLf
        rsSql &= " JOIN ORG_BIDCASE ob ON ob.BCID=a.BCID" & vbCrLf
        rsSql &= " JOIN AUTH_RELSHIP rr ON rr.RID=a.RID" & vbCrLf
        rsSql &= " WHERE a.BCID=@BCID AND kb.TPLANID=@TPLANID AND kb.ORGKINDGW=@ORGKINDGW"
        If Not fg_WPI Then rsSql &= " AND ISNULL(a.WAIVED,'')!='PI'" '異常排除PI

        'rsSql &= " ORDER BY kb.KBID,a.KBSID,a.BCFID" & vbCrLf
        Dim dt As DataTable = DbAccess.GetDataTable(rsSql, oConn, rParms)
        If dt Is Nothing Then Return iProgress '0分

        '10.師資助教基本資料表-要-計算完成度
        Dim dtFLTT As DataTable = GET_ORG_BIDCASEFL_TT(oConn, vBCID)
        '11.各授課師資學／經歷證書影本-要-計算完成度
        Dim dtFLTT2 As DataTable = GET_ORG_BIDCASEFL_TT2(oConn, vBCID)
        '10.師資助教基本資料表
        Dim PMS_S1 As New Hashtable From {{"BCID", $"{drOB("BCID")}"}, {"RID", $"{drOB("RID")}"}, {"AppStage", $"{drOB("AppStage")}"}}
        Dim dtPTT1 As DataTable = GET_PLAN_TEACHER1_TT(oConn, PMS_S1)
        '11.各授課師資學／經歷證書影本
        Dim PMS_S2 As New Hashtable From {{"BCID", $"{drOB("BCID")}"}, {"RID", $"{drOB("RID")}"}, {"AppStage", $"{drOB("AppStage")}"}}
        Dim dtPTT2 As DataTable = GET_PLAN_TEACHER1_TT2(oConn, PMS_S2)

        Dim iFLTT As Integer = If(dtHaveDATA(dtFLTT), dtFLTT.Rows.Count, 0) '10.師資助教基本資料表-已完成,已上傳
        Dim iFLTT2 As Integer = If(dtHaveDATA(dtFLTT2), dtFLTT2.Rows.Count, 0) '11.各授課師資學／經歷證書影本-已完成,已上傳
        Dim iDATA1 As Integer = If(dtHaveDATA(dt), dt.Rows.Count, 0) '(已完成)

        Dim iPTT1 As Integer = If(dtHaveDATA(dtPTT1), dtPTT1.Rows.Count, 0) '10.師資助教基本資料表-'(總共要完成項)
        Dim iPTT2 As Integer = If(dtHaveDATA(dtPTT2), dtPTT2.Rows.Count, 0) '11.各授課師資學／經歷證書影本-'(總共要完成項)
        Dim iDATAA As Integer = If(dtHaveDATA(dtA), dtA.Rows.Count, 0) '(總共要完成項)

        Dim iCNT1 As Double = iDATA1 + iFLTT + iFLTT2 '(已完成)
        Dim iCNTA As Double = iDATAA + iPTT1 + iPTT2 '(總共要完成項)
        iProgress = If(dtHaveDATA(dtA), (iCNT1 / iCNTA * 100), 0)
        If iProgress > 100 Then iProgress = (iCNTA / iCNT1 * 100) '(大於100重新處理)

        If iProgress > 30 AndAlso iProgress < 100 Then
            Dim rParms2 As New Hashtable From {{"ORGKINDGW", vORGKINDGW}, {"TPLANID", sm.UserInfo.TPlanID}, {"BCID", CINT1(vBCID)}}
            Dim sSql2 As String = ""
            sSql2 &= " SELECT ob.BCID,kb.KBID,kb.KBNAME,kb.ORGKINDGW" & vbCrLf
            sSql2 &= " ,concat(kb.KBID,'.',kb.KBNAME) KBNAME2,a.WAIVED" & vbCrLf
            sSql2 &= " ,CASE WHEN a.BCFID IS NULL THEN 'Y' END BCFIDNG" & vbCrLf
            sSql2 &= " FROM ORG_BIDCASE ob" & vbCrLf
            sSql2 &= " JOIN AUTH_RELSHIP rr ON rr.RID=ob.RID" & vbCrLf
            sSql2 &= " JOIN KEY_BIDCASE kb ON kb.ORGKINDGW=@ORGKINDGW AND kb.TPLANID=@TPLANID AND kb.NOPROCESD IS NULL" & vbCrLf
            sSql2 &= " LEFT JOIN ORG_BIDCASEFL a ON a.BCID=ob.BCID and a.KBSID=KB.KBSID" & vbCrLf
            If Not fg_WPI Then sSql2 &= " AND ISNULL(a.WAIVED,'')!='PI'" '異常排除PI
            sSql2 &= " WHERE ob.BCID=@BCID"
            Dim dt2 As DataTable = DbAccess.GetDataTable(sSql2, oConn, rParms2)
            If dtNODATA(dt2) Then Return iProgress
            For Each dr2 As DataRow In dt2.Rows
                If (Convert.ToString(dr2("BCFIDNG")) = "Y") Then
                    showMsg &= $"{If(showMsg <> "", "、", "")}{dr2("KBNAME2")}"
                End If
            Next

            Dim nonRows1() As DataRow = dt2.Select("WAIVED='TT'")
            Dim vKBNAME1 As String = If(nonRows1.Length > 0, $"{nonRows1(0)("KBID")}.{nonRows1(0)("KBNAME")}", "")
            Dim nonRows2() As DataRow = dt2.Select("WAIVED='TT2'")
            Dim vKBNAME2 As String = If(nonRows2.Length > 0, $"{nonRows2(0)("KBID")}.{nonRows2(0)("KBNAME")}", "")

            Dim fg_nsm1 As Boolean = True
            Dim fg_nsm2 As Boolean = True
            '10.師資助教基本資料表,應相等，反之異常
            If iPTT1 > 0 AndAlso iFLTT <> iPTT1 Then
                Dim WAIVED_PT1_KBNAME As String = $"【{vKBNAME1}】(子項)-{iFLTT}/{iPTT1}"
                showMsg &= $"{If(showMsg <> "", "、", "")}{WAIVED_PT1_KBNAME}"
                fg_nsm1 = True
            End If
            '11.各授課師資學／經歷證書影本,應相等，反之異常
            If iPTT2 > 0 AndAlso iFLTT2 <> iPTT2 Then
                Dim WAIVED_PT2_KBNAME As String = $"【{vKBNAME2}】(子項)-{iFLTT2}/{iPTT2}"
                showMsg &= $"{If(showMsg <> "", "、", "")}{WAIVED_PT2_KBNAME}"
                fg_nsm2 = True
            End If
            If fg_nsm1 AndAlso fg_nsm2 Then
                '(10.師資助教基本資料表)(11.各授課師資學/經歷證書影本) 應相等，反之異常
                If iFLTT <> iFLTT2 Then
                    Dim WAIVED_TT2_KBNAME As String = $"【{vKBNAME1}】(子項)或【{vKBNAME2}】(子項)-{iFLTT}/{iFLTT2}"
                    showMsg &= $"{If(showMsg <> "", "、", "")}{WAIVED_TT2_KBNAME}"
                End If
            End If
        End If
        Return iProgress 'labProgress.Text=String.Concat(iProgress, "%")
    End Function

