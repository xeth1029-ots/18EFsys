    ''' <summary>取得目前處分型態 (學員處分) (STUD_BLACKLIST) iStdBlackType,stdBLACK2TPLANID 依 TPlanID </summary>
    ''' <param name="MyPage"></param>
    ''' <param name="oConn"></param>
    ''' <param name="stdBLACK2TPLANID"></param>
    ''' <returns></returns>
    Public Shared Function Chk_StdBlackType(ByRef MyPage As Page, ByRef oConn As SqlConnection, ByRef stdBLACK2TPLANID As String) As Integer
        Dim iRst As Integer = 0
        Dim sm As SessionModel = SessionModel.Instance()

        'SBLACKTYPE
        '0:未設定
        '1：各計畫自行限制處分紀錄
        '2：跨計畫合併限制處分紀錄，因跨計畫合併限制處分紀錄可能會有不同組合，需要另外一個欄位紀錄組合喔
        '3：所有計畫合併限制處分紀錄
        '4：無處分限制(停用處分)
        Dim sTPlanID As String = sm.UserInfo.TPlanID '判斷該計畫是否啟用黑名單功能。
        Dim sql As String = ""
        sql = ""
        sql &= " SELECT DISTINCT TPlanID"
        sql &= " ,SBLACKTYPE,','+SBLACK2TPLANID+',' SBLACK2TPLANID"
        sql &= " FROM KEY_PLAN"
        sql &= " WHERE SBLACKTYPE IS NOT NULL"
        Dim sCmd As New SqlCommand(sql, oConn)
        Call OpenDbConn(oConn)
        Dim dt As New DataTable
        With sCmd
            .Parameters.Clear()
            dt.Load(.ExecuteReader())
        End With
        If dt.Rows.Count = 0 Then Return iRst '0:未設定
        Dim sff As String = ""
        sff = "SBLACKTYPE=4 AND TPlanID='" & sTPlanID & "'"
        If dt.Select(sff).Length > 0 Then Return 4 '4：無處分限制(停用處分)
        sff = "SBLACKTYPE=3"
        If dt.Select(sff).Length > 0 Then Return 3 '3：所有計畫合併限制處分紀錄
        sff = "SBLACKTYPE=2 AND SBLACK2TPLANID LIKE '%," & sTPlanID & ",%'"
        If dt.Select(sff).Length > 0 Then
            '2：跨計畫合併限制處分紀錄，因跨計畫合併限制處分紀錄可能會有不同組合，需要另外一個欄位紀錄組合喔
            sql = "SELECT DISTINCT SBLACK2TPLANID FROM KEY_PLAN WHERE SBLACKTYPE=2 AND ','+SBLACK2TPLANID+',' like '%,'+@TPlanID+',%'"
            Dim sCmd2 As New SqlCommand(sql, oConn)
            Dim dt2 As New DataTable
            With sCmd2
                .Parameters.Clear()
                .Parameters.Add("TPlanID", SqlDbType.VarChar).Value = sTPlanID
                dt2.Load(.ExecuteReader())
            End With
            stdBLACK2TPLANID = ""
            For Each dr2 As DataRow In dt2.Rows
                If stdBLACK2TPLANID <> "" Then stdBLACK2TPLANID &= ","
                stdBLACK2TPLANID &= Convert.ToString(dr2("SBLACK2TPLANID"))
            Next
            stdBLACK2TPLANID = CombiSQM2IN(stdBLACK2TPLANID)
            Return 2 '2：跨計畫合併限制處分紀錄
        End If
        sff = "SBLACKTYPE=1 AND TPlanID='" & sTPlanID & "'"
        If dt.Select(sff).Length > 0 Then Return 1 '1：各計畫自行限制處分紀錄

        Return iRst '0:未設定(其他狀況)
    End Function

    '返回組合後的sql語法(學員處分) 產生 WITH WSB (STUD_BLACKLIST) 。
    ''' <summary>
    ''' iStdBlackType:處分形態 // stdBLACK2TPLANID:部份計畫範圍 // iWith:若為1加WITH
    ''' </summary>
    ''' <param name="MyPage"></param>
    ''' <param name="iStdBlackType"></param>
    ''' <param name="stdBLACK2TPLANID"></param>
    ''' <param name="iWith"></param>
    ''' <returns></returns>
    ''' <remarks></remarks>
    Public Shared Function Get_StdBlackWSB(ByRef MyPage As Page,
                                           ByVal iStdBlackType As Integer,
                                           ByVal stdBLACK2TPLANID As String,
                                           ByVal iWith As Integer) As String
        Dim sql As String = ""
        Dim sm As SessionModel = SessionModel.Instance()

        Dim sTPlanID As String = sm.UserInfo.TPlanID '判斷計畫。
        sql = ""
        'iWith 1:使用 WITH WSB AS 
        Select Case iWith
            Case 1
                sql &= " WITH WSB AS (" & vbCrLf
            Case Else
                sql &= " ,WSB AS (" & vbCrLf
        End Select
        sql &= " SELECT DISTINCT sb.IDNO FROM STUD_BLACKLIST sb" & vbCrLf
        sql &= " WHERE sb.AVAIL='Y' AND GETDATE() BETWEEN sb.SBSDATE AND DATEADD(year, sb.SBYEARS, sb.SBSDATE)" & vbCrLf
        Select Case iStdBlackType
            Case 0 '0:回傳(不啟用)
                sql &= " AND 1<>1" & vbCrLf  'Return rstOrgBlackList '回傳(不啟用)
            Case 1 '1：各計畫自行限制處分紀錄
                sql &= " AND sb.TPlanID='" & sTPlanID & "'" & vbCrLf '有效的(含不在限期內的)
            Case 2 '2：跨計畫合併限制處分紀錄，因跨計畫合併限制處分紀錄可能會有不同組合，需要另外一個欄位紀錄組合喔
                If stdBLACK2TPLANID <> "" Then
                    sql &= " AND sb.TPlanID IN (" & stdBLACK2TPLANID & ")" & vbCrLf '有效的(含不在限期內的)
                Else
                    sql &= " AND sb.TPlanID='" & sTPlanID & "'" & vbCrLf '有效的(含不在限期內的)
                End If
            Case 3 '3：所有計畫合併限制處分紀錄
            Case 4 '4:回傳(無處分限制)
                sql &= " AND 1<>1" & vbCrLf  'Return rstOrgBlackList '回傳(無處分限制)
        End Select
        sql &= " )" & vbCrLf
        Return sql
    End Function


