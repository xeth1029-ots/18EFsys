    ''' <summary> 重參-檢核學員OOO有參訓時段重疊報名情形，無法儲存，請再確認！重複-webservice </summary>
    ''' <param name="timsSer1"></param>
    ''' <param name="sERRMSG"></param>
    ''' <param name="sName"></param>
    ''' <param name="xStudInfo"></param>
    Public Shared Sub ChkStudDouble(ByRef timsSer1 As timsService1.timsService1, ByRef sERRMSG As String, ByVal sName As String, ByVal xStudInfo As String)
        'WebRequest物件如何忽略憑證問題
        'System.Net.ServicePointManager.ServerCertificateValidationCallback=New System.Net.Security.RemoteCertificateValidationCallback(AddressOf TIMS.ValidateServerCertificate)
        'TLS 1.2-基礎連接已關閉: 傳送時發生未預期的錯誤 'HttpClient
        'System.Net.ServicePointManager.SecurityProtocol=Net.SecurityProtocolType.Tls12 '3072
        '檢核學員重複參訓。
        'http://163.29.199.223/TIMSWS/timsService1.asmx
        'https://wltims.wda.gov.tw/TIMSWS/timsService1.asmx
        'Dim timsSer1 As New timsService1.timsService1
        Dim IDNO As String = GetMyValue(xStudInfo, "IDNO")
        Dim OCID1 As String = GetMyValue(xStudInfo, "OCID1")
        If IDNO = "" OrElse OCID1 = "" Then Return 'IDNO/OCID1 空白異常離開不判斷

        Dim errmsg1 As String = ""
        Try
            '(有可能是Y 或是 錯誤訊息)
            Dim TMPMSG_Y_OTH As String = timsSer1.ChkStudDouble2(xStudInfo)
            LOG.DebugFormat("#ChkStudDouble,xStudInfo: {0},TMPMSG_Y_OTH: {1}", xStudInfo, TMPMSG_Y_OTH)
            errmsg1 = "參訓時段重疊報名情形,查詢失敗,請重新查詢!" & vbCrLf
            If TMPMSG_Y_OTH = "Y" Then
                '學員OOO有參訓時段重疊報名情形，無法儲存，請再確認！
                errmsg1 = "該學員有參訓時段重疊報名情形,請再確認!" & vbCrLf
                If sName <> "" Then errmsg1 = String.Format("學員 {0} 有參訓時段重疊報名情形,請再確認!", sName) & vbCrLf
                If errmsg1 <> "" Then sERRMSG &= errmsg1
                Return
            End If
            sERRMSG = TMPMSG_Y_OTH '錯誤訊息-(有可能是Y 或是 錯誤訊息)
            If sERRMSG <> "" Then Return
            errmsg1 = "" '正常結束'清空錯誤訊息
            Return
        Catch ex As Exception
            'sERRMSG &= ex.ToString & vbCrLf
            errmsg1 = "該學員查詢參訓時段重疊報名情形,失敗,請重新查詢!" & vbCrLf
            If sName <> "" Then errmsg1 = String.Format("學員 {0} 查詢參訓時段重疊報名情形,失敗,請重新查詢!!", sName) & vbCrLf
            If errmsg1 <> "" Then sERRMSG &= errmsg1

            Dim strErrmsg As String = ""
            strErrmsg &= String.Concat("#timsSer1.ChkStudDouble2: ", "https://wltims.wda.gov.tw/TIMSWS/timsService1.asmx") & vbCrLf
            strErrmsg &= String.Concat("xStudInfo=", xStudInfo) & vbCrLf
            strErrmsg &= String.Concat("sERRMSG: ", sERRMSG) & vbCrLf
            strErrmsg &= String.Concat("ex.Message: ", ex.Message) & vbCrLf
            strErrmsg &= String.Concat("ex.ToString: ", ex.ToString) & vbCrLf
            Call SendMailTest(strErrmsg)
        End Try
    End Sub

    '屆退官兵者 (依系統日期判斷)
    Public Shared Function CheckRESOLDER(ByRef objconn As SqlConnection, ByRef sIDNO As String, ByRef ReCOMMDISTID As String, ByRef STDate1 As String, ByRef out_POSITION As String) As Boolean
        Dim rst As Boolean = False '不是 (屆退官兵者
        'STDate1:若為空白則使用系統日期為比對日期

        '首頁>>學員動態管理>>招生作業>>錄取作業
        '/SD/02/SD_02_003
        '本作業僅限自辦職前訓練計畫()
        '於錄取作業功能，依據屆退官兵荐訓名冊資料
        '，身分勾稽為屆退官兵者(檢核當日檢核"預定退伍日"是否已過該日，若未過檢核該日，即為屆退官兵者)
        '，則在姓名前面顯示「*」
        '名單上方文字現為：班名，訓練人數@XX人[成績計算方式：(筆試*%)+(口試*%)=總成績]
        '請改為：班名，訓練人數@XX人，成績計算方式：[(筆試*50%)+(口試*50%)]3%=總成績，總成績最高為100分。
        '然後跳下一行顯示："「」為屆退官兵身分者"。
        Dim sql As String = ""
        If STDate1 <> "" Then
            STDate1 = Cdate3(STDate1)
            sql = ""
            sql &= " SELECT POSITION FROM ADP_RESOLDER WHERE convert(date,PREEXDATE) > " & To_date(STDate1)
            sql &= " AND IDNO=@IDNO AND ReCOMMDISTID=@ReCOMMDISTID "
        Else
            sql = ""
            sql &= " SELECT POSITION FROM ADP_RESOLDER WHERE convert(date,PREEXDATE) > convert(date,GETDATE()) "
            sql &= " AND IDNO=@IDNO AND ReCOMMDISTID=@ReCOMMDISTID"
        End If
        Dim sCmd As New SqlCommand(sql, objconn)
        OpenDbConn(objconn)
        Dim dt As New DataTable
        With sCmd
            .Parameters.Clear()
            .Parameters.Add("IDNO", SqlDbType.VarChar).Value = sIDNO
            .Parameters.Add("ReCOMMDISTID", SqlDbType.VarChar).Value = ReCOMMDISTID
            dt.Load(.ExecuteReader())
        End With
        If dt.Rows.Count > 0 Then
            out_POSITION = Convert.ToString(dt.Rows(0)("POSITION"))
            rst = True '是 (屆退官兵者)
        End If
        Return rst
    End Function

