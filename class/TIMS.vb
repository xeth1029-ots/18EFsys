    End Function

    ''' <summary>依 PSNO28 取得 PCS</summary>
    ''' <param name="PSNO28"></param>
    ''' <param name="oConn"></param>
    ''' <returns></returns>
    Public Shared Function Get_PCSforPSNO28(ByRef sm As SessionModel, ByVal PSNO28 As String, ByRef oConn As SqlConnection) As String
        PSNO28 = ClearSQM(PSNO28)
        If PSNO28 = "" Then Return ""

        Dim oRst As Object = Nothing
        Call OpenDbConn(oConn)
        Dim objstr As String = ""
        objstr &= " SELECT concat(pp.PLANID,'x',pp.COMIDNO,'x',pp.SEQNO) PCS" & vbCrLf
        objstr &= " FROM dbo.PLAN_PLANINFO pp" & vbCrLf
        objstr &= " JOIN dbo.ID_PLAN ip on ip.PLANID=pp.PLANID" & vbCrLf
        objstr &= " WHERE pp.ISAPPRPAPER='Y' AND pp.PSNO28=@PSNO28 AND ip.YEARS=@YEARS AND ip.TPLANID=@TPLANID" & vbCrLf
        Dim oCmd As New SqlCommand(objstr, oConn)
        With oCmd
            .Parameters.Clear()
            .Parameters.Add("PSNO28", SqlDbType.VarChar).Value = PSNO28
            .Parameters.Add("YEARS", SqlDbType.VarChar).Value = Convert.ToString(sm.UserInfo.Years)
            .Parameters.Add("TPLANID", SqlDbType.VarChar).Value = sm.UserInfo.TPlanID
            oRst = .ExecuteScalar()
        End With
        If oRst Is Nothing Then Return ""
        Return Convert.ToString(oRst)
    End Function

