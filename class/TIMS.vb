    'stella add 2007/11/02 檢查是否已建立報名資料，若無，請先建立報名資料
    'sType:0只查現場報名資料
    'sType:1若沒有資料查轉班資料
    Public Shared Function CheckIfSingUp(ByVal sIDNO As String, ByVal OCID As String, ByVal sType As Integer, ByRef objconn As SqlConnection) As Boolean
        Dim result As Boolean = False
        If OCID = "" OrElse sIDNO = "" Then Return result

        Dim sql As String = ""
        sql &= " SELECT 'x' FROM STUD_ENTERTEMP a JOIN STUD_ENTERTYPE b ON a.SETID=b.SETID "
        sql &= " WHERE a.IDNO='" & sIDNO & "' and b.OCID1=" & OCID & ""
        Dim dr As DataRow = DbAccess.GetOneRow(sql, objconn)
        If dr IsNot Nothing Then
            '有報名資料
            result = True
            Return result
        End If

        Select Case sType
            Case 1
                sql = ""
                sql &= " SELECT tr.SOCID" & vbCrLf
                sql &= " FROM dbo.STUD_TRANCLASSRECORD tr" & vbCrLf
                sql &= " JOIN dbo.VIEW_STUDENTBASICDATA cs on cs.socid=tr.socid" & vbCrLf
                sql &= " WHERE cs.idno='" & sIDNO & "' and tr.newclassid=" & OCID & ""
                dr = DbAccess.GetOneRow(sql, objconn)
                If dr IsNot Nothing Then
                    '有轉班資料
                    result = True
                    Return result
                End If
        End Select
        Return result
    End Function

    '局:班級審核:複審
    Public Shared Sub UPDATE_APPLIEDRESULT(ByRef MyPage As Page, ByVal PlanID As String, ByVal ComIDNO As String, ByVal SeqNo As String,
                                            ByVal SecResult As String, ByRef tConn As SqlConnection)
        If PlanID <> "" AndAlso ComIDNO <> "" AndAlso SeqNo <> "" Then
            Dim sm As SessionModel = SessionModel.Instance()
            Dim sql As String = ""
            sql &= " UPDATE PLAN_PLANINFO"
            sql &= " SET APPLIEDRESULT=@APPLIEDRESULT,APPRESACCT=@APPRESACCT,APPRESDATE=GETDATE()"
            sql &= " WHERE PlanID=@PlanID and ComIDNO=@ComIDNO and SeqNo=@SeqNo"
            Call OpenDbConn(tConn)
            Dim oCmd As New SqlCommand(sql, tConn)
            With oCmd
                .Parameters.Clear()
                .Parameters.Add("APPLIEDRESULT", SqlDbType.VarChar).Value = If(UCase(SecResult) = "NULL", Convert.DBNull, SecResult)
                .Parameters.Add("APPRESACCT", SqlDbType.VarChar).Value = sm.UserInfo.UserID
                .Parameters.Add("PlanID", SqlDbType.Int).Value = CINT1(PlanID)
                .Parameters.Add("ComIDNO", SqlDbType.VarChar).Value = ComIDNO
                .Parameters.Add("SeqNo", SqlDbType.Int).Value = CINT1(SeqNo)
                .ExecuteNonQuery()
            End With
        End If
    End Sub

    '局/中心:班級審核:複審/初審 PLAN_VERREPORT
    Public Shared Sub PLAN_VERREPROT_UPDATE(ByRef MyPage As Page, ByVal PlanID As String, ByVal ComIDNO As String, ByVal SeqNo As String,
                                            ByVal SecResult As String, ByRef tConn As SqlConnection)
        'FirResult 此參數無用 'SecResult: Y/N/R
        If PlanID <> "" AndAlso ComIDNO <> "" AndAlso SeqNo <> "" Then
            Dim sm As SessionModel = SessionModel.Instance()
            Dim sql As String = ""
            sql &= " UPDATE PLAN_VERREPORT"
            sql &= " SET FirResult=@FirResult ,SecResult=@SecResult ,APPRESACCT=@APPRESACCT ,APPRESDATE=GETDATE()"
            sql &= " WHERE PlanID=@PlanID and ComIDNO=@ComIDNO and SeqNo=@SeqNo"
            Dim iRst As Integer = 0
            'Dim tConn As SqlConnection=DbAccess.GetConnection
            Call OpenDbConn(tConn)
            Dim oCmd As New SqlCommand(sql, tConn)
            With oCmd
                .Parameters.Clear()
                Select Case SecResult '複審
                    Case "N", "Y", "R"
                        '--審核:複審不通過:N '--審核:複審通過:Y '--審核:複審退件修正:R
                        .Parameters.Add("FirResult", SqlDbType.VarChar).Value = "Y" '初審通過
                        .Parameters.Add("SecResult", SqlDbType.VarChar).Value = SecResult '重新審核
                    Case Else 'Case "O" '--審核:複審退件修正，重新送審
                        .Parameters.Add("FirResult", SqlDbType.VarChar).Value = Convert.DBNull '"Y" '初審通過
                        .Parameters.Add("SecResult", SqlDbType.VarChar).Value = Convert.DBNull '重新審核
                End Select
                .Parameters.Add("APPRESACCT", SqlDbType.VarChar).Value = sm.UserInfo.UserID
                .Parameters.Add("PlanID", SqlDbType.Int).Value = CINT1(PlanID)
                .Parameters.Add("ComIDNO", SqlDbType.VarChar).Value = ComIDNO
                .Parameters.Add("SeqNo", SqlDbType.Int).Value = CINT1(SeqNo)
                iRst = .ExecuteNonQuery()
            End With

            If iRst > 0 Then '有異動資料。
                Select Case SecResult '複審
                    Case "N", "Y", "R"
                        Call UPDATE_APPLIEDRESULT(MyPage, PlanID, ComIDNO, SeqNo, SecResult, tConn)
                    Case Else
                        Call UPDATE_APPLIEDRESULT(MyPage, PlanID, ComIDNO, SeqNo, "Null", tConn) '初審通過,複審可審核
                End Select
            End If
            'CloseDbConn(tConn)
        End If
    End Sub

