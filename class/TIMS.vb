    ''' <summary>測試登入使用3--使用 Request傳入-true:可登入</summary>
    ''' <param name="MyPage"></param>
    ''' <param name="txtVCode"></param>
    ''' <param name="txtUserId"></param>
    ''' <param name="txtUserPass"></param>
    ''' <returns></returns>
    Public Shared Function Chk_TEST_Login3Aes(ByRef MyPage As Page, ByRef txtVCode As TextBox, ByRef txtUserId As TextBox, ByRef txtUserPass As TextBox) As Boolean
        Dim rst As Boolean = False '不可登入
        Dim sm As SessionModel = SessionModel.Instance()
        If MyPage Is Nothing Then Return rst
        If String.IsNullOrEmpty(Convert.ToString(MyPage.Request("USER"))) Then Return rst 'Exit Sub
        If String.IsNullOrEmpty(Convert.ToString(MyPage.Request("TID"))) Then Return rst 'Exit Sub
        Dim rqUSER As String = ClearSQM(MyPage.Request("USER"))
        '解解Aes
        Dim vTID_dec As String = DecryptAes(MyPage.Request("TID"))
        If vTID_dec = "" Then Return rst 'Exit Sub
        Dim vUSER As String = GetMyValue(vTID_dec, "USER")
        If rqUSER = "" OrElse vUSER = "" Then Return rst 'Exit Sub
        Dim V_GSTIME As String = GetMyValue(vTID_dec, "GSTIME")
        If V_GSTIME = "" Then Return rst 'Exit Sub
        If Not IsDate1(V_GSTIME) Then Return rst 'Exit Sub

        '差距大於n分鐘 或 小於0
        Dim iMM As Long = DateDiff(DateInterval.Minute, CDate(V_GSTIME), Now)
        If iMM >= 60 OrElse iMM < 0 Then Return rst 'Exit Sub

        Dim vPPWD As String = "" 'GetMyValue(vTID, "PPWD")
        Dim vBACKUSE As String = GetMyValue(vTID_dec, "BACKUSE")
        If rqUSER = vUSER AndAlso vBACKUSE = "Y" Then
            rst = True '可登入
            vPPWD = GetMyValue(vTID_dec, "PPWD")
        End If
        If vBACKUSE = "" OrElse vPPWD = "" Then Return rst 'Exit Sub

        txtVCode.Text = sm.LoginValidateCode
        txtUserId.Text = ClearSQM(vUSER)
        txtUserPass.Text = ClearSQM(vPPWD)
        Return rst
    End Function

    ''' <summary>'極限-測試登入使用2</summary>
    Public Shared Sub Chk_TEST_Login2()
        'Exit Sub '暫不啟用
        Dim sLogTest As String = Utl_GetConfigSet("login_test")
        If sLogTest <> "YY" Then Exit Sub
        Dim flag_test As Boolean = sUtl_ChkTest() '測試
        If Not flag_test Then Exit Sub
        'Dim login_test_acct As String=Utl_GetConfigSet("login_test_acct")
        'Dim login_test_planid As String=Utl_GetConfigSet("login_test_planid")
        Dim sTxtUserID As String = Utl_GetConfigSet("login_test_acct")
        Dim test_PlanID As String = Utl_GetConfigSet("login_test_planid")
        If String.IsNullOrEmpty(sTxtUserID) Then Exit Sub
        If String.IsNullOrEmpty(test_PlanID) Then Exit Sub

        Dim objconn As SqlConnection = DbAccess.GetConnection()

        Dim parms As New Hashtable From {{"account", UCase(sTxtUserID)}}
        Dim sql As String = ""
        sql &= " SELECT a.ACCOUNT, a.ROLEID, a.LID, a.HASHPWD1, a.NAME, a.ISUSED, a.DEFAULT_PLANID, a.DEFAULT_YEAR" & vbCrLf
        sql &= " ,c.RID,c.RELSHIP, c.ORGLEVEL, c.DISTID" & vbCrLf
        sql &= " ,d.ORGID, d.ORGNAME" & vbCrLf
        sql &= " ,CASE WHEN GETDATE()>=STOPDATE THEN 'Y' ELSE 'N' END STOPMSG" & vbCrLf
        sql &= " FROM AUTH_ACCOUNT a" & vbCrLf
        sql &= " JOIN AUTH_RELSHIP c ON a.ORGID=c.ORGID" & vbCrLf
        sql &= " JOIN ORG_ORGINFO d ON c.ORGID=d.ORGID" & vbCrLf
        sql &= " WHERE BACKUSE='Y' AND UPPER(a.ACCOUNT)=@account" & vbCrLf
        Dim odt As DataTable = DbAccess.GetDataTable(sql, objconn, parms)
        If odt.Rows.Count = 0 Then Exit Sub
        Dim dr As DataRow = odt.Rows(0)

        Dim userInfo As LoginUserInfo = New LoginUserInfo With {
            .UserID = Convert.ToString(dr("Account")),
            .UserName = Convert.ToString(dr("Name")),
            .RoleID = Convert.ToString(dr("RoleID")),
            .OrgID = Convert.ToString(dr("OrgID")),
            .OrgName = Convert.ToString(dr("OrgName")),
            .LID = Convert.ToInt16(dr("LID"))
        }
        If userInfo.LID <= 1 Then
            userInfo.OrgLevel = Convert.ToInt16(dr("OrgLevel"))
            userInfo.DistID = Convert.ToString(dr("DistID"))
            userInfo.RID = Convert.ToString(dr("RID"))
            userInfo.RelShip = Convert.ToString(dr("Relship"))
        End If
        'userInfo.Years=Convert.ToString(dr("DEFAULT_YEAR"))
        userInfo.DefaultPlanID = Convert.ToString(dr("DEFAULT_PLANID"))
        userInfo.DefaultYear = Convert.ToString(dr("DEFAULT_YEAR"))

        Dim parms2 As New Hashtable From {{"account", UCase(sTxtUserID)}, {"planid", test_PlanID}}
        Dim sql2 As String = ""
        sql2 &= " SELECT PLANID,TPLANID,YEARS,PLANNAME,DISTNAME,NAME,ACCOUNT" & vbCrLf
        sql2 &= " ,ORGLEVEL,DISTID,RID,RELSHIP" & vbCrLf
        sql2 &= " FROM VIEW_LOGINACCOUNT" & vbCrLf
        sql2 &= " WHERE UPPER(account)=@account AND planid=@planid" & vbCrLf
        Dim dt2 As DataTable = DbAccess.GetDataTable(sql2, objconn, parms2)
        If dt2.Rows.Count = 0 Then Exit Sub
        dr = dt2.Rows(0)

        userInfo.OrgLevel = Convert.ToInt16(dr("OrgLevel"))
        userInfo.DistID = Convert.ToString(dr("DistID"))
        userInfo.RID = Convert.ToString(dr("RID"))
        userInfo.RelShip = Convert.ToString(dr("Relship"))

        userInfo.PlanID = test_PlanID
        userInfo.Years = Convert.ToString(dr("Years")) 'YR
        userInfo.TPlanID = Convert.ToString(dr("TPlanID"))
        userInfo.DefaultYear = Convert.ToString(dr("Years")) 'YR
        userInfo.DefaultPlanID = test_PlanID

        '取出帳號的功能權限表
        userInfo.FunDt = TIMS.GetAuthGroupFun(userInfo.UserID, objconn)
        DbAccess.CloseDbConn(objconn)

        ' 登入成功 Flag (重要, 有設定才是真的登入成功)
        userInfo.LoginSuccess = True
        AuthUtil.LoginLog(sTxtUserID, True)

        ' 登入使用者資訊保存到 SessionModel
        Dim sm As SessionModel = SessionModel.Instance()
        sm.UserInfo = userInfo
    End Sub

