    ''' <summary>資料組合為tr/td </summary>
    ''' <param name="str"></param>
    ''' <param name="flag_all"></param>
    ''' <returns></returns>
    Public Shared Function Get_TABLETR(ByVal str As String, ByVal flag_all As Boolean, ByVal s_Split As String) As String
        'flag_all:true:全部 ／ false:判斷非空白
        Dim astr As String() = Split(str, s_Split)
        Dim rst As String = ""
        For Each strV1 As String In astr
            strV1 = ClearSQM(strV1)
            rst &= If(flag_all, String.Format("<td>{0}</td>", strV1), If(strV1 <> "", String.Format("<td>{0}</td>", strV1), ""))
        Next
        Return String.Concat("<tr>", rst, "</tr>")
    End Function

