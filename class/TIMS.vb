    '產投課程查詢 (含充飛)
    Public Shared Function GetOCIDDate2854(ByVal vOCID As String, ByRef oConn As SqlConnection) As DataRow
        Dim Rst As DataRow = Nothing

        If vOCID = "" Then Return Rst '是空白不回應
        vOCID = ClearSQM(vOCID)
        If Not IsNumeric(vOCID) Then Return Rst '不是數字不回應
        '若是為數字，將它轉為整數
        If IsNumeric(vOCID) Then vOCID = CINT1(vOCID)
        'If tOCID <> vOCID Then Return Rst '有異常不回應(照理應該是不會不一樣)

        Dim sql As String = "
SELECT b.TMID ,b.TRAINID ,b.TRAINNAME
,c.ORGNAME ,a.OCID ,a.CLASSCNAME ,a.CYCLTYPE
,dbo.FN_GET_CLASSCNAME(a.CLASSCNAME,a.CYCLTYPE) CLASSCNAME2
,a.LEVELTYPE ,a.RID ,a.STDATE ,a.FTDATE
,a.ONSHELLDATE ,a.SENTERDATE ,a.FENTERDATE
,a.TNUM ,a.ADMISSIONS
,ip.TPLANID,ip.YEARS,a.ISCLOSED,dp.KID25_8
,GETDATE() TODAY
FROM CLASS_CLASSINFO a
JOIN KEY_TRAINTYPE b ON b.TMID=a.TMID
JOIN AUTH_RELSHIP d ON d.RID=a.RID
JOIN ORG_ORGINFO c ON c.ORGID=d.ORGID
JOIN ID_PLAN ip ON ip.PLANID=a.PLANID
LEFT JOIN V_PLAN_DEPOT dp ON dp.OCID=a.OCID
"
        sql &= $" WHERE ip.TPLANID IN ({Cst_NotTPlanID2})" & vbCrLf '限定產投計畫。
        sql &= " AND a.NOTOPEN='N' AND a.OCID=@OCID" & vbCrLf
        Dim sCmd As New SqlCommand(sql, oConn)
        Call OpenDbConn(oConn)
        Dim dt As New DataTable
        With sCmd
            .Parameters.Clear()
            .Parameters.Add("OCID", SqlDbType.BigInt).Value = TIMS.CINT1(vOCID)
            dt.Load(.ExecuteReader())
        End With
        If dt.Rows.Count > 0 Then Rst = dt.Rows(0)
        Return Rst
    End Function

    '該學員報名資料狀態 預設為 sInfo:"" 有資訊，若有 cst_x 則無資訊
    Public Shared Function CheckStudEnterStatusDt(ByVal strIDNO As String, ByVal conn As SqlConnection,
        Optional ByVal sInfo As String = "") As DataTable
        Dim rst As DataTable
        Const cst_EnterPath As String = "W" '就服站報名資料
        Const cst_x As String = "x" '沒有要什麼資訊

        If strIDNO <> "" Then strIDNO = ClearSQM(UCase(Trim(strIDNO)))
        Dim pms1 As New Hashtable From {{"ENTERPATH", cst_EnterPath}, {"IDNO", strIDNO}}
        Dim sql As String = ""
        'view_EnterTypeW
        If sInfo = cst_x Then
            '沒有要什麼資訊
            sql &= " SELECT 'x'" & vbCrLf
        Else
            '要下列欄位資訊
            sql &= " SELECT a.OCID ,a.NAME ,a.IDNO" & vbCrLf
            sql &= " ,a.ORGNAME ,a.CLASSCNAME ,a.CYCLTYPE" & vbCrLf
            sql &= " ,CONVERT(varchar, a.RELENTERDATE, 111) RELENTERDATE" & vbCrLf
            sql &= " ,a.SETID" & vbCrLf
            sql &= " ,CONVERT(varchar, a.ENTERDATE, 111) ENTERDATE" & vbCrLf
            sql &= " ,a.SERNUM ,a.EXAMNO" & vbCrLf
        End If
        sql &= " FROM VIEW_ENTERTYPEW a" & vbCrLf
        '就服站代碼
        sql &= " WHERE a.ENTERPATH=@ENTERPATH AND a.IDNO=@IDNO" & vbCrLf
        rst = DbAccess.GetDataTable(sql, conn, pms1)
        Return rst
    End Function

    '確認該學員報名資料狀態　'True:有報名資料 False:沒有報名資料　（目前有效的報名資料）(依就服站)
