    '取得 通俗職類 
    Public Shared Function Get_CJOBNAME(ByRef dtSHARECJOB As DataTable, ByVal CJOB_UNKEY As String, ByVal iType As Integer) As String
        Dim rst As String = ""
        If dtSHARECJOB Is Nothing OrElse dtSHARECJOB.Rows.Count = 0 Then Return rst
        If CJOB_UNKEY = "" Then Return rst
        Dim ff3 As String = $"CJOB_UNKEY={CJOB_UNKEY}"
        If dtSHARECJOB.Select(ff3).Length > 0 Then
            Select Case iType
                Case 1
                    rst = $"{dtSHARECJOB.Select(ff3)(0)("CJOBNAME1")}"
                Case 2
                    rst = $"{dtSHARECJOB.Select(ff3)(0)("CJOBNAME2")}"
            End Select
        End If
        Return rst
    End Function

    Public Shared Function Get_PUSHDISTID_NN(ByRef dtDist As DataTable, ByRef sValue As String) As String
        Dim rst As String = ""
        'If oValue Is Nothing Then Return rst
        'Dim sValue As String=Convert.ToString(oValue)
        If sValue = "" Then Return rst

        Dim ff3 As String = ""
        If sValue.IndexOf(",") = -1 Then
            ff3 = String.Format("DISTID='{0}'", sValue)
            If dtDist.Select(ff3).Length > 0 Then rst = dtDist.Select(ff3)(0)("NAME")
            Return rst
        End If
        'Dim s_TMP1 As String=""
        For Each V1 As String In sValue.Split(",")
            ff3 = String.Format("DISTID='{0}'", V1)
            If dtDist.Select(ff3).Length > 0 Then
                rst &= String.Concat(If(rst <> "", ",", ""), dtDist.Select(ff3)(0)("NAME"))
            End If
        Next
        Return rst
    End Function

