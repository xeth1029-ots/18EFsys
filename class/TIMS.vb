    ''' <param name="htSS"></param>
    Public Shared Sub Utl_ExportRp1(ByRef MyPage As Page, ByRef htSS As Hashtable, ByRef daTable1 As DataTable)
        If (MyPage Is Nothing) Then Return
        Dim s_ExpType As String = GetMyValue2(htSS, "ExpType") 'EXCEL/PDF/ODS/XLSX
        'Dim v_ExpType As String=TIMS.GetListValue(RBListExpType) 'EXCEL/PDF/ODS
