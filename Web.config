  <system.webServer>
    <validation validateIntegratedModeConfiguration="false"/>
    <!-- rewrite -->
    <rewrite>
      <rules>
        <rule name="HTTP to HTTPS redirect" stopProcessing="true">
          <match url="(.*)"/>
          <conditions>
            <add input="{HTTPS}" pattern="off" ignoreCase="true"/>
          </conditions>
          <action type="Redirect" url="https://{HTTP_HOST}/{R:1}" redirectType="Permanent"/>
        </rule>
      </rules>
      <outboundRules>
        <rule name="Add Strict-Transport-Security when HTTPS" enabled="true">
          <match serverVariable="RESPONSE_Strict_Transport_Security" pattern=".*"/>
          <conditions>
            <add input="{HTTPS}" pattern="on" ignoreCase="true"/>
          </conditions>
          <action type="Rewrite" value="max-age=31536000; includeSubDomains; preload"/>
        </rule>
        <rule name="Remove ETag">
          <match serverVariable="RESPONSE_ETag" pattern=".+"/>
          <action type="Rewrite" value=""/>
        </rule>
      </outboundRules>
    </rewrite>
    <!-- rewrite -->
    <httpRedirect enabled="false"/>
    <httpProtocol>
      <customHeaders>
        <remove name="X-Powered-By"/>
        <add name="Cache-Control" value="no-cache,no-store"/>
        <add name="X-Frame-Options" value="SAMEORIGIN"/>
        <!-- <add name="X-XSS-Protection" value="1; mode=block"/> -->
        <add name="X-Content-Type-Options" value="nosniff"/>
        <add name="Strict-Transport-Security" value="max-age=31536000;includeSubDomains"/>
        <add name="Content-Security-Policy" value="default-src 'self'; frame-ancestors 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' api.tgos.tw gis.tgos.tw www.gstatic.com www.google.com www.googletagmanager.com www.googleadservices.com googleads.g.doubleclick.net code.highcharts.com code.jquery.com ajax.googleapis.com maxcdn.bootstrapcdn.com; style-src 'self' 'unsafe-inline' www.gstatic.com fonts.googleapis.com www.google.com use.fontawesome.com; font-src 'self' fonts.gstatic.com use.fontawesome.com; frame-src 'self' www.youtube.com bid.g.doubleclick.net www.facebook.com; img-src 'self' www.google.com www.google.com.tw www.googleapis.com clients1.google.com; object-src 'self' flv-player.net; connect-src 'self' ws: wss:;"/>
        <!-- <add name="Content-Security-Policy" value="default-src 'self'; frame-ancestors 'self'; script-src 'self' api.tgos.tw gis.tgos.tw www.gstatic.com www.google.com www.googletagmanager.com www.googleadservices.com googleads.g.doubleclick.net code.highcharts.com code.jquery.com ajax.googleapis.com maxcdn.bootstrapcdn.com; style-src 'self' 'unsafe-inline' www.gstatic.com fonts.googleapis.com www.google.com use.fontawesome.com; font-src 'self' fonts.gstatic.com use.fontawesome.com; frame-src 'self' www.youtube.com bid.g.doubleclick.net www.facebook.com; img-src 'self' www.google.com www.google.com.tw www.googleapis.com clients1.google.com; object-src 'self' flv-player.net; connect-src 'self' ws: wss:;" /> -->
        <!-- <add name="content-security-policy" value="default-src 'self'; frame-ancestors 'self'; script-src 'self' 'unsafe-inline' api.tgos.tw gis.tgos.tw www.gstatic.com www.google.com www.googletagmanager.com www.googleadservices.com googleads.g.doubleclick.net code.highcharts.com code.jquery.com ajax.googleapis.com maxcdn.bootstrapcdn.com; style-src 'self' 'unsafe-inline' www.gstatic.com fonts.googleapis.com www.google.com use.fontawesome.com; font-src 'self' fonts.gstatic.com use.fontawesome.com; frame-src 'self' www.youtube.com bid.g.doubleclick.net www.facebook.com; img-src 'self' www.google.com www.google.com.tw www.googleapis.com clients1.google.com; object-src 'self' flv-player.net; connect-src 'self' ws: wss:;" /> -->
      </customHeaders>
    </httpProtocol>
    <defaultDocument>
